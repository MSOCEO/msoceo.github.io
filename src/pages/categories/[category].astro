---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const cats = new Set(posts.filter(p => !p.data.draft && p.data.category).map(p => p.data.category!));
  return Array.from(cats).map(cat => ({ params: { category: cat } }));
}

const { category } = Astro.params;
const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft && p.data.category === category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`分类: ${category}`}>
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <a href="/" class="text-sm text-[var(--text-tertiary)] hover:text-[var(--accent)] transition-colors">&larr; 返回首页</a>
      <h1 class="font-serif font-black text-3xl mt-2">
        分类: <span class="text-[var(--accent)]">{category}</span>
      </h1>
      <p class="text-sm text-[var(--text-tertiary)] mt-1">共 {posts.length} 篇文章</p>
    </div>

    {posts.length === 0 ? (
      <div class="ink-card p-12 text-center text-[var(--text-tertiary)]">
        <p>该分类下暂无文章</p>
      </div>
    ) : (
      <div class="space-y-4">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            slug={post.id}
            date={post.data.pubDate}
            description={post.data.description}
            category={post.data.category}
            tags={post.data.tags}
            image={post.data.heroImage}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
