---
import Page from '../layouts/Page.astro';

const title = '注册 | 枕星';
const description = '加入枕星，开始记录你的代码与日常';
---

<Page {title} {description}>
  <div class="auth-page">
    <div class="auth-card animate-in">
      <h1>加入枕星</h1>
      <p class="subtitle">开始记录代码与日常的缝隙</p>

      <form id="register-form" class="auth-form">
        <div class="form-group">
          <label for="username">用户名</label>
          <input
            type="text"
            id="username"
            class="input"
            placeholder="你的笔名"
            required
            autocomplete="username"
          />
        </div>

        <div class="form-group">
          <label for="email">邮箱</label>
          <input
            type="email"
            id="email"
            class="input"
            placeholder="your@email.com"
            required
            autocomplete="email"
          />
        </div>

        <div class="form-group">
          <label for="password">密码</label>
          <input
            type="password"
            id="password"
            class="input"
            placeholder="至少 8 位字符"
            required
            minlength="8"
            autocomplete="new-password"
          />
        </div>

        <button type="submit" class="btn btn-primary btn-lg">
          <span class="btn-label">创建账号</span>
          <span class="btn-spinner" hidden></span>
        </button>

        <div id="error-msg" class="form-error" hidden></div>
      </form>

      <div class="divider-text">或</div>

      <button id="oauth-github" class="btn btn-secondary btn-lg btn-oauth" disabled>
        通过 GitHub 注册（即将支持）
      </button>

      <p class="footer-text">
        已有账号？<a href="/login">立即登录</a>
      </p>
    </div>
  </div>
</Page>

<style>
  .auth-form .btn { margin-top: var(--space-sm); }
  .btn-spinner {
    width: 16px; height: 16px;
    border: 2px solid rgba(0,0,0,0.2);
    border-top-color: var(--ink-0);
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .btn.loading .btn-label { display: none; }
  .btn.loading .btn-spinner { display: block; }

  .form-error {
    margin-top: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: rgba(229,72,77,0.1);
    border: 1px solid rgba(229,72,77,0.2);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--error);
  }

  .btn-oauth {
    width: 100%;
    margin-top: 0;
  }
</style>

<script>
  const form = document.getElementById('register-form');
  const submitBtn = form.querySelector('button[type="submit"]');
  const errorMsg = document.getElementById('error-msg');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.classList.add('loading');
    errorMsg.hidden = true;

    // TODO: Replace with real Supabase auth
    await new Promise(r => setTimeout(r, 800));

    errorMsg.hidden = false;
    errorMsg.textContent = '注册服务正在搭建中，请稍后再试。';
    submitBtn.classList.remove('loading');
  });
</script>
