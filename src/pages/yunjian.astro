    .yj-status-inner { gap: 12px; }
    .yj-dash-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // ===== CLI Copy =====
  window.copyCli = function() {
    const cmd = document.getElementById('yjCliCmd').textContent;
    navigator.clipboard.writeText(cmd).then(() => {
      const btn = document.querySelector('.yj-cli-copy');
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
      setTimeout(() => { btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><rect x="9" y="9" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke="currentColor" stroke-width="1.5"/></svg>'; }, 2000);
    });
  };

  // ===== Status Simulator =====
  (function() {
    const elOnline = document.getElementById('yjOnlineUsers');
    const elBlog = document.getElementById('yjBlogCount');
    const elDeploy = document.getElementById('yjDeployToday');
    if (elOnline) setInterval(() => { elOnline.textContent = Math.floor(160 + Math.random() * 60); }, 5000);
    if (elBlog) setInterval(() => { elBlog.textContent = Number(elBlog.textContent) + Math.floor(Math.random() * 3); }, 15000);
    if (elDeploy) setInterval(() => { elDeploy.textContent = Math.floor(30 + Math.random() * 30); }, 10000);
  })();

  // ===== Supabase Auth 状态检测 + 仪表盘 =====
  (async function() {
    const { createClient } = await import('https://esm.sh/@supabase/supabase-js@2');
    const supabase = createClient(
      'https://xwvkdluvixurvgvkhkfe.supabase.co',
      'sb_publishable_NOdEPhf8yD4dMRJIH1JqqA_z5By3p0H'
    );
    const { data: { session } } = await supabase.auth.getSession();

    const heroActions = document.querySelector('.yj-hero-actions');
    if (!heroActions) return;

    if (session?.user) {
      const user = session.user;
      const username = user.user_metadata?.username || user.email?.split('@')[0] || '用户';

      // 替换 Hero 按钮为控制面板入口
      heroActions.innerHTML = `
        <span class="yj-user-greeting">你好，${escapeHtml(username)}</span>
        <a href="/yunjian/dashboard" class="yj-btn yj-btn-primary">进入控制台 &rarr;</a>
        <button class="yj-btn yj-btn-ghost" id="yj-logout-btn">退出登录</button>
      `;
      document.getElementById('yj-logout-btn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.reload();
      });

      // 显示仪表盘
      const dash = document.getElementById('yjDashboard');
      if (dash) dash.style.display = '';
      document.getElementById('yjDashGreeting').textContent = `你好，${escapeHtml(username)}`;

      // 加载 profile 信息
      const { data: profile } = await supabase.from('profiles').select('*').eq('id', user.id).single();

      if (profile?.blog_repo && profile?.blog_status === 'active') {
        document.getElementById('yjHasBlog').style.display = '';
        document.getElementById('yjBlogUrl').href = profile.blog_url || '#';
        document.getElementById('yjBlogUrl').textContent = profile.blog_url || profile.blog_repo;
      } else {
        document.getElementById('yjNoBlog').style.display = '';
      }

      // 加载文章统计
      const { count } = await supabase.from('posts').select('*', { count: 'exact', head: true }).eq('user_id', user.id);
      document.getElementById('yjPostCount').textContent = `共 ${count || 0} 篇文章`;

      // 一键创建博客
      document.getElementById('yjCreateBlog')?.addEventListener('click', async () => {
        const btn = document.getElementById('yjCreateBlog');
        const progressDiv = document.getElementById('yjCreateProgress');
        const progressFill = document.getElementById('yjProgressFill');
        const progressText = document.getElementById('yjProgressText');

        btn.disabled = true;
        btn.textContent = '创建中...';
        progressDiv.style.display = '';
        progressFill.style.width = '10%';
        progressText.textContent = '检查 GitHub 授权...';

        // 如果有 GitHub token (OAuth)，创建仓库
        const providerToken = session.provider_token;
        if (!providerToken) {
          progressText.textContent = '需要 GitHub OAuth 授权，请先退出并使用 GitHub 登录';
          btn.disabled = false;
          btn.textContent = '使用 GitHub 登录';
          return;
        }

        progressFill.style.width = '30%';
        progressText.textContent = '创建 GitHub 仓库...';

        try {
          const repoName = `${username}.github.io`;
          // 检查仓库是否存在
          let checkResp = await fetch(`https://api.github.com/repos/${username}/${repoName}`, {
            headers: { Authorization: `Bearer ${providerToken}`, Accept: 'application/vnd.github+json' }
          });
          if (checkResp.ok) {
            progressText.textContent = `仓库 ${repoName} 已存在，跳过创建`;
          } else {
            // 创建仓库
            const createResp = await fetch('https://api.github.com/user/repos', {
              method: 'POST',
              headers: { Authorization: `Bearer ${providerToken}`, Accept: 'application/vnd.github+json', 'Content-Type': 'application/json' },
              body: JSON.stringify({
                name: repoName,
                description: 'Personal blog powered by HanBlog & YunJian',
                homepage: `https://${username}.github.io`,
                private: false,
                has_issues: false,
                has_projects: false,
                has_wiki: false,
                auto_init: true
              })
            });
            if (!createResp.ok) {
              const err = await createResp.json();
              throw new Error(err.message || '创建仓库失败');
            }
          }

          progressFill.style.width = '60%';
          progressText.textContent = '开启 GitHub Pages...';

          // 开启 Pages
          await fetch(`https://api.github.com/repos/${username}/${repoName}/pages`, {
            method: 'POST',
            headers: { Authorization: `Bearer ${providerToken}`, Accept: 'application/vnd.github+json', 'Content-Type': 'application/json' },
            body: JSON.stringify({ source: { branch: 'main', path: '/' } })
          });

          progressFill.style.width = '85%';
          progressText.textContent = '保存配置...';

          // 保存到 Supabase
          const blogURL = `https://${username}.github.io`;
          await supabase.from('profiles').upsert({
            id: user.id,
            blog_repo: repoName,
            blog_url: blogURL,
            blog_status: 'active',
            blog_theme: 'default'
          });

          progressFill.style.width = '100%';
          progressText.textContent = `博客创建成功！${blogURL}`;
          btn.textContent = '前往博客';
          btn.disabled = false;
          btn.onclick = () => window.open(blogURL, '_blank');

          // 刷新页面以显示已创建状态
          setTimeout(() => window.location.reload(), 2000);

        } catch(e) {
          progressText.textContent = `创建失败: ${e.message}`;
          btn.textContent = '重试';
          btn.disabled = false;
        }
      });
    }

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }
  })();
</script>
