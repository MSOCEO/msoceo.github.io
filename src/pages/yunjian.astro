    margin-top: 12px;
  }

  /* ---- Demo Blogs ---- */
  .yj-demo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .yj-demo-card {
    background: var(--yj-bg-card);
    border: 1px solid var(--yj-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--duration-fast) var(--ease-out);
    cursor: pointer;
  }
  .yj-demo-card:hover {
    border-color: var(--yj-accent);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(16,185,129,0.2);
  }
  .yj-demo-preview {
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .yj-demo-preview::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--yj-bg-card), transparent 60%);
  }
  .yj-demo-info {
    padding: 20px 24px;
    text-align: left;
  }
  .yj-demo-info h3 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--ink-90);
    margin-bottom: 6px;
  }
  .yj-demo-info p {
    font-size: var(--text-sm);
    color: var(--yj-text-dim);
    margin: 0 0 12px;
    line-height: 1.5;
  }
  .yj-demo-tag {
    display: inline-block;
    padding: 3px 10px;
    background: rgba(16,185,129,0.1);
    color: var(--yj-accent);
    font-size: 11px;
    border-radius: 4px;
    font-weight: 600;
  }

  /* Dashboard */
  .yj-dash-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
  .yj-dash-card { background: var(--yj-bg-card); border: 1px solid var(--yj-border); border-radius: 12px; padding: 24px 20px; }
  .yj-dash-card h3 { font-size: var(--text-base); color: var(--ink-90); margin: 0 0 8px; }
  .yj-badge { display: inline-block; padding: 2px 10px; border-radius: 10px; font-size: 11px; font-weight: 600; background: rgba(16,185,129,0.12); color: var(--yj-accent); }
  .yj-progress-bar { width: 100%; height: 6px; background: var(--yj-border); border-radius: 3px; overflow: hidden; margin-top: 8px; }
  .yj-progress-fill { height: 100%; background: linear-gradient(90deg, var(--yj-accent), #3b82f6); border-radius: 3px; transition: width .3s; width: 0%; }

  /* Responsive */
  @media (max-width: 900px) {
    .yj-hero-inner { grid-template-columns: 1fr; }
    .yj-features-grid { grid-template-columns: repeat(2, 1fr); }
    .yj-pricing-grid { grid-template-columns: 1fr; }
    .yj-price-popular { transform: none; }
    .yj-steps { flex-direction: column; }
    .yj-step-arrow { transform: rotate(90deg); }
  }
  @media (max-width: 640px) {
    .yj-features-grid { grid-template-columns: 1fr; }
