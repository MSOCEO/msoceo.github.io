<script>
  import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';
  const supabase = createClient('https://xwvkdluvixurvgvkhkfe.supabase.co','sb_publishable_NOdEPhf8yD4dMRJIH1JqqA_z5By3p0H');

  // 认证状态
  (async function() {
    const { data: { session } } = await supabase.auth.getSession();
    const hdRight = document.getElementById('yjHdRight');
    const heroActions = document.getElementById('yjHeroActions');

    if (session?.user) {
      const username = session.user.user_metadata?.username || session.user.email?.split('@')[0] || '用户';
      hdRight.innerHTML = `<span style="font-size:13px;color:var(--yj-text-dim);margin-right:8px">你好，${escHtml(username)}</span><a href="/yunjian/dashboard" class="yj-btn yj-btn-primary">进入控制台</a>`;
      heroActions.innerHTML = `<a href="/yunjian/dashboard" class="yj-btn yj-btn-primary yj-btn-lg">进入控制台</a><a href="/yunjian/editor" class="yj-btn yj-btn-outline yj-btn-lg">写文章</a>`;
    }

    // 真实统计
    try {
      const { count: blogCount } = await supabase.from('profiles').select('*',{count:'exact',head:true}).eq('blog_status','active');
      const { count: postCount } = await supabase.from('posts').select('*',{count:'exact',head:true}).eq('status','published');
      const { count: userCount } = await supabase.from('profiles').select('*',{count:'exact',head:true});
      document.getElementById('yjStatBlogs').textContent = blogCount || 0;
      document.getElementById('yjStatPosts').textContent = postCount || 0;
      document.getElementById('yjStatUsers').textContent = userCount || 1;
    } catch(e) {}

    function escHtml(s) { const d=document.createElement('div'); d.textContent=s; return d.innerHTML; }
  })();
</script>
