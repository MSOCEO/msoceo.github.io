  }
  .yj-cta-inner h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--ink-100);
    margin-bottom: var(--space-md);
  }
  .yj-cta-inner p {
    font-size: var(--text-base);
    color: var(--ink-50);
    margin-bottom: var(--space-2xl);
  }

  /* Responsive */
  @media (max-width: 900px) {

  /* ---- Status Bar ---- */
  .yj-status-bar {
    background: rgba(16,185,129,0.06);
    border-bottom: 1px solid var(--yj-border);
    padding: 13px 0;
  }
  .yj-status-inner {
    display: flex;
    gap: 32px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .yj-stat-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--text-xs);
    color: var(--ink-50);
  }
  .yj-stat-item strong { color: var(--ink-100); }
  .yj-stat-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--yj-accent);
    flex-shrink: 0;
  }
  .yj-stat-live {
    animation: yj-pulse 2s ease-in-out infinite;
  }
  @keyframes yj-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(16,185,129,0.4); }
    50% { opacity: 0.6; box-shadow: 0 0 0 6px rgba(16,185,129,0); }
  }
  .yj-stat-icon { font-size: 13px; }

  /* ---- CLI Section ---- */
  .yj-cli-section { padding: var(--space-4xl) 0 var(--space-2xl); }
  .yj-cli-box {
    display: flex;
    align-items: center;
    background: #0a0f0c;
    border: 1px solid var(--yj-border);
    border-radius: var(--radius-md);
    padding: 6px 6px 6px 20px;
    transition: border-color var(--duration-fast);
  }
  .yj-cli-box code {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--yj-accent);
    overflow-x: auto;
    white-space: nowrap;
  }
  .yj-cli-copy {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    background: rgba(16,185,129,0.1);
    color: var(--yj-accent);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
  }
  .yj-cli-copy:hover { background: rgba(16,185,129,0.2); }
  .yj-cli-note {
    text-align: center;
    font-size: var(--text-xs);
