  }
  .yj-faq-item summary {
    padding: 18px 24px;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink-70);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .yj-faq-item summary::after {
    content: '+';
    font-size: 18px;
    color: var(--yj-accent);
    transition: transform var(--duration-fast);
  }
  .yj-faq-item[open] summary::after {
    content: '−';
  }
  .yj-faq-item p {
    padding: 0 24px 18px;
    font-size: var(--text-sm);
    color: var(--yj-text-dim);
    line-height: var(--leading-relaxed);
    margin: 0;
  }
  .yj-faq-item code {
    background: rgba(16,185,129,0.08);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 12px;
    color: var(--yj-accent);
  }

  /* CTA */
  .yj-cta {
    padding: var(--space-5xl) 0;
