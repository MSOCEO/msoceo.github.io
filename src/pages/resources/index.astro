---
// 旧路由 /resources 重定向到 /links
const redirectUrl = '/links';
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="refresh" content="0;url={redirectUrl}">
  <link rel="canonical" href="{redirectUrl}">
  <title>页面已迁移</title>
</head>
<body>
  <p>页面已迁移至 <a href="{redirectUrl}">{redirectUrl}</a></p>
</body>
</html>
