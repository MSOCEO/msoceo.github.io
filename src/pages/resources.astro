---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const resources = [
  {
    category: '语言与运行时',
    items: [
      { name: 'Rust', url: 'https://www.rust-lang.org', desc: '无畏的系统编程语言。' },
      { name: 'Zig', url: 'https://ziglang.org', desc: '通用语言与工具链。' },
      { name: 'Bun', url: 'https://bun.sh', desc: '快速的一体化 JavaScript 运行时。' },
    ],
  },
  {
    category: '基础设施与 DevOps',
    items: [
      { name: 'Nix', url: 'https://nixos.org', desc: '可复现的构建与部署。' },
      { name: 'Terraform', url: 'https://www.terraform.io', desc: '基础设施即代码。' },
      { name: 'Fly.io', url: 'https://fly.io', desc: '将应用服务器部署在用户附近。' },
    ],
  },
  {
    category: '数据库与存储',
    items: [
      { name: 'SQLite', url: 'https://www.sqlite.org', desc: '部署最广泛的数据库引擎。' },
      { name: 'DuckDB', url: 'https://duckdb.org', desc: '进程内分析型 SQL 数据库。' },
      { name: 'SurrealDB', url: 'https://surrealdb.com', desc: '面向现代应用的多模型数据库。' },
    ],
  },
  {
    category: '前端与设计',
    items: [
      { name: 'Astro', url: 'https://astro.build', desc: '内容优先的 Web 框架。' },
      { name: 'HTMX', url: 'https://htmx.org', desc: 'HTML 的高功率工具。' },
      { name: 'Tailwind CSS', url: 'https://tailwindcss.com', desc: '实用优先的 CSS 框架。' },
    ],
  },
  {
    category: 'AI 与机器学习',
    items: [
      { name: 'Ollama', url: 'https://ollama.com', desc: '本地运行大语言模型。' },
      { name: 'LangChain', url: 'https://www.langchain.com', desc: '构建 LLM 驱动的应用。' },
      { name: 'Hugging Face', url: 'https://huggingface.co', desc: 'AI 社区平台。' },
    ],
  },
  {
    category: '书籍与参考',
    items: [
      { name: 'Crafting Interpreters', url: 'https://craftinginterpreters.com', desc: '构建你自己的编程语言。' },
      { name: 'The Architecture of Open Source Applications', url: 'https://aosabook.org', desc: '真实系统如何构建。' },
      { name: 'Beej\'s Guide to Network Programming', url: 'https://beej.us/guide/bgnet/', desc: '从零开始的 Socket 编程。' },
    ],
  },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`资源 — ${SITE_TITLE}`} description="精选工具、库与参考，为建造者准备。" />
    <style>
      .resources-page {
        min-height: 100vh;
        position: relative;
        overflow: hidden;
        background: linear-gradient(
          180deg,
          oklch(85% 0.12 60) 0%,
          oklch(75% 0.08 70) 20%,
          oklch(65% 0.05 250) 50%,
          oklch(20% 0.01 250) 100%
        );
      }

      .resources-bg {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
      }

      .resources-mountains {
        position: absolute;
        inset: 0;
        background-image: 
          radial-gradient(ellipse at 70% 20%, oklch(95% 0.01 60) 0%, transparent 20%),
          radial-gradient(ellipse at 30% 25%, oklch(95% 0.01 60) 0%, transparent 15%),
          radial-gradient(ellipse at 50% 40%, oklch(70% 0.1 50) 0%, transparent 30%),
          radial-gradient(ellipse at 40% 60%, oklch(30% 0.05 140) 0%, transparent 25%),
          radial-gradient(ellipse at 60% 65%, oklch(40% 0.06 140) 0%, transparent 20%),
          radial-gradient(ellipse at 50% 90%, oklch(25% 0.02 250) 0%, transparent 40%),
          radial-gradient(ellipse at 50% 95%, oklch(35% 0.03 60) 0%, transparent 30%);
        
        opacity: 0.6;
        mix-blend-mode: multiply;
      }

      .resources-noise {
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.02'/%3E%3C/svg%3E");
      }

      main {
        position: relative;
        z-index: 1;
      }

      .section {
        max-width: 1000px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
        animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
      }

      .page-header {
        margin-bottom: 2.5rem;
      }

      .page-title {
        font-family: 'Fraunces', serif;
        font-size: 1.8rem;
        font-weight: 500;
        color: oklch(15% 0.01 60);
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .page-hash {
        color: oklch(68% 0.15 50);
      }

      .page-sub {
        font-family: 'Onest', system-ui, sans-serif;
        font-size: 0.95rem;
        color: oklch(60% 0.01 60);
        font-weight: 300;
      }

      .resource-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }

      .resource-group {
        background: oklch(100% 0 0 / 0.7);
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        border: 0.5px solid oklch(0% 0 0 / 0.08);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 
          0 4px 6px -1px oklch(0% 0 0 / 0.07),
          0 2px 4px -2px oklch(0% 0 0 / 0.05),
          inset 0 1px 0 oklch(100% 0 0 / 0.1);
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .resource-group:hover {
        border-color: oklch(68% 0.15 50 / 0.3);
        transform: translateY(-2px);
        box-shadow: 
          0 8px 32px oklch(68% 0.15 50 / 0.08),
          0 4px 6px -1px oklch(0% 0 0 / 0.07),
          inset 0 1px 0 oklch(100% 0 0 / 0.1);
      }

      .group-title {
        font-family: 'Onest', system-ui, sans-serif;
        font-size: 0.75rem;
        color: oklch(68% 0.15 50);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 600;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid oklch(90% 0.01 60 / 0.3);
      }

      .group-list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .group-item {
        margin: 0;
      }

      .item-link {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 0.6rem;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .item-link:hover {
        background: oklch(97% 0.01 60);
        text-shadow: none;
      }

      .item-name {
        font-family: 'Fraunces', serif;
        font-size: 0.9rem;
        font-weight: 500;
        color: oklch(15% 0.01 60);
      }

      .item-link:hover .item-name {
        color: oklch(68% 0.15 50);
      }

      .item-desc {
        font-family: 'Onest', system-ui, sans-serif;
        font-size: 0.8rem;
        color: oklch(60% 0.01 60);
        line-height: 1.5;
        font-weight: 300;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 640px) {
        .section {
          padding: 2rem 1rem;
        }

        .resource-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <div class="resources-page">
      <div class="resources-bg">
        <div class="resources-mountains"></div>
        <div class="resources-noise"></div>
      </div>
      
      <main>
        <section class="section">
          <div class="page-header">
            <h1 class="page-title">
              <span class="page-hash">#</span> 数据仓库
            </h1>
            <p class="page-sub">精选工具、库与参考，为建造者准备的活体收藏。</p>
          </div>

          <div class="resource-grid">
            {resources.map((group) => (
              <div class="resource-group">
                <h2 class="group-title">{group.category}</h2>
                <ul class="group-list">
                  {group.items.map((item) => (
                    <li class="group-item">
                      <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-link">
                        <span class="item-name">{item.name}</span>
                        <span class="item-desc">{item.desc}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>
      </main>
    </div>
    <Footer />
  </body>
</html>