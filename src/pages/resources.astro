---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const resources = [
  {
    category: '语言与运行时',
    items: [
      { name: 'Rust', url: 'https://www.rust-lang.org', desc: '无畏的系统编程语言。' },
      { name: 'Zig', url: 'https://ziglang.org', desc: '通用语言与工具链。' },
      { name: 'Bun', url: 'https://bun.sh', desc: '快速的一体化 JavaScript 运行时。' },
    ],
  },
  {
    category: '基础设施与 DevOps',
    items: [
      { name: 'Nix', url: 'https://nixos.org', desc: '可复现的构建与部署。' },
      { name: 'Terraform', url: 'https://www.terraform.io', desc: '基础设施即代码。' },
      { name: 'Fly.io', url: 'https://fly.io', desc: '将应用服务器部署在用户附近。' },
    ],
  },
  {
    category: '数据库与存储',
    items: [
      { name: 'SQLite', url: 'https://www.sqlite.org', desc: '部署最广泛的数据库引擎。' },
      { name: 'DuckDB', url: 'https://duckdb.org', desc: '进程内分析型 SQL 数据库。' },
      { name: 'SurrealDB', url: 'https://surrealdb.com', desc: '面向现代应用的多模型数据库。' },
    ],
  },
  {
    category: '前端与设计',
    items: [
      { name: 'Astro', url: 'https://astro.build', desc: '内容优先的 Web 框架。' },
      { name: 'HTMX', url: 'https://htmx.org', desc: 'HTML 的高功率工具。' },
      { name: 'Tailwind CSS', url: 'https://tailwindcss.com', desc: '实用优先的 CSS 框架。' },
    ],
  },
  {
    category: 'AI 与机器学习',
    items: [
      { name: 'Ollama', url: 'https://ollama.com', desc: '本地运行大语言模型。' },
      { name: 'LangChain', url: 'https://www.langchain.com', desc: '构建 LLM 驱动的应用。' },
      { name: 'Hugging Face', url: 'https://huggingface.co', desc: 'AI 社区平台。' },
    ],
  },
  {
    category: '书籍与参考',
    items: [
      { name: 'Crafting Interpreters', url: 'https://craftinginterpreters.com', desc: '构建你自己的编程语言。' },
      { name: 'The Architecture of Open Source Applications', url: 'https://aosabook.org', desc: '真实系统如何构建。' },
      { name: 'Beej\'s Guide to Network Programming', url: 'https://beej.us/guide/bgnet/', desc: '从零开始的 Socket 编程。' },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`资源 — ${SITE_TITLE}`} description="精选工具、库与参考，为建造者准备。" />
  </head>
  <body>
    <Header />
    <main>
      <section class="section">
        <h1 class="page-title">
          <span class="page-hash">#</span> 数据仓库
        </h1>
        <p class="page-sub">精选工具、库与参考，为建造者准备的活体收藏。</p>

        <div class="resource-grid">
          {resources.map((group) => (
            <div class="resource-group">
              <h2 class="group-title">{group.category}</h2>
              <ul class="group-list">
                {group.items.map((item) => (
                  <li class="group-item">
                    <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-link">
                      <span class="item-name">{item.name}</span>
                      <span class="item-desc">{item.desc}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .section {
    max-width: 1000px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg);
  }

  .page-title {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-sm);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .page-hash {
    color: var(--accent);
  }

  .page-sub {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin-bottom: var(--space-xl);
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .resource-group {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-surface);
    padding: var(--space-lg);
  }

  .group-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border);
  }

  .group-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .group-item {
    margin: 0;
  }

  .item-link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-sm);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .item-link:hover {
    background: var(--bg-hover);
    text-shadow: none;
  }

  .item-name {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
  }

  .item-link:hover .item-name {
    color: var(--electric);
  }

  .item-desc {
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: var(--leading-normal);
  }

  @media (max-width: 640px) {
    .section {
      padding: var(--space-xl) var(--space-md);
    }

    .resource-grid {
      grid-template-columns: 1fr;
    }
  }
</style>