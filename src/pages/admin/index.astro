        <h2 style="margin-top:20px;">字体大小</h2>
        <div class="slider-wrap">
          <span style="font-size:11px;color:var(--text-muted)">A</span>
          <input type="range" min="12" max="18" value="14" oninput="document.getElementById('contentArea').style.fontSize=this.value+'px';document.getElementById('fontSizeVal').textContent=this.value+'px'">
          <span style="font-size:16px;color:var(--text-muted)">A</span>
          <span id="fontSizeVal" style="font-size:11px;color:var(--text-muted)">14px</span>
        </div>
      </div>
    `,

    plugins: () => `
      <div class="card">
