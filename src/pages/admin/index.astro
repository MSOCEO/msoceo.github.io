  // === UI Actions ===
  function switchView(name) {
    currentView = name;
    document.getElementById('breadcrumbView').textContent =
      {dashboard:'仪表盘',content:'内容管理',themes:'主题市场',plugins:'插件市场',store:'应用商店',security:'安全中心',migration:'数据迁移',settings:'系统设置'}[name] || name;
    document.getElementById('contentArea').innerHTML = views[name]();
    document.querySelectorAll('#sidebarNav button').forEach(b => b.classList.toggle('active', b.dataset.view === name));
    if (window.innerWidth < 768) document.getElementById('sidebar').classList.remove('open');
  }

  function sortTable(tableId, colIdx) {
    const table = document.getElementById(tableId);
    if (!table) return;
    const tbody = table.querySelector('tbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    const isAsc = table.dataset.sortCol == colIdx && table.dataset.sortDir === 'asc';
    rows.sort((a,b) => {
      let va = a.children[colIdx].textContent.trim();
      let vb = b.children[colIdx].textContent.trim();
      return isAsc ? vb.localeCompare(va, 'zh') : va.localeCompare(vb, 'zh');
    });
    rows.forEach(r => tbody.appendChild(r));
    table.dataset.sortCol = colIdx;
    table.dataset.sortDir = isAsc ? 'desc' : 'asc';
  }

  function togglePlugin(id) {
    const p = plugins.find(x => x.id === id);
    if (p) { p.installed = !p.installed; switchView('plugins'); }
  }

  function filterPlugins(q) {
    const grid = document.getElementById('pluginGrid');
    if (!grid) return;
    grid.querySelectorAll('.plugin-card').forEach(card => {
      const name = card.querySelector('.p-name').textContent.toLowerCase();
      card.style.display = name.includes(q.toLowerCase()) ? '' : 'none';
    });
  }

  function handleGlobalSearch(q) {
    if (!q) { switchView(currentView); return; }
    const lq = q.toLowerCase();
    // search blog
    const found = blogPosts.filter(p => p.title.toLowerCase().includes(lq) || p.category.toLowerCase().includes(lq));
    if (found.length) {
      document.getElementById('contentArea').innerHTML = `
        <div class="card"><h2>搜索结果: "${q}" (${found.length})</h2>
        <div class="table-wrap"><table><thead><tr><th>标题</th><th>分类</th><th>日期</th></tr></thead>
        <tbody>${found.map(p=>`<tr><td style="font-weight:500"><a href="/blog/${p.slug}" style="color:var(--text-primary);text-decoration:none">${p.title}</a></td><td><span class="tag tag-info">${p.category}</span></td><td style="color:var(--text-muted)">${p.date}</td></tr>`).join('')}</tbody></table></div></div>`;
    } else {
      document.getElementById('contentArea').innerHTML = `<div class="card"><p style="color:var(--text-muted)">未找到 "${q}" 相关结果</p></div>`;
    }
  }

  function openPostModal() { document.getElementById('postModal').classList.add('show'); }
  function closeModal() { document.getElementById('postModal').classList.remove('show'); }
  function submitPost() {
    const title = document.getElementById('postTitle').value.trim();
    const excerpt = document.getElementById('postExcerpt').value.trim();
    const category = document.getElementById('postCategory').value;
    const status = document.getElementById('postStatus').value;
    if (!title) { alert('请填写标题'); return; }
    blogPosts.push({ title, slug: title.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,''), date: new Date().toISOString().slice(0,10), status: status === '已发布' ? 'published' : 'draft', category });
    closeModal();
    switchView('content');
    document.getElementById('postTitle').value = '';
    document.getElementById('postExcerpt').value = '';
  }

  function togglePostStatus(idx) {
    blogPosts[idx].status = blogPosts[idx].status === 'published' ? 'draft' : 'published';
    switchView('content');
  }

  function deletePost(idx) {
    if (confirm('确定删除 "' + blogPosts[idx].title + '" ？')) {
      blogPosts.splice(idx, 1);
      switchView('content');
    }
  }

  function setDensity(level, btn) {
    const area = document.getElementById('contentArea');
    if (level === 'comfortable') area.style.setProperty('--density-padding', '32px');
    else if (level === 'compact') area.style.setProperty('--density-padding', '16px');
    else area.style.removeProperty('--density-padding');
    document.querySelectorAll('.density-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    // adjust card padding
    const cards = area.querySelectorAll('.card');
    cards.forEach(c => {
      if (level === 'comfortable') c.style.padding = '32px';
      else if (level === 'compact') c.style.padding = '14px';
      else c.style.padding = '';
    });
  }

  function toggleNotify() {
    document.getElementById('notifyDropdown').classList.toggle('show');
  }

  // === Init ===
  document.querySelectorAll('#sidebarNav button').forEach(btn => {
    btn.addEventListener('click', () => switchView(btn.dataset.view));
  });

  document.getElementById('hamburger').addEventListener('click', () => {
    document.getElementById('sidebar').classList.toggle('open');
  });

  document.addEventListener('click', (e) => {
    if (!e.target.closest('.topbar-notify') && !e.target.closest('#notifyDropdown')) {
      document.getElementById('notifyDropdown').classList.remove('show');
    }
  });

  document.getElementById('postModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  switchView('dashboard');
</script>
