    '星云紫雾': { '--bg-primary':'#0d0812','--bg-secondary':'#150f1e','--bg-card':'#1d1428','--accent':'#a855f7','--accent-secondary':'#c084fc','--accent-glow':'rgba(168,85,247,0.15)','--text-primary':'#ede2f2','--text-secondary':'#b894c0','--text-muted':'#7d5c8a','--border':'#2e1e33','--success':'#22c55e','--warning':'#f59e0b','--danger':'#ef4444' },
