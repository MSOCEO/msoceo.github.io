          <div class="progress-wrap"><div class="progress-label"><span>内存</span><span>45%</span></div><div class="progress-bar"><div class="progress-fill" style="width:45%;background:var(--success)"></div></div></div>
          <div class="progress-wrap"><div class="progress-label"><span>存储</span><span>32%</span></div><div class="progress-bar"><div class="progress-fill" style="width:32%;background:var(--warning)"></div></div></div>
