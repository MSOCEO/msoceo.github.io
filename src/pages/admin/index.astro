---
// 枕星 CMS — 仪表板后台（单页 Hash 路由）
import BaseHead from '../../components/BaseHead.astro';
const title = '仪表板 | 枕星后台';
const description = '枕星内容管理系统后台仪表板';
---

<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead title={title} description={description} />
</head>
<body class="admin-body">

<!-- ========== 侧边栏 ========== -->
<aside class="admin-sidebar" id="sidebar">
  <div class="sidebar-brand">
    <span class="brand-name">枕星 CMS</span>
    <span class="brand-version">v1.0</span>
  </div>
  <nav class="sidebar-nav">
    <a href="#dashboard" class="admin-nav-item active" data-hash="dashboard">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      仪表板
    </a>
    <a href="#posts" class="admin-nav-item" data-hash="posts">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      文章 <span class="nav-badge">5</span>
    </a>
    <a href="#pages" class="admin-nav-item" data-hash="pages">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      页面 <span class="nav-badge">2</span>
    </a>
    <a href="#media" class="admin-nav-item" data-hash="media">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      媒体库
    </a>
    <a href="#comments" class="admin-nav-item" data-hash="comments">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      评论 <span class="nav-badge">3</span>
    </a>
    <a href="#appearance" class="admin-nav-item" data-hash="appearance">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
      外观
    </a>
    <a href="#users" class="admin-nav-item" data-hash="users">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
      用户 <span class="nav-badge">2</span>
    </a>
    <a href="#tools" class="admin-nav-item" data-hash="tools">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      工具
    </a>
    <a href="#settings" class="admin-nav-item" data-hash="settings">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      设置
    </a>
    <a href="#navlinks" class="admin-nav-item" data-hash="navlinks">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
      导航站
    </a>
  </nav>
  <div class="sidebar-footer">
    <button id="logout-btn" class="btn-logout">退出登录</button>
  </div>
</aside>

<!-- ========== 主内容区 ========== -->
<div class="admin-main" id="admin-main">
  <!-- 顶栏 -->
  <header class="admin-topbar">
    <button class="hamburger" id="hamburger" aria-label="菜单"><span></span><span></span><span></span></button>
    <div class="topbar-breadcrumb" id="breadcrumb">仪表板 / 概览</div>
    <div class="topbar-actions">
      <span class="topbar-icon" title="通知">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/></svg>
      </span>
      <div class="topbar-avatar">管理员</div>
    </div>
  </header>

  <div class="admin-content">

    <!-- ================================================================
         视图 1: #dashboard（仪表板）
         ================================================================ -->
    <div data-page="dashboard" class="page-view active">

      <!-- 统计卡片 -->
      <div class="stats-grid">
        <div class="stat-card" style="--accent:#3b82f6">
          <div class="stat-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </div>
          <div class="stat-info">
            <div class="stat-value">5</div>
            <div class="stat-label">文章</div>
            <div class="stat-sub">3 已发布 / 2 草稿</div>
          </div>
        </div>
        <div class="stat-card" style="--accent:#10b981">
          <div class="stat-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <div class="stat-info">
            <div class="stat-value">2</div>
            <div class="stat-label">页面</div>
            <div class="stat-sub">全部已发布</div>
          </div>
        </div>
        <div class="stat-card" style="--accent:#f59e0b">
          <div class="stat-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <div class="stat-info">
            <div class="stat-value">3</div>
            <div class="stat-label">评论</div>
            <div class="stat-sub">1 待审核</div>
          </div>
        </div>
        <div class="stat-card" style="--accent:#8b5cf6">
          <div class="stat-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <div class="stat-info">
            <div class="stat-value">128</div>
            <div class="stat-label">今日访客</div>
            <div class="stat-sub">+12% 较昨日</div>
          </div>
        </div>
      </div>

      <!-- 网站健康 + 快速草稿 -->
      <div class="content-grid-2col">
        <div class="panel">
          <h3 class="panel-title">网站健康状态</h3>
          <div class="health-list">
            <div class="health-item"><span class="health-dot ok"></span> 站点运行正常</div>
            <div class="health-item"><span class="health-dot ok"></span> Astro 5.x</div>
            <div class="health-item"><span class="health-dot ok"></span> GitHub Pages</div>
            <div class="health-item"><span class="health-dot ok"></span> HTTPS 已启用</div>
            <div class="health-item"><span class="health-dot ok"></span> 最后构建 2026-06-15</div>
          </div>
        </div>
        <div class="panel">
          <h3 class="panel-title">快速草稿</h3>
          <div class="quick-draft">
            <input class="input" type="text" id="draft-title" placeholder="输入标题..." />
            <textarea class="input textarea" id="draft-content" rows="3" placeholder="写点什么..."></textarea>
            <button class="btn btn-primary btn-sm" id="save-draft-btn">保存草稿</button>
          </div>
        </div>
      </div>

      <!-- 最近动态时间线 -->
      <div class="panel">
        <h3 class="panel-title">最近动态</h3>
        <div class="timeline">
          <div class="tl-item"><span class="tl-dot post"></span><span class="tl-time">06-15 14:30</span><span class="tl-text">文章 <strong>Astro 5 升级笔记</strong> 已发布</span></div>
          <div class="tl-item"><span class="tl-dot page"></span><span class="tl-time">06-12 09:15</span><span class="tl-text">页面 <strong>留言板</strong> 已更新</span></div>
          <div class="tl-item"><span class="tl-dot comment"></span><span class="tl-time">06-10 16:42</span><span class="tl-text">收到新评论：<strong>写得真好，学习了！</strong></span></div>
          <div class="tl-item"><span class="tl-dot setting"></span><span class="tl-time">06-08 11:00</span><span class="tl-text">设置变更：固定链接结构已更新</span></div>
          <div class="tl-item"><span class="tl-dot build"></span><span class="tl-time">06-05 03:00</span><span class="tl-text">站点构建完成</span></div>
        </div>
      </div>
    </div>

    <!-- ================================================================
         视图 2: #posts（文章管理）
         ================================================================ -->
    <div data-page="posts" class="page-view">
      <div class="page-toolbar">
        <h2 class="page-heading">所有文章</h2>
        <div class="toolbar-actions">
          <input class="input toolbar-input" type="text" placeholder="搜索文章..." />
          <select class="input toolbar-select">
            <option>全部分类</option><option>技术</option><option>教程</option><option>随笔</option>
          </select>
          <button class="btn btn-primary btn-sm">写文章</button>
        </div>
      </div>
      <div class="panel panel-table">
        <table class="data-table">
          <thead>
            <tr><th><input type="checkbox" /></th><th>标题</th><th>作者</th><th>分类</th><th>日期</th><th>状态</th><th></th></tr>
          </thead>
          <tbody>
            <tr><td><input type="checkbox" /></td><td><a href="#">First post</a><br><small class="text-muted">first-post</small></td><td>管理员</td><td><span class="tag tag-accent">技术</span></td><td>2022-07-08</td><td><span class="status status-published">已发布</span></td><td class="row-actions"><a href="#">编辑</a> | <a href="#">快速编辑</a> | <a href="#" class="text-danger">移至回收站</a></td></tr>
            <tr><td><input type="checkbox" /></td><td><a href="#">Markdown Style Guide</a><br><small class="text-muted">markdown-style-guide</small></td><td>管理员</td><td><span class="tag tag-accent">教程</span></td><td>2024-06-19</td><td><span class="status status-published">已发布</span></td><td class="row-actions"><a href="#">编辑</a> | <a href="#">快速编辑</a> | <a href="#" class="text-danger">移至回收站</a></td></tr>
            <tr><td><input type="checkbox" /></td><td><a href="#">Second post</a><br><small class="text-muted">second-post</small></td><td>管理员</td><td><span class="tag tag-accent">技术</span></td><td>2022-07-15</td><td><span class="status status-published">已发布</span></td><td class="row-actions"><a href="#">编辑</a> | <a href="#">快速编辑</a> | <a href="#" class="text-danger">移至回收站</a></td></tr>
            <tr><td><input type="checkbox" /></td><td><a href="#">Third post</a><br><small class="text-muted">third-post</small></td><td>管理员</td><td><span class="tag tag-accent">随笔</span></td><td>2022-07-22</td><td><span class="status status-draft">草稿</span></td><td class="row-actions"><a href="#">编辑</a> | <a href="#">快速编辑</a> | <a href="#" class="text-danger">移至回收站</a></td></tr>
            <tr><td><input type="checkbox" /></td><td><a href="#">Using MDX</a><br><small class="text-muted">using-mdx</small></td><td>管理员</td><td><span class="tag tag-accent">教程</span></td><td>2024-06-25</td><td><span class="status status-draft">草稿</span></td><td class="row-actions"><a href="#">编辑</a> | <a href="#">快速编辑</a> | <a href="#" class="text-danger">移至回收站</a></td></tr>
          </tbody>
        </table>
      </div>
      <div class="table-footer">
        <div class="bulk-actions">
          <select class="input toolbar-select"><option>批量操作</option><option>编辑</option><option>移至回收站</option></select>
          <button class="btn btn-secondary btn-sm">应用</button>
        </div>
        <div class="pagination-info">共 5 篇</div>
      </div>
    </div>

    <!-- ================================================================
         视图 3: #pages（页面管理）
         ================================================================ -->
    <div data-page="pages" class="page-view">
      <div class="page-toolbar">
        <h2 class="page-heading">所有页面</h2>
        <div class="toolbar-actions">
          <button class="btn btn-primary btn-sm">新建页面</button>
        </div>
      </div>
      <div class="panel panel-table">
        <table class="data-table">
          <thead>
            <tr><th><input type="checkbox" /></th><th>标题</th><th>作者</th><th>Slug</th><th>日期</th><th>状态</th><th></th></tr>
          </thead>
          <tbody>
            <tr><td><input type="checkbox" /></td><td><a href="#">关于</a></td><td>管理员</td><td>about</td><td>2026-01-01</td><td><span class="status status-published">已发布</span></td><td class="row-actions"><a href="#">编辑</a> | <a href="#" class="text-danger">移至回收站</a></td></tr>
            <tr><td><input type="checkbox" /></td><td><a href="#">留言板</a></td><td>管理员</td><td>guestbook</td><td>2026-06-01</td><td><span class="status status-published">已发布</span></td><td class="row-actions"><a href="#">编辑</a> | <a href="#" class="text-danger">移至回收站</a></td></tr>
          </tbody>
        </table>
      </div>
      <div class="table-footer">
        <div class="bulk-actions">
          <select class="input toolbar-select"><option>批量操作</option><option>移至回收站</option></select>
          <button class="btn btn-secondary btn-sm">应用</button>
        </div>
        <div class="pagination-info">共 2 页</div>
      </div>
    </div>

    <!-- ================================================================
         视图 4: #media（媒体库）
         ================================================================ -->
    <div data-page="media" class="page-view">
      <div class="page-toolbar">
        <h2 class="page-heading">媒体库</h2>
        <div class="toolbar-actions">
          <div class="view-toggle">
            <button class="btn btn-secondary btn-sm view-btn active" data-view="grid">网格</button>
            <button class="btn btn-secondary btn-sm view-btn" data-view="list">列表</button>
          </div>
          <button class="btn btn-primary btn-sm">添加新媒体</button>
        </div>
      </div>
      <div class="media-grid" id="media-grid">
        <div class="media-card"><div class="media-thumb" style="background:linear-gradient(135deg,#1a1a2e,#3b82f6)"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div><div class="media-info"><span class="media-name">hero-banner.png</span><span class="media-meta">2.4 MB · 2026-06-10</span></div></div>
        <div class="media-card"><div class="media-thumb" style="background:linear-gradient(135deg,#1a1a2e,#10b981)"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div><div class="media-info"><span class="media-name">avatar-admin.jpg</span><span class="media-meta">128 KB · 2026-06-09</span></div></div>
        <div class="media-card"><div class="media-thumb" style="background:linear-gradient(135deg,#1a1a2e,#f59e0b)"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div><div class="media-info"><span class="media-name">blog-placeholder-1.jpg</span><span class="media-meta">1.1 MB · 2026-06-08</span></div></div>
        <div class="media-card"><div class="media-thumb" style="background:linear-gradient(135deg,#1a1a2e,#8b5cf6)"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div><div class="media-info"><span class="media-name">og-image.png</span><span class="media-meta">890 KB · 2026-06-07</span></div></div>
        <div class="media-card"><div class="media-thumb" style="background:linear-gradient(135deg,#1a1a2e,#ef4444)"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div><div class="media-info"><span class="media-name">screenshot-01.png</span><span class="media-meta">2.0 MB · 2026-06-06</span></div></div>
        <div class="media-card"><div class="media-thumb" style="background:linear-gradient(135deg,#1a1a2e,#06b6d4)"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div><div class="media-info"><span class="media-name">icon-favicon.svg</span><span class="media-meta">4 KB · 2026-06-05</span></div></div>
        <div class="media-card"><div class="media-thumb" style="background:linear-gradient(135deg,#1a1a2e,#84cc16)"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div><div class="media-info"><span class="media-name">photo-album.zip</span><span class="media-meta">15 MB · 2026-06-04</span></div></div>
        <div class="media-card"><div class="media-thumb" style="background:linear-gradient(135deg,#1a1a2e,#a855f7)"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div><div class="media-info"><span class="media-name">background-dark.jpg</span><span class="media-meta">3.2 MB · 2026-06-03</span></div></div>
      </div>
      <div class="table-footer"><div class="pagination-info">共 8 个文件</div></div>
    </div>

    <!-- ================================================================
         视图 5: #comments（评论管理）
         ================================================================ -->
    <div data-page="comments" class="page-view">
      <div class="comment-filters">
        <button class="comment-filter-btn active">全部 <span class="c-count">3</span></button>
        <button class="comment-filter-btn">待审核 <span class="c-count c-pending">1</span></button>
        <button class="comment-filter-btn">已批准 <span class="c-count">2</span></button>
        <button class="comment-filter-btn">垃圾评论 <span class="c-count">0</span></button>
      </div>
      <div class="panel panel-table">
        <table class="data-table">
          <thead>
            <tr><th><input type="checkbox" /></th><th>作者</th><th>评论内容</th><th>回复至</th><th>日期</th><th>状态</th><th></th></tr>
          </thead>
          <tbody>
