---
// 枕星 CMS — 仪表板后台
import BaseHead from '../../components/BaseHead.astro';
const title = '仪表板 | 枕星后台';
const description = '枕星内容管理系统后台仪表板';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="admin-body">
    <!-- ========== 侧边栏 ========== -->
    <aside class="admin-sidebar" id="sidebar">
      <div class="sidebar-brand">
        <span class="brand-name">枕星 CMS</span>
        <span class="brand-version">v1.0</span>
      </div>
      <nav class="sidebar-nav">
        <a href="#" class="nav-item active">
          <span class="nav-dot"></span> 仪表板
        </a>
        <a href="#" class="nav-item">
          文章 <span class="nav-badge">5</span>
        </a>
        <a href="#" class="nav-item">
          页面 <span class="nav-badge">2</span>
        </a>
        <a href="#" class="nav-item">媒体库</a>
        <a href="#" class="nav-item">
          评论 <span class="nav-badge">3</span>
        </a>
        <a href="#" class="nav-item">外观</a>
        <a href="#" class="nav-item">用户</a>
        <a href="#" class="nav-item">设置</a>
        <a href="#" class="nav-item">导航站</a>
      </nav>
      <div class="sidebar-footer">
        <button id="logout-btn" class="btn-logout">退出登录</button>
      </div>
    </aside>

    <!-- ========== 主内容区 ========== -->
    <div class="admin-main">
      <!-- 顶栏 -->
      <header class="admin-topbar">
        <button class="hamburger" id="hamburger" aria-label="菜单">
          <span></span><span></span><span></span>
        </button>
        <div class="topbar-breadcrumb">仪表板 / 概览</div>
        <div class="topbar-actions">
          <span class="topbar-icon" title="通知">🔔</span>
          <div class="topbar-avatar">管理员</div>
        </div>
      </header>

      <!-- 内容区 -->
      <div class="admin-content">
        <!-- 统计卡片 -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon">📝</div>
            <div class="stat-info">
              <div class="stat-value">5</div>
              <div class="stat-label">文章总数</div>
              <div class="stat-sub">3 篇已发布</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon">📄</div>
            <div class="stat-info">
              <div class="stat-value">2</div>
              <div class="stat-label">页面总数</div>
              <div class="stat-sub">全部已发布</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon">💬</div>
            <div class="stat-info">
              <div class="stat-value">3</div>
              <div class="stat-label">总评论数</div>
              <div class="stat-sub">1 条待审核</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon">👁</div>
            <div class="stat-info">
              <div class="stat-value">128</div>
              <div class="stat-label">今日访客</div>
              <div class="stat-sub">+12% 较昨日</div>
            </div>
          </div>
        </div>

        <!-- 两列布局 -->
        <div class="content-grid">
          <!-- 左列: 最近文章 -->
          <div class="panel panel-recent">
            <h3 class="panel-title">最近文章</h3>
            <table class="data-table">
              <thead>
                <tr>
                  <th>标题</th>
                  <th>分类</th>
                  <th>日期</th>
                  <th>状态</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>First post</td>
                  <td>技术</td>
                  <td>2022-07-08</td>
                  <td><span class="status status-published">已发布</span></td>
                </tr>
                <tr>
                  <td>Markdown Style Guide</td>
                  <td>教程</td>
                  <td>2024-06-19</td>
                  <td><span class="status status-published">已发布</span></td>
                </tr>
                <tr>
                  <td>Second post</td>
                  <td>技术</td>
                  <td>2022-07-15</td>
                  <td><span class="status status-published">已发布</span></td>
                </tr>
                <tr>
                  <td>Third post</td>
                  <td>技术</td>
                  <td>2022-07-22</td>
                  <td><span class="status status-draft">草稿</span></td>
                </tr>
                <tr>
                  <td>Astro 5 升级笔记</td>
                  <td>开发</td>
                  <td>2026-06-10</td>
                  <td><span class="status status-draft">草稿</span></td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- 右列: 快速操作 + 最近评论 -->
          <div class="panel-group">
            <div class="panel panel-actions">
              <h3 class="panel-title">快速操作</h3>
              <div class="quick-actions">
                <button class="btn-action">写文章</button>
                <button class="btn-action">新建页面</button>
                <button class="btn-action">上传媒体</button>
                <button class="btn-action">管理评论</button>
              </div>
            </div>
            <div class="panel panel-comments">
              <h3 class="panel-title">最近评论</h3>
              <ul class="comment-list">
                <li class="comment-item">
                  <span class="comment-author">访客_张三</span>
                  <span class="comment-text">好文章，学习了！</span>
                  <span class="comment-meta">First post · 2 天前</span>
                </li>
                <li class="comment-item">
                  <span class="comment-author">访客_李四</span>
                  <span class="comment-text">请问 Markdown 支持表格吗？</span>
                  <span class="comment-meta">Markdown Style Guide · 5 天前</span>
                </li>
                <li class="comment-item pending">
                  <span class="comment-author">访客_Wang</span>
                  <span class="comment-text">期待更多内容更新</span>
                  <span class="comment-meta">Second post · 1 周前</span>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- 系统信息 -->
        <div class="panel panel-system">
          <h3 class="panel-title">系统信息</h3>
          <div class="system-info-grid">
            <div class="sys-item">
              <span class="sys-label">Astro 版本</span>
              <span class="sys-value">5.x</span>
            </div>
            <div class="sys-item">
              <span class="sys-label">部署方式</span>
              <span class="sys-value">GitHub Pages</span>
            </div>
            <div class="sys-item">
              <span class="sys-label">主题</span>
              <span class="sys-value">墨影 Monoshade</span>
            </div>
            <div class="sys-item">
              <span class="sys-label">最后更新</span>
              <span class="sys-value">2026-06-15</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>

<style>
  /* ============================================
     Admin Layout — CMS 仪表板
     墨影暗色主题 + 琥珀金强调色
     ============================================ */

  .admin-body {
    display: flex;
    min-height: 100vh;
    background: var(--ink-5, #0d0d0d);
    font-family: var(--font-body);
    color: var(--ink-70);
  }

  /* ---- 侧边栏 ---- */
  .admin-sidebar {
    width: 240px;
    min-width: 240px;
    background: #1a1a2e;
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(255,255,255,0.06);
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 100;
    overflow-y: auto;
  }

  .sidebar-brand {
    padding: var(--space-lg) var(--space-xl);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--amber-400);
    letter-spacing: 0.04em;
  }

  .brand-version {
    font-size: var(--text-xs);
    color: var(--ink-40);
  }

  .sidebar-nav {
    flex: 1;
    padding: var(--space-md) 0;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.7rem var(--space-xl);
    color: #a0a0b0;
    font-size: var(--text-sm);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out);
    position: relative;
  }

  .nav-item:hover {
    color: var(--ink-90);
    background: rgba(255,255,255,0.04);
  }

  .nav-item.active {
    color: var(--amber-400);
    background: rgba(212,165,116,0.08);
  }

  .nav-item.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 4px;
    bottom: 4px;
    width: 3px;
    background: var(--amber-400);
    border-radius: 0 2px 2px 0;
  }

  .nav-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--amber-400);
  }

  .nav-badge {
    margin-left: auto;
    background: rgba(212,165,116,0.15);
    color: var(--amber-400);
    font-size: 11px;
    padding: 1px 7px;
    border-radius: var(--radius-full);
    line-height: 1.5;
  }

  .sidebar-footer {
    padding: var(--space-md) var(--space-xl);
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .btn-logout {
    width: 100%;
    padding: 0.5rem 0;
    background: transparent;
    border: 1px solid rgba(229,72,77,0.2);
    border-radius: var(--radius-md);
    color: var(--error);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .btn-logout:hover {
    background: rgba(229,72,77,0.1);
  }

  /* ---- 主内容区 ---- */
  .admin-main {
    flex: 1;
    margin-left: 240px;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .admin-topbar {
    display: flex;
    align-items: center;
    padding: 0 var(--space-xl);
    height: 60px;
    background: var(--ink-10);
    border-bottom: 1px solid var(--ink-20);
    gap: var(--space-lg);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--ink-50);
    border-radius: 2px;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .topbar-breadcrumb {
    font-size: var(--text-sm);
    color: var(--ink-50);
  }

  .topbar-actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .topbar-icon {
    font-size: 1.2rem;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity var(--duration-fast);
  }

  .topbar-icon:hover { opacity: 1; }

  .topbar-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--amber-400);
    color: var(--ink-0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    cursor: pointer;
  }

  /* ---- 内容区 ---- */
  .admin-content {
    flex: 1;
    padding: var(--space-xl);
    background: var(--ink-5, #0d0d0d);
  }

  /* ---- 统计卡片 ---- */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .stat-card {
    background: var(--ink-10);
    border: 1px solid var(--ink-20);
    border-left: 3px solid var(--amber-400);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .stat-card:hover {
    border-color: var(--ink-30);
    box-shadow: var(--shadow-md);
  }

  .stat-icon {
    font-size: 1.8rem;
    line-height: 1;
    opacity: 0.8;
  }

  .stat-value {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--ink-90);
    line-height: 1.1;
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--ink-50);
    margin-top: 2px;
  }

  .stat-sub {
    font-size: 11px;
    color: var(--ink-40);
    margin-top: 1px;
  }

  /* ---- 两列布局 ---- */
  .content-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  /* ---- 面板 ---- */
  .panel {
    background: var(--ink-10);
    border: 1px solid var(--ink-20);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
  }

  .panel-title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--ink-90);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--ink-20);
  }

  .panel-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  /* ---- 数据表格 ---- */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .data-table th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    color: var(--ink-40);
    font-weight: var(--weight-medium);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--ink-20);
  }

  .data-table td {
    padding: 0.6rem 0.75rem;
    color: var(--ink-70);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }

  .data-table tbody tr:hover {
    background: rgba(255,255,255,0.03);
  }

  .status {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: var(--radius-full);
    font-weight: var(--weight-medium);
  }

  .status-published {
    background: rgba(61,186,130,0.12);
    color: var(--success);
  }

  .status-draft {
    background: rgba(136,136,136,0.12);
    color: var(--ink-50);
  }

  /* ---- 快速操作 ---- */
  .quick-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
  }

  .btn-action {
    padding: 0.6rem 0.8rem;
    background: var(--ink-15);
    border: 1px solid var(--ink-20);
    border-radius: var(--radius-md);
    color: var(--ink-70);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    text-align: center;
  }

  .btn-action:hover {
    border-color: var(--amber-400);
    color: var(--amber-400);
    background: rgba(212,165,116,0.06);
  }

  /* ---- 评论列表 ---- */
  .comment-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-height: 260px;
    overflow-y: auto;
  }

  .comment-item {
    padding: var(--space-sm) var(--space-md);
    background: var(--ink-15);
    border-radius: var(--radius-sm);
    border-left: 2px solid transparent;
  }

  .comment-item.pending {
    border-left-color: var(--warn);
  }

  .comment-author {
    font-weight: var(--weight-semibold);
    color: var(--ink-70);
    font-size: var(--text-sm);
  }

  .comment-text {
    display: block;
    color: var(--ink-50);
    font-size: var(--text-xs);
    margin-top: 2px;
  }

  .comment-meta {
    display: block;
    color: var(--ink-40);
    font-size: 11px;
    margin-top: 4px;
  }

  /* ---- 系统信息 ---- */
  .panel-system {
    margin-top: 0;
  }

  .system-info-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  .sys-item {
    text-align: center;
    padding: var(--space-md);
    background: var(--ink-15);
    border-radius: var(--radius-sm);
  }

  .sys-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--ink-40);
    margin-bottom: 4px;
  }

  .sys-value {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--amber-400);
  }

  /* ---- 响应式 ---- */
  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .content-grid {
      grid-template-columns: 1fr;
    }
    .system-info-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .admin-sidebar {
      transform: translateX(-100%);
      transition: transform var(--duration-slow) var(--ease-out);
    }
    .admin-sidebar.open {
      transform: translateX(0);
    }
    .admin-main {
      margin-left: 0;
    }
    .hamburger {
      display: flex;
    }
    .stats-grid {
      grid-template-columns: 1fr;
    }
    .system-info-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script>
  // 汉堡菜单
  const hamburger = document.getElementById('hamburger');
  const sidebar = document.getElementById('sidebar');
  hamburger.addEventListener('click', () => {
    sidebar.classList.toggle('open');
  });

  // 退出登录
  document.getElementById('logout-btn').addEventListener('click', () => {
    localStorage.removeItem('zhenxing_auth');
    window.location.href = '/login';
  });
</script>
