              <div class="name">${name}</div>
              <div class="desc">点击应用</div>
            </div>
          `).join('')}
        </div>
      </div>
      <div class="card">
        <h2>页面独立主题</h2>
        <div class="table-wrap">
          <table>
            <thead><tr><th>页面</th><th>路径</th><th>主题方案</th></tr></thead>
            <tbody>${SITE.pages.map(p => `
              <tr>
                <td style="font-weight:500;">${p.title}</td>
                <td style="font-family:monospace;font-size:12px;color:var(--text-muted)">${p.path}</td>
                <td>
                  <select onchange="pageThemes['${p.path}']=this.value" style="padding:4px 8px;background:var(--bg-primary);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text-primary);font-size:12px;">
