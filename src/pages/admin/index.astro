<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>后台管理 · 星舟</title>
<style>
  :root {
    --bg: #0b0e14;
    --bg-card: #13161e;
    --text: #e2e8f0;
    --text-secondary: #94a3b8;
    --text-muted: #64748b;
    --accent: #818cf8;
    --border: #1e2130;
    --radius: 10px;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Noto Sans SC", sans-serif;
    font-size: 14px;
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { opacity: 0.8; }

  /* Layout */
  .topbar {
    position: sticky; top: 0; z-index: 50;
    background: rgba(11,14,20,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 24px; height: 52px;
    display: flex; align-items: center; gap: 20px;
  }
  .topbar-brand { font-weight: 600; font-size: 15px; color: var(--text); }
  .topbar-nav { display: flex; gap: 4px; }
  .topbar-nav a, .topbar-nav button {
    padding: 6px 14px; border-radius: 6px; font-size: 13px;
    color: var(--text-secondary); border: none; background: none;
    cursor: pointer; transition: all 0.15s; font-family: inherit;
  }
  .topbar-nav a:hover, .topbar-nav button:hover { color: var(--text); background: rgba(255,255,255,0.04); }
  .topbar-nav a.active, .topbar-nav button.active { color: var(--accent); background: rgba(129,140,248,0.08); }
  .topbar-spacer { flex: 1; }
  .topbar-link { font-size: 13px; color: var(--text-secondary); }

  .container { max-width: 1100px; margin: 0 auto; padding: 32px 24px; }

  /* Stats */
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px; }
  .stat-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 20px 24px;
  }
  .stat-label { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
  .stat-value { font-size: 28px; font-weight: 700; font-variant-numeric: tabular-nums; }

  /* Cards */
  .card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 24px; margin-bottom: 20px;
  }
  .card h2 { font-size: 16px; font-weight: 600; margin-bottom: 16px; }

  /* Table */
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th {
    text-align: left; padding: 10px 14px; font-weight: 600; font-size: 11px;
    text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }
  td { padding: 12px 14px; border-bottom: 1px solid var(--border); color: var(--text-secondary); }
  tr:hover td { background: rgba(255,255,255,0.02); }
  tr:last-child td { border-bottom: none; }
  .td-title { color: var(--text); font-weight: 500; }
  .td-mono { font-family: "SF Mono", "Fira Code", monospace; font-size: 12px; color: var(--text-muted); }
  .tag {
    display: inline-block; font-size: 10px; padding: 2px 8px; border-radius: 4px;
    font-weight: 500; letter-spacing: 0.03em;
  }
  .tag-blog { background: rgba(129,140,248,0.12); color: #818cf8; }
  .tag-page { background: rgba(52,211,153,0.12); color: #34d399; }
  .tag-system { background: rgba(251,191,36,0.12); color: #fbbf24; }

  /* Quick actions */
  .actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 18px; border-radius: 6px; font-size: 13px; font-weight: 500;
    border: 1px solid var(--border); color: var(--text-secondary);
    background: transparent; cursor: pointer; transition: all 0.15s;
    font-family: inherit;
  }
  .btn:hover { border-color: var(--accent); color: var(--accent); }
  .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn-primary:hover { opacity: 0.88; }

  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .list-simple { display: flex; flex-direction: column; gap: 10px; }
  .list-item { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid var(--border); }
  .list-item:last-child { border-bottom: none; }
  .list-item .label { color: var(--text-secondary); }
  .list-item .value { font-weight: 500; }

  @media (max-width: 768px) {
    .stats { grid-template-columns: repeat(2, 1fr); }
    .grid-2 { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
  <header class="topbar">
    <span class="topbar-brand">星舟后台</span>
    <nav class="topbar-nav" id="topNav">
      <button class="active" data-view="overview">概览</button>
      <button data-view="content">内容</button>
      <button data-view="pages">页面</button>
      <button data-view="settings">设置</button>
    </nav>
    <span class="topbar-spacer"></span>
    <a href="/" class="topbar-link">返回前台</a>
  </header>

  <div class="container" id="mainContent"></div>

  <script>
    // Site manifest — captures all pages for this static blog
    const SITE = {
      blog: [
        { title: 'Getting Started', slug: 'first-post', date: '2026-01-15', status: 'published' },
        { title: 'Markdown 样式指南', slug: 'markdown-style-guide', date: '2026-01-20', status: 'published' },
        { title: 'Building with Astro', slug: 'second-post', date: '2026-02-10', status: 'published' },
        { title: 'MDX in Astro', slug: 'third-post', date: '2026-03-05', status: 'published' },
        { title: 'Using MDX', slug: 'using-mdx', date: '2026-03-05', status: 'published' },
      ],
      pages: [
        { title: '首页', path: '/', status: 'published' },
        { title: '导航', path: '/links', status: 'published' },
        { title: '关于', path: '/about', status: 'published' },
        { title: '博客', path: '/blog', status: 'published' },
        { title: '资源', path: '/resources', status: 'published' },
        { title: '留言板', path: '/guestbook', status: 'published' },
        { title: 'ICP备案', path: '/icp', status: 'published' },
        { title: '管理后台', path: '/admin', status: 'system' },
        { title: '登录', path: '/login', status: 'system' },
        { title: '注册', path: '/register', status: 'system' },
      ]
    };

    const views = {
      overview: () => `
        <div class="stats">
          <div class="stat-card">
            <div class="stat-label">文章</div>
            <div class="stat-value" style="color:#818cf8">${SITE.blog.length}</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">页面</div>
            <div class="stat-value" style="color:#34d399">${SITE.pages.length}</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">最后更新</div>
            <div class="stat-value" style="color:#fbbf24;font-size:16px;">${new Date().toISOString().slice(0,10)}</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">状态</div>
            <div class="stat-value" style="color:#34d399;font-size:16px;">运行中</div>
          </div>
        </div>

        <div class="grid-2">
          <div class="card">
            <h2>最近文章</h2>
            <div class="list-simple">
              ${[...SITE.blog].reverse().slice(0,5).map(p => `
                <div class="list-item">
                  <span><a href="/blog/${p.slug}">${p.title}</a></span>
                  <span style="color:var(--text-muted);font-size:12px;">${p.date}</span>
                </div>
              `).join('')}
            </div>
          </div>
          <div class="card">
            <h2>快捷操作</h2>
            <div class="actions" style="flex-direction:column;">
              <a href="/links" class="btn">前往导航站</a>
              <a href="/icp" class="btn">ICP备案系统</a>
              <a href="/blog" class="btn">查看博客</a>
              <button class="btn" onclick="alert('静态站点，内容通过 Git 管理。\\n编辑源文件后运行 npm run build 部署。')">如何发布文章</button>
            </div>
          </div>
        </div>
      `,

      content: () => `
        <div class="card">
          <h2>文章列表 (${SITE.blog.length})</h2>
          <div class="table-wrap">
            <table>
              <thead><tr><th>标题</th><th>别名</th><th>日期</th><th>状态</th></tr></thead>
              <tbody>${[...SITE.blog].reverse().map(p => `
                <tr>
                  <td class="td-title"><a href="/blog/${p.slug}">${p.title}</a></td>
                  <td class="td-mono">${p.slug}</td>
                  <td>${p.date}</td>
                  <td><span class="tag tag-blog">${p.status === 'published' ? '已发布' : p.status}</span></td>
                </tr>
              `).join('')}</tbody>
            </table>
          </div>
        </div>
      `,

      pages: () => `
        <div class="card">
          <h2>页面列表 (${SITE.pages.length})</h2>
          <div class="table-wrap">
            <table>
              <thead><tr><th>页面</th><th>路径</th><th>类型</th></tr></thead>
              <tbody>${SITE.pages.map(p => `
                <tr>
                  <td class="td-title"><a href="${p.path}">${p.title}</a></td>
                  <td class="td-mono">${p.path}</td>
                  <td><span class="tag ${p.status === 'system' ? 'tag-system' : 'tag-page'}">${p.status === 'published' ? '内容页' : p.status === 'system' ? '系统页' : p.status}</span></td>
                </tr>
              `).join('')}</tbody>
            </table>
          </div>
        </div>
      `,

      settings: () => `
        <div class="card">
          <h2>站点信息</h2>
          <div class="list-simple">
            <div class="list-item"><span class="label">站点名称</span><span class="value">星舟博客</span></div>
            <div class="list-item"><span class="label">域名</span><span class="value">msoceo.github.io</span></div>
            <div class="list-item"><span class="label">框架</span><span class="value">Astro SSG</span></div>
            <div class="list-item"><span class="label">构建方式</span><span class="value">GitHub Actions / 手动 push</span></div>
            <div class="list-item"><span class="label">内容管理</span><span class="value">Git 仓库 · src/content/</span></div>
            <div class="list-item"><span class="label">部署分支</span><span class="value">gh-pages / master</span></div>
          </div>
        </div>
        <div class="card">
          <h2>发布流程</h2>
          <p style="color:var(--text-secondary);font-size:13px;line-height:2;">
            1. 在 <code style="background:rgba(255,255,255,0.04);padding:2px 6px;border-radius:4px;">src/content/blog/</code> 下创建 Markdown 文件<br>
            2. 本地运行 <code style="background:rgba(255,255,255,0.04);padding:2px 6px;border-radius:4px;">npm run dev</code> 预览<br>
            3. <code style="background:rgba(255,255,255,0.04);padding:2px 6px;border-radius:4px;">git add -A && git commit && git push</code> 即可自动部署
          </p>
        </div>
      `
    };

    function render(view) {
      document.getElementById('mainContent').innerHTML = views[view]();
      document.querySelectorAll('#topNav button').forEach(b => b.classList.toggle('active', b.dataset.view === view));
    }

    document.querySelectorAll('#topNav button').forEach(btn => {
      btn.addEventListener('click', () => render(btn.dataset.view));
    });

    // Init
    render('overview');
  </script>
</body>
</html>
