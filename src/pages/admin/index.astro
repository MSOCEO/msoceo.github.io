<style>
  /* ============================================
     Admin Layout — CMS 仪表板 暗色+琥珀金
     ============================================ */
  :root {
    --sidebar-w: 240px;
    --topbar-h: 60px;
  }
  .admin-body {
    display: flex; min-height: 100vh;
    background: var(--ink-0); color: var(--ink-70);
    font-family: var(--font-body);
  }
  /* ---- 侧边栏 ---- */
  .admin-sidebar {
    width: var(--sidebar-w); min-width: var(--sidebar-w);
    background: #1a1a2e; display: flex; flex-direction: column;
    border-right: 1px solid rgba(255,255,255,0.06);
    position: fixed; top:0; left:0; bottom:0; z-index:100; overflow-y:auto;
  }
  .sidebar-brand {
    padding: var(--space-lg) var(--space-xl);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex; align-items: baseline; gap: var(--space-sm);
  }
  .brand-name { font-family: var(--font-display); font-size: var(--text-xl); font-weight: var(--weight-bold); color: var(--amber-400); letter-spacing: 0.04em; }
  .brand-version { font-size: var(--text-xs); color: var(--ink-40); }
  .sidebar-nav { flex:1; padding: var(--space-md) 0; }
  .admin-nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 0.7rem var(--space-xl); color: #a0a0b0; font-size: var(--text-sm);
    text-decoration: none; transition: all var(--duration-fast) var(--ease-out); position: relative;
  }
  .admin-nav-item:hover { color: var(--ink-90); background: rgba(255,255,255,0.04); }
  .admin-nav-item.active { color: var(--amber-400); background: rgba(212,165,116,0.08); }
  .admin-nav-item.active::before { content:''; position:absolute; left:0; top:4px; bottom:4px; width:3px; background:var(--amber-400); border-radius:0 2px 2px 0; }
  .nav-icon { width:18px; height:18px; flex-shrink:0; }
  .nav-badge { margin-left:auto; background:rgba(212,165,116,0.15); color:var(--amber-400); font-size:11px; padding:1px 7px; border-radius:var(--radius-full); line-height:1.5; }
  .sidebar-footer { padding:var(--space-md) var(--space-xl); border-top:1px solid rgba(255,255,255,0.06); }
  .btn-logout { width:100%; padding:0.5rem 0; background:transparent; border:1px solid rgba(229,72,77,0.2); border-radius:var(--radius-md); color:var(--error); font-size:var(--text-sm); cursor:pointer; transition:all var(--duration-fast); }
  .btn-logout:hover { background:rgba(229,72,77,0.1); }

  /* ---- 主内容区 ---- */
  .admin-main { flex:1; margin-left:var(--sidebar-w); display:flex; flex-direction:column; min-height:100vh; }
  .admin-topbar { display:flex; align-items:center; padding:0 var(--space-xl); height:var(--topbar-h); background:var(--ink-10); border-bottom:1px solid var(--ink-20); gap:var(--space-lg); position:sticky; top:0; z-index:50; }
  .hamburger { display:none; flex-direction:column; gap:4px; background:none; border:none; cursor:pointer; padding:4px; }
  .hamburger span { display:block; width:20px; height:2px; background:var(--ink-50); border-radius:2px; }
  .topbar-breadcrumb { font-size:var(--text-sm); color:var(--ink-50); }
  .topbar-actions { margin-left:auto; display:flex; align-items:center; gap:var(--space-lg); }
  .topbar-icon { cursor:pointer; opacity:0.7; color:var(--ink-50); transition:opacity var(--duration-fast); }
  .topbar-icon:hover { opacity:1; }
  .topbar-avatar { width:36px; height:36px; border-radius:50%; background:var(--amber-400); color:var(--ink-0); display:flex; align-items:center; justify-content:center; font-size:var(--text-xs); font-weight:var(--weight-semibold); cursor:pointer; }
  .admin-content { flex:1; padding:var(--space-xl); background:var(--ink-5, #0d0d0d); }

  /* ---- 页面视图 ---- */
  .page-view { display:none; }
  .page-view.active { display:block; }

  /* ---- 统计卡片 ---- */
  .stats-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--space-lg); margin-bottom:var(--space-xl); }
  .stat-card {
    background:var(--ink-10); border:1px solid var(--ink-20); border-left:4px solid var(--accent);
    border-radius:12px; padding:var(--space-lg); display:flex; align-items:flex-start; gap:var(--space-md);
    transition:all var(--duration-fast);
  }
  .stat-card:hover { border-color:var(--ink-30); box-shadow:var(--shadow-md); }
  .stat-icon { color:var(--accent); flex-shrink:0; margin-top:2px; }
  .stat-value { font-family:var(--font-mono); font-size:32px; font-weight:var(--weight-bold); color:var(--ink-90); line-height:1.1; }
  .stat-label { font-size:var(--text-xs); color:var(--ink-50); margin-top:2px; }
  .stat-sub { font-size:11px; color:var(--ink-40); margin-top:1px; }

  /* ---- 面板 ---- */
  .panel { background:var(--ink-10); border:1px solid var(--ink-20); border-radius:12px; padding:20px; margin-bottom:var(--space-lg); }
  .panel-title { font-size:var(--text-base); font-weight:var(--weight-semibold); color:var(--ink-90); margin-bottom:var(--space-md); padding-bottom:var(--space-sm); border-bottom:1px solid var(--ink-20); }
  .content-grid-2col { display:grid; grid-template-columns:1fr 1fr; gap:var(--space-lg); margin-bottom:var(--space-lg); }
  .panel-group { display:flex; flex-direction:column; gap:var(--space-lg); }

  /* ---- 页面工具栏 ---- */
  .page-toolbar { display:flex; justify-content:space-between; align-items:center; margin-bottom:var(--space-lg); flex-wrap:wrap; gap:var(--space-md); }
  .page-heading { font-size:var(--text-2xl); color:var(--ink-90); margin:0 0 var(--space-lg); }
  .toolbar-actions { display:flex; gap:var(--space-sm); align-items:center; flex-wrap:wrap; }
  .toolbar-input { width:200px; }
  .toolbar-select { width:auto; }

  /* ---- 表格 ---- */
  .panel-table { padding:0; overflow-x:auto; }
  .data-table { width:100%; border-collapse:collapse; font-size:var(--text-sm); }
  .data-table th { text-align:left; padding:0.6rem 0.75rem; color:var(--ink-40); font-weight:var(--weight-medium); font-size:var(--text-xs); text-transform:uppercase; letter-spacing:0.05em; border-bottom:1px solid var(--ink-20); background:var(--ink-15); }
  .data-table td { padding:0.65rem 0.75rem; color:var(--ink-70); border-bottom:1px solid rgba(255,255,255,0.04); vertical-align:middle; }
  .data-table tbody tr:hover { background:rgba(255,255,255,0.03); }
  .row-actions { opacity:0; transition:opacity var(--duration-fast); font-size:var(--text-xs); }
  .data-table tbody tr:hover .row-actions { opacity:1; }
  .row-actions a { margin:0 4px; }
  .text-muted { color:var(--ink-40); font-size:11px; }
  .text-danger { color:var(--error); }
  .text-success { color:var(--success); }
  .table-footer { display:flex; justify-content:space-between; align-items:center; padding:var(--space-md) var(--space-lg); }
  .bulk-actions { display:flex; gap:var(--space-sm); align-items:center; }
  .pagination-info { font-size:var(--text-sm); color:var(--ink-50); }

  /* ---- 状态标签 ---- */
  .status { font-size:11px; padding:2px 8px; border-radius:var(--radius-full); font-weight:var(--weight-medium); white-space:nowrap; }
  .status-published { background:rgba(61,186,130,0.12); color:var(--success); }
  .status-draft { background:rgba(136,136,136,0.12); color:var(--ink-50); }
  .status-pending { background:rgba(245,158,11,0.12); color:var(--warn); }

  /* ---- 标签 ---- */
  .tag { display:inline-flex; padding:0.15em 0.6em; font-size:var(--text-xs); font-weight:var(--weight-medium); border-radius:var(--radius-full); background:var(--ink-15); color:var(--ink-50); border:1px solid var(--ink-20); white-space:nowrap; }
  .tag-accent { background:rgba(212,165,116,0.1); color:var(--amber-400); border-color:rgba(212,165,116,0.2); }

  /* ---- 按钮 ---- */
  .btn { display:inline-flex; align-items:center; justify-content:center; gap:var(--space-sm); padding:0.5rem 1rem; font-family:var(--font-body); font-size:var(--text-sm); font-weight:var(--weight-medium); border:none; border-radius:var(--radius-md); cursor:pointer; transition:all var(--duration-fast); text-decoration:none; line-height:1; white-space:nowrap; }
  .btn-primary { background:var(--amber-400); color:var(--ink-0); }
  .btn-primary:hover { background:var(--amber-500); }
  .btn-secondary { background:var(--ink-15); color:var(--ink-70); border:1px solid var(--ink-20); }
  .btn-secondary:hover { background:var(--ink-20); color:var(--ink-90); }
  .btn-sm { padding:0.4rem 0.8rem; font-size:var(--text-xs); }
  .btn-lg { padding:0.75rem 1.5rem; font-size:var(--text-base); }
  .btn-block { width:100%; margin-bottom:var(--space-sm); }

  /* ---- 输入框 ---- */
  .input { width:100%; padding:0.6rem 0.75rem; background:var(--ink-15); border:1px solid var(--ink-20); border-radius:var(--radius-md); color:var(--ink-90); font-family:var(--font-body); font-size:var(--text-sm); transition:all var(--duration-fast); outline:none; }
  .input::placeholder { color:var(--ink-40); }
  .input:focus { border-color:var(--amber-400); box-shadow:0 0 0 3px rgba(212,165,116,0.1); }
  .textarea { resize:vertical; min-height:60px; }

  /* ---- 健康状态 ---- */
  .health-list { display:flex; flex-direction:column; gap:var(--space-sm); }
  .health-item { display:flex; align-items:center; gap:8px; font-size:var(--text-sm); color:var(--ink-70); }
  .health-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
  .health-dot.ok { background:var(--success); }

  /* ---- 快速草稿 ---- */
  .quick-draft { display:flex; flex-direction:column; gap:var(--space-sm); }
  .quick-draft .input { font-size:var(--text-sm); }

  /* ---- 时间线 ---- */
  .timeline { position:relative; padding-left:var(--space-lg); }
  .timeline::before { content:''; position:absolute; left:5px; top:0; bottom:0; width:2px; background:var(--ink-20); }
  .tl-item { position:relative; padding:var(--space-sm) 0 var(--space-sm) var(--space-lg); display:flex; flex-wrap:wrap; align-items:baseline; gap:8px; }
  .tl-dot { position:absolute; left:-3px; top:14px; width:10px; height:10px; border-radius:50%; flex-shrink:0; }
  .tl-dot.post { background:#3b82f6; }
  .tl-dot.page { background:#10b981; }
  .tl-dot.comment { background:#f59e0b; }
  .tl-dot.setting { background:#8b5cf6; }
  .tl-dot.build { background:#ef4444; }
  .tl-time { font-size:var(--text-xs); color:var(--ink-40); min-width:70px; }
  .tl-text { font-size:var(--text-sm); color:var(--ink-70); }

  /* ---- 评论筛选 ---- */
  .comment-filters { display:flex; gap:var(--space-sm); margin-bottom:var(--space-lg); flex-wrap:wrap; }
  .comment-filter-btn { padding:0.4rem 0.8rem; background:var(--ink-15); border:1px solid var(--ink-20); border-radius:var(--radius-md); color:var(--ink-50); font-size:var(--text-sm); cursor:pointer; transition:all var(--duration-fast); }
  .comment-filter-btn:hover { color:var(--ink-90); }
  .comment-filter-btn.active { background:var(--amber-400); color:var(--ink-0); border-color:var(--amber-400); }
  .c-count { font-size:11px; font-weight:var(--weight-semibold); }
  .c-pending { color:var(--warn); }

  /* ---- 媒体库 ---- */
  .view-toggle { display:flex; gap:2px; }
  .view-btn.active { background:var(--amber-400); color:var(--ink-0); border-color:var(--amber-400); }
  .media-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--space-md); }
  .media-card { background:var(--ink-10); border:1px solid var(--ink-20); border-radius:12px; overflow:hidden; transition:all var(--duration-fast); }
  .media-card:hover { border-color:var(--amber-400); }
  .media-thumb { height:140px; display:flex; align-items:center; justify-content:center; }
  .media-info { padding:var(--space-sm) var(--space-md); }
  .media-name { display:block; font-size:var(--text-xs); font-weight:var(--weight-medium); color:var(--ink-70); margin-bottom:2px; word-break:break-all; }
  .media-meta { font-size:11px; color:var(--ink-40); }

  /* ---- 主题 ---- */
  .theme-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--space-lg); margin-bottom:var(--space-xl); }
  .theme-card { background:var(--ink-10); border:2px solid var(--ink-20); border-radius:12px; overflow:hidden; transition:all var(--duration-fast); }
  .theme-card:hover { border-color:var(--ink-30); }
  .theme-card.active-theme { border-color:var(--amber-400); }
  .theme-thumb { height:120px; display:flex; align-items:flex-end; justify-content:flex-end; padding:8px; position:relative; }
  .theme-label { font-size:10px; padding:2px 8px; background:var(--amber-400); color:var(--ink-0); border-radius:var(--radius-sm); font-weight:var(--weight-semibold); }
  .theme-info { padding:var(--space-md); }
  .theme-info p { font-size:var(--text-xs); color:var(--ink-50); margin:4px 0 var(--space-sm); }
  .theme-info strong { font-size:var(--text-sm); color:var(--ink-90); }

  /* ---- 设置 ---- */
  .settings-panel { margin-bottom:var(--space-lg); }
  .settings-group { margin-bottom:var(--space-lg); }
  .settings-group h4 { font-size:var(--text-sm); color:var(--amber-400); margin-bottom:var(--space-md); }
  .form-row { margin-bottom:var(--space-md); display:flex; align-items:center; gap:var(--space-md); }
  .form-row label { min-width:120px; font-size:var(--text-sm); color:var(--ink-50); }
  .form-row-inline { margin-bottom:var(--space-md); display:flex; align-items:center; gap:var(--space-sm); }
  .form-row-inline label { min-width:120px; font-size:var(--text-sm); color:var(--ink-50); }
  .form-row input[type="checkbox"], .form-row-inline input[type="checkbox"] { accent-color:var(--amber-400); }

  /* ---- 快速操作 ---- */
  .quick-actions { display:grid; grid-template-columns:1fr 1fr; gap:var(--space-sm); }
  .btn-action { padding:0.6rem 0.8rem; background:var(--ink-15); border:1px solid var(--ink-20); border-radius:var(--radius-md); color:var(--ink-70); font-size:var(--text-sm); cursor:pointer; transition:all var(--duration-fast); text-align:center; }
  .btn-action:hover { border-color:var(--amber-400); color:var(--amber-400); background:rgba(212,165,116,0.06); }

  /* ---- 工具 ---- */
  .tools-actions { display:flex; flex-direction:column; gap:var(--space-sm); }

  /* ---- 系统信息 ---- */
  .system-info-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--space-md); }
  .sys-item { text-align:center; padding:var(--space-md); background:var(--ink-15); border-radius:var(--radius-sm); }
  .sys-label { display:block; font-size:var(--text-xs); color:var(--ink-40); margin-bottom:4px; }
  .sys-value { display:block; font-family:var(--font-mono); font-size:var(--text-sm); font-weight:var(--weight-medium); color:var(--amber-400); }

  /* ---- 响应式 ---- */
  @media (max-width:1024px) {
    .stats-grid { grid-template-columns:repeat(2,1fr); }
    .content-grid-2col { grid-template-columns:1fr; }
    .theme-grid { grid-template-columns:repeat(2,1fr); }
    .media-grid { grid-template-columns:repeat(3,1fr); }
    .system-info-grid { grid-template-columns:repeat(2,1fr); }
  }
  @media (max-width:768px) {
    .admin-sidebar { transform:translateX(-100%); transition:transform var(--duration-slow); }
    .admin-sidebar.open { transform:translateX(0); }
    .admin-main { margin-left:0; }
    .hamburger { display:flex; }
    .stats-grid { grid-template-columns:1fr; }
    .theme-grid { grid-template-columns:1fr; }
    .media-grid { grid-template-columns:repeat(2,1fr); }
    .system-info-grid { grid-template-columns:1fr 1fr; }
    .page-toolbar { flex-direction:column; align-items:flex-start; }
  }
</style>

<script>
  // ========== 路由系统 ==========
  const pageMap = {
    dashboard: '仪表板 / 概览',
    posts: '文章 / 所有文章',
    pages: '页面 / 所有页面',
    media: '媒体库 / 概览',
    comments: '评论 / 所有评论',
    appearance: '外观 / 主题',
    users: '用户 / 所有用户',
    tools: '工具 / 系统信息',
    settings: '设置 / 常规',
    navlinks: '导航站 / 概览',
  };

  function navigate() {
    const hash = (location.hash.slice(1) || 'dashboard').split('?')[0];
    // 更新页面视图
    document.querySelectorAll('[data-page]').forEach(p => p.classList.remove('active'));
    const target = document.querySelector(`[data-page="${hash}"]`);
    if (target) target.classList.add('active');
    // 更新侧边栏
    document.querySelectorAll('.admin-nav-item').forEach(item => {
      item.classList.toggle('active', item.dataset.hash === hash);
    });
    // 更新面包屑
    document.getElementById('breadcrumb').textContent = pageMap[hash] || hash;
  }

  window.addEventListener('hashchange', navigate);
  navigate();

  // 侧边栏菜单点击
  document.querySelectorAll('.admin-nav-item').forEach(item => {
    item.addEventListener('click', (e) => { /* hash 自动触发 */ });
  });

  // 汉堡菜单
  document.getElementById('hamburger').addEventListener('click', () => {
    document.getElementById('sidebar').classList.toggle('open');
  });
  // 点击内容区关闭侧边栏
  document.getElementById('admin-main').addEventListener('click', (e) => {
    if (e.target === document.getElementById('admin-main')) {
      document.getElementById('sidebar').classList.remove('open');
    }
  });

  // 退出登录
  document.getElementById('logout-btn').addEventListener('click', () => {
    localStorage.removeItem('zhenxing_auth');
    window.location.href = '/login';
  });

  // ---- 各视图交互 ----

  // 快速草稿
  document.getElementById('save-draft-btn')?.addEventListener('click', () => {
    alert('草稿已保存（本地）');
  });

  // 评论筛选
  document.querySelectorAll('.comment-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.comment-filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  // 媒体视图切换
  document.querySelectorAll('.view-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  // 保存外观
  document.getElementById('save-appearance-btn')?.addEventListener('click', () => {
    alert('主题设置已保存（本地存储）');
  });

  // 保存设置
  document.getElementById('settings-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('设置已保存（本地存储）');
    const formData = {};
    document.querySelectorAll('#settings-form input, #settings-form select, #settings-form textarea').forEach(el => {
      if (el.type === 'checkbox') formData[el.closest('.form-row')?.querySelector('label')?.textContent || ''] = el.checked;
      else if (el.type === 'radio' && !el.checked) return;
      else if (el.name) formData[el.name] = el.value;
    });
    localStorage.setItem('zhenxing_settings', JSON.stringify(formData));
  });

  // 工具页 - 导出
  document.getElementById('export-btn')?.addEventListener('click', () => {
    alert('导出功能：将所有文章/页面导出为 JSON 文件（即将支持）');
  });
  document.getElementById('import-btn')?.addEventListener('click', () => {
    document.getElementById('import-file')?.click();
  });

  // 导航站 - 重新抓取
  document.getElementById('rescrape-btn')?.addEventListener('click', () => {
    alert('正在重新抓取站点信息...模拟完成！');
  });
  document.getElementById('export-json-btn')?.addEventListener('click', () => {
    alert('导航站数据已导出为 JSON！');
  });
</script>
