              <div class="p-desc">${p.desc}</div>
              <div class="p-footer">
                <span class="stars">${'&#9733;'.repeat(Math.floor(p.rating))}${p.rating%1>=0.5?'&#9733;':''} ${p.rating}</span>
                ${p.installed
                  ? '<button class="btn btn-sm btn-danger" onclick="togglePlugin(\''+p.id+'\')">卸载</button>'
                  : '<button class="btn btn-sm btn-primary" onclick="togglePlugin(\''+p.id+'\')">安装</button>'}
              </div>
            </div>
          `).join('')}
        </div>
      </div>
    `,

    store: () => `
      <div class="card">
        <h2>主题模板市场</h2>
        <div class="store-grid">
          <div class="store-card">
            <div class="store-preview">极简博客 · 预览</div>
