// ============================================================
// ROUTER
// ============================================================
const pageNames = { dashboard:'仪表板',posts:'文章',pages:'页面',media:'媒体库',comments:'评论',appearance:'外观',users:'用户',analytics:'分析',navlinks:'导航站',friends:'友链管理',shuoshuo:'说说',tools:'工具',settings:'设置' };
const mainArea = document.getElementById('main-area');
let currentPage = null;

function navigate(hash) {
  const page = hash || 'dashboard';
  if (currentPage === page) return;
  currentPage = page;

  // Update sidebar
  document.querySelectorAll('[data-nav]').forEach(n => n.classList.toggle('active', n.dataset.nav === page));
  document.getElementById('breadcrumb').textContent = '管理后台 / ' + (pageNames[page] || page);

  // Render view
  if (VIEWS[page]) {
    mainArea.innerHTML = VIEWS[page];
  }
  mainArea.scrollTop = 0;

  // Re-bind dynamic elements in the new view
  bindViewEvents(page);
}

function bindViewEvents(page) {
  // Pill groups
  mainArea.querySelectorAll('.pill[data-pills]').forEach(p => {
    p.addEventListener('click', function() {
      const group = this.closest('.pill-group');
      if (group) group.querySelectorAll('.pill').forEach(s => s.classList.remove('active'));
      this.classList.add('active');
    });
  });

  // Accordion triggers
  mainArea.querySelectorAll('.acc-trigger').forEach(btn => {
    btn.addEventListener('click', function() {
      this.parentElement.classList.toggle('open');
    });
  });

  // Char count for shuoshuo
  if (page === 'shuoshuo') {
    const ssInput = document.getElementById('shuoshuo-input');
    if (ssInput) {
      ssInput.addEventListener('input', function() {
        const cc = document.getElementById('char-count');
        if (cc) cc.textContent = ssInput.value.length + '/500';
      });
    }
  }
}

window.addEventListener('hashchange', () => navigate(location.hash.slice(1)));
navigate(location.hash.slice(1));

// Sidebar nav clicks
document.querySelectorAll('[data-nav]').forEach(item => {
  item.addEventListener('click', e => { e.preventDefault(); location.hash = item.dataset.nav; });
});

// Hamburger
const hamburger = document.getElementById('hamburger');
const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('overlay');
hamburger.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('show'); });
overlay.addEventListener('click', () => { sidebar.classList.remove('open'); overlay.classList.remove('show'); });

// Toast
function toast(msg) {
  const t = document.createElement('div');
  t.className = 'toast'; t.textContent = msg;
  document.body.appendChild(t);
  requestAnimationFrame(() => t.classList.add('show'));
  setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 200); }, 2000);
}

// Settings save
function saveSettings() {
  const data = {};
  mainArea.querySelectorAll('.field-input').forEach(el => {
    if (el.type === 'checkbox') {
      const label = el.closest('.setting-group')?.querySelector('.field-label');
      if (label) data[label.textContent] = el.checked;
    } else if (el.type === 'radio') {
      if (el.checked) data['固定链接'] = el.parentElement?.textContent?.trim();
    } else {
      const label = el.closest('.setting-group')?.querySelector('.field-label');
      if (label) data[label.textContent] = el.value;
    }
  });
  localStorage.setItem('zhenxing_settings', JSON.stringify(data));
  toast('设置已保存');
}

// Logout
document.getElementById('btn-logout').addEventListener('click', () => {
  localStorage.removeItem('zhenxing_auth');
  location.href = '/login';
});
</script>