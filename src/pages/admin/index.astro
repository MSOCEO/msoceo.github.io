                <td>
                  <button class="btn btn-sm" onclick="alert('编辑: ${p.title}')">编辑</button>
                  <button class="btn btn-sm btn-success" onclick="togglePostStatus(${blogPosts.length-1-i})">${p.status==='published'?'下架':'发布'}</button>
                  <button class="btn btn-sm btn-danger" onclick="deletePost(${blogPosts.length-1-i})">删除</button>
                </td>
              </tr>`).join('')}</tbody>
          </table>
        </div>
      </div>
      <div class="card">
        <h2>页面管理 (${SITE.pages.length})</h2>
