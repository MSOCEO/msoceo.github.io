    '暮光橙霞': { '--bg-primary':'#140a06','--bg-secondary':'#1e100a','--bg-card':'#281810','--accent':'#f97316','--accent-secondary':'#fb923c','--accent-glow':'rgba(249,115,22,0.15)','--text-primary':'#f2e8e0','--text-secondary':'#b8a090','--text-muted':'#7d6050','--border':'#33201a','--success':'#22c55e','--warning':'#f59e0b','--danger':'#ef4444' },
  };

  function applyTheme(name) {
    const vars = themePresets[name];
    if (!vars) return;
    Object.entries(vars).forEach(([k, v]) => document.documentElement.style.setProperty(k, v));
  }

