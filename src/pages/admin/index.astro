---
// 枕星 CMS — 管理后台 v2.0
import BaseHead from '../../components/BaseHead.astro';
const title = '管理后台 | 枕星 CMS';
const description = '枕星内容管理系统后台';
---

<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead title={title} description={description} />
</head>
<body class="admin-root">

<!-- ============ TOPBAR ============ -->
<header class="topbar">
  <button class="btn-hamburger" id="hamburger" aria-label="菜单">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
  </button>
  <span class="topbar-breadcrumb" id="breadcrumb">管理后台 / 仪表板</span>
  <div class="topbar-spacer"></div>
  <button class="topbar-icon-btn" aria-label="搜索">
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M11 11l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
  </button>
  <button class="topbar-icon-btn has-dot" aria-label="通知">
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2a4 4 0 00-4 4v3l-1.5 2h11l-1.5-2V6a4 4 0 00-4-4z" stroke="currentColor" stroke-width="1.5"/><path d="M6 13a2 2 0 004 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
  </button>
  <div class="topbar-avatar" title="管理员">
    <div class="avatar-img"></div>
    <span class="avatar-name">管理员</span>
  </div>
</header>

<!-- ============ SIDEBAR ============ -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <div class="brand-name">枕星 CMS</div>
    <div class="brand-sub">管理控制台 v2.0</div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section-label">内容管理</div>
    <a href="#dashboard" class="nav-item active" data-nav="dashboard">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h2l1-1v9h6v-6h4v6h6v-9l1 1h2L13 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      仪表板
    </a>
    <a href="#posts" class="nav-item" data-nav="posts">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      文章 <span class="nav-badge">5</span>
    </a>
    <a href="#pages" class="nav-item" data-nav="pages">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="9" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="3" width="7" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="12" width="7" height="9" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="16" width="7" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>
      页面 <span class="nav-badge">2</span>
    </a>
    <a href="#media" class="nav-item" data-nav="media">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="8.5" cy="8.5" r="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      媒体库
    </a>
    <a href="#comments" class="nav-item" data-nav="comments">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2v10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      评论 <span class="nav-badge">3</span>
    </a>

    <div class="nav-section-label">站点管理</div>
    <a href="#navlinks" class="nav-item" data-nav="navlinks">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      导航站
    </a>
    <a href="#friends" class="nav-item" data-nav="friends">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      友链管理 <span class="nav-badge nav-badge-new">新</span>
    </a>
    <a href="#shuoshuo" class="nav-item" data-nav="shuoshuo">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M13 2L4.093 12.688c-.348.418-.523.627-.525.865a.5.5 0 00.185.383c.138.118.397.172.915.28l1.538.32c.15.031.225.047.292.08a.5.5 0 01.153.153c.033.067.049.142.08.292l.32 1.538c.108.518.162.777.28.915a.5.5 0 00.383.185c.238-.002.447-.177.865-.525L13 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      说说
    </a>

    <div class="nav-section-label">系统设置</div>
    <a href="#appearance" class="nav-item" data-nav="appearance">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      外观
    </a>
    <a href="#users" class="nav-item" data-nav="users">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      用户 <span class="nav-badge">2</span>
    </a>
    <a href="#analytics" class="nav-item" data-nav="analytics">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M18 20V10M12 20V4M6 20v-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      分析
    </a>
    <a href="#tools" class="nav-item" data-nav="tools">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      工具
    </a>
    <a href="#settings" class="nav-item" data-nav="settings">
      <svg class="nav-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z" stroke="currentColor" stroke-width="1.5"/></svg>
      设置
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="sidebar-avatar"></div>
      <div class="sidebar-user-info">
        <div class="sidebar-user-name">管理员</div>
        <div class="sidebar-user-role">administrator</div>
      </div>
    </div>
    <button class="btn-logout" id="btn-logout">退出登录</button>
  </div>
</aside>

<!-- ============ MAIN CONTENT ============ -->
<main class="main-area" id="main-area"></main>

<!-- ============ OVERLAY ============ -->
<div class="overlay" id="overlay"></div>

</body>
</html>

<style>
/* ============ DESIGN TOKENS & RESET ============ */
:root {
  --bg-root: #0d0d12;
  --bg-surface: #131318;
  --bg-elevated: #1a1a21;
  --bg-hover: #1f1f28;
  --bg-active: #252530;
  --text-primary: #e4e4ec;
  --text-secondary: #8b8b9e;
  --text-tertiary: #5c5c6e;
  --text-disabled: #3a3a48;
  --accent: #d4a853;
  --accent-hover: #e0b963;
  --accent-muted: #3d3424;
  --accent-border: #4a3a1f;
  --green: #3cb371; --green-bg: #142c1f;
  --blue: #5b9bd5; --blue-bg: #162438;
  --amber: #d4a853; --amber-bg: #3d3424;
  --red: #e0556a; --red-bg: #2d1820;
  --purple: #9b7ec4; --purple-bg: #241e32;
  --border-subtle: #1e1e28;
  --border-default: #272730;
  --border-strong: #343440;
  --space-1:4px;--space-2:8px;--space-3:12px;--space-4:16px;--space-5:20px;--space-6:24px;--space-8:32px;--space-10:40px;--space-12:48px;
  --radius-sm:4px;--radius-md:6px;--radius-lg:8px;--radius-xl:10px;
  --shadow-sm:0 1px 2px rgba(0,0,0,0.3);
  --shadow-md:0 2px 4px rgba(0,0,0,0.2),0 0 0 1px rgba(255,255,255,0.03);
  --shadow-lg:0 8px 24px rgba(0,0,0,0.4),0 0 0 1px rgba(255,255,255,0.04);
  --font-mono:'SF Mono','Fira Code','Cascadia Code',monospace;
  --font-sans:-apple-system,BlinkMacSystemFont,'SF Pro Display','Inter',sans-serif;
  --transition-fast:120ms ease-out;
  --transition-base:150ms ease-out;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;scroll-behavior:smooth}
body{font-family:var(--font-sans);font-size:13px;line-height:1.5;color:var(--text-primary);background:var(--bg-root);min-height:100vh}
::selection{background:var(--accent-muted);color:var(--text-primary)}
a{color:var(--accent);text-decoration:none}
a:hover{color:var(--accent-hover)}
input,textarea,select,button{font-family:inherit;font-size:inherit}
button{cursor:pointer;border:none;background:none;color:inherit}
input[type="text"],input[type="email"],input[type="number"],input[type="color"],textarea,select{background:var(--bg-root);border:1px solid var(--border-default);border-radius:var(--radius-sm);color:var(--text-primary);padding:5px 8px;height:30px;font-size:13px;outline:none;transition:border-color var(--transition-fast)}
input:focus,textarea:focus,select:focus{border-color:var(--accent);outline:1.5px solid var(--accent);outline-offset:-1px}
::placeholder{color:var(--text-tertiary)}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border-default);border-radius:2px}
::-webkit-scrollbar-thumb:hover{background:var(--border-strong)}
[hidden]{display:none!important}

/* ============ LAYOUT ============ */
.admin-root{display:flex;min-height:100vh;padding-top:48px}

/* ---- Topbar ---- */
.topbar{position:fixed;top:0;left:0;right:0;height:48px;background:var(--bg-surface);border-bottom:1px solid var(--border-subtle);display:flex;align-items:center;padding:0 var(--space-4);z-index:200;gap:var(--space-3)}
.topbar-breadcrumb{font-size:12px;color:var(--text-tertiary);white-space:nowrap}
.topbar-spacer{flex:1}
.topbar-icon-btn{display:flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:var(--radius-sm);color:var(--text-tertiary);position:relative;transition:all var(--transition-fast)}
.topbar-icon-btn:hover{background:var(--bg-hover);color:var(--text-secondary)}
.topbar-icon-btn.has-dot::after{content:'';position:absolute;top:5px;right:5px;width:6px;height:6px;border-radius:50%;background:var(--red);border:1.5px solid var(--bg-surface)}
.topbar-avatar{display:flex;align-items:center;gap:var(--space-2);cursor:pointer;padding:2px;border-radius:var(--radius-md);transition:background var(--transition-fast)}
.topbar-avatar:hover{background:var(--bg-hover)}
.avatar-img{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#2a1f3d,#1f2a3d)}
.avatar-name{font-size:12px;color:var(--text-secondary)}

/* ---- Sidebar ---- */
.sidebar{position:fixed;top:48px;left:0;bottom:0;width:240px;background:var(--bg-surface);border-right:1px solid var(--border-subtle);display:flex;flex-direction:column;z-index:100;overflow-y:auto}
.sidebar-brand{padding:var(--space-4) var(--space-4) var(--space-3);border-bottom:1px solid var(--border-subtle)}
.brand-name{font-size:13px;font-weight:600;color:var(--text-primary);letter-spacing:0.02em}
.brand-sub{font-size:10px;color:var(--text-tertiary);margin-top:1px}
.sidebar-nav{flex:1;padding:var(--space-2) 0}
.nav-section-label{font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-tertiary);padding:var(--space-3) var(--space-4) var(--space-1)}
.nav-item{display:flex;align-items:center;gap:var(--space-2);height:32px;padding:0 var(--space-2);margin:1px var(--space-2);border-radius:var(--radius-md);font-size:13px;color:var(--text-secondary);text-decoration:none;transition:all var(--transition-fast);position:relative}
.nav-item:hover{background:var(--bg-hover);color:var(--text-primary)}
.nav-item.active{background:var(--bg-active);color:var(--text-primary);font-weight:500}
.nav-icon{flex-shrink:0;opacity:0.6}
.nav-item.active .nav-icon{opacity:1;color:var(--accent)}
.nav-badge{font-size:10px;background:var(--bg-elevated);color:var(--text-tertiary);padding:1px 5px;border-radius:var(--radius-sm);margin-left:auto;line-height:1.4}
.nav-item.active .nav-badge{background:var(--accent-muted);color:var(--accent)}
.nav-badge-new{background:var(--blue-bg)!important;color:var(--blue)!important;font-size:9px;padding:1px 4px}
.sidebar-footer{padding:var(--space-3) var(--space-4);border-top:1px solid var(--border-subtle)}
.sidebar-user{display:flex;align-items:center;gap:var(--space-2);margin-bottom:var(--space-2)}
.sidebar-avatar{width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,#2a1f3d,#1f2a3d);flex-shrink:0}
.sidebar-user-name{font-size:12px;font-weight:500;color:var(--text-secondary);line-height:1.2}
.sidebar-user-role{font-size:10px;color:var(--text-tertiary)}
.btn-logout{display:block;width:100%;padding:4px 0;font-size:12px;color:var(--text-tertiary);text-align:left;transition:color var(--transition-fast)}
.btn-logout:hover{color:var(--red)}

/* ---- Main Area ---- */
.main-area{flex:1;margin-left:240px;padding:var(--space-8);min-height:calc(100vh - 48px);overflow-y:auto}

/* ---- Page Header ---- */
.page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-6);flex-wrap:wrap;gap:var(--space-3)}
.page-title{font-size:20px;font-weight:500;color:var(--text-primary);letter-spacing:-0.01em}
.page-desc{font-size:12px;color:var(--text-tertiary)}
.page-header-right{display:flex;align-items:center;gap:var(--space-2)}

/* ============ CARDS & GRIDS ============ */
.card{background:var(--bg-surface);border:1px solid var(--border-subtle);border-radius:var(--radius-md);padding:var(--space-5)}
.card-header-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-3)}
.card-title{font-size:12px;font-weight:500;color:var(--text-secondary);letter-spacing:0.02em}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-4);margin-bottom:var(--space-4)}
.stat-card{background:var(--bg-surface);border:1px solid var(--border-subtle);border-radius:var(--radius-md);padding:var(--space-4) var(--space-5);transition:border-color var(--transition-fast)}
.stat-card:hover{border-color:var(--border-default)}
.stat-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-2)}
.stat-label{font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-tertiary)}
.stat-icon-box{display:flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:var(--radius-sm)}
.stat-icon-blue{background:var(--blue-bg);color:var(--blue)}
.stat-icon-green{background:var(--green-bg);color:var(--green)}
.stat-icon-amber{background:var(--amber-bg);color:var(--amber)}
.stat-icon-purple{background:var(--purple-bg);color:var(--purple)}
.stat-value{font-family:var(--font-mono);font-size:26px;font-weight:600;color:var(--text-primary);line-height:1.1;margin-bottom:2px}
.stat-change{font-size:12px}
.stat-change.positive{color:var(--green)}
.stat-change.negative{color:var(--red)}
.stat-change.dimmed{color:var(--text-tertiary)}
.grid-2col{display:grid;grid-template-columns:3fr 2fr;gap:var(--space-4);margin-bottom:var(--space-4)}

/* ============ CHART ============ */
.chart-card{padding-bottom:var(--space-3)}
.chart-svg{width:100%;height:120px;display:block}
.chart-labels{display:flex;justify-content:space-between;font-size:10px;color:var(--text-tertiary);margin-top:var(--space-2);padding:0 2px}

/* ============ PILLS ============ */
.pill-group{display:flex;gap:2px}
.pill{font-size:11px;padding:2px 8px;border-radius:var(--radius-sm);color:var(--text-tertiary);transition:all var(--transition-fast)}
.pill:hover{color:var(--text-secondary)}
.pill.active{background:var(--bg-active);color:var(--text-primary)}
.pill-count{color:var(--text-tertiary);font-size:10px}
.pill-count-amber{color:var(--amber)}

/* ============ DRAFT ============ */
.draft-input{width:100%;margin-bottom:var(--space-2)}
.draft-textarea{width:100%;resize:vertical;min-height:80px;padding:6px 8px;background:var(--bg-root);border:1px solid var(--border-default);border-radius:var(--radius-sm);color:var(--text-primary);font-size:13px;outline:none;font-family:inherit;transition:border-color var(--transition-fast)}
.draft-textarea:focus{border-color:var(--accent);outline:1.5px solid var(--accent);outline-offset:-1px}
.draft-textarea::placeholder{color:var(--text-tertiary)}

/* ============ BUTTONS ============ */
.btn-accent-sm{display:inline-flex;align-items:center;padding:4px 12px;background:var(--accent);color:#0d0d12;font-size:12px;font-weight:500;border-radius:var(--radius-sm);transition:all var(--transition-fast);border:none;line-height:1.5}
.btn-accent-sm:hover{background:var(--accent-hover)}
.btn-ghost-sm{display:inline-flex;align-items:center;padding:4px 12px;background:transparent;color:var(--text-secondary);font-size:12px;border-radius:var(--radius-sm);border:1px solid var(--border-default);transition:all var(--transition-fast);line-height:1.5}
.btn-ghost-sm:hover{background:var(--bg-hover);border-color:var(--border-strong);color:var(--text-primary)}
.btn-ghost-xs{padding:2px 6px;font-size:11px;color:var(--text-tertiary);border-radius:var(--radius-sm);transition:all var(--transition-fast);background:transparent;border:none}
.btn-ghost-xs:hover{background:var(--bg-hover);color:var(--text-primary)}
.btn-ghost-xs.active{background:var(--bg-active);color:var(--text-primary)}
.btn-ghost-xs.btn-danger:hover{color:var(--red);background:var(--red-bg)}
.btn-hamburger{display:none;align-items:center;justify-content:center;width:28px;height:28px;border-radius:var(--radius-sm);color:var(--text-tertiary);transition:all var(--transition-fast)}
.btn-hamburger:hover{background:var(--bg-hover);color:var(--text-secondary)}

/* ============ TABLE ============ */
.table-wrap{border:1px solid var(--border-subtle);border-radius:var(--radius-md);overflow:hidden;background:var(--bg-surface)}
.data-table{width:100%;border-collapse:collapse}
