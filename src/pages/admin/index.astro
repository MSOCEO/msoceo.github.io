        <div class="stat-card"><div class="label">插件</div><div class="value" style="color:var(--warning)">${plugins.filter(p=>p.installed).length}</div></div>
        <div class="stat-card"><div class="label">状态</div><div class="value" style="color:var(--success);font-size:16px;">运行中</div></div>
      </div>
      <div class="grid-2">
        <div class="card">
          <h2>最近更新</h2>
