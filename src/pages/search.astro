---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const query = Astro.url.searchParams.get('q')?.toLowerCase().trim() || '';

let results: typeof allPosts = [];
if (query) {
  const allPosts = (await getCollection('blog')).filter(p => !p.data.draft);
  results = allPosts.filter(post => {
    const title = post.data.title.toLowerCase();
    const desc = post.data.description?.toLowerCase() || '';
    const tags = post.data.tags?.join(' ').toLowerCase() || '';
    const cat = post.data.category?.toLowerCase() || '';
    return title.includes(query) || desc.includes(query) || tags.includes(query) || cat.includes(query);
  });
}
---

<BaseLayout title={`搜索: ${query || '搜索'}`}>
  <div class="max-w-2xl mx-auto">
    <h1 class="font-serif font-black text-3xl mb-6">搜索</h1>

    <form class="mb-8" method="get" action="/search">
      <div class="flex gap-2">
        <input
          type="text"
          name="q"
          value={query}
          placeholder="输入关键词搜索文章..."
          class="flex-1 px-4 py-3 rounded-lg border border-[var(--border-color)] bg-[var(--bg-card)] text-[var(--text-primary)] outline-none focus:border-[var(--accent)] transition-colors text-sm"
          autofocus
        />
        <button
          type="submit"
          class="px-6 py-3 rounded-lg bg-[var(--accent)] text-white font-medium text-sm hover:bg-[var(--accent-hover)] transition-colors"
        >
          搜索
        </button>
      </div>
    </form>

    {!query ? (
      <div class="ink-card p-12 text-center text-[var(--text-tertiary)]">
        <p class="text-lg font-serif mb-2">输入关键词，搜寻墨痕</p>
        <p class="text-sm">试试 "Astro"、"前端"、"Linux" 等关键词</p>
      </div>
    ) : results.length === 0 ? (
      <div class="ink-card p-12 text-center text-[var(--text-tertiary)]">
        <p class="text-lg font-serif mb-2">未找到 "{query}" 相关文章</p>
        <p class="text-sm">试试其他关键词</p>
      </div>
    ) : (
      <div>
        <p class="text-sm text-[var(--text-tertiary)] mb-4">找到 {results.length} 篇相关文章</p>
        <div class="space-y-4">
          {results.map(post => (
            <BlogCard
              title={post.data.title}
              slug={post.id}
              date={post.data.pubDate}
              description={post.data.description}
              category={post.data.category}
              tags={post.data.tags}
              image={post.data.heroImage}
            />
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
