<script>
  // ===== 樱花飘落背景 =====
  (function() {
    const canvas = document.getElementById('starCanvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h;

    const lightColors = ['#e890a8','#f098b0','#f4a8c0','#ec98b0','#f0a0b8','#f8b0c8','#f8bcd4'];
