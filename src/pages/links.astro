          <line x1="20" y1="8" x2="20" y2="40" stroke="currentColor" stroke-width="0.4" opacity="0.08"/>
          <line x1="28" y1="8" x2="28" y2="40" stroke="currentColor" stroke-width="0.4" opacity="0.08"/>
          <circle cx="14" cy="16" r="1.5" fill="currentColor" opacity="0.5"/>
          <circle cx="34" cy="16" r="1.2" fill="currentColor" opacity="0.4"/>
          <circle cx="18" cy="34" r="1.4" fill="currentColor" opacity="0.45"/>
