  { cat: '影音娱乐', name: 'YouTube', url: 'https://www.youtube.com', desc: '全球视频分享平台' },
  { cat: '影音娱乐', name: 'Spotify', url: 'https://open.spotify.com', desc: '全球音乐流媒体服务' },
  { cat: '影音娱乐', name: 'Apple Music', url: 'https://music.apple.com', desc: 'Apple 无损音乐服务' },
  { cat: '影音娱乐', name: '豆瓣', url: 'https://www.douban.com', desc: '书影音评分社区' },
