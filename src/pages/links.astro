  { cat: '阅读资讯', name: 'Product Hunt', url: 'https://www.producthunt.com', desc: '每日新产品发现社区' },
  { cat: '阅读资讯', name: 'ReadHub', url: 'https://readhub.cn', desc: '科技新闻聚合，无废话版' },
  // 开源项目
  { cat: '开源项目', name: 'Oh My Zsh', url: 'https://ohmyz.sh', desc: '终端配置框架，开发者标配' },
  { cat: '开源项目', name: 'Homebrew', url: 'https://brew.sh', desc: 'macOS 包管理器' },
  { cat: '开源项目', name: 'VS Code', url: 'https://code.visualstudio.com', desc: '微软开源代码编辑器' },
  { cat: '开源项目', name: 'Linux Kernel', url: 'https://www.kernel.org', desc: 'Linux 内核主线仓库' },
