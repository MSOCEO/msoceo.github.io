    </p>
  </footer>
</body>
</html>

<script define:vars={{ linksJson, catsJson }}>
  const links = JSON.parse(linksJson);
  const cats = JSON.parse(catsJson);

  // ===== 搜索引擎切换 =====
  let searchEngine = 'web';
  const engineLabels = document.querySelectorAll('.nav-engine-label');
  engineLabels.forEach(el => {
    el.addEventListener('click', () => {
      engineLabels.forEach(e => e.classList.remove('active'));
      el.classList.add('active');
      searchEngine = el.dataset.engine;
      if (searchEngine !== 'web') {
        document.getElementById('navSearch').placeholder = `在 ${el.textContent} 上搜索...`;
      } else {
        document.getElementById('navSearch').placeholder = '搜索星图...';
      }
    });
  });

  // ===== 分类标签 =====
  let activeCat = '全部';
  const navCats = document.getElementById('navCats');
  document.getElementById('catCount').textContent = cats.length - 1;

  // ===== 分类图标映射 =====
  const catEmoji = {
    'AI 工具·国内': '\u{1F1E8}\u{1F1F3} ',
    'AI 工具·国外': '\u{1F30F} ',
    '开发技术':   '\u{1F4BB} ',
    '设计创意':   '\u{1F3A8} ',
    '常用工具':   '\u{1F527} ',
    '学习资源':   '\u{1F4DA} ',
    '阅读资讯':   '\u{1F4F0} ',
    '开源项目':   '\u{1F419} ',
    '影音娱乐':   '\u{1F3AC} ',
    '效率办公':   '\u{26A1} ',
    '生活服务':   '\u{1F3E0} ',
    '主机服务':   '\u{2601}\u{FE0F} ',
  };

  cats.forEach(cat => {
    const btn = document.createElement('button');
    btn.className = 'nav-cat' + (cat === '全部' ? ' active' : '');
    btn.dataset.cat = cat;
    btn.textContent = (cat !== '全部' ? (catEmoji[cat] || '') : '\u{1F52D} ') + cat;
    btn.addEventListener('click', () => filterCats(cat, btn));
    navCats.appendChild(btn);
  });

  function filterCats(cat, btn) {
    activeCat = cat;
    document.querySelectorAll('.nav-cat').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderLinks();
  }

  // ===== 卡片主导色（左色条 + hover 文字色） =====
  const catAccent = {
    'AI 工具·国内': '#ef4444',
    'AI 工具·国外': '#6366f1',
    '开发技术':   '#3b82f6',
    '设计创意':   '#ec4899',
    '常用工具':   '#10b981',
    '学习资源':   '#f59e0b',
    '阅读资讯':   '#f97316',
    '开源项目':   '#8b5cf6',
    '影音娱乐':   '#ef4444',
    '效率办公':   '#14b8a6',
    '生活服务':   '#84cc16',
    '主机服务':   '#06b6d4',
  };

  // ===== 渲染 =====
  const navGrid = document.getElementById('navGrid');
  const linkCount = document.getElementById('linkCount');
  const navSearch = document.getElementById('navSearch');

  function esc(s) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function renderCardHTML(l, i) {
    let hostname;
    try { hostname = new URL(l.url).hostname; } catch { hostname = ''; }
    const faviconHtml = hostname
      ? `<img src="https://www.google.com/s2/favicons?domain=${hostname}&sz=64" class="nav-card-icon" alt="" loading="lazy" width="20" height="20" onerror="this.outerHTML='<span class=\'nav-card-icon-fallback\'>${esc(l.name).charAt(0)}</span>'">`
      : `<span class="nav-card-icon-fallback">${esc(l.name).charAt(0)}</span>`;
    const accent = catAccent[l.cat] || '#6366f1';
    return `
      <a href="${esc(l.url)}" target="_blank" rel="noopener noreferrer" class="nav-card" style="--card-delay:${i * 20}ms;--card-accent:${accent}">
        ${faviconHtml}
        <span class="nav-card-name">${esc(l.name)}</span>
        ${l.desc ? `<span class="nav-card-tip" style="background:${accent}">${esc(l.desc)}</span>` : ''}
      </a>
    `;
  }

  function renderLinks(filter = '') {
    const q = filter.toLowerCase().trim();
    let filtered = activeCat === '全部' ? links : links.filter(l => l.cat === activeCat);
    if (q) {
      filtered = filtered.filter(l =>
        l.name.toLowerCase().includes(q) ||
        l.desc.toLowerCase().includes(q) ||
        l.cat.toLowerCase().includes(q)
      );
    }
    linkCount.textContent = filtered.length;

    if (filtered.length === 0) {
      navGrid.innerHTML = '<div class="nav-empty"><svg width="40" height="40" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1" opacity="0.3"/><path d="M8 12h8" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3"/></svg><p>这片星空暂未收录此类站点</p></div>';
      return;
    }

    if (activeCat === '全部') {
      const grouped = {};
      filtered.forEach(l => {
        if (!grouped[l.cat]) grouped[l.cat] = [];
        grouped[l.cat].push(l);
      });
      let html = '';
      cats.forEach(cat => {
        if (cat === '全部') return;
        const sectionLinks = grouped[cat];
        if (!sectionLinks || sectionLinks.length === 0) return;
        const total = sectionLinks.length;
        const sectionAccent = catAccent[cat] || '#6366f1';
        html += `<div class="nav-section collapsed" data-cat="${esc(cat)}" style="--section-accent:${sectionAccent}">
  <div class="nav-section-header" onclick="this.parentElement.classList.toggle('collapsed')">
    <span class="nav-section-icon" style="background:${sectionAccent}">${catEmoji[cat] || cat.charAt(0)}</span>
    <h2 class="nav-section-title">${esc(cat)}</h2>
    <span class="nav-section-count">${total} 个站点</span>
  </div>
  <div class="nav-section-grid">
    ${sectionLinks.map((l, i) => renderCardHTML(l, i)).join('')}
  </div>
</div>`;
      });
      navGrid.innerHTML = html;
    } else {
      let html = `<div class="nav-section" data-static data-cat="${esc(activeCat)}" style="--section-accent:${catAccent[activeCat] || '#6366f1'}">
  <div class="nav-section-header">
    <span class="nav-section-icon" style="background:${catAccent[activeCat] || '#6366f1'}">${catEmoji[activeCat] || activeCat.charAt(0)}</span>
    <h2 class="nav-section-title">${esc(activeCat)}</h2>
    <span class="nav-section-count">${filtered.length} 个站点</span>
  </div>
  <div class="nav-section-grid">
    ${filtered.map((l, i) => renderCardHTML(l, i)).join('')}
  </div>
</div>`;
      navGrid.innerHTML = html;
    }
  }

  // 当搜索引擎不是"站内"时，回车触发外部搜索
  navSearch.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const q = navSearch.value.trim();
      if (!q) return;
      if (searchEngine === 'web') {
        renderLinks(q);
        return;
      }
      const engines = {
        google: `https://www.google.com/search?q=${encodeURIComponent(q)}`,
        baidu: `https://www.baidu.com/s?wd=${encodeURIComponent(q)}`,
        bing: `https://www.bing.com/search?q=${encodeURIComponent(q)}`,
        github: `https://github.com/search?q=${encodeURIComponent(q)}`,
      };
      window.open(engines[searchEngine], '_blank');
    }
  });

  navSearch.addEventListener('input', () => {
    if (searchEngine === 'web') renderLinks(navSearch.value);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement !== navSearch && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
      e.preventDefault();
      navSearch.focus();
    }
    if (e.key === 'Escape') navSearch.blur();
  });

  // ===== 精选推荐 =====
  const featuredLinks = [
    { name: 'ChatGPT', url: 'https://chatgpt.com', desc: '最强 AI 对话', icon: 'https://www.google.com/s2/favicons?domain=chatgpt.com&sz=64', accent: '#10b981' },
    { name: 'GitHub', url: 'https://github.com', desc: '代码托管圣地', icon: 'https://www.google.com/s2/favicons?domain=github.com&sz=64', accent: '#6366f1' },
    { name: 'Figma', url: 'https://www.figma.com', desc: '设计协作工具', icon: 'https://www.google.com/s2/favicons?domain=figma.com&sz=64', accent: '#ec4899' },
    { name: 'V2EX', url: 'https://www.v2ex.com', desc: '技术创意社区', icon: 'https://www.google.com/s2/favicons?domain=v2ex.com&sz=64', accent: '#f59e0b' },
  ];

  const navFeatured = document.getElementById('navFeatured');
  navFeatured.innerHTML = featuredLinks.map((f, i) => `
    <a href="${esc(f.url)}" target="_blank" rel="noopener noreferrer" class="nav-featured-card" style="--feat-accent:${f.accent};animation-delay:${i * 50}ms">
      <img src="${f.icon}" class="nav-featured-icon" alt="" loading="lazy" width="24" height="24" onerror="this.outerHTML='<span class=\'nav-featured-icon-fallback\' style=\'background:${f.accent}\'>${esc(f.name).charAt(0)}</span>'">
      <span class="nav-featured-name">${esc(f.name)}</span>
      <span class="nav-featured-desc">${esc(f.desc)}</span>
    </a>
  `).join('');

  // ===== 搜索热词点击 =====
  document.querySelectorAll('.nav-hotword').forEach(btn => {
    btn.addEventListener('click', () => {
      const kw = btn.dataset.kw;
      navSearch.value = kw;
      // switch to web search mode
      searchEngine = 'web';
      engineLabels.forEach(e => e.classList.remove('active'));
      const webLabel = document.querySelector('.nav-engine-label[data-engine="web"]');
      if (webLabel) webLabel.classList.add('active');
      document.getElementById('navSearch').placeholder = '搜索星图...';
      renderLinks(kw);
    });
  });

  // ===== 顶栏时间与天气 =====
  (function() {
    const weekNames = ['日', '一', '二', '三', '四', '五', '六'];
    let weatherEmoji = '';
    let weatherTemp = '';

    function pad(n) { return String(n).padStart(2, '0'); }

    function getLunarDay(y, m, d) {
      const lunarInfo = [0x04bd8,0x04ae0,0x0a570,0x054d5,0x0d260,0x0d950,0x16554,0x056a0,0x09ad0,0x055d2,
        0x04ae0,0x0a5b6,0x0a4d0,0x0d250,0x1d255,0x0b540,0x0d6a0,0x0ada2,0x095b0,0x14977,
        0x04970,0x0a4b0,0x0b4b5,0x06a50,0x06d40,0x1ab54,0x02b60,0x09570,0x052f2,0x04970,
        0x06566,0x0d4a0,0x0ea50,0x06e95,0x05ad0,0x02b60,0x186e3,0x092e0,0x1c8d7,0x0c950,
        0x0d4a0,0x1d8a6,0x0b550,0x056a0,0x1a5b4,0x025d0,0x092d0,0x0d2b2,0x0a950,0x0b557,
        0x06ca0,0x0b550,0x15355,0x04da0,0x0a5b0,0x14573,0x052b0,0x0a9a8,0x0e950,0x06aa0,
        0x0aea6,0x0ab50,0x04b60,0x0aae4,0x0a570,0x05260,0x0f263,0x0d950,0x05b57,0x056a0,
        0x096d0,0x04dd5,0x04ad0,0x0a4d0,0x0d4d4,0x0d250,0x0d558,0x0b540,0x0b6a0,0x195a6,
        0x095b0,0x049b0,0x0a974,0x0a4b0,0x0b27a,0x06a50,0x06d40,0x0af46,0x0ab60,0x09570,
        0x04af5,0x04970,0x064b0,0x074a3,0x0ea50,0x06b58,0x055c0,0x0ab60,0x096d5,0x092e0,
        0x0c960,0x0d954,0x0d4a0,0x0da50,0x07552,0x056a0,0x0abb7,0x025d0,0x092d0,0x0cab5,
        0x0a950,0x0b4a0,0x0baa4,0x0ad50,0x055d9,0x04ba0,0x0a5b0,0x15176,0x052b0,0x0a930,
        0x07954,0x06aa0,0x0ad50,0x05b52,0x04b60,0x0a6e6,0x0a4e0,0x0d260,0x0ea65,0x0d530,
        0x05aa0,0x076a3,0x096d0,0x04afb,0x04ad0,0x0a4d0,0x1d0b6,0x0d250,0x0d520,0x0dd45,
        0x0b5a0,0x056d0,0x055b2,0x049b0,0x0a577,0x0a4b0,0x0aa50,0x1b255,0x06d20,0x0ada0];
      const lunarMonths = ['正','二','三','四','五','六','七','八','九','十','冬','腊'];
      const lunarDays = ['初一','初二','初三','初四','初五','初六','初七','初八','初九','初十','十一','十二','十三','十四','十五','十六','十七','十八','十九','二十','廿一','廿二','廿三','廿四','廿五','廿六','廿七','廿八','廿九','三十'];

      function lunarYearDays(y) {
        let sum = 348;
        for (let i2 = 0x8000; i2 > 0x8; i2 >>= 1) sum += (lunarInfo[y-1900] & i2) ? 1 : 0;
        return sum + lunarLeapDays(y);
      }
      function lunarLeapMonth(y) { return lunarInfo[y-1900] & 0xf; }
      function lunarLeapDays(y) { return lunarLeapMonth(y) ? ((lunarInfo[y-1900] & 0x10000) ? 30 : 29) : 0; }
      function lunarMonthDays(y, mn) { return (lunarInfo[y-1900] & (0x10000 >> mn)) ? 30 : 29; }

      let baseDate = new Date(1900, 0, 31);
      let targetDate = new Date(y, m-1, d);
      let days = Math.floor((targetDate - baseDate) / 86400000);
      
      let year;
      for (year = 1900; year < 2101 && days > 0; year++) {
        days -= lunarYearDays(year);
      }
      if (days < 0) { days += lunarYearDays(--year); }
      
      let leap = false, leapMonth = 0;
      let month = 0, tmp = 0;
      for (month = 1; month <= 12 && days > 0; month++) {
        leapMonth = lunarLeapMonth(year);
        if (leapMonth > 0 && month === leapMonth + 1 && !leap) {
          --month;
          leap = true;
          tmp = lunarLeapDays(year);
        } else {
          tmp = lunarMonthDays(year, month);
        }
        if (leap && month === leapMonth + 1) leap = false;
        days -= tmp;
      }
      if (days === 0 && leapMonth > 0 && month === leapMonth + 1) {
        if (leap) leap = false; else { leap = true; --month; }
      }
      if (days < 0) { days += tmp; --month; }
      return (leap ? '闰' : '') + lunarMonths[month - 1] + '月' + lunarDays[days];
    }

    function updateTopbar() {
      const now = new Date();
      const h = pad(now.getHours());
      const m = pad(now.getMinutes());
      const timeStr = `${h}:${m}`;
      const month = now.getMonth() + 1;
      const day = now.getDate();
      const w = now.getDay();

      let parts = [`${timeStr}`];
      if (weatherTemp) {
        parts.push(`${weatherTemp} ${weatherEmoji}`);
      }
      const lunarText = getLunarDay(now.getFullYear(), month, day);
      parts.push(`${now.getFullYear()}年${month}月${day}日 星期${weekNames[w]} ${lunarText}`);
      document.getElementById('navTopbarDate').textContent = parts.join(' · ');
    }

    // fetch weather
    fetch('https://wttr.in/?format=%C+%t')
      .then(res => { if (!res.ok) throw new Error('fetch failed'); return res.text(); })
      .then(text => {
        const m = text.trim().match(/^(.+?)\s+([+-]?\d+°C)$/);
        if (m) { weatherEmoji = m[1]; weatherTemp = m[2]; }
        updateTopbar();
      })
      .catch(() => { updateTopbar(); });

    updateTopbar();
    setInterval(updateTopbar, 30000);
  })();

  renderLinks();

  // ===== 点击涟漪效果 =====
  document.addEventListener('click', (e) => {
    const card = e.target.closest('.nav-card');
    if (!card) return;
    const rect = card.getBoundingClientRect();
    const x = ((e.clientX - rect.left) / rect.width) * 100;
    const y = ((e.clientY - rect.top) / rect.height) * 100;
    card.style.setProperty('--ripple-x', x + '%');
    card.style.setProperty('--ripple-y', y + '%');
  });
</script>

<style is:global>
  :root, [data-theme="light"] {
    --nav-bg: #f3f5f7;
    --nav-surface: #ffffff;
    --nav-surface-hover: #f8f9fc;
    --nav-border: rgba(0,0,0,0.06);
    --nav-border-hover: rgba(0,0,0,0.12);
    --nav-text: #1a1a2e;
    --nav-text-secondary: #6b7280;
    --nav-accent: #6366f1;
    --nav-accent-glow: rgba(99,102,241,0.12);
    --nav-accent-pale: rgba(99,102,241,0.06);
    --nav-engine-bg: rgba(0,0,0,0.02);
    --nav-search-bg-hover: rgba(0,0,0,0.015);
    --nav-search-placeholder: #94a3b8;
    --nav-kbd-bg: rgba(0,0,0,0.05);
    --radius: 12px;
    --font-mono: "SF Mono", "Fira Code", "Cascadia Code", monospace;
  }
  [data-theme="dark"] {
    --nav-bg: #0b0e14;
    --nav-surface: rgba(255,255,255,0.055);
    --nav-surface-hover: rgba(255,255,255,0.09);
    --nav-border: rgba(255,255,255,0.09);
    --nav-border-hover: rgba(255,255,255,0.18);
    --nav-text: rgba(255,255,255,0.9);
    --nav-text-secondary: rgba(255,255,255,0.58);
    --nav-accent: #a78bfa;
    --nav-accent-glow: rgba(167,139,250,0.2);
    --nav-accent-pale: rgba(167,139,250,0.08);
    --nav-engine-bg: rgba(255,255,255,0.02);
    --nav-search-bg-hover: rgba(255,255,255,0.02);
    --nav-search-placeholder: rgba(255,255,255,0.2);
    --nav-kbd-bg: rgba(255,255,255,0.06);
    --radius: 12px;
    --font-mono: "SF Mono", "Fira Code", "Cascadia Code", monospace;
  }

  .nav-body {
    margin: 0;
    background: var(--nav-bg);
    color: var(--nav-text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Noto Sans SC", sans-serif;
    line-height: 1.5;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* ===== 星际背景画布 ===== */
  .star-canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 1;
  }

  /* ===== 顶栏 ===== */
  .nav-topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255,255,255,0.72);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    border-bottom: 1px solid var(--nav-border);
  }
  [data-theme="dark"] .nav-topbar {
    background: rgba(11,14,20,0.78);
  }
  .nav-topbar-inner {
    max-width: 1480px;
    margin: 0 auto;
    padding: 0 24px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-topbar-title {
    font-size: 17px;
    font-weight: 600;
    color: var(--nav-text);
    letter-spacing: 2px;
    font-family: var(--font-mono);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }
  .nav-topbar-title:hover { opacity: 0.85; }
  /* Logo 单字霓虹 */
  .nav-logo-c { display: inline-block; }
  .nav-logo-c:nth-child(1) {
    color: #c4b5fd;
    text-shadow: 0 0 6px #a78bfa, 0 0 14px #7c3aed, 0 0 26px #7c3aed;
  }
  .nav-logo-c:nth-child(2) {
    color: #67e8f9;
    text-shadow: 0 0 6px #22d3ee, 0 0 14px #06b6d4, 0 0 26px #06b6d4;
  }

  .nav-topbar-date {
    font-size: 12.5px;
    color: var(--nav-text-secondary);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    margin-left: auto;
    margin-right: 16px;
  }

  .nav-theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--nav-border);
    background: transparent;
    color: var(--nav-text-secondary);
    cursor: pointer;
    transition: all 0.25s;
  }
  .nav-theme-btn:hover {
    color: var(--nav-text);
    border-color: var(--nav-border-hover);
    background: var(--nav-surface);
  }
  [data-theme="dark"] .nav-theme-sun { display: block; }
  [data-theme="dark"] .nav-theme-moon { display: none; }
  [data-theme="light"] .nav-theme-sun { display: none; }
  [data-theme="light"] .nav-theme-moon { display: block; }

  /* ===== 主区域 ===== */
  .nav-main {
    position: relative;
    z-index: 1;
    max-width: 1480px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  /* ===== 标题区 ===== */
  .nav-hero {
    text-align: center;
    padding: 60px 0 44px;
  }
  .nav-constellation {
    display: block;
    text-align: center;
    margin-bottom: 20px;
    color: var(--nav-accent);
    opacity: 0.55;
    animation: constellation-pulse 4s ease-in-out infinite;
  }
  @keyframes constellation-pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.03); }
  }
  .nav-hero-title {
    display: block;
