  { cat: '阅读资讯', name: 'V2EX', url: 'https://www.v2ex.com', desc: '国内技术创意交流社区' },
  { cat: '阅读资讯', name: '掘金', url: 'https://juejin.cn', desc: '前端/后端/移动开发技术分享' },
