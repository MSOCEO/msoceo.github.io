---

<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead title={title} description={description} />
  <link rel="preconnect" href="https://www.google.com" crossorigin />
</head>
<body class="nav-body">
  <!-- 星际画布 -->
  <canvas id="starCanvas" class="star-canvas" aria-hidden="true"></canvas>

  <!-- 极简顶栏 — 仅中间品牌 -->
  <header class="nav-topbar">
    <div class="nav-topbar-inner">
      <a href="/" class="nav-back" aria-label="返回枕星">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M19 12H5m7-7l-7 7 7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <span class="nav-sep"></span>
    </div>
  </header>

  <main class="nav-main">
    <!-- 星图标题区 -->
    <section class="nav-hero">
      <div class="nav-constellation" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
          <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="0.5" opacity="0.12"/>
          <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="0.3" opacity="0.2" stroke-dasharray="3 8" stroke-dashoffset="1"/>
          <line x1="8" y1="20" x2="40" y2="20" stroke="currentColor" stroke-width="0.4" opacity="0.08"/>
          <line x1="8" y1="28" x2="40" y2="28" stroke="currentColor" stroke-width="0.4" opacity="0.08"/>
          <line x1="20" y1="8" x2="20" y2="40" stroke="currentColor" stroke-width="0.4" opacity="0.08"/>
          <line x1="28" y1="8" x2="28" y2="40" stroke="currentColor" stroke-width="0.4" opacity="0.08"/>
          <circle cx="14" cy="16" r="1.5" fill="currentColor" opacity="0.5"/>
          <circle cx="34" cy="16" r="1.2" fill="currentColor" opacity="0.4"/>
          <circle cx="18" cy="34" r="1.4" fill="currentColor" opacity="0.45"/>
          <circle cx="32" cy="32" r="1" fill="currentColor" opacity="0.35"/>
        </svg>
      </div>
      <h1 class="nav-hero-title">枕星 · 星图</h1>
      <p class="nav-hero-desc">星辰为引 · 链接为舟 · 手工甄别 · 持续更新</p>

      <!-- 搜索 -->
      <div class="nav-search-wrap" id="searchWrap">
        <div class="nav-search-engine" id="searchEngine">
          <span class="nav-engine-label" data-engine="web">站内</span>
          <span class="nav-engine-divider"></span>
          <span class="nav-engine-label active" data-engine="google">Google</span>
          <span class="nav-engine-divider"></span>
          <span class="nav-engine-label" data-engine="baidu">百度</span>
          <span class="nav-engine-divider"></span>
          <span class="nav-engine-label" data-engine="bing">Bing</span>
          <span class="nav-engine-divider"></span>
          <span class="nav-engine-label" data-engine="github">GitHub</span>
        </div>
        <div class="nav-search-bar">
          <svg class="nav-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <input type="text" class="nav-search-input" id="navSearch" placeholder="搜索星图..." autocomplete="off" />
          <kbd class="nav-search-kbd">/</kbd>
        </div>
      </div>

      <div class="nav-stats" id="navStats">
        <span>已收录 <strong id="linkCount">0</strong> 颗星</span>
        <span class="nav-stats-dot">·</span>
        <span>共 <strong id="catCount">0</strong> 个星座</span>
      </div>
    </section>

    <!-- 分类星座 -->
    <nav class="nav-cats" id="navCats"></nav>

    <!-- 星图网格 -->
    <div class="nav-grid" id="navGrid"></div>
  </main>

  <footer class="nav-footer">
    <p>手工筛选，定期剔除失效 / 投毒站点 · 仅收录活跃可靠网站</p>
  </footer>
</body>
</html>

<script define:vars={{ linksJson, catsJson }}>
  const links = JSON.parse(linksJson);
  const cats = JSON.parse(catsJson);

  // ===== 搜索引擎切换 =====
  let searchEngine = 'web';
  const engineLabels = document.querySelectorAll('.nav-engine-label');
  engineLabels.forEach(el => {
    el.addEventListener('click', () => {
      engineLabels.forEach(e => e.classList.remove('active'));
      el.classList.add('active');
      searchEngine = el.dataset.engine;
      if (searchEngine !== 'web') {
        document.getElementById('navSearch').placeholder = `在 ${el.textContent} 上搜索...`;
      } else {
        document.getElementById('navSearch').placeholder = '搜索星图...';
      }
    });
  });

  // ===== 分类标签 =====
  let activeCat = '全部';
  const navCats = document.getElementById('navCats');
  document.getElementById('catCount').textContent = cats.length - 1;

  cats.forEach(cat => {
    const btn = document.createElement('button');
    btn.className = 'nav-cat' + (cat === '全部' ? ' active' : '');
    btn.dataset.cat = cat;
    btn.textContent = cat;
    btn.addEventListener('click', () => filterCats(cat, btn));
    navCats.appendChild(btn);
  });

  function filterCats(cat, btn) {
    activeCat = cat;
    document.querySelectorAll('.nav-cat').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderLinks();
  }

  // ===== 渲染 =====
  const navGrid = document.getElementById('navGrid');
  const linkCount = document.getElementById('linkCount');
  const navSearch = document.getElementById('navSearch');

  function esc(s) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function renderLinks(filter = '') {
    const q = filter.toLowerCase().trim();
    let filtered = activeCat === '全部' ? links : links.filter(l => l.cat === activeCat);
    if (q) {
      filtered = filtered.filter(l =>
        l.name.toLowerCase().includes(q) ||
        l.desc.toLowerCase().includes(q) ||
        l.cat.toLowerCase().includes(q)
      );
    }
    linkCount.textContent = filtered.length;

    if (filtered.length === 0) {
      navGrid.innerHTML = '<div class="nav-empty"><svg width="40" height="40" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1" opacity="0.3"/><path d="M8 12h8" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3"/></svg><p>这片星空暂未收录此类站点</p></div>';
      return;
    }

    navGrid.innerHTML = filtered.map((l, i) => `
      <a href="${esc(l.url)}" target="_blank" rel="noopener noreferrer" class="nav-card" style="--card-delay:${i * 30}ms">
        <span class="nav-card-cat">${esc(l.cat)}</span>
        <h3 class="nav-card-name">${esc(l.name)}</h3>
        <p class="nav-card-desc">${esc(l.desc)}</p>
      </a>
    `).join('');
  }

  // 当搜索引擎不是"站内"时，回车触发外部搜索
  navSearch.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const q = navSearch.value.trim();
      if (!q) return;
      if (searchEngine === 'web') {
        renderLinks(q);
        return;
      }
      const engines = {
        google: `https://www.google.com/search?q=${encodeURIComponent(q)}`,
        baidu: `https://www.baidu.com/s?wd=${encodeURIComponent(q)}`,
        bing: `https://www.bing.com/search?q=${encodeURIComponent(q)}`,
        github: `https://github.com/search?q=${encodeURIComponent(q)}`,
      };
      window.open(engines[searchEngine], '_blank');
    }
  });

  navSearch.addEventListener('input', () => {
    if (searchEngine === 'web') renderLinks(navSearch.value);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement !== navSearch && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
      e.preventDefault();
      navSearch.focus();
    }
    if (e.key === 'Escape') navSearch.blur();
  });

  renderLinks();
</script>

