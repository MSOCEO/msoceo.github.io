const CATS = ['全部', ...new Set(LINKS.map(l => l.cat))];
const linksJson = JSON.stringify(LINKS);
const catsJson = JSON.stringify(CATS);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="nav-body">
    <header class="nav-topbar">
      <div class="nav-topbar-inner">
        <a href="/" class="nav-brand" aria-label="枕星首页">
          <svg width="22" height="22" viewBox="0 0 48 48" fill="none">
            <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="0.8" opacity="0.15"/>
            <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="0.5" opacity="0.3" stroke-dasharray="4 8" stroke-dashoffset="2"/>
            <line x1="24" y1="6" x2="24" y2="42" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.9"/>
            <line x1="6" y1="24" x2="42" y2="24" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.9"/>
            <line x1="11.3" y1="11.3" x2="36.7" y2="36.7" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" opacity="0.5"/>
            <line x1="36.7" y1="11.3" x2="11.3" y2="36.7" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" opacity="0.5"/>
            <circle cx="24" cy="24" r="3" fill="currentColor" opacity="0.8"/>
          </svg>
          <span>枕星导航</span>
        </a>
      </div>
    </header>

    <main class="nav-main">
      <section class="nav-hero">
        <h1 class="nav-hero-title">枕星导航</h1>
        <p class="nav-hero-desc">精选书签 · 手工甄别 · 无广告无套路 · 持续更新</p>
        <div class="nav-search-wrap">
          <svg class="nav-search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <input type="text" class="nav-search-input" id="navSearch" placeholder="搜索站点..." autocomplete="off" />
          <kbd class="nav-search-kbd">/</kbd>
        </div>
        <div class="nav-stats" id="navStats">共收录 <strong id="linkCount">0</strong> 个站点</div>
      </section>

      <nav class="nav-cats" id="navCats"></nav>
      <div class="nav-grid" id="navGrid"></div>
    </main>

    <footer class="nav-footer">
      <p>手工筛选，定期剔除失效/投毒站点 · <a href="/">返回枕星</a></p>
    </footer>
  </body>
</html>

<script define:vars={{ linksJson, catsJson }}>
  const links = JSON.parse(linksJson);
  const cats = JSON.parse(catsJson);
  let activeCat = '全部';

  const navCats = document.getElementById('navCats');
  cats.forEach(cat => {
    const btn = document.createElement('button');
    btn.className = 'nav-cat' + (cat === '全部' ? ' active' : '');
    btn.dataset.cat = cat;
    btn.textContent = cat;
    btn.addEventListener('click', () => filterCats(cat, btn));
    navCats.appendChild(btn);
  });

  function filterCats(cat, btn) {
    activeCat = cat;
    document.querySelectorAll('.nav-cat').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderLinks();
  }

  const navGrid = document.getElementById('navGrid');
  const linkCount = document.getElementById('linkCount');
  const navSearch = document.getElementById('navSearch');

  function renderLinks(filter = '') {
    const q = filter.toLowerCase().trim();
    let filtered = activeCat === '全部' ? links : links.filter(l => l.cat === activeCat);
    if (q) {
      filtered = filtered.filter(l =>
        l.name.toLowerCase().includes(q) ||
        l.desc.toLowerCase().includes(q) ||
        l.cat.toLowerCase().includes(q)
      );
    }
    linkCount.textContent = filtered.length;

    if (filtered.length === 0) {
      navGrid.innerHTML = '<div class="nav-empty">没有匹配的站点</div>';
      return;
    }

    navGrid.innerHTML = filtered.map(l => {
      const safeUrl = l.url.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      const safeName = l.name.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      const safeDesc = l.desc.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      const safeCat = l.cat.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      return `<a href="${safeUrl}" target="_blank" rel="noopener noreferrer" class="nav-card" data-cat="${safeCat}">
        <div class="nav-card-cat">${safeCat}</div>
        <h3 class="nav-card-name">${safeName}</h3>
        <p class="nav-card-desc">${safeDesc}</p>
      </a>`;
    }).join('');
  }

  navSearch.addEventListener('input', () => renderLinks(navSearch.value));
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement !== navSearch && document.activeElement?.tagName !== 'INPUT') {
      e.preventDefault();
      navSearch.focus();
    }
    if (e.key === 'Escape') navSearch.blur();
  });

  renderLinks();
</script>

<style is:global>
  :root {
    --nav-bg: #080b12;
    --nav-surface: rgba(255,255,255,0.03);
    --nav-border: rgba(255,255,255,0.06);
    --nav-text: rgba(255,255,255,0.87);
    --nav-text-secondary: rgba(255,255,255,0.5);
    --nav-accent: #a78bfa;
    --nav-accent-dim: rgba(167,139,250,0.12);
    --radius: 10px;
  }
  .nav-body {
    margin: 0;
    background: var(--nav-bg);
    color: var(--nav-text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Noto Sans SC", sans-serif;
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }
  .nav-topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(8,11,18,0.85);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--nav-border);
  }
  .nav-topbar-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--nav-text);
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.03em;
  }
  .nav-brand svg { color: var(--nav-accent); }
  .nav-main {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }
  .nav-hero {
    text-align: center;
    padding: 56px 0 40px;
  }
  .nav-hero-title {
    font-size: 36px;
    font-weight: 700;
    margin: 0 0 8px;
    letter-spacing: 0.04em;
    background: linear-gradient(135deg, var(--nav-accent), #f0abfc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .nav-hero-desc {
    color: var(--nav-text-secondary);
    font-size: 15px;
    margin: 0 0 32px;
  }
  .nav-stats {
    margin-top: 12px;
    font-size: 13px;
    color: var(--nav-text-secondary);
  }
  .nav-stats strong { color: var(--nav-accent); }
  .nav-search-wrap {
    display: flex;
    align-items: center;
    max-width: 520px;
    margin: 0 auto;
    background: var(--nav-surface);
    border: 1px solid var(--nav-border);
    border-radius: var(--radius);
    padding: 12px 16px;
    gap: 10px;
    transition: border-color 0.2s;
  }
  .nav-search-wrap:focus-within { border-color: var(--nav-accent); }
  .nav-search-icon { color: var(--nav-text-secondary); flex-shrink: 0; }
  .nav-search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--nav-text);
    font-size: 15px;
  }
  .nav-search-input::placeholder { color: rgba(255,255,255,0.25); }
  .nav-search-kbd {
    font-size: 12px;
    padding: 2px 7px;
    border-radius: 4px;
    background: rgba(255,255,255,0.06);
    color: var(--nav-text-secondary);
    flex-shrink: 0;
  }
  .nav-cats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
    justify-content: center;
  }
  .nav-cat {
    padding: 6px 16px;
    border-radius: 20px;
    border: 1px solid var(--nav-border);
    background: transparent;
    color: var(--nav-text-secondary);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .nav-cat:hover { color: var(--nav-text); border-color: rgba(255,255,255,0.15); }
  .nav-cat.active {
    background: var(--nav-accent-dim);
    border-color: var(--nav-accent);
    color: var(--nav-accent);
  }
  .nav-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }
  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 18px 20px;
    border-radius: var(--radius);
    background: var(--nav-surface);
    border: 1px solid var(--nav-border);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .nav-card:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.12);
    transform: translateY(-2px);
  }
  .nav-card-cat {
    font-size: 11px;
    color: var(--nav-accent);
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .nav-card-name {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    color: var(--nav-text);
  }
  .nav-card-desc {
    margin: 0;
    font-size: 13px;
    color: var(--nav-text-secondary);
    line-height: 1.5;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .nav-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 0;
    color: var(--nav-text-secondary);
    font-size: 15px;
  }
  .nav-footer {
    text-align: center;
    padding: 24px;
    border-top: 1px solid var(--nav-border);
    font-size: 13px;
    color: var(--nav-text-secondary);
  }
  .nav-footer a { color: var(--nav-accent); text-decoration: none; }

  @media (max-width: 640px) {
    .nav-main { padding: 0 16px 60px; }
    .nav-hero-title { font-size: 28px; }
    .nav-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 8px; }
    .nav-card { padding: 14px 16px; }
    .nav-cats { gap: 6px; }
    .nav-cat { padding: 5px 12px; font-size: 12px; }
  }
</style>
