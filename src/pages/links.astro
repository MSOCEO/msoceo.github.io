    }

    const petals = [];
    const MAX = 55;

    function spawnPetal(fromTop) {
      const colors = getColors();
      petals.push({
        x: Math.random() * (w + 60) - 30,
        y: fromTop ? -20 - Math.random() * 300 : Math.random() * h,
        size: 10 + Math.random() * 20,
        speed: 0.3 + Math.random() * 1.0,
        wobble: 0.3 + Math.random() * 2.0,
        wobbleSpeed: 0.006 + Math.random() * 0.014,
        rotation: Math.random() * Math.PI * 2,
        rotationSpeed: (Math.random() - 0.5) * 0.025,
        color: colors[Math.floor(Math.random() * colors.length)],
        opacity: 0.45 + Math.random() * 0.45,
        phase: Math.random() * Math.PI * 2,
      });
    }

    for (let i = 0; i < MAX; i++) spawnPetal(false);

    function drawPetal(x, y, size, rotation, color, opacity) {
      ctx.save();
      ctx.translate(x, y);
      ctx.rotate(rotation);
      ctx.globalAlpha = opacity;
      const hw = size * 0.5;
      const hh = size * 0.32;
      ctx.beginPath();
      ctx.moveTo(0, -hh);
      ctx.bezierCurveTo(-hw * 0.6, -hh * 0.6, -hw, hh * 0.3, 0, hh * 1.4);
      ctx.bezierCurveTo(hw, hh * 0.3, hw * 0.6, -hh * 0.6, 0, -hh);
      ctx.fillStyle = color;
      ctx.fill();
      ctx.beginPath();
      ctx.moveTo(0, -hh * 0.7);
      ctx.lineTo(0, hh * 1.1);
      ctx.strokeStyle = 'rgba(255,255,255,0.25)';
      ctx.lineWidth = 0.5;
      ctx.stroke();
      ctx.restore();
    }

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = Math.max(window.innerHeight, document.body.scrollHeight, document.documentElement.scrollHeight);
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);
      for (let i = petals.length - 1; i >= 0; i--) {
        const p = petals[i];
        p.phase += p.wobbleSpeed;
        const dx = Math.sin(p.phase) * p.wobble;
        p.y += p.speed;
        p.rotation += p.rotationSpeed;
        drawPetal(p.x + dx, p.y, p.size, p.rotation, p.color, p.opacity);
        if (p.y > h + 30) petals.splice(i, 1);
      }
      while (petals.length < MAX) spawnPetal(true);
      requestAnimationFrame(draw);
    }

    resize();
    window.addEventListener('resize', resize);
    requestAnimationFrame(draw);
  })();

  // ===== 主题切换 =====
  (function() {
    const toggle = document.getElementById('themeToggle');
    const body = document.body;
    const saved = localStorage.getItem('star-theme');
    if (saved === 'dark') body.setAttribute('data-theme', 'dark');
    toggle.addEventListener('click', () => {
      const next = body.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      body.setAttribute('data-theme', next);
      localStorage.setItem('star-theme', next);
    });
  })();
</script>
