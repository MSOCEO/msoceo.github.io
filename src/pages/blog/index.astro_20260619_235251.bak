---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const allPostsUnsorted = await getCollection('blog');
const allPosts = allPostsUnsorted.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const PAGE_SIZE = 3;
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);

// Tag cloud from ALL posts
const allTags = new Map();
allPosts.forEach(p => {
  const tags = p.data.tags || [];
  tags.forEach(t => {
    const tag = String(t).trim();
    if (tag) allTags.set(tag, (allTags.get(tag) || 0) + 1);
  });
});
const tagsSorted = [...allTags.entries()].sort((a, b) => b[1] - a[1]);

const title = '寒影·拾光';
const description = '在深夜书房里，拾取散落的光';
---

<Page {title} {description}>
  <!-- 全屏星空 Hero -->
  <div class="blog-hero">
    <div class="blog-hero-inner">
      <h1 class="blog-hero-title"><span class="accent-purple">寒</span>影<span class="accent-purple">·</span>拾光</h1>
      <p class="blog-hero-sub">在深夜书房里，拾取散落的光</p>
      <div class="blog-hero-line"></div>
    </div>
    <div class="blog-hero-scroll">
      <span>下滑阅读</span>
      <div class="blog-hero-arrow"></div>
    </div>
  </div>
  <section class="blog-section">
    <div class="blog-content">
      <header class="blog-header animate-in">
        <h1 class="blog-header-title">博客</h1>
        <p class="blog-header-desc">{description}</p>
      </header>

      <!-- Search Bar -->
      <div class="blog-search-bar animate-in" style="animation-delay:0.05s">
        <svg class="blog-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <input type="text" class="blog-search-input" id="blogSearch" placeholder="搜索文章..." autocomplete="off" />
        <span class="blog-search-count" id="blogSearchCount">{allPosts.length} 篇</span>
      </div>

      <!-- Tag Cloud -->
      {tagsSorted.length > 0 && (
        <div class="blog-tag-cloud animate-in" style="animation-delay:0.15s">
          <button class="blog-tag blog-tag-active" onclick="filterByTag(null, this)">全部</button>
          {tagsSorted.map(([tag, count]) => (
            <button class="blog-tag" onclick={`filterByTag('${tag}', this)`}>{tag} ({count})</button>
          ))}
        </div>
      )}

      <div class="post-grid" id="postGrid">
        {allPosts.map((post, i) => {
          const isEven = i % 2 === 0;
          return (
          <article class={`post-card ${!isEven ? 'post-card--reverse' : ''}`} style={`--anim-delay: ${i * 100}ms`} data-tags={JSON.stringify(post.data.tags || [])}>
            <a href={`/blog/${post.id}`} class="post-card-link">
              <div class="post-card-body">
                <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-CN', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-excerpt">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="post-tags">
                    {post.data.tags.map(t => <span class="post-tag">{String(t)}</span>)}
                  </div>
                )}
                <span class="post-read-more">
                  阅读全文
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>
              <div class="post-card-thumb">
                <div class="post-thumb-bg"></div>
                <span class="post-thumb-num">{String(i + 1).padStart(2, '0')}</span>
              </div>
            </a>
          </article>
        )})}
      </div>

      <div class="blog-no-result" id="blogNoResult" style="display:none">没有找到匹配的文章</div>

      <!-- ====== Pagination ====== -->
      {totalPages > 1 && (
        <nav class="pagination" aria-label="博客分页">
          <div class="pagination-inner">
            <button class="pagination-btn pagination-disabled" id="pgPrev">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              上一页
            </button>

            <div class="pagination-pages" id="pgPages">
              <span class="pagination-num pagination-active" data-pg="1">1</span>
            </div>

            <button class="pagination-btn" id="pgNext">
              下一页
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
          <div class="pagination-info" id="pgInfo">第 1 / {totalPages} 页，共 {allPosts.length} 篇文章</div>
        </nav>
      )}
    </div>
  </section>
</Page>

<script>
  const PAGE_SIZE = 3;
  const grid = document.getElementById('postGrid');
  const searchCount = document.getElementById('blogSearchCount');
  const noResult = document.getElementById('blogNoResult');
  let activeTag = null;

  function getVisibleCards() {
    return Array.from(grid.querySelectorAll('.post-card')).filter(c => c.style.display !== 'none');
  }

  function filterPosts() {
    const q = document.getElementById('blogSearch').value.toLowerCase().trim();
    const cards = grid.querySelectorAll('.post-card');
    let visible = 0;
    cards.forEach(card => {
      const title = card.querySelector('.post-title')?.textContent?.toLowerCase() || '';
      const excerpt = card.querySelector('.post-excerpt')?.textContent?.toLowerCase() || '';
      const tagsText = card.dataset.tags || '[]';
      const tags = JSON.parse(tagsText).map(t => String(t).toLowerCase());
      const matchesSearch = !q || title.includes(q) || excerpt.includes(q) || tags.some(t => t.includes(q));
      const matchesTag = !activeTag || tags.some(t => t.toLowerCase() === activeTag.toLowerCase());
      const show = matchesSearch && matchesTag;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    searchCount.textContent = visible + ' 篇';
    noResult.style.display = visible === 0 ? 'block' : 'none';
    goToPage(1);
  }

  window.filterByTag = function(tag, btn) {
    activeTag = tag;
    document.querySelectorAll('.blog-tag').forEach(b => b.classList.remove('blog-tag-active'));
    if (btn) btn.classList.add('blog-tag-active');
    filterPosts();
  };

  // Pagination
  function goToPage(pg) {
    const visible = getVisibleCards();
    const totalVisible = visible.length;
    const vPages = Math.ceil(totalVisible / PAGE_SIZE);

    visible.forEach((c, i) => {
      const page = Math.floor(i / PAGE_SIZE) + 1;
      c.style.display = page === pg ? '' : 'none';
    });

    // Update buttons
    const prev = document.getElementById('pgPrev');
    const next = document.getElementById('pgNext');
    const info = document.getElementById('pgInfo');
    const pages = document.getElementById('pgPages');

    if (prev) {
      if (pg <= 1) prev.classList.add('pagination-disabled');
      else prev.classList.remove('pagination-disabled');
    }
    if (next) {
      if (pg >= vPages) next.classList.add('pagination-disabled');
      else next.classList.remove('pagination-disabled');
    }
    if (info) info.textContent = '第 ' + pg + ' / ' + vPages + ' 页，共 ' + totalVisible + ' 篇可见';

    if (pages) {
      let html = '';
      for (let n = 1; n <= vPages; n++) {
        if (n === 1 || n === vPages || Math.abs(n - pg) <= 1) {
          html += '<span class="pagination-num' + (n === pg ? ' pagination-active' : '') + '" data-pg="' + n + '">' + n + '</span>';
        } else if (n === 2 && pg > 3) {
          html += '<span class="pagination-ellipsis">...</span>';
        } else if (n === vPages - 1 && pg < vPages - 2) {
          html += '<span class="pagination-ellipsis">...</span>';
        }
      }
      pages.innerHTML = html;
      pages.querySelectorAll('.pagination-num:not(.pagination-active)').forEach(el => {
        el.addEventListener('click', () => goToPage(parseInt(el.dataset.pg)));
      });
    }
  }

  document.getElementById('pgPrev')?.addEventListener('click', () => {
    const cur = document.querySelector('.pagination-active');
    const pg = cur ? parseInt(cur.dataset.pg) : 1;
    if (pg > 1) goToPage(pg - 1);
  });
  document.getElementById('pgNext')?.addEventListener('click', () => {
    const cur = document.querySelector('.pagination-active');
    const pg = cur ? parseInt(cur.dataset.pg) : 1;
    const visible = getVisibleCards();
    const vPages = Math.ceil(visible.length / PAGE_SIZE);
    if (pg < vPages) goToPage(pg + 1);
  });

  // Scroll active tag into view
  (function() {
    const tagContainer = document.querySelector('.blog-tag-cloud');
    if (!tagContainer) return;
    const activeBtn = tagContainer.querySelector('.blog-tag-active');
    if (activeBtn) activeBtn.scrollIntoView({ inline: 'center', block: 'nearest' });
  })();
</script>

<style>
  .blog-section {
    padding: var(--space-4xl) 0 var(--space-2xl);
  }

  /* ---- 宽幅内容容器 ---- */
  .blog-content {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  @media (max-width: 1200px) {
    .blog-content {
      max-width: 960px;
    }
  }

  @media (max-width: 768px) {
    .blog-content {
      padding: 0 var(--space-md);
    }
    .blog-section {
      padding: var(--space-3xl) 0 var(--space-md);
    }
  }

  /* ---- 博客头部 ---- */
  .blog-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .blog-header-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, var(--text-4xl));
    font-weight: var(--weight-bold);
    color: var(--ink-100);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-sm);
  }

  .blog-header-desc {
    font-size: var(--text-lg);
    color: var(--ink-50);
    margin: 0 auto;
    max-width: 520px;
  }

  /* Search Bar */
  .blog-search-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: 520px;
    margin: 0 auto var(--space-2xl);
    padding: 10px 16px;
    background: var(--ink-15);
    border: 1px solid var(--ink-25);
    border-radius: var(--radius-full);
    transition: border-color var(--duration-fast);
  }
  .blog-search-bar:focus-within {
    border-color: var(--amber-400);
  }
  .blog-search-icon {
    color: var(--ink-40);
    flex-shrink: 0;
  }
  .blog-search-input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--ink-100);
    font-size: var(--text-sm);
    font-family: inherit;
    outline: none;
  }
  .blog-search-input::placeholder { color: var(--ink-40); }
  .blog-search-count {
    font-size: var(--text-xs);
    color: var(--ink-40);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Tag Cloud */
  .blog-tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-bottom: var(--space-2xl);
  }
  .blog-tag {
    padding: 5px 14px;
    border-radius: var(--radius-full);
    border: 1px solid var(--ink-25);
    background: transparent;
    color: var(--ink-50);
    font-size: var(--text-xs);
    cursor: pointer;
    transition: all var(--duration-fast);
    font-family: inherit;
  }
  .blog-tag:hover {
    border-color: var(--amber-400);
    color: var(--amber-400);
  }
  .blog-tag-active {
    background: var(--amber-400);
    border-color: var(--amber-400);
    color: #1a1a1a;
    font-weight: 600;
  }
  .blog-tag-active:hover { color: #1a1a1a; }

  /* ---- 文章列表（下滑式横向交替卡片） ---- */
  .post-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .post-card {
    opacity: 0;
    animation: postFadeSlide 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--anim-delay, 0ms);
  }

  @keyframes postFadeSlide {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .post-card-link {
    display: flex;
    align-items: stretch;
    gap: 0;
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(167, 139, 250, 0.08);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post-card:hover .post-card-link {
    border-color: rgba(167, 139, 250, 0.22);
    box-shadow: 0 8px 32px rgba(167, 139, 250, 0.06);
    transform: translateY(-2px);
  }

  /* 偶数卡片反转：缩略图在左，正文在右 */
  .post-card--reverse .post-card-link {
    flex-direction: row-reverse;
  }

  /* ---- 正文区 ---- */
  .post-card-body {
    flex: 1;
    padding: var(--space-xl) var(--space-lg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .post-date {
    display: block;
    font-size: var(--text-xs);
    color: var(--ink-40);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-sm);
  }

  .post-title {
    font-family: 'Noto Serif SC', serif;
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: #E4E4E7;
    margin-bottom: var(--space-xs);
    line-height: var(--leading-snug);
  }

  .post-excerpt {
    font-size: var(--text-sm);
    color: var(--ink-50);
    margin-bottom: var(--space-md);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: var(--space-md);
  }
  .post-tag {
    display: inline-block;
    padding: 2px 10px;
    background: var(--ink-20);
    color: var(--ink-50);
    font-size: 11px;
    border-radius: var(--radius-sm);
  }

  .post-read-more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: #A78BFA;
    transition: color var(--duration-fast) var(--ease-out);
    margin-top: auto;
  }
  .post-read-more:hover { color: #8B5CF6; }
  .post-read-more svg {
    transition: transform var(--duration-fast) var(--ease-out);
  }
  .post-card:hover .post-read-more svg {
    transform: translateX(4px);
  }

  /* ---- 缩略图区 ---- */
  .post-card-thumb {
    width: 260px;
    min-height: 200px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(167,139,250,0.08) 0%, rgba(99,102,241,0.04) 100%);
    position: relative;
    overflow: hidden;
  }

  .post-thumb-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(167,139,250,0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 50%, rgba(99,102,241,0.08) 0%, transparent 50%);
  }

  .post-card:hover .post-thumb-bg {
    background:
      radial-gradient(ellipse at 20% 50%, rgba(167,139,250,0.2) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 50%, rgba(99,102,241,0.14) 0%, transparent 50%);
    transition: background 0.35s ease;
  }

  .post-thumb-num {
    font-family: 'Ma Shan Zheng', 'Noto Serif SC', serif;
    font-size: 4rem;
    color: rgba(167, 139, 250, 0.15);
    z-index: 1;
    user-select: none;
  }

  .post-card:hover .post-thumb-num {
    color: rgba(167, 139, 250, 0.3);
    transition: color 0.35s ease;
  }

  /* ---- 移动端降级为纵向卡片 ---- */
  @media (max-width: 768px) {
    .post-card-link,
    .post-card--reverse .post-card-link {
      flex-direction: column;
    }

    .post-card-thumb {
      width: 100%;
      min-height: 120px;
    }

    .post-card-body {
      padding: var(--space-md);
    }

    .post-thumb-num {
      font-size: 2.5rem;
    }

    .post-card-link {
      border-radius: 12px;
    }
  }

  .blog-no-result {
    text-align: center;
    padding: var(--space-3xl);
    color: var(--ink-40);
    font-size: var(--text-base);
  }

  /* ====== Pagination ====== */
  .pagination {
    padding: var(--space-3xl) 0 var(--space-5xl);
    text-align: center;
  }

  .pagination-inner {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px;
    background: var(--ink-10);
    border: 1px solid var(--ink-20);
    border-radius: var(--radius-lg);
  }

  .pagination-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--ink-70);
    background: none;
    border: none;
    cursor: pointer;
    transition: all var(--duration-fast);
    font-family: inherit;
  }
  .pagination-btn:hover {
    background: var(--ink-15);
    color: var(--amber-400);
  }

  .pagination-disabled {
    color: var(--ink-30);
    cursor: not-allowed;
    pointer-events: none;
  }

  .pagination-pages {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0 8px;
  }

  .pagination-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--ink-50);
    cursor: pointer;
    transition: all var(--duration-fast);
    font-family: inherit;
  }
  .pagination-num:hover {
    background: var(--ink-15);
    color: var(--amber-400);
  }

  .pagination-active {
    background: #6366f1;
    color: #fff;
    cursor: default;
    pointer-events: none;
  }
  .pagination-active:hover {
    background: #6366f1;
    color: #fff;
  }

  .pagination-ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    font-size: var(--text-sm);
    color: var(--ink-40);
    user-select: none;
  }

  .pagination-info {
    margin-top: var(--space-md);
    font-size: var(--text-xs);
    color: var(--ink-40);
  }

  @media (max-width: 480px) {
    .pagination-pages { display: none; }
    .pagination-info { display: none; }
    .pagination-btn { padding: 10px 20px; font-size: var(--text-base); }
    .pagination-inner { gap: 0; }
  }

  /* ===== Blog Hero ===== */
  .blog-hero {
    position: relative;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }

  .blog-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .blog-hero-title {
    font-family: 'Ma Shan Zheng', 'Noto Serif SC', serif;
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 400;
    letter-spacing: 0.12em;
    color: #fff;
    text-shadow: 0 0 60px rgba(180,140,255,0.35), 0 0 120px rgba(140,100,220,0.2);
    margin: 0;
  }

  .blog-hero-title .accent-purple {
    color: #b48cff;
    text-shadow: 0 0 80px rgba(180,140,255,0.5), 0 0 160px rgba(140,100,220,0.3);
  }

  .blog-hero-sub {
    margin-top: 1.2rem;
    font-size: 1.15rem;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.35em;
    opacity: 0;
    animation: heroFadeUp 1.2s 0.6s ease-out forwards;
  }

  .blog-hero-line {
    width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #b48cff, transparent);
    margin: 2rem auto;
    opacity: 0;
    animation: heroFadeUp 1s 1s ease-out forwards;
  }

  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .blog-hero-scroll {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.35);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    opacity: 0;
    animation: heroFadeUp 1s 1.4s ease-out forwards;
  }

  .blog-hero-arrow {
    width: 24px;
    height: 24px;
    border-right: 2px solid #b48cff;
    border-bottom: 2px solid #b48cff;
    transform: rotate(45deg);
    animation: heroBounce 2s infinite;
  }

  @keyframes heroBounce {
    0%, 100% { transform: rotate(45deg) translateY(0); opacity: 0.6; }
    50%      { transform: rotate(45deg) translateY(8px); opacity: 1; }
  }

  @media (max-width: 640px) {
    .blog-hero-title { font-size: clamp(2.5rem, 12vw, 3.5rem); }
    .blog-hero-sub { font-size: 0.9rem; letter-spacing: 0.2em; }
  }
</style>
