---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = '博客 | 枕星';
const description = '探索关于技术、生活与发现的文字记录';
---

<Page {title} {description}>
  <section class="blog-section">
    <div class="content-narrow">
      <header class="blog-header animate-in">
        <h1>博客</h1>
        <p>{description}</p>
      </header>

      <div class="post-grid">
        {sortedPosts.map((post) => (
          <article class="post-card animate-in" style={`animation-delay: ${sortedPosts.indexOf(post) * 80}ms`}>
            <a href={`/blog/${post.id}`} class="post-card-link">
              <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('zh-CN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-excerpt">{post.data.description}</p>
              <span class="post-read-more">
                阅读全文
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Page>

<style>
  .blog-section {
    padding: var(--space-4xl) 0 var(--space-5xl);
  }

  .blog-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .blog-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, var(--text-4xl));
    font-weight: var(--weight-bold);
    color: var(--ink-100);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-sm);
  }

  .blog-header p {
    font-size: var(--text-lg);
    color: var(--ink-50);
    margin: 0 auto;
  }

  .post-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .post-card {
    border: 1px solid var(--ink-20);
    border-radius: var(--radius-lg);
    background: var(--ink-10);
    transition: all var(--duration-normal) var(--ease-out);
    position: relative;
    overflow: hidden;
  }

  .post-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--amber-400);
    opacity: 0;
    border-radius: 0 2px 2px 0;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .post-card:hover {
    border-color: var(--ink-30);
    transform: translateX(6px);
    box-shadow: var(--shadow-md);
  }
  .post-card:hover::before { opacity: 1; }

  .post-card-link {
    display: block;
    padding: var(--space-xl);
    text-decoration: none;
    color: inherit;
  }

  .post-date {
    display: block;
    font-size: var(--text-xs);
    color: var(--ink-40);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-sm);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--ink-90);
    margin-bottom: var(--space-xs);
    line-height: var(--leading-snug);
  }

  .post-excerpt {
    font-size: var(--text-sm);
    color: var(--ink-50);
    margin-bottom: var(--space-md);
  }

  .post-read-more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--amber-400);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .post-read-more:hover { color: var(--amber-500); }
  .post-read-more svg {
    transition: transform var(--duration-fast) var(--ease-out);
  }
  .post-card:hover .post-read-more svg {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .blog-section { padding: var(--space-3xl) 0; }
  }
</style>
