---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const allPostsUnsorted = await getCollection('blog');
const allPosts = allPostsUnsorted.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const PAGE_SIZE = 3;
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);

const allTags = new Map();
allPosts.forEach(p => {
  const tags = p.data.tags || [];
  tags.forEach(t => {
    const tag = String(t).trim();
    if (tag) allTags.set(tag, (allTags.get(tag) || 0) + 1);
  });
});
const tagsSorted = [...allTags.entries()].sort((a, b) => b[1] - a[1]);

// 节气/日名映射（简要版）
const SOLAR_TERMS: Record<string, string> = {
  '1-1': '元旦', '2-4': '立春', '3-5': '惊蛰', '3-20': '春分',
  '4-4': '清明', '4-20': '谷雨', '5-5': '立夏', '5-21': '小满',
  '6-5': '芒种', '6-21': '夏至', '7-7': '小暑', '7-23': '大暑',
  '8-7': '立秋', '8-23': '处暑', '9-7': '白露', '9-23': '秋分',
  '10-8': '寒露', '10-23': '霜降', '11-7': '立冬', '11-22': '小雪',
  '12-7': '大雪', '12-21': '冬至', '1-5': '小寒', '1-20': '大寒',
};
const WEEKDAYS = ['日曜', '月曜', '火曜', '水曜', '木曜', '金曜', '土曜'];

function formatDiaryDate(date: Date): string {
  const m = date.getMonth() + 1;
  const d = date.getDate();
  const key = `${m}-${d}`;
  const term = SOLAR_TERMS[key] || '';
  const wd = WEEKDAYS[date.getDay()];
  const base = `${m}月${d}日 · ${wd}`;
  return term ? `${base} · ${term}` : base;
}

const title = '寒影·拾光';
const description = '在深夜书房里，拾取散落的光';
---

<Page {title} {description}>
  <div class="diary-page">
    <!-- 页面头部 -->
    <header class="diary-header">
      <div class="diary-header-decoration">
        <span class="decoration-dot"></span>
        <span class="decoration-line"></span>
        <span class="decoration-dot"></span>
      </div>
      <h1 class="diary-title">拾光日记</h1>
      <p class="diary-subtitle">{description}</p>
    </header>

    <!-- 搜索栏 -->
    <div class="diary-search-bar">
      <svg class="diary-search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="text" class="diary-search-input" id="blogSearch" placeholder="搜索日记..." autocomplete="off" />
      <span class="diary-search-count" id="blogSearchCount">{allPosts.length} 篇</span>
    </div>

    <!-- 标签云 -->
    {tagsSorted.length > 0 && (
      <div class="diary-tag-cloud">
        <button class="diary-tag diary-tag-active" onclick="filterByTag(null, this)">全部</button>
        {tagsSorted.map(([tag, count]) => (
          <button class="diary-tag" onclick={`filterByTag('${tag}', this)`}>{tag}({count})</button>
        ))}
      </div>
    )}

    <!-- 日记卡片流 -->
    <div class="diary-feed" id="postGrid">
      {allPosts.map((post, i) => (
        <article class="diary-card" style={`--anim-delay: ${i * 80}ms`} data-tags={JSON.stringify(post.data.tags || [])}>
          <a href={`/blog/${post.id}`} class="diary-card-link">
            <div class="diary-card-line"></div>
            <div class="diary-card-inner">
              <time class="diary-date" datetime={post.data.pubDate.toISOString()}>
                {formatDiaryDate(post.data.pubDate)}
              </time>
              <h2 class="diary-entry-title">{post.data.title}</h2>
              <p class="diary-excerpt">{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="diary-tags">
                  {post.data.tags.map(t => <span class="diary-tag-chip">{String(t)}</span>)}
                </div>
              )}
              <span class="diary-read-more">
                继续阅读
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
          <!-- 纸张纹理装饰 -->
          <div class="diary-card-texture"></div>
        </article>
      ))}
    </div>

    <div class="diary-no-result" id="blogNoResult" style="display:none">没有找到匹配的日记</div>

    <!-- 分页 -->
    {totalPages > 1 && (
      <nav class="diary-pagination" aria-label="日记分页">
        <div class="pagination-inner">
          <button class="pagination-btn pagination-disabled" id="pgPrev">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
            上一页
          </button>
          <div class="pagination-pages" id="pgPages">
            <span class="pagination-num pagination-active" data-pg="1">1</span>
          </div>
          <button class="pagination-btn" id="pgNext">
            下一页
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
        <div class="pagination-info" id="pgInfo">第 1 / {totalPages} 页，共 {allPosts.length} 篇日记</div>
      </nav>
    )}
  </div>
</Page>

<script>
  const PAGE_SIZE = 3;
  const grid = document.getElementById('postGrid');
  const searchCount = document.getElementById('blogSearchCount');
  const noResult = document.getElementById('blogNoResult');
  let activeTag = null;

  function getVisibleCards() {
    return Array.from(grid.querySelectorAll('.diary-card')).filter(c => c.style.display !== 'none');
  }

  function filterPosts() {
    const q = document.getElementById('blogSearch').value.toLowerCase().trim();
    const cards = grid.querySelectorAll('.diary-card');
    let visible = 0;
    cards.forEach(card => {
      const title = card.querySelector('.diary-entry-title')?.textContent?.toLowerCase() || '';
      const excerpt = card.querySelector('.diary-excerpt')?.textContent?.toLowerCase() || '';
      const tagsText = card.dataset.tags || '[]';
      const tags = JSON.parse(tagsText).map(t => String(t).toLowerCase());
      const matchesSearch = !q || title.includes(q) || excerpt.includes(q) || tags.some(t => t.includes(q));
      const matchesTag = !activeTag || tags.some(t => t.toLowerCase() === activeTag.toLowerCase());
      const show = matchesSearch && matchesTag;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    searchCount.textContent = visible + ' 篇';
    noResult.style.display = visible === 0 ? 'block' : 'none';
    goToPage(1);
  }

  window.filterByTag = function(tag, btn) {
    activeTag = tag;
    document.querySelectorAll('.diary-tag').forEach(b => b.classList.remove('diary-tag-active'));
    if (btn) btn.classList.add('diary-tag-active');
    filterPosts();
  };

  document.getElementById('blogSearch')?.addEventListener('input', filterPosts);

  function goToPage(pg) {
    const visible = getVisibleCards();
    const totalVisible = visible.length;
    const vPages = Math.ceil(totalVisible / PAGE_SIZE);
    visible.forEach((c, i) => {
      const page = Math.floor(i / PAGE_SIZE) + 1;
      c.style.display = page === pg ? '' : 'none';
    });
    const prev = document.getElementById('pgPrev');
    const next = document.getElementById('pgNext');
    const info = document.getElementById('pgInfo');
    const pages = document.getElementById('pgPages');
    if (prev) prev.classList.toggle('pagination-disabled', pg <= 1);
    if (next) next.classList.toggle('pagination-disabled', pg >= vPages);
    if (info) info.textContent = '第 ' + pg + ' / ' + vPages + ' 页，共 ' + totalVisible + ' 篇可见';
    if (pages) {
      let html = '';
      for (let n = 1; n <= vPages; n++) {
        if (n === 1 || n === vPages || Math.abs(n - pg) <= 1) {
          html += '<span class="pagination-num' + (n === pg ? ' pagination-active' : '') + '" data-pg="' + n + '">' + n + '</span>';
        } else if (n === 2 && pg > 3) {
          html += '<span class="pagination-ellipsis">...</span>';
        } else if (n === vPages - 1 && pg < vPages - 2) {
          html += '<span class="pagination-ellipsis">...</span>';
        }
      }
      pages.innerHTML = html;
      pages.querySelectorAll('.pagination-num:not(.pagination-active)').forEach(el => {
        el.addEventListener('click', () => goToPage(parseInt(el.dataset.pg)));
      });
    }
  }

  document.getElementById('pgPrev')?.addEventListener('click', () => {
    const cur = document.querySelector('.pagination-active');
    const pg = cur ? parseInt(cur.dataset.pg) : 1;
    if (pg > 1) goToPage(pg - 1);
  });
  document.getElementById('pgNext')?.addEventListener('click', () => {
    const cur = document.querySelector('.pagination-active');
    const pg = cur ? parseInt(cur.dataset.pg) : 1;
    const visible = getVisibleCards();
    const vPages = Math.ceil(visible.length / PAGE_SIZE);
    if (pg < vPages) goToPage(pg + 1);
  });
</script>

<style>
/* ===== 日记页容器 ===== */
.diary-page {
  max-width: var(--content-width);
  margin: 0 auto;
  padding: 0;
}

/* ---- 页面头部 ---- */
.diary-header {
  text-align: center;
  padding: 2rem 0 1.5rem;
}

.diary-header-decoration {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-bottom: 0.8rem;
}
.decoration-dot {
  width: 4px; height: 4px;
  border-radius: 50%;
  background: var(--color-gold);
}
.decoration-line {
  width: 40px; height: 1px;
  background: linear-gradient(90deg, var(--color-gold), var(--color-accent));
}

.diary-title {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 600;
  color: var(--color-text-primary);
  margin: 0 0 0.3rem;
  letter-spacing: 0.08em;
}
.diary-subtitle {
  font-size: 0.82rem;
  color: var(--color-text-muted);
  margin: 0;
  letter-spacing: 0.06em;
}

/* ---- 搜索栏 ---- */
.diary-search-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  max-width: 420px;
  margin: 0 auto 1.5rem;
  padding: 8px 14px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  transition: border-color var(--duration-fast) var(--ease-out);
}
.diary-search-bar:focus-within {
  border-color: var(--color-accent);
}
.diary-search-icon {
  color: var(--color-text-muted);
  flex-shrink: 0;
}
.diary-search-input {
  flex: 1;
  border: none;
  background: transparent;
  color: var(--color-text-primary);
  font-size: 0.82rem;
  font-family: inherit;
  outline: none;
}
.diary-search-input::placeholder { color: var(--color-text-muted); }
.diary-search-count {
  font-size: 0.7rem;
  color: var(--color-text-muted);
  white-space: nowrap;
}

/* ---- 标签云 ---- */
.diary-tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  justify-content: center;
  margin-bottom: 1.75rem;
}
.diary-tag {
  padding: 3px 12px;
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border);
  background: transparent;
  color: var(--color-text-secondary);
  font-size: 0.72rem;
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-out);
  font-family: inherit;
}
.diary-tag:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
}
.diary-tag-active {
  background: var(--color-accent-soft);
  border-color: var(--color-accent);
  color: var(--color-accent);
}

/* ===== 日记卡片 ===== */
.diary-feed {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.diary-card {
  position: relative;
  opacity: 0;
  animation: diaryFadeIn 0.6s var(--ease-out) forwards;
  animation-delay: var(--anim-delay, 0ms);
  border-radius: var(--radius-md);
  overflow: hidden;
}

@keyframes diaryFadeIn {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

.diary-card-link {
  display: flex;
  gap: 0;
  text-decoration: none;
  color: inherit;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  transition: all var(--duration-normal) var(--ease-out);
  position: relative;
  z-index: 1;
}

.diary-card-link:hover {
  transform: translateX(6px);
  border-color: var(--color-accent-soft);
  box-shadow: var(--shadow-card-hover);
}

/* ---- 左侧竖线 ---- */
.diary-card-line {
  width: 3px;
  flex-shrink: 0;
  background: linear-gradient(
    180deg,
    transparent 8%,
    var(--color-gold) 8%,
    var(--color-accent) 50%,
    var(--color-gold) 92%,
    transparent 92%
  );
  border-radius: 2px;
  margin: 0.6rem 0;
  transition: opacity var(--duration-fast) var(--ease-out);
}
.diary-card-link:hover .diary-card-line {
  opacity: 0.7;
}

/* ---- 卡片内容 ---- */
.diary-card-inner {
  flex: 1;
  padding: 1.25rem 1.25rem 1.25rem 1rem;
  min-width: 0;
}

.diary-date {
  display: block;
  font-family: var(--font-serif);
  font-size: 0.78rem;
  color: var(--color-accent);
  margin-bottom: 0.5rem;
  letter-spacing: 0.04em;
}

.diary-entry-title {
  font-family: var(--font-serif);
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--color-text-primary);
  margin: 0 0 0.4rem;
  line-height: 1.4;
}

.diary-excerpt {
  font-size: 0.84rem;
  color: var(--color-text-secondary);
  line-height: 1.75;
  margin: 0 0 0.6rem;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.diary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-bottom: 0.6rem;
}

.diary-tag-chip {
  display: inline-block;
  padding: 1px 8px;
  background: var(--color-bg-tertiary);
  color: var(--color-text-muted);
  font-size: 0.68rem;
  border-radius: 2px;
  border: 1px solid var(--color-border);
}

.diary-read-more {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.78rem;
  color: var(--color-accent);
  transition: gap var(--duration-fast) var(--ease-out);
}
.diary-card-link:hover .diary-read-more {
  gap: 8px;
}

/* ---- 纸张纹理层 ---- */
.diary-card-texture {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  opacity: 0.015;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.4'/%3E%3C/svg%3E");
}

/* ---- 无结果 ---- */
.diary-no-result {
  text-align: center;
  padding: 3rem 1rem;
  color: var(--color-text-muted);
  font-size: 0.9rem;
}

/* ===== 分页 ===== */
.diary-pagination {
  padding: 2rem 0 3rem;
  text-align: center;
}

.pagination-inner {
  display: inline-flex;
  align-items: center;
  gap: 2px;
  padding: 4px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
}

.pagination-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 7px 14px;
  border-radius: var(--radius-md);
  font-size: 0.8rem;
  color: var(--color-text-secondary);
  background: none;
  border: none;
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-out);
  font-family: inherit;
}
.pagination-btn:hover { background: var(--color-bg-hover); color: var(--color-accent); }
.pagination-disabled { color: var(--color-text-muted); cursor: not-allowed; pointer-events: none; }

.pagination-pages { display: flex; align-items: center; gap: 2px; padding: 0 6px; }

.pagination-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 34px; height: 34px;
  border-radius: var(--radius-md);
  font-size: 0.8rem;
  color: var(--color-text-secondary);
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-out);
}
.pagination-num:hover { background: var(--color-bg-hover); color: var(--color-accent); }

.pagination-active {
  background: var(--color-accent-soft);
  color: var(--color-accent);
  cursor: default;
  pointer-events: none;
}

.pagination-ellipsis {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px; height: 34px;
  font-size: 0.8rem;
  color: var(--color-text-muted);
  user-select: none;
}

.pagination-info {
  margin-top: 0.6rem;
  font-size: 0.7rem;
  color: var(--color-text-muted);
}

/* ---- 移动端 ---- */
@media (max-width: 768px) {
  .diary-page {
    padding: 0;
  }
  .diary-header { padding: 1rem 0; }
  .diary-title { font-size: 1.25rem; }
  .diary-card-link:hover { transform: translateX(3px); }
  .diary-card-inner { padding: 1rem; }
  .diary-entry-title { font-size: 1rem; }
  .pagination-pages { display: none; }
  .pagination-info { display: none; }
}
</style>
