---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`文章 — ${SITE_TITLE}`} description="工程技术与深度探索。" />
  </head>
  <body>
    <Header />
    <main>
      <section class="section">
        <h1 class="page-title">文章</h1>
        <p class="page-sub">深度探索、笔记与实验。共 {posts.length} 篇。</p>

        <div class="article-list">
          {posts.map((post) => (
            <article class="list-item">
              <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} class="list-link">
                <div class="list-meta">
                  <span class="list-date">
                    <FormattedDate date={post.data.pubDate} />
                  </span>
                </div>
                <div class="list-body">
                  <h2 class="list-title">{post.data.title}</h2>
                  <p class="list-desc">{post.data.description}</p>
                </div>
                <span class="list-arrow">→</span>
              </a>
            </article>
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .section {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    animation: fadeInUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  .page-title {
    font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: oklch(92% 0.01 265);
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .page-sub {
    font-size: 0.95rem;
    color: oklch(58% 0.015 265);
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .list-item {
    border-bottom: 1px solid oklch(28% 0.025 265 / 0.4);
    transition: border-color 0.3s ease;
  }

  .list-item:hover {
    border-color: oklch(72% 0.18 62 / 0.3);
  }

  .list-link {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.25rem 0;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 6px;
  }

  .list-link:hover {
    color: inherit;
    text-shadow: none;
  }

  .list-meta {
    flex-shrink: 0;
    width: 90px;
    padding-top: 2px;
  }

  .list-date {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.78rem;
    color: oklch(48% 0.015 265);
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .list-body {
    flex: 1;
    min-width: 0;
  }

  .list-title {
    font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: oklch(92% 0.01 265);
    margin-bottom: 4px;
    line-height: 1.25;
    transition: color 0.3s ease;
  }

  .list-link:hover .list-title {
    color: oklch(72% 0.18 62);
  }

  .list-desc {
    font-size: 0.85rem;
    color: oklch(58% 0.015 265);
    line-height: 1.55;
    margin-bottom: 0;
    font-weight: 300;
  }

  .list-arrow {
    flex-shrink: 0;
    color: oklch(38% 0.025 265);
    font-size: 1rem;
    padding-top: 1px;
    opacity: 0;
    transform: translateX(-8px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .list-item:hover .list-arrow {
    opacity: 1;
    transform: translateX(0);
    color: oklch(72% 0.18 62);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    .section {
      padding: 2rem 1rem;
    }

    .list-link {
      gap: 0.75rem;
    }

    .list-meta {
      width: auto;
    }

    .list-arrow {
      display: none;
    }
  }
</style>