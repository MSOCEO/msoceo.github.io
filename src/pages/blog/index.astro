---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Collect all tags from posts
const allTags = new Map();
sortedPosts.forEach(p => {
  const tags = p.data.tags || [];
  tags.forEach(t => {
    const tag = String(t).trim();
    if (tag) allTags.set(tag, (allTags.get(tag) || 0) + 1);
  });
});
const tagsSorted = [...allTags.entries()].sort((a, b) => b[1] - a[1]);

const postsJson = JSON.stringify(sortedPosts.map(p => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description || '',
  pubDate: p.data.pubDate.toISOString(),
  tags: p.data.tags || [],
  url: `/blog/${p.id}`,
})));

const title = '博客 | 寒影';
const description = '探索关于技术、生活与发现的文字记录';
---

<Page {title} {description}>
  <section class="blog-section">
    <div class="content-narrow">
      <header class="blog-header animate-in">
        <h1>博客</h1>
        <p>{description}</p>
      </header>

      <!-- Search Bar -->
      <div class="blog-search-bar animate-in" style="animation-delay:0.1s">
        <svg class="blog-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <input type="text" id="blogSearch" class="blog-search-input" placeholder="搜索文章..." oninput="filterPosts()" />
        <span class="blog-search-count" id="blogSearchCount">{sortedPosts.length} 篇文章</span>
      </div>

      <!-- Tag Cloud -->
      {tagsSorted.length > 0 && (
        <div class="blog-tag-cloud animate-in" style="animation-delay:0.15s">
          <button class="blog-tag blog-tag-active" onclick="filterByTag(null, this)">全部</button>
          {tagsSorted.map(([tag, count]) => (
            <button class="blog-tag" onclick={`filterByTag('${tag}', this)`}>{tag} ({count})</button>
          ))}
        </div>
      )}

      <div class="post-grid" id="postGrid">
        {sortedPosts.map((post) => (
          <article class="post-card animate-in" style={`animation-delay: ${sortedPosts.indexOf(post) * 80}ms`} data-tags={JSON.stringify(post.data.tags || [])}>
            <a href={`/blog/${post.id}`} class="post-card-link">
              <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('zh-CN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-excerpt">{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.map(t => <span class="post-tag">{String(t)}</span>)}
                </div>
              )}
              <span class="post-read-more">
                阅读全文
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          </article>
        ))}
      </div>

      <div class="blog-no-result" id="blogNoResult" style="display:none">
        <p>没有找到匹配的文章</p>
      </div>
    </div>
  </section>
</Page>

<script>
  const postsData = JSON.parse(document.getElementById('postGrid')?.parentElement?.querySelector('script')?.textContent || '[]');

  // Embed posts data directly
  (function() {
    window.__blogPosts = {postsData};
  })();
</script>

<style>
  .blog-section {
    padding: var(--space-4xl) 0 var(--space-5xl);
  }

  .blog-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .blog-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, var(--text-4xl));
    font-weight: var(--weight-bold);
    color: var(--ink-100);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-sm);
  }

  .blog-header p {
    font-size: var(--text-lg);
    color: var(--ink-50);
    margin: 0 auto;
  }

  /* Search Bar */
  .blog-search-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: 520px;
    margin: 0 auto var(--space-2xl);
    padding: 10px 16px;
    background: var(--ink-15);
    border: 1px solid var(--ink-25);
    border-radius: var(--radius-full);
    transition: border-color var(--duration-fast);
  }
  .blog-search-bar:focus-within {
    border-color: var(--amber-400);
  }
  .blog-search-icon {
    color: var(--ink-40);
    flex-shrink: 0;
  }
  .blog-search-input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--ink-100);
    font-size: var(--text-sm);
    font-family: inherit;
    outline: none;
  }
  .blog-search-input::placeholder { color: var(--ink-40); }
  .blog-search-count {
    font-size: var(--text-xs);
    color: var(--ink-40);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Tag Cloud */
  .blog-tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-bottom: var(--space-2xl);
  }
  .blog-tag {
    padding: 5px 14px;
    border-radius: var(--radius-full);
    border: 1px solid var(--ink-25);
    background: transparent;
    color: var(--ink-50);
    font-size: var(--text-xs);
    cursor: pointer;
    transition: all var(--duration-fast);
    font-family: inherit;
  }
  .blog-tag:hover {
    border-color: var(--amber-400);
    color: var(--amber-400);
  }
  .blog-tag-active {
    background: var(--amber-400);
    border-color: var(--amber-400);
    color: #1a1a1a;
    font-weight: 600;
  }
  .blog-tag-active:hover { color: #1a1a1a; }

  .post-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .post-card {
    border: 1px solid var(--ink-20);
    border-radius: var(--radius-lg);
    background: var(--ink-10);
    transition: all var(--duration-normal) var(--ease-out);
    position: relative;
    overflow: hidden;
  }

  .post-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--amber-400);
    opacity: 0;
    border-radius: 0 2px 2px 0;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .post-card:hover {
    border-color: var(--ink-30);
    transform: translateX(6px);
    box-shadow: var(--shadow-md);
  }
  .post-card:hover::before { opacity: 1; }

  .post-card-link {
    display: block;
    padding: var(--space-xl);
    text-decoration: none;
    color: inherit;
  }

  .post-date {
    display: block;
    font-size: var(--text-xs);
    color: var(--ink-40);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-sm);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--ink-90);
    margin-bottom: var(--space-xs);
    line-height: var(--leading-snug);
  }

  .post-excerpt {
    font-size: var(--text-sm);
    color: var(--ink-50);
    margin-bottom: var(--space-md);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: var(--space-md);
  }
  .post-tag {
    display: inline-block;
    padding: 2px 10px;
    background: var(--ink-20);
    color: var(--ink-50);
    font-size: 11px;
    border-radius: var(--radius-sm);
  }

  .post-read-more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--amber-400);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .post-read-more:hover { color: var(--amber-500); }
  .post-read-more svg {
    transition: transform var(--duration-fast) var(--ease-out);
  }
  .post-card:hover .post-read-more svg {
    transform: translateX(4px);
  }

  .blog-no-result {
    text-align: center;
    padding: var(--space-3xl);
    color: var(--ink-40);
    font-size: var(--text-base);
  }

  @media (max-width: 768px) {
    .blog-section { padding: var(--space-3xl) 0; }
  }
</style>

<script>
  const ALL_POSTS = {postsData};
  const grid = document.getElementById('postGrid');
  const searchCount = document.getElementById('blogSearchCount');
  const noResult = document.getElementById('blogNoResult');
  let activeTag = null;

  function filterPosts() {
    const q = document.getElementById('blogSearch').value.toLowerCase().trim();
    const cards = grid.querySelectorAll('.post-card');
    let visible = 0;
    cards.forEach(card => {
      const title = card.querySelector('.post-title')?.textContent?.toLowerCase() || '';
      const excerpt = card.querySelector('.post-excerpt')?.textContent?.toLowerCase() || '';
      const tagsText = card.dataset.tags || '[]';
      const tags = JSON.parse(tagsText).map(t => String(t).toLowerCase());
      const matchesSearch = !q || title.includes(q) || excerpt.includes(q) || tags.some(t => t.includes(q));
      const matchesTag = !activeTag || tags.some(t => t.toLowerCase() === activeTag.toLowerCase());
      const show = matchesSearch && matchesTag;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    searchCount.textContent = visible + ' 篇文章';
    noResult.style.display = visible === 0 ? 'block' : 'none';
  }

  window.filterByTag = function(tag, btn) {
    activeTag = tag;
    document.querySelectorAll('.blog-tag').forEach(b => b.classList.remove('blog-tag-active'));
    if (btn) btn.classList.add('blog-tag-active');
    filterPosts();
  };

  // Scroll current tag cloud button into view
  (function() {
    const tagContainer = document.querySelector('.blog-tag-cloud');
    if (!tagContainer) return;
    // handle overflow scroll on mobile
    const allBtn = tagContainer.querySelector('.blog-tag-active');
    if (allBtn) allBtn.scrollIntoView({ inline: 'center', block: 'nearest' });
  })();
</script>
