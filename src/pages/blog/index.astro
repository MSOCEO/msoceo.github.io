---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const allPostsUnsorted = await getCollection('blog');
const allPosts = allPostsUnsorted.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const PAGE_SIZE = 3;
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);

// Tag cloud from ALL posts
const allTags = new Map();
allPosts.forEach(p => {
  const tags = p.data.tags || [];
  tags.forEach(t => {
    const tag = String(t).trim();
    if (tag) allTags.set(tag, (allTags.get(tag) || 0) + 1);
  });
});
const tagsSorted = [...allTags.entries()].sort((a, b) => b[1] - a[1]);

const title = '博客 | 寒影';
const description = '探索关于技术、生活与发现的文字记录';
---

<Page {title} {description}>
  <section class="blog-section">
    <div class="content-narrow">
      <header class="blog-header animate-in">
        <h1>博客</h1>
        <p>{description}</p>
      </header>

      <!-- Search Bar -->
      <div class="blog-search-bar animate-in" style="animation-delay:0.05s">
        <svg class="blog-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <input type="text" class="blog-search-input" id="blogSearch" placeholder="搜索文章..." autocomplete="off" />
        <span class="blog-search-count" id="blogSearchCount">{allPosts.length} 篇</span>
      </div>

      <!-- Tag Cloud -->
      {tagsSorted.length > 0 && (
        <div class="blog-tag-cloud animate-in" style="animation-delay:0.15s">
          <button class="blog-tag blog-tag-active" onclick="filterByTag(null, this)">全部</button>
          {tagsSorted.map(([tag, count]) => (
            <button class="blog-tag" onclick={`filterByTag('${tag}', this)`}>{tag} ({count})</button>
          ))}
        </div>
      )}

      <div class="post-grid" id="postGrid">
        {allPosts.map((post, i) => (
          <article class="post-card animate-in" style={`animation-delay: ${i * 80}ms`} data-tags={JSON.stringify(post.data.tags || [])}>
            <a href={`/blog/${post.id}`} class="post-card-link">
              <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('zh-CN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-excerpt">{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.map(t => <span class="post-tag">{String(t)}</span>)}
                </div>
              )}
              <span class="post-read-more">
                阅读全文
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          </article>
        ))}
      </div>

      <div class="blog-no-result" id="blogNoResult" style="display:none">没有找到匹配的文章</div>

      <!-- ====== Pagination ====== -->
      {totalPages > 1 && (
        <nav class="pagination" aria-label="博客分页">
          <div class="pagination-inner">
            <button class="pagination-btn pagination-disabled" id="pgPrev">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              上一页
            </button>

            <div class="pagination-pages" id="pgPages">
              <span class="pagination-num pagination-active" data-pg="1">1</span>
            </div>

            <button class="pagination-btn" id="pgNext">
              下一页
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
          <div class="pagination-info" id="pgInfo">第 1 / {totalPages} 页，共 {allPosts.length} 篇文章</div>
        </nav>
      )}
    </div>
  </section>
</Page>

<script>
  const PAGE_SIZE = 3;
  const grid = document.getElementById('postGrid');
  const searchCount = document.getElementById('blogSearchCount');
  const noResult = document.getElementById('blogNoResult');
  let activeTag = null;

  function getVisibleCards() {
    return Array.from(grid.querySelectorAll('.post-card')).filter(c => c.style.display !== 'none');
  }

  function filterPosts() {
    const q = document.getElementById('blogSearch').value.toLowerCase().trim();
    const cards = grid.querySelectorAll('.post-card');
    let visible = 0;
    cards.forEach(card => {
      const title = card.querySelector('.post-title')?.textContent?.toLowerCase() || '';
      const excerpt = card.querySelector('.post-excerpt')?.textContent?.toLowerCase() || '';
      const tagsText = card.dataset.tags || '[]';
      const tags = JSON.parse(tagsText).map(t => String(t).toLowerCase());
      const matchesSearch = !q || title.includes(q) || excerpt.includes(q) || tags.some(t => t.includes(q));
      const matchesTag = !activeTag || tags.some(t => t.toLowerCase() === activeTag.toLowerCase());
      const show = matchesSearch && matchesTag;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    searchCount.textContent = visible + ' 篇';
    noResult.style.display = visible === 0 ? 'block' : 'none';
    goToPage(1);
  }

  window.filterByTag = function(tag, btn) {
    activeTag = tag;
    document.querySelectorAll('.blog-tag').forEach(b => b.classList.remove('blog-tag-active'));
    if (btn) btn.classList.add('blog-tag-active');
    filterPosts();
  };

  // Pagination
  function goToPage(pg) {
    const visible = getVisibleCards();
    const totalVisible = visible.length;
    const vPages = Math.ceil(totalVisible / PAGE_SIZE);

    visible.forEach((c, i) => {
      const page = Math.floor(i / PAGE_SIZE) + 1;
      c.style.display = page === pg ? '' : 'none';
    });

    // Update buttons
    const prev = document.getElementById('pgPrev');
    const next = document.getElementById('pgNext');
    const info = document.getElementById('pgInfo');
    const pages = document.getElementById('pgPages');

    if (prev) {
      if (pg <= 1) prev.classList.add('pagination-disabled');
      else prev.classList.remove('pagination-disabled');
    }
    if (next) {
      if (pg >= vPages) next.classList.add('pagination-disabled');
      else next.classList.remove('pagination-disabled');
    }
    if (info) info.textContent = '第 ' + pg + ' / ' + vPages + ' 页，共 ' + totalVisible + ' 篇可见';

    if (pages) {
      let html = '';
      for (let n = 1; n <= vPages; n++) {
        if (n === 1 || n === vPages || Math.abs(n - pg) <= 1) {
          html += '<span class="pagination-num' + (n === pg ? ' pagination-active' : '') + '" data-pg="' + n + '">' + n + '</span>';
        } else if (n === 2 && pg > 3) {
          html += '<span class="pagination-ellipsis">...</span>';
        } else if (n === vPages - 1 && pg < vPages - 2) {
          html += '<span class="pagination-ellipsis">...</span>';
        }
      }
      pages.innerHTML = html;
      pages.querySelectorAll('.pagination-num:not(.pagination-active)').forEach(el => {
        el.addEventListener('click', () => goToPage(parseInt(el.dataset.pg)));
      });
    }
  }

  document.getElementById('pgPrev')?.addEventListener('click', () => {
    const cur = document.querySelector('.pagination-active');
    const pg = cur ? parseInt(cur.dataset.pg) : 1;
    if (pg > 1) goToPage(pg - 1);
  });
  document.getElementById('pgNext')?.addEventListener('click', () => {
    const cur = document.querySelector('.pagination-active');
    const pg = cur ? parseInt(cur.dataset.pg) : 1;
    const visible = getVisibleCards();
    const vPages = Math.ceil(visible.length / PAGE_SIZE);
    if (pg < vPages) goToPage(pg + 1);
  });

  // Scroll active tag into view
  (function() {
    const tagContainer = document.querySelector('.blog-tag-cloud');
    if (!tagContainer) return;
    const activeBtn = tagContainer.querySelector('.blog-tag-active');
    if (activeBtn) activeBtn.scrollIntoView({ inline: 'center', block: 'nearest' });
  })();
</script>

<style>
  .blog-section {
    padding: var(--space-4xl) 0 var(--space-2xl);
  }

  .blog-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .blog-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, var(--text-4xl));
    font-weight: var(--weight-bold);
    color: var(--ink-100);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-sm);
  }

  .blog-header p {
    font-size: var(--text-lg);
    color: var(--ink-50);
    margin: 0 auto;
  }

  /* Search Bar */
  .blog-search-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: 520px;
    margin: 0 auto var(--space-2xl);
    padding: 10px 16px;
    background: var(--ink-15);
    border: 1px solid var(--ink-25);
    border-radius: var(--radius-full);
    transition: border-color var(--duration-fast);
  }
  .blog-search-bar:focus-within {
    border-color: var(--amber-400);
  }
  .blog-search-icon {
    color: var(--ink-40);
    flex-shrink: 0;
  }
  .blog-search-input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--ink-100);
    font-size: var(--text-sm);
    font-family: inherit;
    outline: none;
  }
  .blog-search-input::placeholder { color: var(--ink-40); }
  .blog-search-count {
    font-size: var(--text-xs);
    color: var(--ink-40);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Tag Cloud */
  .blog-tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-bottom: var(--space-2xl);
  }
  .blog-tag {
    padding: 5px 14px;
    border-radius: var(--radius-full);
    border: 1px solid var(--ink-25);
    background: transparent;
    color: var(--ink-50);
    font-size: var(--text-xs);
    cursor: pointer;
    transition: all var(--duration-fast);
    font-family: inherit;
  }
  .blog-tag:hover {
    border-color: var(--amber-400);
    color: var(--amber-400);
  }
  .blog-tag-active {
    background: var(--amber-400);
    border-color: var(--amber-400);
    color: #1a1a1a;
    font-weight: 600;
  }
  .blog-tag-active:hover { color: #1a1a1a; }

  .post-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .post-card {
    border: 1px solid var(--ink-20);
    border-radius: var(--radius-lg);
    background: var(--ink-10);
    transition: all var(--duration-normal) var(--ease-out);
    position: relative;
    overflow: hidden;
  }

  .post-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--amber-400);
    opacity: 0;
    border-radius: 0 2px 2px 0;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .post-card:hover {
    border-color: var(--ink-30);
    transform: translateX(6px);
    box-shadow: var(--shadow-md);
  }
  .post-card:hover::before { opacity: 1; }

  .post-card-link {
    display: block;
    padding: var(--space-xl);
    text-decoration: none;
    color: inherit;
  }

  .post-date {
    display: block;
    font-size: var(--text-xs);
    color: var(--ink-40);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-sm);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--ink-90);
    margin-bottom: var(--space-xs);
    line-height: var(--leading-snug);
  }

  .post-excerpt {
    font-size: var(--text-sm);
    color: var(--ink-50);
    margin-bottom: var(--space-md);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: var(--space-md);
  }
  .post-tag {
    display: inline-block;
    padding: 2px 10px;
    background: var(--ink-20);
    color: var(--ink-50);
    font-size: 11px;
    border-radius: var(--radius-sm);
  }

  .post-read-more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--amber-400);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .post-read-more:hover { color: var(--amber-500); }
  .post-read-more svg {
    transition: transform var(--duration-fast) var(--ease-out);
  }
  .post-card:hover .post-read-more svg {
    transform: translateX(4px);
  }

  .blog-no-result {
    text-align: center;
    padding: var(--space-3xl);
    color: var(--ink-40);
    font-size: var(--text-base);
  }

  /* ====== Pagination ====== */
  .pagination {
    padding: var(--space-3xl) 0 var(--space-5xl);
    text-align: center;
  }

  .pagination-inner {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px;
    background: var(--ink-10);
    border: 1px solid var(--ink-20);
    border-radius: var(--radius-lg);
  }

  .pagination-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--ink-70);
    background: none;
    border: none;
    cursor: pointer;
    transition: all var(--duration-fast);
    font-family: inherit;
  }
  .pagination-btn:hover {
    background: var(--ink-15);
    color: var(--amber-400);
  }

  .pagination-disabled {
    color: var(--ink-30);
    cursor: not-allowed;
    pointer-events: none;
  }

  .pagination-pages {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0 8px;
  }

  .pagination-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--ink-50);
    cursor: pointer;
    transition: all var(--duration-fast);
    font-family: inherit;
  }
  .pagination-num:hover {
    background: var(--ink-15);
    color: var(--amber-400);
  }

  .pagination-active {
    background: #6366f1;
    color: #fff;
    cursor: default;
    pointer-events: none;
  }
  .pagination-active:hover {
    background: #6366f1;
    color: #fff;
  }

  .pagination-ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    font-size: var(--text-sm);
    color: var(--ink-40);
    user-select: none;
  }

  .pagination-info {
    margin-top: var(--space-md);
    font-size: var(--text-xs);
    color: var(--ink-40);
  }

  @media (max-width: 480px) {
    .pagination-pages { display: none; }
    .pagination-info { display: none; }
    .pagination-btn { padding: 10px 20px; font-size: var(--text-base); }
    .pagination-inner { gap: 0; }
  }

  @media (max-width: 768px) {
    .blog-section { padding: var(--space-3xl) 0 var(--space-md); }
  }
</style>
