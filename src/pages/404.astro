---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - 页面未找到" showSidebar={false}>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="mb-8">
      <svg width="120" height="120" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- 墨迹风格的 404 插画 -->
        <circle cx="60" cy="60" r="56" stroke="currentColor" stroke-width="1.5" opacity="0.15" />
        <path d="M45 45 L75 75 M75 45 L45 75" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.2" />
        <text x="60" y="68" text-anchor="middle" font-family="serif" font-size="28" font-weight="900" fill="currentColor" opacity="0.5">404</text>
      </svg>
    </div>
    <h1 class="font-serif font-black text-3xl mb-3">此页暂无墨迹</h1>
    <p class="text-[var(--text-tertiary)] mb-8 max-w-sm">
      你寻找的页面可能已被移除、链接失效，或者从未存在过。
    </p>
    <div class="flex gap-3">
      <a href="/" class="px-6 py-3 rounded-full bg-[var(--accent)] text-white font-medium text-sm hover:bg-[var(--accent-hover)] transition-colors">
        返回首页
      </a>
      <a href="/search" class="px-6 py-3 rounded-full border border-[var(--border-color)] text-[var(--text-secondary)] font-medium text-sm hover:bg-[var(--bg-secondary)] transition-colors">
        搜索文章
      </a>
    </div>
  </div>
</BaseLayout>
