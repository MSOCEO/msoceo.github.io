---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="留言板">
  <div class="max-w-2xl mx-auto">
    <h1 class="font-serif font-black text-3xl mb-2">留言板</h1>
    <p class="text-sm text-[var(--text-tertiary)] mb-8">笔墨留痕，说点什么吧。</p>

    <div class="ink-card ink-card-alt p-6 mb-8">
      <p class="text-sm text-[var(--text-tertiary)] leading-relaxed mb-4">
        留言板使用 GitHub Discussions 驱动，请前往
        <a href="https://github.com/msoceo/msoceo.github.io/discussions" target="_blank" rel="noopener" class="underline">
          GitHub Discussions
        </a>
        留言。
      </p>
      <p class="text-sm text-[var(--text-tertiary)]">
        也可以使用 Giscus 评论系统（待配置后启用）。
      </p>
    </div>

    <!-- Giscus 评论区（待启用） -->
    <div class="ink-card ink-card-alt p-6">
      <div id="giscus-container" class="min-h-[200px] flex items-center justify-center text-sm text-[var(--text-tertiary)]">
        <p>评论区待配置 Giscus 后启用</p>
      </div>
    </div>
  </div>
</BaseLayout>
