---
---

<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>博客设置 · 云笺</title>
</head>
<body>
<div class="st-root">
  <header class="st-header">
    <a href="/yunjian" class="st-logo">&#10236; 云笺</a>
    <nav class="st-nav">
      <a href="/yunjian/dashboard">控制台</a>
      <a href="/yunjian/editor">写文章</a>
      <a href="/yunjian/settings" class="st-nav-active">设置</a>
    </nav>
    <div class="st-header-right">
      <span id="stUserName"></span>
      <button class="st-btn-danger-ghost" id="stLogout">退出</button>
    </div>
  </header>

  <div class="st-container" id="stNotLoggedIn" style="text-align:center;padding:80px 20px">
    <div style="font-size:48px;margin-bottom:16px">&#128274;</div>
    <h2>请先登录</h2>
    <p style="color:#8b949e;margin-bottom:20px">登录后即可管理博客设置</p>
    <a href="/yunjian/login" class="st-btn-primary">登录 / 注册</a>
  </div>

  <div class="st-container" id="stLoggedIn" style="display:none">

    <!-- 基本信息 -->
    <div class="st-card">
      <h2 class="st-section-title">基本信息</h2>
      <div class="st-form">
        <label class="st-field">
          <span class="st-field-label">博客标题</span>
          <input type="text" class="st-input" id="stTitle" placeholder="我的博客">
        </label>
        <label class="st-field">
          <span class="st-field-label">副标题</span>
          <input type="text" class="st-input" id="stSubtitle" placeholder="记录生活与思考">
        </label>
        <label class="st-field">
          <span class="st-field-label">作者名称</span>
          <input type="text" class="st-input" id="stAuthor" placeholder="你的名字">
        </label>
        <label class="st-field">
          <span class="st-field-label">每页文章数</span>
          <select class="st-input" id="stPostsPerPage">
            <option value="5">5</option><option value="10" selected>10</option><option value="15">15</option><option value="20">20</option>
          </select>
        </label>
      </div>
    </div>

    <!-- 主题切换 -->
    <div class="st-card" id="theme">
      <h2 class="st-section-title">主题切换</h2>
      <p style="color:#8b949e;font-size:13px;margin-bottom:16px">选择一套主题，提交后将重新构建博客</p>
      <div class="st-theme-grid" id="stThemeGrid"></div>
    </div>

    <!-- 导航菜单 -->
    <div class="st-card">
      <h2 class="st-section-title">导航菜单</h2>
      <p style="color:#8b949e;font-size:13px;margin-bottom:12px">管理博客顶部导航链接</p>
      <div id="stNavList"></div>
      <button class="st-btn-ghost" id="stAddNav" style="margin-top:12px">+ 添加链接</button>
    </div>

    <!-- 社交链接 -->
    <div class="st-card">
      <h2 class="st-section-title">社交链接</h2>
      <div class="st-form">
        <label class="st-field">
          <span class="st-field-label">GitHub</span>
          <input type="text" class="st-input" id="stSocialGithub" placeholder="https://github.com/yourname">
        </label>
        <label class="st-field">
          <span class="st-field-label">Twitter / X</span>
          <input type="text" class="st-input" id="stSocialTwitter" placeholder="https://twitter.com/yourname">
        </label>
      </div>
    </div>

    <!-- 自定义域名 -->
    <div class="st-card">
      <h2 class="st-section-title">自定义域名</h2>
      <p style="color:#8b949e;font-size:13px;margin-bottom:12px">绑定你自己的域名（需先在 DNS 中添加 CNAME 记录指向你的 GitHub Pages 地址）</p>
      <div class="st-form">
        <label class="st-field">
          <span class="st-field-label">CNAME 域名</span>
          <input type="text" class="st-input" id="stCname" placeholder="blog.yourdomain.com">
          <span style="font-size:11px;color:#8b949e;margin-top:4px">留空则使用默认的 GitHub Pages 域名</span>
        </label>
      </div>
    </div>

    <!-- 保存 -->
    <div class="st-card" style="text-align:center;padding:32px">
      <button class="st-btn-primary st-btn-lg" id="stSave" disabled>保存设置并重新部署</button>
      <div id="stSaveProgress" style="display:none;margin-top:16px"></div>
    </div>

    <!-- 删除博客 -->
    <div class="st-card" style="border-color:#da3633;border-width:1px">
      <h2 class="st-section-title" style="color:#da3633">危险区域</h2>
      <p style="color:#8b949e;font-size:13px;margin-bottom:16px">删除博客将移除所有 GitHub 仓库内容，此操作不可撤销。文章内容仍保留在云笺中，但博客页面将无法访问。</p>
      <button class="st-btn-danger" id="stDeleteBlog">&#9888; 删除我的博客</button>
      <div id="stDeleteProgress" style="display:none;margin-top:12px"></div>
    </div>

  </div>
</div>
</body>
</html>

<style>
  :root { --st-bg:#0d1117; --st-card-bg:#161b22; --st-border:#21262d; --st-text:#c9d1d9; --st-dim:#8b949e; --st-muted:#484f58; --st-accent:#58a6ff; --st-green:#238636; --st-green-hover:#2ea043; --st-red:#da3633; }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; background:var(--st-bg); color:var(--st-text); }
  .st-root { min-height:100vh; }
  .st-header { display:flex; align-items:center; padding:0 24px; height:56px; background:var(--st-card-bg); border-bottom:1px solid var(--st-border); }
  .st-logo { color:var(--st-accent); text-decoration:none; font-weight:700; font-size:16px; margin-right:24px; }
  .st-nav { display:flex; gap:4px; }
  .st-nav a { padding:8px 16px; border-radius:6px; font-size:14px; color:var(--st-dim); text-decoration:none; transition:.15s; }
  .st-nav a:hover { background:var(--st-border); color:var(--st-text); }
  .st-nav-active { background:rgba(31,111,235,0.13)!important; color:var(--st-accent)!important; }
  .st-header-right { margin-left:auto; display:flex; align-items:center; gap:12px; color:var(--st-dim); font-size:13px; }

  .st-container { max-width:720px; margin:0 auto; padding:32px 20px; }
  .st-card { background:var(--st-card-bg); border:1px solid var(--st-border); border-radius:12px; padding:24px; margin-bottom:24px; }
  .st-section-title { font-size:16px; font-weight:600; color:#f0f6fc; margin:0 0 16px; }
  .st-form { display:flex; flex-direction:column; gap:16px; }
  .st-field { display:flex; flex-direction:column; gap:6px; }
  .st-field-label { font-size:13px; color:var(--st-dim); }
  .st-input { padding:8px 12px; background:var(--st-bg); border:1px solid var(--st-border); border-radius:6px; color:var(--st-text); font-size:14px; outline:none; font-family:inherit; }
  .st-input:focus { border-color:var(--st-accent); }
  select.st-input { cursor:pointer; }

  .st-btn-primary { display:inline-flex; align-items:center; padding:8px 20px; background:var(--st-green); color:#fff; border:none; border-radius:6px; font-size:14px; font-weight:600; cursor:pointer; text-decoration:none; border:1px solid rgba(240,246,252,0.1); font-family:inherit; }
  .st-btn-primary:hover { background:var(--st-green-hover); }
  .st-btn-primary:disabled { opacity:0.5; cursor:not-allowed; }
  .st-btn-lg { padding:12px 32px; font-size:16px; }
  .st-btn-ghost { display:inline-flex; align-items:center; padding:8px 16px; background:transparent; color:var(--st-text); border:1px solid #30363d; border-radius:6px; font-size:14px; cursor:pointer; font-family:inherit; }
  .st-btn-ghost:hover { background:var(--st-border); }
  .st-btn-sm { padding:4px 10px; font-size:12px; }
  .st-btn-danger { display:inline-flex; align-items:center; padding:8px 20px; background:rgba(218,54,51,0.1); color:var(--st-red); border:1px solid rgba(218,54,51,0.3); border-radius:6px; font-size:14px; cursor:pointer; font-family:inherit; }
  .st-btn-danger:hover { background:rgba(218,54,51,0.2); }
  .st-btn-danger-ghost { padding:6px 12px; border-radius:6px; border:1px solid rgba(218,54,51,0.3); background:transparent; color:var(--st-red); cursor:pointer; font-size:12px; font-family:inherit; }

  .st-theme-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:12px; }
  .st-theme-card { background:var(--st-bg); border:2px solid var(--st-border); border-radius:10px; padding:16px; text-align:center; cursor:pointer; transition:.15s; }
  .st-theme-card:hover { border-color:rgba(88,166,255,0.27); }
  .st-theme-card.active { border-color:var(--st-accent)!important; }
  .st-theme-swatch { height:60px; border-radius:8px; margin-bottom:10px; }
  .st-theme-name { font-size:13px; font-weight:600; }
  .st-theme-desc { font-size:11px; color:var(--st-dim); margin-top:4px; }

  .st-nav-item { display:flex; align-items:center; gap:8px; padding:8px 0; border-bottom:1px solid rgba(48,54,61,0.27); }
  .st-nav-item input { flex:1; padding:6px 10px; background:var(--st-bg); border:1px solid var(--st-border); border-radius:6px; color:var(--st-text); font-size:13px; outline:none; font-family:inherit; }
  .st-nav-item input:focus { border-color:var(--st-accent); }

  .st-toast { position:fixed; bottom:24px; right:24px; padding:12px 20px; background:var(--st-card-bg); border:1px solid #30363d; border-radius:8px; color:var(--st-text); font-size:13px; z-index:100; box-shadow:0 4px 16px rgba(0,0,0,.4); }
</style>

<script>
  import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';
  const supabase = createClient('https://xwvkdluvixurvgvkhkfe.supabase.co','sb_publishable_NOdEPhf8yD4dMRJIH1JqqA_z5By3p0H');

  const themes = [
    { id:'default', name:'极简', desc:'白底黑字 · Bear Blog风格', colors:['#fafafa','#222'] },
    { id:'ink', name:'墨迹', desc:'水墨风格 · 东方美学', colors:['#f5f0e8','#1a1a1a'] },
    { id:'glass', name:'玻璃', desc:'玻璃态 · 深色毛玻璃', colors:['#1e1e2e','#cdd6f4'] },
    { id:'paper', name:'纸张', desc:'纸张纹理 · 暖色阅读', colors:['#fdf6e3','#586e75'] },
    { id:'mono', name:'等宽', desc:'等宽字体 · 极客风', colors:['#1a1a1a','#e0e0e0'] },
    { id:'aurora', name:'极光', desc:'渐变炫彩 · 视觉冲击', colors:['#0f0c29','#f0f0f0'] }
  ];

  let currentUser = null;
  let currentSession = null;
  let currentProfile = null;
  let navItems = [{ label:'首页', url:'/' }, { label:'归档', url:'/archive' }];

  (async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session?.user) return;
    currentUser = session.user;
    currentSession = session;

    document.getElementById('stLoggedIn').style.display = '';
    document.getElementById('stNotLoggedIn').style.display = 'none';
    document.getElementById('stUserName').textContent = currentUser.user_metadata?.username || currentUser.email?.split('@')[0] || '用户';

    document.getElementById('stLogout').addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/yunjian';
    });

    const { data: profile } = await supabase.from('profiles').select('*').eq('id', currentUser.id).single();
    currentProfile = profile;
    const currentTheme = profile?.blog_theme || 'default';

    // 主题网格
    const themeGrid = document.getElementById('stThemeGrid');
    themes.forEach(t => {
      const card = document.createElement('div');
      card.className = `st-theme-card${t.id === currentTheme ? ' active' : ''}`;
      card.dataset.theme = t.id;
      card.innerHTML = `<div class="st-theme-swatch" style="background:linear-gradient(135deg, ${t.colors[0]}, ${t.colors[1]})"></div><div class="st-theme-name">${t.name}</div><div class="st-theme-desc">${t.desc}</div>`;
      card.addEventListener('click', () => {
        document.querySelectorAll('.st-theme-card').forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        document.getElementById('stSave').disabled = false;
      });
      themeGrid.appendChild(card);
    });

    // 导航
    function renderNav() {
      const c = document.getElementById('stNavList');
      c.innerHTML = navItems.map((item, idx) => `
        <div class="st-nav-item">
          <input value="${esc(item.label)}" placeholder="名称" data-idx="${idx}" data-field="label">
          <input value="${esc(item.url)}" placeholder="链接" data-idx="${idx}" data-field="url">
          <button class="st-btn-ghost st-btn-sm" data-idx="${idx}" data-action="up" ${idx===0?'disabled':''}>&uarr;</button>
          <button class="st-btn-ghost st-btn-sm" data-idx="${idx}" data-action="down" ${idx===navItems.length-1?'disabled':''}>&darr;</button>
          <button class="st-btn-danger st-btn-sm" data-idx="${idx}" data-action="del">删除</button>
        </div>
      `).join('');
      c.querySelectorAll('input').forEach(inp => inp.addEventListener('input', () => {
        navItems[parseInt(inp.dataset.idx)][inp.dataset.field] = inp.value;
        document.getElementById('stSave').disabled = false;
      }));
      c.querySelectorAll('[data-action="up"]').forEach(btn => btn.addEventListener('click', () => {
        const i = parseInt(btn.dataset.idx);
        if (i > 0) { [navItems[i], navItems[i-1]] = [navItems[i-1], navItems[i]]; renderNav(); document.getElementById('stSave').disabled = false; }
      }));
      c.querySelectorAll('[data-action="down"]').forEach(btn => btn.addEventListener('click', () => {
        const i = parseInt(btn.dataset.idx);
        if (i < navItems.length-1) { [navItems[i], navItems[i+1]] = [navItems[i+1], navItems[i]]; renderNav(); document.getElementById('stSave').disabled = false; }
      }));
      c.querySelectorAll('[data-action="del"]').forEach(btn => btn.addEventListener('click', () => {
        navItems.splice(parseInt(btn.dataset.idx), 1); renderNav(); document.getElementById('stSave').disabled = false;
      }));
    }
    renderNav();

    document.getElementById('stAddNav').addEventListener('click', () => {
      navItems.push({ label:'新链接', url:'/new' }); renderNav(); document.getElementById('stSave').disabled = false;
    });

    document.querySelectorAll('.st-input').forEach(inp => {
      inp.addEventListener('input', () => { document.getElementById('stSave').disabled = false; });
    });

    // 加载 config
    if (profile?.blog_repo) await loadConfig(profile);

    // 保存
    document.getElementById('stSave').addEventListener('click', () => saveSettings());

    // 删除博客
    document.getElementById('stDeleteBlog').addEventListener('click', deleteBlog);
  })();

  async function loadConfig(profile) {
    const [owner, repo] = profile.blog_repo.split('/');
    try {
      const resp = await fetch(`https://raw.githubusercontent.com/${owner}/${repo}/main/config.json`);
      if (resp.ok) {
        const config = await resp.json();
        document.getElementById('stTitle').value = config.title || '';
        document.getElementById('stSubtitle').value = config.subtitle || '';
        document.getElementById('stAuthor').value = config.author || '';
        document.getElementById('stPostsPerPage').value = config.posts_per_page || 10;
        if (config.social) {
          document.getElementById('stSocialGithub').value = config.social.github || '';
          document.getElementById('stSocialTwitter').value = config.social.twitter || '';
        }
        if (config.nav) { navItems = config.nav.map(n => ({ label: n.label, url: n.url })); renderNav(); }
        if (config.cname) document.getElementById('stCname').value = config.cname;
        document.getElementById('stSave').disabled = false;
      }
    } catch(e) {}
  }

  function renderNav() {
    const c = document.getElementById('stNavList');
    c.innerHTML = navItems.map((item, idx) => `
      <div class="st-nav-item">
        <input value="${esc(item.label)}" placeholder="名称" data-idx="${idx}" data-field="label">
        <input value="${esc(item.url)}" placeholder="链接" data-idx="${idx}" data-field="url">
        <button class="st-btn-ghost st-btn-sm" data-idx="${idx}" data-action="up" ${idx===0?'disabled':''}>&uarr;</button>
        <button class="st-btn-ghost st-btn-sm" data-idx="${idx}" data-action="down" ${idx===navItems.length-1?'disabled':''}>&darr;</button>
        <button class="st-btn-danger st-btn-sm" data-idx="${idx}" data-action="del">删除</button>
      </div>
    `).join('');
    c.querySelectorAll('input').forEach(inp => inp.addEventListener('input', () => {
      navItems[parseInt(inp.dataset.idx)][inp.dataset.field] = inp.value;
      document.getElementById('stSave').disabled = false;
    }));
    c.querySelectorAll('[data-action="up"]').forEach(btn => btn.addEventListener('click', () => {
      const i = parseInt(btn.dataset.idx);
      if (i > 0) { [navItems[i], navItems[i-1]] = [navItems[i-1], navItems[i]]; renderNav(); document.getElementById('stSave').disabled = false; }
    }));
    c.querySelectorAll('[data-action="down"]').forEach(btn => btn.addEventListener('click', () => {
      const i = parseInt(btn.dataset.idx);
      if (i < navItems.length-1) { [navItems[i], navItems[i+1]] = [navItems[i+1], navItems[i]]; renderNav(); document.getElementById('stSave').disabled = false; }
    }));
    c.querySelectorAll('[data-action="del"]').forEach(btn => btn.addEventListener('click', () => {
      navItems.splice(parseInt(btn.dataset.idx), 1); renderNav(); document.getElementById('stSave').disabled = false;
    }));
  }

  async function saveSettings() {
    if (!currentProfile?.blog_repo) { toast('请先创建博客', 'error'); return; }
    const btn = document.getElementById('stSave');
    const progress = document.getElementById('stSaveProgress');
    const activeTheme = document.querySelector('.st-theme-card.active')?.dataset?.theme || currentProfile.blog_theme || 'default';

    btn.disabled = true; btn.textContent = '保存中...';
    progress.style.display = '';
    progress.innerHTML = '<p style="color:var(--st-dim)">更新配置并推送至 GitHub...</p>';

    try {
      const [owner, repo] = currentProfile.blog_repo.split('/');
      const providerToken = currentSession.provider_token;
      if (!providerToken) { toast('需要 GitHub OAuth 授权', 'error'); btn.disabled = false; return; }

      const config = {
        title: document.getElementById('stTitle').value || '我的博客',
        subtitle: document.getElementById('stSubtitle').value || '',
        author: document.getElementById('stAuthor').value || '',
        theme: activeTheme,
        language: 'zh-CN',
        posts_per_page: parseInt(document.getElementById('stPostsPerPage').value) || 10,
        nav: navItems,
        social: {
          github: document.getElementById('stSocialGithub').value || '',
          twitter: document.getElementById('stSocialTwitter').value || ''
        }
      };

      const cnameVal = document.getElementById('stCname').value.trim();
      if (cnameVal) config.cname = cnameVal;

      // 更新 config.json
      let sha = '';
      const getResp = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/config.json`, {
        headers: { Authorization: `Bearer ${providerToken}`, Accept: 'application/vnd.github+json' }
      });
      if (getResp.ok) { const d = await getResp.json(); sha = d.sha; }

      const content = JSON.stringify(config, null, 2);
      const encoded = btoa(unescape(encodeURIComponent(content)));
      const putResp = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/config.json`, {
        method: 'PUT',
        headers: { Authorization: `Bearer ${providerToken}`, Accept: 'application/vnd.github+json', 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: '更新博客配置', content: encoded, sha: sha || undefined })
      });

      if (!putResp.ok) { const e = await putResp.json(); throw new Error(e.message); }

      // CNAME 文件
      if (cnameVal) {
        let cnameSha = '';
        const cnGet = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/CNAME`, {
          headers: { Authorization: `Bearer ${providerToken}`, Accept: 'application/vnd.github+json' }
        });
        if (cnGet.ok) { const d = await cnGet.json(); cnameSha = d.sha; }

        await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/CNAME`, {
          method: 'PUT',
          headers: { Authorization: `Bearer ${providerToken}`, Accept: 'application/vnd.github+json', 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: 'Update CNAME', content: btoa(cnameVal), sha: cnameSha || undefined })
        });
      }

      await supabase.from('profiles').upsert({
        id: currentUser.id, blog_theme: activeTheme, blog_status: 'deploying',
        updated_at: new Date().toISOString()
      });

      progress.innerHTML = '<p style="color:#3fb950">配置已保存，GitHub Actions 正在部署...</p>';
      btn.textContent = '已保存'; btn.disabled = false;

    } catch(e) {
      progress.innerHTML = `<p style="color:var(--st-red)">保存失败: ${e.message}</p>`;
      btn.disabled = false;
    }
  }

  async function deleteBlog() {
    if (!confirm('确定要删除你的博客吗？此操作不可撤销。\n\nGitHub 仓库将被删除，但云笺中的文章数据会保留。')) return;
    if (!confirm('再次确认：删除后博客 URL 将无法访问，确定继续？')) return;

    const progress = document.getElementById('stDeleteProgress');
    progress.style.display = '';
    progress.innerHTML = '<p style="color:var(--st-dim)">删除中...</p>';

    try {
      if (currentProfile?.blog_repo && currentSession?.provider_token) {
        const [owner, repo] = currentProfile.blog_repo.split('/');
        const resp = await fetch(`https://api.github.com/repos/${owner}/${repo}`, {
          method: 'DELETE',
          headers: { Authorization: `Bearer ${currentSession.provider_token}`, Accept: 'application/vnd.github+json' }
        });
        if (!resp.ok && resp.status !== 404) {
          const e = await resp.json();
          if (e.message.includes('Not Found')) { /* ok */ }
          else throw new Error(e.message);
        }
      }

      await supabase.from('profiles').update({
        blog_repo: null, blog_url: null, blog_status: null, blog_theme: null
      }).eq('id', currentUser.id);

      progress.innerHTML = '<p style="color:#3fb950">博客已删除。GitHub 仓库已移除，文章仍保留在云笺中。</p>';
      setTimeout(() => { window.location.href = '/yunjian/dashboard'; }, 2000);

    } catch(e) {
      progress.innerHTML = `<p style="color:var(--st-red)">删除失败: ${e.message}</p>`;
    }
  }

  function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
  function toast(msg, type) {
    const t = document.createElement('div');
    t.className = 'st-toast';
    t.style.borderColor = type==='error'?'var(--st-red)':'#30363d';
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 3000);
  }
</script>
