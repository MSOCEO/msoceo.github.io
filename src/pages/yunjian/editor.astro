---
---

<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>编辑器 · 云笺</title>
<meta name="description" content="在线 Markdown 编辑，实时预览">
</head>
<body>
<div class="editor-root">
  <!-- 顶部工具栏 -->
  <header class="ed-header">
    <a href="/yunjian/dashboard" class="ed-logo">&#10236; 云笺</a>
    <div class="ed-toolbar">
      <button class="ed-tb-btn" data-action="bold" title="粗体 Ctrl+B">B</button>
      <button class="ed-tb-btn" data-action="italic" title="斜体 Ctrl+I"><em>I</em></button>
      <button class="ed-tb-btn" data-action="heading" title="标题">H</button>
      <button class="ed-tb-btn" data-action="link" title="链接 Ctrl+K">&#128279;</button>
      <button class="ed-tb-btn" data-action="image" title="图片">&#128247;</button>
      <button class="ed-tb-btn" data-action="code" title="代码块">&lt;/&gt;</button>
      <button class="ed-tb-btn" data-action="table" title="表格">&#9638;</button>
      <button class="ed-tb-btn" data-action="quote" title="引用">&#8220;</button>
      <span class="ed-tb-sep"></span>
      <button class="ed-tb-btn" data-action="undo" title="撤销">&#8630;</button>
      <button class="ed-tb-btn" data-action="redo" title="重做">&#8631;</button>
    </div>
    <div class="ed-header-right">
      <span class="ed-stats" id="edStats">0 字 · 阅读约 0 分钟</span>
      <span class="ed-status-tag" id="edStatusTag">未保存</span>
      <button class="ed-btn ed-btn-ghost" id="edSaveDraft">保存草稿</button>
      <button class="ed-btn ed-btn-primary" id="edPublish">发布</button>
    </div>
  </header>

  <!-- 文章元信息 -->
  <div class="ed-meta" id="edMeta">
    <input type="text" class="ed-meta-title" id="edTitle" placeholder="文章标题" autofocus>
    <div class="ed-meta-row">
      <input type="text" class="ed-meta-input" id="edCategory" placeholder="分类（可选）">
      <input type="text" class="ed-meta-input" id="edTags" placeholder="标签，逗号分隔（可选）">
      <input type="date" class="ed-meta-input" id="edDate">
    </div>
    <div class="ed-meta-row" style="margin-top:6px">
      <input type="url" class="ed-meta-input" id="edCoverImage" placeholder="封面图 URL（可选）">
      <span class="ed-slug-label">固定链接: /posts/</span>
      <span class="ed-slug-val" id="edSlugPreview">---</span>
    </div>
  </div>

  <!-- 编辑区 -->
  <div class="ed-main">
    <div class="ed-pane ed-pane-left">
      <div class="ed-pane-label">Markdown</div>
      <textarea class="ed-textarea" id="edEditor" placeholder="开始写作...&#10;&#10;Markdown 语法全支持，右侧实时预览"></textarea>
      <div class="ed-dropzone" id="edDropzone">拖拽图片到此上传</div>
      <input type="file" id="edImageInput" accept="image/*" style="display:none" multiple>
    </div>
    <div class="ed-pane ed-pane-right">
      <div class="ed-pane-label">预览</div>
      <div class="ed-preview" id="edPreview"></div>
    </div>
  </div>

  <!-- 发布进度弹窗 -->
  <div class="ed-modal" id="edPublishModal" hidden>
    <div class="ed-modal-card">
      <h2 id="edPublishTitle">发布文章</h2>
      <div id="edPublishContent">
        <p>文章将通过 GitHub API 提交到你的博客仓库，自动触发构建部署。</p>
      </div>
      <div id="edPublishProgress" style="display:none">
        <div class="db-progress-bar" style="margin-bottom:12px"><div class="db-progress-fill" id="edProgressFill"></div></div>
        <p class="db-progress-text" id="edProgressText" style="color:#8b949e;font-size:13px"></p>
      </div>
      <div class="ed-modal-actions" id="edPublishActions">
        <button class="ed-btn ed-btn-ghost" id="edCancelPublish">取消</button>
        <button class="ed-btn ed-btn-primary" id="edConfirmPublish">确认发布</button>
      </div>
    </div>
  </div>
</div>
</body>
</html>

<style>
  .editor-root { display:flex; flex-direction:column; height:100vh; background: #0f1117; color: #c9d1d9; font-family: -apple-system,BlinkMacSystemFont,sans-serif; }
  .ed-header { display:flex; align-items:center; padding: 0 16px; height: 48px; background: #161b22; border-bottom: 1px solid #21262d; flex-shrink:0; }
  .ed-logo { color: #58a6ff; text-decoration:none; font-weight:700; font-size:15px; margin-right:16px; }
  .ed-toolbar { display:flex; align-items:center; gap:2px; }
  .ed-tb-btn { width:32px; height:32px; border:none; background:transparent; color:#8b949e; cursor:pointer; border-radius:6px; font-size:14px; display:flex; align-items:center; justify-content:center; }
  .ed-tb-btn:hover { background:#21262d; color:#c9d1d9; }
  .ed-tb-sep { width:1px; height:20px; background:#21262d; margin:0 6px; }
  .ed-header-right { margin-left:auto; display:flex; align-items:center; gap:10px; }
  .ed-stats { font-size:12px; color:#484f58; }
  .ed-status-tag { padding:2px 10px; border-radius:10px; font-size:11px; font-weight:600; background:rgba(210,153,34,0.12); color:#d29922; }
  .ed-status-tag.published { background:rgba(35,134,54,0.12); color:#3fb950; }
  .ed-status-tag.draft { background:rgba(88,166,255,0.12); color:#58a6ff; }
  .ed-btn { padding:6px 16px; border-radius:6px; font-size:13px; font-weight:600; cursor:pointer; border:1px solid #30363d; transition:.15s; }
  .ed-btn-ghost { background:transparent; color:#c9d1d9; }
  .ed-btn-ghost:hover { background:#21262d; }
  .ed-btn-primary { background:#238636; color:#fff; border-color:rgba(240,246,252,0.1); }
  .ed-btn-primary:hover { background:#2ea043; }
  .ed-btn-primary:disabled { opacity:0.5; cursor:not-allowed; }

  .ed-meta { padding:12px 24px; background:#0d1117; border-bottom:1px solid #21262d; flex-shrink:0; }
  .ed-meta-title { width:100%; font-size:22px; font-weight:700; background:transparent; border:none; color:#c9d1d9; padding:4px 0; outline:none; }
  .ed-meta-title::placeholder { color:#30363d; }
  .ed-meta-row { display:flex; gap:10px; margin-top:8px; align-items:center; }
  .ed-meta-input { background:#161b22; border:1px solid #21262d; border-radius:6px; padding:4px 10px; color:#c9d1d9; font-size:13px; outline:none; flex:1; }
  .ed-meta-input:focus { border-color:#58a6ff; }
  .ed-slug-label { color:#484f58; font-size:12px; white-space:nowrap; }
  .ed-slug-val { color:#58a6ff; font-size:12px; }

  .ed-main { display:flex; flex:1; overflow:hidden; }
  .ed-pane { flex:1; display:flex; flex-direction:column; border-right:1px solid #21262d; position:relative; }
  .ed-pane:last-child { border-right:none; }
  .ed-pane-label { padding:6px 16px; font-size:11px; color:#484f58; text-transform:uppercase; letter-spacing:.5px; border-bottom:1px solid #21262d; background:#0d1117; }
  .ed-textarea { flex:1; background:transparent; border:none; color:#c9d1d9; padding:16px 24px; font-family:"JetBrains Mono","SF Mono",Consolas,monospace; font-size:14px; line-height:1.7; resize:none; outline:none; tab-size:2; }
  .ed-preview { flex:1; padding:16px 24px; overflow-y:auto; line-height:1.8; font-size:15px; }
  .ed-preview h1 { font-size:1.8em; border-bottom:1px solid #21262d; padding-bottom:.3em; }
  .ed-preview h2 { font-size:1.4em; margin-top:1.2em; }
  .ed-preview pre { background:#161b22; border:1px solid #30363d; border-radius:6px; padding:16px; overflow-x:auto; }
  .ed-preview code { font-family:"JetBrains Mono",monospace; font-size:.9em; background:rgba(110,118,129,0.2); padding:2px 5px; border-radius:4px; }
  .ed-preview pre code { background:transparent; padding:0; }
  .ed-preview blockquote { border-left:3px solid #30363d; padding:0 1em; color:#8b949e; }
  .ed-preview table { border-collapse:collapse; width:100%; }
  .ed-preview th, .ed-preview td { border:1px solid #30363d; padding:6px 13px; }
  .ed-preview img { max-width:100%; border-radius:6px; }
  .ed-preview a { color:#58a6ff; }

  .ed-dropzone { position:absolute; bottom:20px; left:50%; transform:translateX(-50%); padding:8px 24px; background:rgba(88,166,255,0.08); border:1px dashed #30363d; border-radius:8px; color:#484f58; font-size:12px; pointer-events:none; opacity:0; transition:.2s; }
  .ed-dropzone.active { opacity:1; border-color:#58a6ff; color:#58a6ff; }

  .ed-modal { position:fixed; inset:0; background:rgba(0,0,0,0.7); display:flex; align-items:center; justify-content:center; z-index:100; }
  .ed-modal-card { background:#161b22; border:1px solid #30363d; border-radius:12px; padding:32px; max-width:460px; width:90%; }
  .ed-modal-card h2 { color:#c9d1d9; margin-bottom:12px; }
  .ed-modal-card p { color:#8b949e; font-size:14px; margin-bottom:20px; }
  .ed-modal-actions { display:flex; gap:10px; justify-content:flex-end; }
  .db-progress-bar { width:100%; height:6px; background:#21262d; border-radius:3px; overflow:hidden; }
  .db-progress-fill { height:100%; background:linear-gradient(90deg,#238636,#58a6ff); border-radius:3px; transition:width .3s; width:0%; }
  .db-progress-text { margin-top:4px; font-size:13px; color:#8b949e; }

  @media (max-width:768px) {
    .ed-main { flex-direction:column; }
    .ed-toolbar { display:none; }
    .ed-stats { display:none; }
  }
</style>

<script>
  import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

  const SUPABASE_URL = 'https://xwvkdluvixurvgvkhkfe.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_NOdEPhf8yD4dMRJIH1JqqA_z5By3p0H';

  const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);
  let currentSession = null;
  let currentUser = null;
  let currentProfile = null;
  let currentPostSlug = null;
  let saveTimer = null;

  // DOM
  const editor = document.getElementById('edEditor');
  const preview = document.getElementById('edPreview');
  const titleInput = document.getElementById('edTitle');
  const categoryInput = document.getElementById('edCategory');
  const tagsInput = document.getElementById('edTags');
  const dateInput = document.getElementById('edDate');
  const coverInput = document.getElementById('edCoverImage');
  const statsEl = document.getElementById('edStats');
  const slugPreview = document.getElementById('edSlugPreview');
  const statusTag = document.getElementById('edStatusTag');
  const dropzone = document.getElementById('edDropzone');
  const imageInput = document.getElementById('edImageInput');
  const publishModal = document.getElementById('edPublishModal');

  // ===== Markdown 渲染 =====
  function renderPreview(md) {
    if (!md) return '<p style="color:#30363d">预览区域</p>';
    let html = md
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/^### (.+)$/gm,'<h3>$1</h3>')
      .replace(/^## (.+)$/gm,'<h2>$1</h2>')
      .replace(/^# (.+)$/gm,'<h1>$1</h1>')
      .replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>')
      .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
      .replace(/\*(.+?)\*/g,'<em>$1</em>')
      .replace(/`([^`]+)`/g,'<code>$1</code>')
      .replace(/!\[([^\]]*)\]\(([^)]+)\)/g,'<img src="$2" alt="$1" loading="lazy">')
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g,'<a href="$2">$1</a>')
      .replace(/^> (.+)$/gm,'<blockquote><p>$1</p></blockquote>');
    html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_,lang,code) => {
      code = code.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      return `<pre><code>${code}</code></pre>`;
    });
    const paras = html.split(/\n\n+/);
    html = paras.map(p => { p=p.trim(); if(!p)return''; if(p.startsWith('<'))return p; return `<p>${p.replace(/\n/g,'<br>')}</p>`; }).join('\n');
    return html;
  }

  function updatePreview() {
    preview.innerHTML = renderPreview(editor.value);
    updateStats();
  }

  function getSlug() {
    return titleInput.value
      ? titleInput.value.toLowerCase().replace(/[^\w\u4e00-\u9fff]+/g,'-').replace(/(^-|-$)/g,'') || 'untitled'
      : 'untitled';
  }

  function updateStats() {
    const text = editor.value.replace(/[^\u4e00-\u9fff\w]/g,'');
    const count = text.length;
    const minutes = Math.max(1, Math.ceil(count / 400));
    statsEl.textContent = `${count} 字 · 阅读约 ${minutes} 分钟`;
    slugPreview.textContent = getSlug();
  }

  editor.addEventListener('input', updatePreview);
  titleInput.addEventListener('input', updatePreview);
  dateInput.value = new Date().toISOString().split('T')[0];
  updatePreview();

  // ===== 工具栏 =====
  document.querySelectorAll('.ed-tb-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const action = btn.dataset.action;
      const ta = editor;
      const start = ta.selectionStart;
      const end = ta.selectionEnd;
      const sel = ta.value.substring(start, end);
      const actions = {
        bold: () => insertFormat(ta, `**${sel || '粗体文字'}**`, start, end, 2, sel ? 2+sel.length : 6),
        italic: () => insertFormat(ta, `*${sel || '斜体文字'}*`, start, end, 1, sel ? 1+sel.length : 5),
        heading: () => { const line = ta.value.substring(0, start).lastIndexOf('\n')+1; ta.setRangeText('## ', line, line, 'end'); ta.focus(); },
        link: () => insertFormat(ta, `[${sel || '链接文字'}](url)`, start, end, sel ? 1 : 0, sel ? sel.length+1 : 4),
        image: () => insertFormat(ta, `![${sel || '图片描述'}](url)`, start, end, sel ? 2 : 0, sel ? sel.length+2 : 3),
        code: () => insertFormat(ta, '```\n' + (sel || '代码') + '\n```', start, end, 4, sel ? 0 : 2),
        table: () => { ta.setRangeText('\n| 列1 | 列2 | 列3 |\n|:---|:---:|:---|\n| 内容 | 内容 | 内容 |\n', start, end, 'end'); ta.focus(); },
        quote: () => { const line = ta.value.substring(0, start).lastIndexOf('\n')+1; ta.setRangeText('> ', line, line, 'end'); ta.focus(); },
        undo: () => document.execCommand('undo'),
        redo: () => document.execCommand('redo')
      };
      if (actions[action]) actions[action]();
      ta.focus(); updatePreview();
    });
  });

  function insertFormat(ta, text, start, end, selStartOffset, selEndOffset) {
    ta.setRangeText(text, start, end, 'end');
    const newStart = start + selStartOffset;
    ta.setSelectionRange(newStart, newStart + (end - start) + selEndOffset);
  }

  // ===== 图片拖拽 =====
  editor.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('active'); });
  editor.addEventListener('dragleave', () => dropzone.classList.remove('active'));
  editor.addEventListener('drop', async e => {
    e.preventDefault(); dropzone.classList.remove('active');
    for (const file of e.dataTransfer.files) {
      if (!file.type.startsWith('image/')) continue;
      const reader = new FileReader();
      reader.onload = (ev) => {
        editor.setRangeText(`\n![${file.name}](${ev.target.result})\n`, editor.selectionStart, editor.selectionStart, 'end');
        updatePreview();
      };
      reader.readAsDataURL(file);
    }
  });
  dropzone.addEventListener('click', () => imageInput.click());
  imageInput.addEventListener('change', () => {
    for (const file of imageInput.files) {
      const reader = new FileReader();
      reader.onload = (ev) => {
        editor.setRangeText(`\n![${file.name}](${ev.target.result})\n`, editor.selectionStart, editor.selectionStart, 'end');
        updatePreview();
      };
      reader.readAsDataURL(file);
    }
  });

  // ===== 自动保存草稿 =====
  function setStatus(type) {
    statusTag.className = 'ed-status-tag';
    if (type === 'draft') { statusTag.className += ' draft'; statusTag.textContent = '草稿已存'; }
    else if (type === 'published') { statusTag.className += ' published'; statusTag.textContent = '已发布'; }
    else { statusTag.textContent = '未保存'; }
  }

  function buildFrontMatter() {
    const tags = tagsInput.value.split(',').map(t=>t.trim()).filter(Boolean);
    const cover = coverInput.value.trim();
    let fm = `---
title: "${titleInput.value.trim() || '未命名'}"
date: ${dateInput.value || new Date().toISOString().split('T')[0]}
tags: [${tags.join(', ')}]
category: "${categoryInput.value.trim() || '未分类'}"`;
    if (cover) fm += `\ncover: "${cover}"`;
    fm += '\n---';
    return fm;
  }

  async function saveDraftToSupabase() {
    if (!currentUser) return;
    const title = titleInput.value.trim();
    if (!title && !editor.value.trim()) return;
    const slug = getSlug();
    const content = buildFrontMatter() + '\n\n' + editor.value;
    const tags = tagsInput.value.split(',').map(t=>t.trim()).filter(Boolean);
    const { error } = await supabase.from('posts').upsert({
      user_id: currentUser.id,
      title: title || '未命名',
      slug,
      content,
      excerpt: editor.value.replace(/[#*`\[\]()!_~>|-]/g,'').slice(0,200),
      tags,
      category: categoryInput.value.trim() || '未分类',
      status: 'draft',
      updated_at: new Date().toISOString()
    }, { onConflict: 'user_id,slug' });
    if (!error) { setStatus('draft'); currentPostSlug = slug; }
  }

  document.getElementById('edSaveDraft').addEventListener('click', async () => {
    await saveDraftToSupabase();
    const btn = document.getElementById('edSaveDraft');
    btn.textContent = '已保存';
    setTimeout(() => { btn.textContent = '保存草稿'; }, 2000);
  });

  editor.addEventListener('input', () => {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(saveDraftToSupabase, 30000);
  });

  // ===== 发布流程 =====
  document.getElementById('edPublish').addEventListener('click', () => {
    const title = titleInput.value.trim();
    if (!title) { alert('请输入文章标题'); return; }
    if (!editor.value.trim()) { alert('请输入文章内容'); return; }
    document.getElementById('edPublishTitle').textContent = '发布文章';
    document.getElementById('edPublishContent').innerHTML = '<p>文章将通过 GitHub API 提交到你的博客仓库，自动触发构建部署。</p>';
    document.getElementById('edPublishProgress').style.display = 'none';
    document.getElementById('edPublishActions').style.display = '';
    publishModal.hidden = false;
  });

  document.getElementById('edCancelPublish').addEventListener('click', () => { publishModal.hidden = true; });

  document.getElementById('edConfirmPublish').addEventListener('click', async () => {
    document.getElementById('edPublishActions').style.display = 'none';
    document.getElementById('edPublishContent').style.display = 'none';
    document.getElementById('edPublishProgress').style.display = '';
    const progressFill = document.getElementById('edProgressFill');
    const progressText = document.getElementById('edProgressText');
    const btn = document.getElementById('edPublish');
    btn.textContent = '发布中...'; btn.disabled = true;

    function setProgress(pct, msg) { progressFill.style.width = pct+'%'; progressText.textContent = msg; }

    try {
      const title = titleInput.value.trim();
      const slug = getSlug();
      const content = buildFrontMatter() + '\n\n' + editor.value;
      const tags = tagsInput.value.split(',').map(t=>t.trim()).filter(Boolean);

      setProgress(10, '保存到云笺...');

      // 保存到 Supabase
      if (currentUser) {
        await supabase.from('posts').upsert({
          user_id: currentUser.id,
          title, slug, content,
          excerpt: editor.value.replace(/[#*`\[\]()!_~>|-]/g,'').slice(0,200),
          tags, category: categoryInput.value.trim() || '未分类',
          status: 'published', published_at: new Date().toISOString(),
          updated_at: new Date().toISOString()
        }, { onConflict: 'user_id,slug' });
      }

      setProgress(30, '提交到 GitHub...');

      // GitHub 提交
      if (currentProfile?.blog_repo && currentSession?.provider_token) {
        const [owner, repo] = currentProfile.blog_repo.split('/');
        const providerToken = currentSession.provider_token;
        const path = `posts/${slug}.md`;
        const encoded = btoa(unescape(encodeURIComponent(content)));

        // 检查文件是否存在（获取 sha）
        let sha = '';
        const getResp = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${path}`, {
          headers: { Authorization: `Bearer ${providerToken}`, Accept: 'application/vnd.github+json' }
        });
        if (getResp.ok) { const d = await getResp.json(); sha = d.sha; }

        setProgress(50, '推送文章内容...');
        const putResp = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${path}`, {
          method: 'PUT',
          headers: { Authorization: `Bearer ${providerToken}`, Accept: 'application/vnd.github+json', 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: `发布: ${title}`, content: encoded, sha: sha || undefined })
        });

        if (!putResp.ok) { const e = await putResp.json(); throw new Error(e.message); }

        setProgress(80, 'GitHub Actions 构建中...');
        const blogUrl = currentProfile.blog_url || `https://${owner}.github.io`;
        setProgress(100, `发布成功！`);

        document.getElementById('edPublishTitle').textContent = '发布成功';
        document.getElementById('edPublishContent').style.display = '';
        document.getElementById('edPublishContent').innerHTML = `
          <p style="margin-bottom:8px">文章已提交，约 1-2 分钟后上线。</p>
          <p>访问地址: <a href="${blogUrl}/posts/${slug}" target="_blank" style="color:#58a6ff">${blogUrl}/posts/${slug}</a></p>
        `;
        document.getElementById('edPublishActions').style.display = '';
        document.getElementById('edPublishActions').innerHTML = '<button class="ed-btn ed-btn-primary" id="edClosePublish">完成</button>';
        document.getElementById('edClosePublish').addEventListener('click', () => {
          publishModal.hidden = true;
          window.location.href = '/yunjian/dashboard';
        });
      } else {
        setProgress(100, '已保存到云笺（未关联 GitHub，文件已下载）');
        const blob = new Blob([content], { type: 'text/markdown' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a'); a.href = url; a.download = `${slug}.md`; a.click();
        URL.revokeObjectURL(url);

        document.getElementById('edPublishTitle').textContent = '已保存';
        document.getElementById('edPublishContent').style.display = '';
        document.getElementById('edPublishContent').innerHTML = '<p>文章已保存到云笺。如需自动部署，请先创建博客并关联 GitHub。</p>';
        document.getElementById('edPublishActions').style.display = '';
        document.getElementById('edPublishActions').innerHTML = '<button class="ed-btn ed-btn-primary" id="edClosePublish">完成</button>';
        document.getElementById('edClosePublish').addEventListener('click', () => { publishModal.hidden = true; });
      }

      localStorage.removeItem('yunjian_draft');
      setStatus('published');
      btn.textContent = '已发布'; btn.disabled = true;

    } catch(e) {
      setProgress(0, `发布失败: ${e.message}`);
      document.getElementById('edPublishActions').style.display = '';
      document.getElementById('edPublishActions').innerHTML = '<button class="ed-btn ed-btn-ghost" id="edClosePublish">关闭</button>';
      document.getElementById('edClosePublish').addEventListener('click', () => { publishModal.hidden = true; });
      btn.textContent = '重试'; btn.disabled = false;
    }
  });

  // ===== 加载已有文章 (?post=xxx) =====
  async function loadPostBySlug(slug) {
    if (!currentUser) return;
    const { data } = await supabase.from('posts').select('*').eq('user_id', currentUser.id).eq('slug', slug).single();
    if (!data) return;
    currentPostSlug = data.slug;
    if (data.content) {
      // 解析 Front Matter
      const fmMatch = data.content.match(/^---\n([\s\S]*?)\n---/);
      if (fmMatch) {
        const fm = fmMatch[1];
        const titleMatch = fm.match(/title:\s*"?(.+?)"?\n/);
        const dateMatch = fm.match(/date:\s*(\S+)/);
        const tagsMatch = fm.match(/tags:\s*\[(.*?)\]/);
        const catMatch = fm.match(/category:\s*"?(.+?)"?\n/);
        const coverMatch = fm.match(/cover:\s*"?(.+?)"?\n/);

        if (titleMatch) titleInput.value = titleMatch[1];
        if (dateMatch) dateInput.value = dateMatch[1];
        if (tagsMatch) tagsInput.value = tagsMatch[1];
        if (catMatch) categoryInput.value = catMatch[1];
        if (coverMatch) coverInput.value = coverMatch[1];
        editor.value = data.content.replace(/^---\n[\s\S]*?\n---\n?/, '');
      } else {
        editor.value = data.content;
      }
      updatePreview();
      setStatus(data.status === 'published' ? 'published' : 'draft');
    }
    if (data.title && !titleInput.value) titleInput.value = data.title;
    if (data.tags && !tagsInput.value) tagsInput.value = data.tags.join(', ');
    if (data.category && !categoryInput.value) categoryInput.value = data.category;
    updatePreview();
  }

  // ===== 初始化 =====
  (async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (session?.user) {
      currentSession = session;
      currentUser = session.user;
      const { data: profile } = await supabase.from('profiles').select('*').eq('id', session.user.id).single();
      currentProfile = profile;
    }

    // 检查 ?post=xxx 参数
    const params = new URLSearchParams(window.location.search);
    const postSlug = params.get('post');
    if (postSlug) {
      await loadPostBySlug(postSlug);
    } else {
      // 恢复 localStorage 草稿（仅当无 post 参数时）
      const raw = localStorage.getItem('yunjian_draft');
      if (raw) {
        try {
          const draft = JSON.parse(raw);
          if (draft.title) titleInput.value = draft.title;
          if (draft.category) categoryInput.value = draft.category;
          if (draft.tags) tagsInput.value = draft.tags;
          if (draft.content) editor.value = draft.content;
          updatePreview();
        } catch(e) {}
      }
    }

    dateInput.value = dateInput.value || new Date().toISOString().split('T')[0];
    updatePreview();
  })();

  // ===== 快捷键 =====
  document.addEventListener('keydown', e => {
    if ((e.ctrlKey || e.metaKey) && e.key === 's') {
      e.preventDefault(); saveDraftToSupabase();
    }
    if ((e.ctrlKey || e.metaKey) && e.key === 'b') {
      e.preventDefault(); document.querySelector('[data-action="bold"]').click();
    }
    if ((e.ctrlKey || e.metaKey) && e.key === 'i') {
      e.preventDefault(); document.querySelector('[data-action="italic"]').click();
    }
  });
</script>
