---
---

<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>控制台 · 云笺</title>
<meta name="description" content="云笺博客控制台">
</head>
<body>
<div class="db-root">
  <!-- 侧边栏 -->
  <aside class="db-side">
    <a href="/yunjian/dashboard" class="db-logo">&#10236; 云笺</a>
    <nav class="db-nav">
      <a href="/yunjian/dashboard" class="db-nav-item active">&#9632; 仪表盘</a>
      <a href="/yunjian/editor" class="db-nav-item">&#9997; 写文章</a>
      <a href="/yunjian/dashboard#posts" class="db-nav-item">&#128196; 文章管理</a>
      <a href="/yunjian/settings" class="db-nav-item">&#9881; 博客设置</a>
    </nav>
    <div class="db-side-footer">
      <a href="/yunjian" class="db-nav-item">&#8617; 返回首页</a>
    </div>
  </aside>

  <!-- 主内容 -->
  <main class="db-main">
    <!-- 无博客引导 -->
    <div id="dbNoBlogBlock" style="display:none">
      <div class="db-no-blog">
        <div class="db-no-blog-icon">&#127881;</div>
        <h1>欢迎来到云笺</h1>
        <p class="db-no-blog-sub">三分钟拥有独立博客，基于 GitHub Pages，永久免费</p>
        <div class="db-steps">
          <div class="db-step"><div class="db-step-num">1</div><div class="db-step-text">用 GitHub 登录云笺</div></div>
          <div class="db-step-arrow">&rarr;</div>
          <div class="db-step"><div class="db-step-num">2</div><div class="db-step-text">一键创建仓库</div></div>
          <div class="db-step-arrow">&rarr;</div>
          <div class="db-step"><div class="db-step-num">3</div><div class="db-step-text">博客自动上线</div></div>
        </div>
        <button class="db-btn db-btn-lg db-btn-primary" id="dbCreateBlog">&#9889; 一键创建博客</button>
        <div id="dbCreateProgress" style="display:none;margin-top:20px;max-width:400px;margin-left:auto;margin-right:auto">
          <div class="db-progress-bar"><div class="db-progress-fill" id="dbProgressFill"></div></div>
          <p class="db-progress-text" id="dbProgressText"></p>
        </div>
        <p class="db-no-blog-hint" id="dbNoBlogHint" style="display:none">你也可以 <a href="/yunjian/editor">直接开始写文章</a>，稍后再部署博客。</p>
      </div>
    </div>

    <!-- 已有博客内容 -->
    <div id="dbBlogContent" style="display:none">
      <!-- 顶部状态栏 -->
      <div class="db-topbar">
        <div class="db-topbar-left">
          <span class="db-status-dot" id="dbStatusDot"></span>
          <span id="dbStatusText">加载中...</span>
          <span class="db-topbar-sep">·</span>
          <span id="dbLastDeploy">--</span>
        </div>
        <div class="db-topbar-right">
          <input type="text" class="db-topbar-input" id="dbBlogUrlInput" readonly value="加载中..." onclick="this.select()">
          <button class="db-btn db-btn-sm db-btn-ghost" id="dbCopyUrl">复制</button>
          <button class="db-btn db-btn-sm" id="dbVisitBlog" onclick="window.open(document.getElementById('dbBlogUrlInput').value,'_blank')">访问</button>
        </div>
      </div>

      <!-- 统计卡片 -->
      <div class="db-stats-row">
        <div class="db-stat-card">
          <div class="db-stat-num" id="dbStatTotal">0</div>
          <div class="db-stat-label">文章总数</div>
        </div>
        <div class="db-stat-card">
          <div class="db-stat-num" id="dbStatPublished">0</div>
          <div class="db-stat-label">已发布</div>
        </div>
        <div class="db-stat-card">
          <div class="db-stat-num" id="dbStatDrafts">0</div>
          <div class="db-stat-label">草稿</div>
        </div>
        <div class="db-stat-card">
          <div class="db-stat-num" id="dbStatWords">0</div>
          <div class="db-stat-label">总字数</div>
        </div>
      </div>

      <!-- 双栏布局 -->
      <div class="db-columns">
        <!-- 左：文章表格 -->
        <div class="db-col-main" id="posts">
          <div class="db-panel">
            <div class="db-panel-header">
              <h2>文章管理</h2>
              <div class="db-panel-actions">
                <input type="text" class="db-search" id="dbSearchPosts" placeholder="搜索文章...">
                <a href="/yunjian/editor" class="db-btn db-btn-sm db-btn-primary">新建</a>
              </div>
            </div>
            <div class="db-table-wrap">
              <table class="db-table">
                <thead><tr><th>标题</th><th>状态</th><th>日期</th><th>字数</th><th>操作</th></tr></thead>
                <tbody id="dbPostsTable"><tr><td colspan="5" style="text-align:center;color:#484f58;padding:32px">加载中...</td></tr></tbody>
              </table>
            </div>
            <div class="db-pagination" id="dbPagination"></div>
          </div>

          <!-- 部署日志 -->
          <div class="db-panel" style="margin-top:16px">
            <div class="db-panel-header">
              <h2>部署日志</h2>
              <span style="font-size:12px;color:#484f58">最近 5 次</span>
            </div>
            <div id="dbDeployLogs"><p style="color:#484f58;font-size:13px;padding:16px">暂无部署记录</p></div>
          </div>
        </div>

        <!-- 右：快捷面板 -->
        <div class="db-col-side">
          <div class="db-panel">
            <div class="db-panel-header"><h2>快捷操作</h2></div>
            <div class="db-quick-actions">
              <a href="/yunjian/editor" class="db-quick-btn db-quick-btn-primary">&#9997; 写新文章</a>
              <a href="/yunjian/settings" class="db-quick-btn">&#9881; 博客设置</a>
              <a href="/yunjian/settings#theme" class="db-quick-btn">&#127912; 管理主题</a>
              <a href="#posts" class="db-quick-btn">&#128196; 管理文章</a>
            </div>
          </div>
          <div class="db-panel" style="margin-top:16px">
            <div class="db-panel-header"><h2>最近草稿</h2></div>
            <div id="dbRecentDrafts"><p style="color:#484f58;font-size:13px;padding:16px">暂无草稿</p></div>
          </div>
          <div class="db-panel" style="margin-top:16px">
            <div class="db-panel-header"><h2>博客信息</h2></div>
            <div class="db-info-list" id="dbBlogInfo">
              <div class="db-info-row"><span class="db-info-label">主题</span><span class="db-info-val" id="dbInfoTheme">--</span></div>
              <div class="db-info-row"><span class="db-info-label">仓库</span><span class="db-info-val" id="dbInfoRepo">--</span></div>
              <div class="db-info-row"><span class="db-info-label">语言</span><span class="db-info-val">zh-CN</span></div>
              <div class="db-info-row"><span class="db-info-label">平台</span><span class="db-info-val">GitHub Pages</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>

<style>
  :root { --db-bg:#0d1117; --db-card:#161b22; --db-border:#21262d; --db-text:#c9d1d9; --db-dim:#8b949e; --db-muted:#484f58; --db-accent:#58a6ff; --db-green:#238636; --db-green-light:#3fb950; --db-yellow:#d29922; --db-red:#da3633; }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; background:var(--db-bg); color:var(--db-text); }
  .db-root { display:flex; min-height:100vh; }
  /* 侧边栏 */
  .db-side { width:220px; background:var(--db-card); border-right:1px solid var(--db-border); padding:20px 0; flex-shrink:0; display:flex; flex-direction:column; }
  .db-logo { display:block; padding:0 20px 20px; color:var(--db-accent); text-decoration:none; font-weight:700; font-size:18px; border-bottom:1px solid var(--db-border); }
  .db-nav { padding:12px 0; flex:1; }
  .db-nav-item { display:block; padding:8px 20px; color:var(--db-dim); text-decoration:none; font-size:14px; transition:.15s; }
  .db-nav-item:hover { color:var(--db-text); background:rgba(88,166,255,0.05); }
  .db-nav-item.active { color:var(--db-accent); background:rgba(88,166,255,0.08); border-right:2px solid var(--db-accent); }
  .db-side-footer { padding:12px 0; border-top:1px solid var(--db-border); }
  /* 主区域 */
  .db-main { flex:1; overflow-y:auto; padding:24px; }
  /* 无博客 */
  .db-no-blog { text-align:center; padding:80px 20px; max-width:560px; margin:0 auto; }
  .db-no-blog-icon { font-size:64px; margin-bottom:16px; }
  .db-no-blog h1 { font-size:1.8rem; font-weight:700; color:var(--db-text); margin-bottom:8px; }
  .db-no-blog-sub { color:var(--db-dim); margin-bottom:32px; }
  .db-no-blog-hint { color:var(--db-muted); font-size:13px; margin-top:16px; }
  .db-no-blog-hint a { color:var(--db-accent); }
  .db-steps { display:flex; align-items:center; justify-content:center; gap:16px; margin-bottom:28px; flex-wrap:wrap; }
  .db-step { display:flex; align-items:center; gap:8px; }
  .db-step-num { width:32px; height:32px; border-radius:50%; background:var(--db-border); color:var(--db-dim); font-size:14px; font-weight:700; display:flex; align-items:center; justify-content:center; }
  .db-step-text { color:var(--db-dim); font-size:14px; }
  .db-step-arrow { color:var(--db-muted); font-size:18px; }
  /* 按钮 */
  .db-btn { display:inline-flex; align-items:center; justify-content:center; gap:6px; padding:8px 16px; border-radius:6px; font-size:13px; font-weight:600; cursor:pointer; border:1px solid var(--db-border); background:var(--db-card); color:var(--db-text); text-decoration:none; transition:.15s; }
  .db-btn:hover { background:#21262d; }
  .db-btn-sm { padding:4px 10px; font-size:12px; }
  .db-btn-lg { padding:12px 28px; font-size:15px; }
  .db-btn-primary { background:var(--db-green); color:#fff; border-color:rgba(240,246,252,0.1); }
  .db-btn-primary:hover { background:#2ea043; }
  .db-btn-ghost { background:transparent; border-color:transparent; color:var(--db-dim); }
  .db-btn-ghost:hover { background:var(--db-border); color:var(--db-text); }
  .db-btn-danger { color:var(--db-red); border-color:rgba(218,54,51,0.3); }
  .db-btn-danger:hover { background:rgba(218,54,51,0.1); }
  /* 进度条 */
  .db-progress-bar { width:100%; height:6px; background:var(--db-border); border-radius:3px; overflow:hidden; }
  .db-progress-fill { height:100%; background:linear-gradient(90deg,var(--db-green-light),var(--db-accent)); border-radius:3px; transition:width .3s; width:0%; }
  .db-progress-text { margin-top:6px; font-size:13px; color:var(--db-dim); }
  /* 顶部栏 */
  .db-topbar { display:flex; align-items:center; justify-content:space-between; background:var(--db-card); border:1px solid var(--db-border); border-radius:8px; padding:10px 16px; margin-bottom:20px; }
  .db-topbar-left { display:flex; align-items:center; gap:8px; font-size:13px; }
  .db-status-dot { width:8px; height:8px; border-radius:50%; background:var(--db-green-light); }
  .db-status-dot.warn { background:var(--db-yellow); }
  .db-status-dot.err { background:var(--db-red); }
  .db-topbar-sep { color:var(--db-muted); }
  .db-topbar-right { display:flex; align-items:center; gap:8px; }
  .db-topbar-input { background:var(--db-bg); border:1px solid var(--db-border); border-radius:4px; padding:4px 10px; color:var(--db-accent); font-family:monospace; font-size:12px; width:260px; outline:none; }
  /* 统计卡片 */
  .db-stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:20px; }
  .db-stat-card { background:var(--db-card); border:1px solid var(--db-border); border-radius:8px; padding:20px; text-align:center; }
  .db-stat-num { font-size:28px; font-weight:700; color:var(--db-text); }
  .db-stat-label { font-size:12px; color:var(--db-muted); margin-top:4px; }
  /* 双栏 */
  .db-columns { display:flex; gap:16px; align-items:flex-start; }
  .db-col-main { flex:1; min-width:0; }
  .db-col-side { width:280px; flex-shrink:0; }
  /* 面板 */
  .db-panel { background:var(--db-card); border:1px solid var(--db-border); border-radius:8px; overflow:hidden; }
  .db-panel-header { display:flex; align-items:center; justify-content:space-between; padding:14px 16px; border-bottom:1px solid var(--db-border); }
  .db-panel-header h2 { font-size:14px; font-weight:600; }
  .db-panel-actions { display:flex; align-items:center; gap:8px; }
  .db-search { background:var(--db-bg); border:1px solid var(--db-border); border-radius:4px; padding:4px 10px; color:var(--db-text); font-size:12px; width:160px; outline:none; }
  .db-search:focus { border-color:var(--db-accent); }
  /* 表格 */
  .db-table-wrap { overflow-x:auto; }
  .db-table { width:100%; border-collapse:collapse; }
  .db-table th { text-align:left; padding:10px 16px; font-size:11px; font-weight:600; color:var(--db-muted); text-transform:uppercase; letter-spacing:.5px; border-bottom:1px solid var(--db-border); }
  .db-table td { padding:10px 16px; font-size:13px; border-bottom:1px solid var(--db-border); }
  .db-table tr:hover td { background:rgba(88,166,255,0.03); }
  .db-table tr:last-child td { border-bottom:none; }
  .db-tag { display:inline-block; padding:2px 8px; border-radius:10px; font-size:11px; font-weight:600; }
  .db-tag-pub { background:rgba(35,134,54,0.12); color:var(--db-green-light); }
  .db-tag-draft { background:rgba(88,166,255,0.12); color:var(--db-accent); }
  .db-tag-err { background:rgba(218,54,51,0.1); color:var(--db-red); }
  /* 快捷按钮 */
  .db-quick-actions { padding:12px; display:flex; flex-direction:column; gap:8px; }
  .db-quick-btn { display:flex; align-items:center; gap:8px; padding:10px 14px; border-radius:6px; color:var(--db-text); text-decoration:none; font-size:13px; border:1px solid var(--db-border); transition:.15s; }
  .db-quick-btn:hover { background:var(--db-border); }
  .db-quick-btn-primary { background:var(--db-green); color:#fff; border-color:rgba(240,246,252,0.1); }
  .db-quick-btn-primary:hover { background:#2ea043; }
  /* 信息列表 */
  .db-info-list { padding:12px 16px; }
  .db-info-row { display:flex; justify-content:space-between; padding:8px 0; font-size:13px; border-bottom:1px solid var(--db-border); }
  .db-info-row:last-child { border-bottom:none; }
  .db-info-label { color:var(--db-muted); }
  .db-info-val { color:var(--db-text); }
  /* 分页 */
  .db-pagination { padding:12px 16px; display:flex; justify-content:center; gap:6px; }
  .db-page-btn { padding:4px 10px; border-radius:4px; border:1px solid var(--db-border); background:var(--db-card); color:var(--db-dim); font-size:12px; cursor:pointer; }
  .db-page-btn.active { background:var(--db-accent); border-color:var(--db-accent); color:#fff; }
  /* 部署日志 */
  .db-log-item { padding:10px 16px; border-bottom:1px solid var(--db-border); display:flex; align-items:center; gap:10px; font-size:13px; }
  .db-log-item:last-child { border-bottom:none; }
  .db-log-status { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
  .db-log-status.ok { background:var(--db-green-light); }
  .db-log-status.fail { background:var(--db-red); }
  .db-log-status.pending { background:var(--db-yellow); }
  .db-log-time { color:var(--db-muted); margin-left:auto; font-size:12px; }

  @media (max-width:900px) {
    .db-side { display:none; }
    .db-columns { flex-direction:column; }
    .db-col-side { width:100%; }
    .db-stats-row { grid-template-columns:repeat(2,1fr); }
    .db-topbar { flex-direction:column; gap:10px; align-items:flex-start; }
    .db-topbar-input { width:100%; }
  }
</style>

<script>
  import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';
  const supabase = createClient('https://xwvkdluvixurvgvkhkfe.supabase.co','sb_publishable_NOdEPhf8yD4dMRJIH1JqqA_z5By3p0H');

  let currentUser = null, currentSession = null, currentProfile = null;
  const POSTS_PER_PAGE = 10;
  let allPosts = [];

  // ===== 初始化 =====
  (async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session?.user) { window.location.href = '/yunjian/login'; return; }
    currentUser = session.user;
    currentSession = session;
    const username = currentUser.user_metadata?.username || currentUser.email?.split('@')[0] || '用户';

    // 加载 profile
    const { data: profile } = await supabase.from('profiles').select('*').eq('id', currentUser.id).single();
    currentProfile = profile;

    if (profile?.blog_repo && profile?.blog_status === 'active') {
      renderBlogView(profile, username);
    } else {
      renderNoBlogView(username);
    }
  })();

  // ===== 无博客视图 =====
  function renderNoBlogView(username) {
    document.getElementById('dbNoBlogBlock').style.display = '';
    const btn = document.getElementById('dbCreateBlog');
    btn.addEventListener('click', () => createBlog());
    // 显示提示
    document.getElementById('dbNoBlogHint').style.display = '';
  }

  async function createBlog() {
    const btn = document.getElementById('dbCreateBlog');
    const progDiv = document.getElementById('dbCreateProgress');
    const fill = document.getElementById('dbProgressFill');
    const text = document.getElementById('dbProgressText');

    btn.disabled = true; btn.textContent = '创建中...';
    progDiv.style.display = '';
    fill.style.width = '10%'; text.textContent = '检查 GitHub 授权...';

    if (!currentSession?.provider_token) {
      text.textContent = '需要 GitHub 授权，请先使用 GitHub 登录云笺。';
      btn.textContent = '使用 GitHub 登录'; btn.disabled = false;
      btn.onclick = () => { window.location.href = '/yunjian/login'; };
      return;
    }

    const providerToken = currentSession.provider_token;
    const githubUsername = currentUser.user_metadata?.github_username || currentUser.user_metadata?.user_name;
    const repoName = 'yunjian-blog';

    fill.style.width = '25%'; text.textContent = '创建 GitHub 仓库...';

    try {
      // 1. 创建仓库
      let createResp = await fetch('https://api.github.com/user/repos', {
        method:'POST',
        headers:{ Authorization:`Bearer ${providerToken}`, Accept:'application/vnd.github+json', 'Content-Type':'application/json' },
        body:JSON.stringify({ name:repoName, description:'Personal blog powered by YunJian', private:false, has_issues:false, has_projects:false, has_wiki:false, auto_init:true })
      });
      if (!createResp.ok) { const e=await createResp.json(); throw new Error(e.message); }

      fill.style.width = '50%'; text.textContent = '推送配置文件...';

      // 2. 推送模板文件
      const files = [
        { path:'config.json', content:btoa(JSON.stringify({title:`${githubUsername}的博客`,subtitle:'',author:githubUsername,theme:'default',language:'zh-CN',posts_per_page:10,nav:[{label:'首页',url:'/'},{label:'归档',url:'/archive'}],social:{github:'',twitter:''}},null,2)) },
        { path:'posts/hello-world.md', content:btoa('---\ntitle: "Hello World"\ndate: '+new Date().toISOString().split('T')[0]+'\ntags: []\ncategory: "未分类"\n---\n\n欢迎来到我的博客！这是第一篇文章。\n\n## 关于本博客\n\n本博客由**云笺**平台自动创建，基于 GitHub Pages 托管，永久免费。\n\n## 开始写作\n\n1. 登录云笺平台\n2. 使用在线编辑器写作\n3. 点击发布，自动部署上线\n') },
        { path:'package.json', content:btoa(JSON.stringify({name:'yunjian-blog',private:true,scripts:{build:'node build.js'}},null,2)) },
        { path:'.github/workflows/deploy.yml', content:btoa('name: Deploy Blog\non:\n  push:\n    branches: [main]\n  workflow_dispatch:\njobs:\n  build:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - run: |\n          mkdir -p public\n          echo "<!DOCTYPE html><html><head><meta charset=utf-8><title>Blog</title></head><body><h1>Blog Setup Complete</h1><p>Site is being deployed...</p></body></html>" > public/index.html\n      - uses: peaceiris/actions-gh-pages@v4\n        with:\n          github_token: ${{ secrets.GITHUB_TOKEN }}\n          publish_dir: ./public\n') }
      ];

      for (const f of files) {
        await fetch(`https://api.github.com/repos/${githubUsername}/${repoName}/contents/${f.path}`, {
          method:'PUT',
          headers:{ Authorization:`Bearer ${providerToken}`, Accept:'application/vnd.github+json', 'Content-Type':'application/json' },
          body:JSON.stringify({ message:`Add ${f.path}`, content:f.content })
        });
      }

      fill.style.width = '75%'; text.textContent = '开启 GitHub Pages...';

      // 3. 开启 Pages
      await fetch(`https://api.github.com/repos/${githubUsername}/${repoName}/pages`, {
        method:'POST',
        headers:{ Authorization:`Bearer ${providerToken}`, Accept:'application/vnd.github+json', 'Content-Type':'application/json' },
        body:JSON.stringify({ source:{ branch:'main', path:'/' } })
      });

      fill.style.width = '90%'; text.textContent = '保存配置...';

      // 4. 保存到 Supabase
      const blogURL = `https://${githubUsername}.github.io/${repoName}`;
      await supabase.from('profiles').upsert({
        id: currentUser.id, blog_repo: `${githubUsername}/${repoName}`, blog_url: blogURL,
        blog_status: 'active', blog_theme: 'default'
      });

      fill.style.width = '100%'; text.textContent = `博客创建成功！${blogURL}`;
      btn.textContent = '前往博客'; btn.disabled = false;
      btn.onclick = () => window.open(blogURL, '_blank');
      setTimeout(() => location.reload(), 2500);

    } catch(e) {
      text.textContent = `创建失败: ${e.message}`;
      btn.textContent = '重试'; btn.disabled = false;
    }
  }

  // ===== 已有博客视图 =====
  async function renderBlogView(profile, username) {
    document.getElementById('dbBlogContent').style.display = '';

    // 状态栏
    document.getElementById('dbStatusText').textContent = '运行中';
    document.getElementById('dbBlogUrlInput').value = profile.blog_url || '部署中...';

    // 统计
    const { data: posts } = await supabase.from('posts').select('*').eq('user_id', currentUser.id).order('updated_at', { ascending: false });
    allPosts = posts || [];
    const published = allPosts.filter(p=>p.status==='published');
    const drafts = allPosts.filter(p=>p.status==='draft');
    const totalWords = allPosts.reduce((sum,p)=>sum+(p.content?p.content.replace(/[#*`\[\]()!_~>|-\s]/g,'').length:0), 0);

    document.getElementById('dbStatTotal').textContent = allPosts.length;
    document.getElementById('dbStatPublished').textContent = published.length;
    document.getElementById('dbStatDrafts').textContent = drafts.length;
    document.getElementById('dbStatWords').textContent = totalWords.toLocaleString();

    // 博客信息
    document.getElementById('dbInfoTheme').textContent = profile.blog_theme || 'default';
    document.getElementById('dbInfoRepo').textContent = profile.blog_repo || '--';

    // 文章表格 - 第一页
    renderPostsTable(1);

    // 最近草稿
    const recentDrafts = drafts.slice(0, 5);
    const draftEl = document.getElementById('dbRecentDrafts');
    if (recentDrafts.length === 0) { draftEl.innerHTML = '<p style="color:#484f58;font-size:13px;padding:16px">暂无草稿</p>'; }
    else {
      draftEl.innerHTML = recentDrafts.map(p => `
        <div class="db-log-item" style="cursor:pointer" onclick="location.href='/yunjian/editor?post=${p.slug}'">
          <span>${p.title || '未命名'}</span>
          <span class="db-log-time">${new Date(p.updated_at).toLocaleDateString('zh-CN')}</span>
        </div>
      `).join('');
    }

    // 搜索
    document.getElementById('dbSearchPosts').addEventListener('input', e => {
      const q = e.target.value.toLowerCase();
      const filtered = allPosts.filter(p => p.title?.toLowerCase().includes(q));
      renderPostsTable(1, filtered);
    });

    // 复制 URL
    document.getElementById('dbCopyUrl').addEventListener('click', () => {
      const inp = document.getElementById('dbBlogUrlInput');
      inp.select(); document.execCommand('copy');
      const btn = document.getElementById('dbCopyUrl');
      btn.textContent = '已复制';
      setTimeout(()=>{ btn.textContent = '复制'; }, 2000);
    });
  }

  function renderPostsTable(page = 1, filteredPosts = null) {
    const posts = filteredPosts || allPosts;
    const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE) || 1;
    const start = (page-1)*POSTS_PER_PAGE;
    const pagePosts = posts.slice(start, start+POSTS_PER_PAGE);

    const tbody = document.getElementById('dbPostsTable');
    if (pagePosts.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:#484f58;padding:32px">暂无文章</td></tr>';
    } else {
      tbody.innerHTML = pagePosts.map(p => `
        <tr>
          <td><a href="/yunjian/editor?post=${p.slug}" style="color:var(--db-accent);text-decoration:none;font-weight:600">${p.title || '未命名'}</a></td>
          <td><span class="db-tag ${p.status==='published'?'db-tag-pub':'db-tag-draft'}">${p.status==='published'?'已发布':'草稿'}</span></td>
          <td style="color:var(--db-muted)">${p.published_at?new Date(p.published_at).toLocaleDateString('zh-CN'):'--'}</td>
          <td style="color:var(--db-muted)">${p.content?p.content.replace(/[#*`\[\]()!_~>|-\s]/g,'').length:0}</td>
          <td>
            <a href="/yunjian/editor?post=${p.slug}" class="db-btn db-btn-sm" style="margin-right:4px">编辑</a>
            <button class="db-btn db-btn-sm db-btn-danger" onclick="event.stopPropagation();deletePost('${p.slug}')">删除</button>
          </td>
        </tr>
      `).join('');
    }

    // 分页
    const pagEl = document.getElementById('dbPagination');
    if (totalPages <= 1) { pagEl.innerHTML = ''; return; }
    pagEl.innerHTML = Array.from({length:totalPages}, (_,i) => i+1).map(i =>
      `<button class="db-page-btn ${i===page?'active':''}" onclick="window._renderPage(${i})">${i}</button>`
    ).join('');
    window._renderPage = (p) => renderPostsTable(p, filteredPosts);
  }

  // ===== 删除文章 =====
  window.deletePost = async function(slug) {
    if (!confirm('确定删除这篇文章？')) return;
    await supabase.from('posts').delete().eq('user_id', currentUser.id).eq('slug', slug);
    location.reload();
  };
</script>
