---
---

<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>注册 · 云笺</title>
</head>
<body>
<div class="auth-root">
  <div class="auth-split">
    <!-- 左：表单 -->
    <div class="auth-form-side">
      <a href="/yunjian" class="auth-back">&larr; 返回云笺</a>
      <h1>创建你的云笺账号</h1>
      <p class="auth-sub">三分钟拥有自己的独立博客</p>

      <div id="auth-msg" class="auth-msg" style="display:none"></div>

      <form class="auth-form" id="register-form">
        <div class="form-group">
          <label for="username">用户名</label>
          <input type="text" id="username" placeholder="你的用户名" autocomplete="username" required />
        </div>
        <div class="form-group">
          <label for="email">邮箱</label>
          <input type="email" id="email" placeholder="you@example.com" autocomplete="email" required />
        </div>
        <div class="form-group">
          <label for="password">密码</label>
          <input type="password" id="password" placeholder="至少 8 位字符" autocomplete="new-password" required />
          <div class="pw-meter"><div class="pw-bar" id="pw-bar"></div></div>
          <span class="pw-hint" id="pw-hint"></span>
        </div>
        <div class="form-group">
          <label for="confirm-password">确认密码</label>
          <input type="password" id="confirm-password" placeholder="再次输入密码" autocomplete="new-password" required />
        </div>

        <button type="button" class="auth-btn-github" id="btn-github">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          使用 GitHub 注册
        </button>

        <div class="form-group form-check">
          <label class="check-label">
            <input type="checkbox" id="agree" required />
            <span>我已阅读并同意 <a href="/links/terms">服务协议</a> 和 <a href="/links/privacy">隐私政策</a></span>
          </label>
        </div>

        <button type="submit" class="auth-btn-submit" id="btn-submit">创建账号</button>
      </form>

      <div class="auth-footer">
        已有账号？<a href="/yunjian/login">立即登录</a>
      </div>
    </div>

    <!-- 右：理由 -->
    <div class="auth-info-side">
      <div class="auth-info-cta">
        <h2>为什么选择云笺</h2>
        <div class="auth-reason-list">
          <div class="auth-reason">
            <div class="auth-reason-icon">&#9889;</div>
            <div>
              <strong>三分钟上线</strong>
              <p>GitHub 授权后一键创建仓库，博客自动部署上线，无需配置服务器。</p>
            </div>
          </div>
          <div class="auth-reason">
            <div class="auth-reason-icon">&#127379;</div>
            <div>
              <strong>永久免费</strong>
              <p>基于 GitHub Pages 托管，无流量限制，无隐藏费用。你的内容永远属于你。</p>
            </div>
          </div>
          <div class="auth-reason">
            <div class="auth-reason-icon">&#127760;</div>
            <div>
              <strong>独立域名</strong>
              <p>默认 GitHub Pages 域名，支持绑定自定义域名，HTTPS 自动配置，全球 CDN 加速。</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>

<style>
  :root { --auth-bg:#ffffff; --auth-card:#ffffff; --auth-border:#e8ecf1; --auth-text:#1f2328; --auth-dim:#656d76; --auth-muted:#8b949e; --auth-accent:#0969da; --auth-green:#1a7f37; }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; background:#f6f8fa; color:var(--auth-text); }
  .auth-root { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:40px 20px; }
  .auth-split { display:flex; max-width:920px; width:100%; background:var(--auth-card); border-radius:16px; box-shadow:0 4px 24px rgba(0,0,0,0.06); overflow:hidden; }
  /* 左侧表单 */
  .auth-form-side { flex:1; padding:48px 40px; }
  .auth-back { display:inline-block; color:var(--auth-dim); text-decoration:none; font-size:13px; margin-bottom:24px; }
  .auth-back:hover { color:var(--auth-accent); }
  .auth-form-side h1 { font-size:1.6rem; font-weight:800; color:var(--auth-text); margin-bottom:4px; }
  .auth-sub { color:var(--auth-dim); font-size:0.95rem; margin-bottom:24px; }
  .auth-msg { padding:10px 14px; border-radius:6px; font-size:13px; margin-bottom:18px; display:none; }
  .auth-msg.error { display:block; background:#fff1f0; border:1px solid #ffccc7; color:#cf1322; }
  .auth-msg.success { display:block; background:#f6ffed; border:1px solid #b7eb8f; color:#389e0d; }
  .auth-form { display:flex; flex-direction:column; gap:16px; }
  .form-group { display:flex; flex-direction:column; gap:6px; }
  .form-group label { font-size:13px; font-weight:600; color:var(--auth-text); }
  .form-group input[type="text"],
  .form-group input[type="email"],
  .form-group input[type="password"] {
    padding:10px 14px; background:#f6f8fa; border:1px solid var(--auth-border); border-radius:6px; font-size:14px; color:var(--auth-text); outline:none; transition:.15s; font-family:inherit;
  }
  .form-group input:focus { border-color:var(--auth-accent); box-shadow:0 0 0 3px rgba(9,105,218,0.1); background:#fff; }
  .form-group input::placeholder { color:var(--auth-muted); }
  .pw-meter { height:3px; background:#e8ecf1; border-radius:2px; margin-top:4px; overflow:hidden; }
  .pw-bar { height:100%; border-radius:2px; transition:width .3s; width:0; }
  .pw-hint { font-size:11px; color:var(--auth-muted); }
  .form-check { flex-direction:row; }
  .check-label { display:flex; align-items:center; gap:8px; font-size:13px; color:var(--auth-dim); cursor:pointer; }
  .check-label input[type="checkbox"] { accent-color:var(--auth-accent); }
  .check-label a { color:var(--auth-accent); text-decoration:none; }
  .check-label a:hover { text-decoration:underline; }
  .auth-btn-github { display:flex; align-items:center; justify-content:center; gap:10px; padding:12px; background:#24292e; border:1px solid #444d56; border-radius:6px; color:#fff; font-size:14px; font-weight:600; cursor:pointer; width:100%; font-family:inherit; }
  .auth-btn-github:hover { background:#2f363d; }
  .auth-btn-submit { padding:12px; background:var(--auth-accent); border:none; border-radius:6px; color:#fff; font-size:14px; font-weight:700; cursor:pointer; width:100%; font-family:inherit; }
  .auth-btn-submit:hover { background:#0550ae; }
  .auth-btn-submit:disabled { opacity:0.6; cursor:not-allowed; }
  .auth-footer { text-align:center; margin-top:24px; font-size:13px; color:var(--auth-dim); }
  .auth-footer a { color:var(--auth-accent); text-decoration:none; font-weight:600; }

  /* 右侧信息 */
  .auth-info-side { width:380px; flex-shrink:0; background:linear-gradient(135deg, #0969da 0%, #0550ae 100%); padding:48px 36px; display:flex; align-items:center; }
  .auth-info-cta { color:#fff; }
  .auth-info-cta h2 { font-size:1.3rem; font-weight:700; margin-bottom:32px; }
  .auth-reason-list { display:flex; flex-direction:column; gap:28px; }
  .auth-reason { display:flex; gap:14px; align-items:flex-start; }
  .auth-reason-icon { font-size:24px; width:40px; height:40px; background:rgba(255,255,255,0.15); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .auth-reason strong { display:block; font-size:1rem; margin-bottom:4px; }
  .auth-reason p { font-size:0.85rem; opacity:0.85; line-height:1.6; margin:0; }

  @media (max-width:768px) {
    .auth-split { flex-direction:column; }
    .auth-info-side { width:100%; padding:32px 24px; }
    .auth-form-side { padding:32px 24px; }
  }
</style>

<script>
  import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';
  const supabase = createClient('https://xwvkdluvixurvgvkhkfe.supabase.co','sb_publishable_NOdEPhf8yD4dMRJIH1JqqA_z5By3p0H');

  const form = document.getElementById('register-form');
  const pwInput = document.getElementById('password');
  const pwBar = document.getElementById('pw-bar');
  const pwHint = document.getElementById('pw-hint');
  const msgBox = document.getElementById('auth-msg');
  const btnSubmit = document.getElementById('btn-submit');

  function showMsg(text, type) {
    msgBox.textContent = text;
    msgBox.className = 'auth-msg ' + type;
  }

  function assessPassword(pw) {
    let score = 0;
    if (pw.length >= 8) score++;
    if (pw.length >= 12) score++;
    if (/[A-Z]/.test(pw)) score++;
    if (/[a-z]/.test(pw)) score++;
    if (/[0-9]/.test(pw)) score++;
    if (/[^A-Za-z0-9]/.test(pw)) score++;
    const levels = [
      { w: 0,   color: 'transparent', text: '' },
      { w: 16,  color: '#cf222e', text: '弱 — 太短了' },
      { w: 33,  color: '#d1242f', text: '较弱 — 增加大小写和数字' },
      { w: 50,  color: '#bf8700', text: '中等 — 还可更强' },
      { w: 66,  color: '#1a7f37', text: '较强' },
      { w: 83,  color: '#1a7f37', text: '强' },
      { w: 100, color: '#1a7f37', text: '很强' }
    ];
    return levels[Math.min(score, levels.length - 1)];
  }

  pwInput.addEventListener('input', () => {
    const r = assessPassword(pwInput.value);
    pwBar.style.width = r.w + '%';
    pwBar.style.background = r.color;
    pwHint.textContent = r.text;
  });

  document.getElementById('btn-github').addEventListener('click', async () => {
    const { data, error } = await supabase.auth.signInWithOAuth({
      provider: 'github',
      options: { redirectTo: window.location.origin + '/yunjian/dashboard' }
    });
    if (error) showMsg('GitHub 授权失败: ' + error.message, 'error');
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const username = document.getElementById('username').value.trim();
    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value;
    const confirmPw = document.getElementById('confirm-password').value;
    const agreed = document.getElementById('agree').checked;

    if (!username) return showMsg('请输入用户名', 'error');
    if (username.length < 2) return showMsg('用户名至少 2 个字符', 'error');
    if (!email) return showMsg('请输入邮箱', 'error');
    if (!password) return showMsg('请输入密码', 'error');
    if (password.length < 8) return showMsg('密码至少 8 位字符', 'error');
    if (password !== confirmPw) return showMsg('两次输入的密码不一致', 'error');
    if (!agreed) return showMsg('请先同意服务协议和隐私政策', 'error');

    btnSubmit.disabled = true; btnSubmit.textContent = '注册中...';

    const { data, error } = await supabase.auth.signUp({
      email, password,
      options: { data: { username } }
    });

    if (error) {
      if (error.message.includes('registered') || error.message.includes('exists'))
        showMsg('该邮箱已被注册，请直接登录', 'error');
      else
        showMsg('注册失败: ' + error.message, 'error');
      btnSubmit.disabled = false; btnSubmit.textContent = '创建账号';
      return;
    }

    if (data?.user?.identities?.length === 0) {
      showMsg('该邮箱已被注册，请直接登录', 'error');
      btnSubmit.disabled = false; btnSubmit.textContent = '创建账号';
      return;
    }

    showMsg('注册成功！正在跳转...', 'success');
    setTimeout(() => { window.location.href = '/yunjian/dashboard'; }, 1500);
  });
</script>
