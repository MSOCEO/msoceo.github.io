---
import Page from '../../layouts/Page.astro';

const title = '登录 · 云笺';
const description = '登录你的云笺账号';
---

<Page {title} {description}>
  <div class="auth-root">
    <div class="auth-card">
      <div class="auth-header">
        <a href="/yunjian" class="auth-back">&larr; 返回云笺</a>
        <h1>欢迎回来</h1>
        <p>登录你的云笺账号</p>
      </div>

      <form class="auth-form">
        <div class="form-group">
          <label for="email">邮箱</label>
          <input type="email" id="email" placeholder="you@example.com" autocomplete="email" />
        </div>
        <div class="form-group">
          <label for="password">密码</label>
          <input type="password" id="password" placeholder="输入密码" autocomplete="current-password" />
        </div>

        <button type="button" class="auth-btn-github">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          使用 GitHub 授权登录
        </button>

        <button type="submit" class="auth-btn-submit">登录</button>
      </form>

      <div class="auth-footer">
        还没有账号？<a href="/yunjian/register">免费注册</a>
      </div>
    </div>
  </div>
</Page>

<style>
  .auth-root {
    min-height: calc(100vh - var(--header-height));
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ink-10);
    position: relative;
    padding: var(--space-2xl) var(--space-xl);
  }
  .auth-root::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--texture-noise);
    pointer-events: none;
  }
  .auth-card {
    position: relative;
    z-index: 2;
    background: #0f1a16;
    border: 1px solid rgba(16,185,129,0.12);
    border-radius: var(--radius-lg);
    padding: 40px;
    width: 100%;
    max-width: 440px;
    box-shadow: var(--shadow-card);
  }
  .auth-header { text-align: center; margin-bottom: 32px; }
  .auth-back {
    display: inline-block;
    font-size: var(--text-xs);
    color: var(--ink-50);
    text-decoration: none;
    margin-bottom: 20px;
    transition: color 0.15s;
  }
  .auth-back:hover { color: #10b981; }
  .auth-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--ink-100);
    margin-bottom: 8px;
  }
  .auth-header p {
    font-size: var(--text-sm);
    color: #6b8a7a;
    margin: 0;
  }

  .auth-form { display: flex; flex-direction: column; gap: 18px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group label {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--ink-50);
  }
  .form-group input[type="text"],
  .form-group input[type="email"],
  .form-group input[type="password"] {
    padding: 11px 14px;
    background: #0a0f0c;
    border: 1px solid rgba(16,185,129,0.15);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--ink-90);
    outline: none;
    transition: border-color 0.2s;
    font-family: inherit;
  }
  .form-group input:focus {
    border-color: #10b981;
    box-shadow: 0 0 0 3px rgba(16,185,129,0.1);
  }
  .form-group input::placeholder { color: var(--ink-40); }

  .auth-btn-github {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 13px;
    background: #24292e;
    border: 1px solid #444d56;
    border-radius: var(--radius-sm);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    font-family: inherit;
    width: 100%;
  }
  .auth-btn-github:hover { background: #2f363d; }

  .auth-btn-submit {
    padding: 13px;
    background: #10b981;
    border: none;
    border-radius: var(--radius-sm);
    color: #0a0a0a;
    font-size: var(--text-sm);
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }
  .auth-btn-submit:hover {
    background: #059669;
    box-shadow: 0 0 20px rgba(16,185,129,0.15);
  }

  .auth-footer {
    text-align: center;
    margin-top: 24px;
    font-size: var(--text-xs);
    color: var(--ink-50);
  }
  .auth-footer a {
    color: #10b981;
    text-decoration: none;
    font-weight: 500;
  }
  .auth-footer a:hover { text-decoration: underline; }
</style>
