---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_AUTHOR } from '../consts';
---

<BaseLayout title="关于">
  <div class="max-w-2xl mx-auto">
    <h1 class="font-serif font-black text-3xl mb-8">关于</h1>

    <!-- 个人简介 -->
    <div class="ink-card ink-card-alt p-6 mb-8">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-5">
        <div class="avatar-sketch w-24 h-24 flex-shrink-0">
          <div class="w-full h-full rounded-full bg-[var(--ink-200)] dark:bg-[var(--ink-700)] flex items-center justify-center text-3xl font-serif text-[var(--accent)]">
            寒
          </div>
        </div>
        <div>
          <h2 class="font-serif font-bold text-2xl mb-2">{SITE_AUTHOR}</h2>
          <p class="text-sm text-[var(--text-tertiary)] leading-relaxed">
            全栈开发者 · 文字爱好者 · 终身学习者<br/>
            坐标：互联网深处
          </p>
          <div class="flex gap-3 mt-3">
            <a href="https://github.com/msoceo" target="_blank" rel="noopener" class="tag-pill">GitHub</a>
            <a href="/rss.xml" class="tag-pill">RSS</a>
          </div>
        </div>
      </div>
    </div>

    <!-- 技术栈 -->
    <div class="ink-card ink-card-alt p-6 mb-8">
      <h3 class="font-serif font-bold text-lg mb-4">技术栈</h3>
      <div class="flex flex-wrap gap-2">
        {['TypeScript', 'Python', 'Astro', 'React', 'Next.js', 'TailwindCSS', 'Node.js', 'Docker', 'Linux', 'PostgreSQL'].map(skill => (
          <span class="tag-pill">{skill}</span>
        ))}
      </div>
    </div>

    <!-- 项目 -->
    <div class="ink-card ink-card-alt p-6 mb-8">
      <h3 class="font-serif font-bold text-lg mb-4">项目</h3>
      <div class="space-y-4">
        <div class="p-4 rounded-lg bg-[var(--bg-secondary)]">
          <h4 class="font-medium mb-1">寒影博客</h4>
          <p class="text-sm text-[var(--text-tertiary)]">Astro + TailwindCSS 构建的个人博客，墨迹主题。</p>
        </div>
      </div>
    </div>

    <!-- 联系方式 -->
    <div class="ink-card ink-card-alt p-6">
      <h3 class="font-serif font-bold text-lg mb-4">联系</h3>
      <p class="text-sm text-[var(--text-tertiary)] leading-relaxed">
        如需联系，欢迎通过 <a href="https://github.com/msoceo" target="_blank" rel="noopener" class="underline">GitHub Issues</a> 留言。
      </p>
    </div>
  </div>
</BaseLayout>
