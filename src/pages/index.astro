---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <style>
    .gate {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      background: radial-gradient(ellipse at 50% 50%, oklch(14% 0.02 265) 0%, oklch(8% 0.015 265) 100%);
    }

    .gate-bg {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
    }

    .gate-grid {
      position: absolute;
      inset: 0;
      background-image: 
        linear-gradient(to right, oklch(28% 0.025 265 / 0.08) 1px, transparent 1px),
        linear-gradient(to bottom, oklch(28% 0.025 265 / 0.08) 1px, transparent 1px);
      background-size: 60px 60px;
    }

    .gate-scanline {
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.025) 2px,
        rgba(0, 0, 0, 0.025) 4px
      );
    }

    .gate-noise {
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.015'/%3E%3C/svg%3E");
    }

    .gate-main {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 2rem;
      max-width: 640px;
    }

    .gate-title {
      font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
      font-size: clamp(2.8rem, 5vw, 4.2rem);
      font-weight: 300;
      letter-spacing: -0.03em;
      line-height: 1.1;
      color: oklch(92% 0.01 265);
      opacity: 0;
      animation: gateIn 1s cubic-bezier(0.4, 0, 0.2, 1) 0.2s forwards;
    }

    .gate-title-line {
      display: block;
      letter-spacing: 0.06em;
    }

    .gate-title-line + .gate-title-line {
      margin-top: -0.15em;
    }

    .gate-motto {
      font-size: clamp(1rem, 2vw, 1.25rem);
      color: oklch(68% 0.015 265);
      font-weight: 300;
      letter-spacing: 0.04em;
      margin-top: 1.5rem;
      opacity: 0;
      animation: gateIn 1s cubic-bezier(0.4, 0, 0.2, 1) 0.5s forwards;
    }

    .gate-desc {
      font-size: clamp(0.85rem, 1.5vw, 0.95rem);
      color: oklch(48% 0.015 265);
      margin-top: 0.5rem;
      font-weight: 300;
      line-height: 1.6;
      opacity: 0;
      animation: gateIn 1s cubic-bezier(0.4, 0, 0.2, 1) 0.7s forwards;
    }

    .gate-enter {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 3rem;
      padding: 0.9rem 2.5rem;
      background: transparent;
      border: 1px solid oklch(28% 0.025 265);
      color: oklch(68% 0.015 265);
      font-family: 'Space Grotesk', system-ui, sans-serif;
      font-size: 0.95rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      border-radius: 4px;
      position: relative;
      overflow: hidden;
      transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      opacity: 0;
      animation: gateIn 1s cubic-bezier(0.4, 0, 0.2, 1) 1s forwards;
    }

    .gate-enter::before {
      content: '';
      position: absolute;
      inset: 0;
      background: oklch(72% 0.18 62);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: -1;
    }

    .gate-enter:hover {
      color: oklch(10% 0.025 265);
      border-color: oklch(72% 0.18 62);
      transform: translateY(-2px);
      box-shadow: 0 4px 24px oklch(72% 0.18 62 / 0.15);
    }

    .gate-enter:hover::before {
      transform: scaleX(1);
    }

    .gate-arrow {
      display: inline-block;
      transition: transform 0.3s ease;
    }

    .gate-enter:hover .gate-arrow {
      transform: translateX(4px);
    }

    .gate-footer {
      position: absolute;
      bottom: 2rem;
      left: 0;
      right: 0;
      text-align: center;
      font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', monospace;
      font-size: 0.72rem;
      color: oklch(48% 0.015 265);
      letter-spacing: 0.05em;
      opacity: 0;
      animation: gateIn 1s cubic-bezier(0.4, 0, 0.2, 1) 1.3s forwards;
    }

    @keyframes gateIn {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 640px) {
      .gate-main {
        padding: 1.5rem;
      }

      .gate-enter {
        padding: 0.8rem 2rem;
        font-size: 0.88rem;
      }
    }
  </style>
</head>
<body>
  <div class="gate">
    <div class="gate-bg">
      <div class="gate-grid"></div>
      <div class="gate-scanline"></div>
      <div class="gate-noise"></div>
    </div>

    <div class="gate-main">
      <h1 class="gate-title">
        <span class="gate-title-line">离 群 索 居</span>
        <span class="gate-title-line">不 是 野 兽</span>
        <span class="gate-title-line">便 是 神 灵</span>
      </h1>
      <p class="gate-motto">当极简主义遇上工程之美</p>
      <p class="gate-desc">{SITE_DESCRIPTION}</p>

      <a href="/home" class="gate-enter">
        <span>进入首页</span>
        <span class="gate-arrow">→</span>
      </a>
    </div>

    <div class="gate-footer">
      <span>MSOCEO &copy; {new Date().getFullYear()} &mdash; Powered by Astro</span>
    </div>
  </div>
</body>
</html>