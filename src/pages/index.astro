---
import Page from '../layouts/Page.astro';
import AuroraBg from '../components/AuroraBg.astro';
import Fireflies from '../components/Fireflies.astro';
import GlowFollow from '../components/GlowFollow.astro';
import { getCollection } from 'astro:content';

const allPostsUnsorted = await getCollection('blog');
const allPosts = allPostsUnsorted.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const PAGE_SIZE = 3;
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);

const allTags = new Map();
allPosts.forEach(p => {
  const tags = p.data.tags || [];
  tags.forEach(t => {
    const tag = String(t).trim();
    if (tag) allTags.set(tag, (allTags.get(tag) || 0) + 1);
  });
});
const tagsSorted = [...allTags.entries()].sort((a, b) => b[1] - a[1]);

const SOLAR_TERMS: Record<string, string> = {
  '1-1': '元旦', '2-4': '立春', '3-5': '惊蛰', '3-20': '春分',
  '4-4': '清明', '4-20': '谷雨', '5-5': '立夏', '5-21': '小满',
  '6-5': '芒种', '6-21': '夏至', '7-7': '小暑', '7-23': '大暑',
  '8-7': '立秋', '8-23': '处暑', '9-7': '白露', '9-23': '秋分',
  '10-8': '寒露', '10-23': '霜降', '11-7': '立冬', '11-22': '小雪',
  '12-7': '大雪', '12-21': '冬至', '1-5': '小寒', '1-20': '大寒',
};
const WEEKDAYS = ['日曜', '月曜', '火曜', '水曜', '木曜', '金曜', '土曜'];

function formatDiaryDate(date: Date): string {
  const m = date.getMonth() + 1;
  const d = date.getDate();
  const key = `${m}-${d}`;
  const term = SOLAR_TERMS[key] || '';
  const wd = WEEKDAYS[date.getDay()];
  const base = `${m}月${d}日 · ${wd}`;
  return term ? `${base} · ${term}` : base;
}

const title = '寒影·拾光';
const description = '在深夜书房里，拾取散落的光';
---

<Page {title} {description}>
  <!-- v3 动态装饰层 -->
  <AuroraBg />
  <Fireflies />
  <GlowFollow />

  <div class="diary-page">
    <header class="diary-header">
      <div class="diary-header-decoration">
        <span class="decoration-dot"></span>
        <span class="decoration-line"></span>
        <span class="decoration-dot"></span>
      </div>
      <h1 class="diary-title">拾光日记</h1>
      <p class="diary-subtitle">{description}</p>
    </header>

    <div class="diary-search-bar">
      <svg class="diary-search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="text" class="diary-search-input" id="blogSearch" placeholder="搜索日记..." autocomplete="off" />
      <span class="diary-search-count">{allPosts.length} 篇</span>
    </div>

    {tagsSorted.length > 0 && (
      <div class="diary-tag-cloud">
        <button class="diary-tag diary-tag-active" onclick="filterByTag(null, this)">全部</button>
        {tagsSorted.map(([tag, count]) => (
          <button class="diary-tag" onclick={`filterByTag('${tag}', this)`}>{tag}({count})</button>
        ))}
      </div>
    )}

    <div class="bento-grid" id="postGrid">
      {allPosts.map((post, i) => (
        <article
          class="diary-card"
          style={`--anim-delay: ${i * 80}ms`}
          data-tags={JSON.stringify(post.data.tags || [])}
        >
          <a href={`/blog/${post.id}`} class="diary-card-link">
            <time class="card-date" datetime={post.data.pubDate.toISOString()}>
              {formatDiaryDate(post.data.pubDate)}
            </time>
            <h2 class="card-title">{post.data.title}</h2>
            <p class="card-desc">{post.data.description}</p>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="diary-tags">
                {post.data.tags.map(tag => <span class="diary-post-tag">{tag}</span>)}
              </div>
            )}
          </a>
        </article>
      ))}
    </div>
  </div>
</Page>

<style>
  .diary-page {
    max-width: 780px;
    margin: 0 auto;
    position: relative;
    z-index: 10;
  }

  /* ---- 页头 ---- */
  .diary-header {
    text-align: center;
    padding: 2.5rem 0 1.5rem;
  }

  .diary-header-decoration {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .decoration-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .decoration-line {
    width: 60px; height: 1px;
    background: linear-gradient(to right, transparent, var(--color-accent), transparent);
  }

  .diary-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
  }

  .diary-subtitle {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  /* ---- 搜索框 ---- */
  .diary-search-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: 0.6rem 1rem;
    margin-bottom: 1.5rem;
    transition: border-color var(--duration-fast);
  }

  .diary-search-bar:focus-within {
    border-color: var(--glass-border-hover);
  }

  .diary-search-icon {
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  .diary-search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-size: 0.9rem;
    color: var(--color-text-primary);
    font-family: inherit;
  }

  .diary-search-input::placeholder {
    color: var(--color-text-muted);
  }

  .diary-search-count {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  /* ---- 标签云 ---- */
  .diary-tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .diary-tag {
    font-size: 0.75rem;
    padding: 0.25em 0.75em;
    border-radius: 14px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    font-family: inherit;
  }

  .diary-tag:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .diary-tag-active {
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* ---- 卡片进入动画 ---- */
  .diary-card {
    opacity: 0;
    animation: diaryFadeIn 0.5s var(--ease-out) forwards;
    animation-delay: var(--anim-delay, 0ms);
  }

  @keyframes diaryFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ---- 卡片内部链接 ---- */
  .diary-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  /* ---- 标签 ---- */
  .diary-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }

  .diary-post-tag {
    font-size: 0.7rem;
    padding: 0.15em 0.55em;
    border-radius: 10px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .diary-page { max-width: 100%; padding: 0 1rem; }
    .diary-title { font-size: 1.5rem; }
    .diary-card { padding: 1.2rem 1rem; }
  }
</style>

<script>
  function filterByTag(tag, btn) {
    document.querySelectorAll('.diary-tag').forEach(b => b.classList.remove('diary-tag-active'));
    if (btn) btn.classList.add('diary-tag-active');
    
    const cards = document.querySelectorAll('.diary-card');
    cards.forEach(card => {
      if (!tag) {
        card.style.display = '';
        return;
      }
      try {
        const tags = JSON.parse(card.dataset.tags || '[]');
        card.style.display = tags.includes(tag) ? '' : 'none';
      } catch(e) {
        card.style.display = '';
      }
    });
  }

  document.getElementById('blogSearch')?.addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase();
    document.querySelectorAll('.diary-card').forEach(card => {
      const text = card.textContent?.toLowerCase() || '';
      card.style.display = text.includes(q) ? '' : 'none';
    });
  });
</script>
