---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE } from '../consts';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sorted = allPosts
  .filter(p => !p.data.draft)
  .map(p => ({
    title: p.data.title,
    date: p.data.pubDate.toISOString().split('T')[0],
    excerpt: p.data.description,
    tags: p.data.tags,
    slug: p.id,
    readingTime: `${Math.max(1, Math.ceil((p.body?.length || 0) / 500))} 分钟`,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout>
  <!-- 全屏 Hero 首屏 -->
  <div class="blog-hero">
    <div class="blog-hero-inner">
      <h1 class="blog-hero-title"><span class="accent-purple">寒</span>影<span class="accent-purple">·</span>拾光</h1>
      <p class="blog-hero-sub">在深夜书房里，拾取散落的光</p>
      <div class="blog-hero-line"></div>
    </div>
    <div class="blog-hero-scroll">
      <span>下滑阅读</span>
      <div class="blog-hero-arrow"></div>
    </div>
  </div>
  <div class="home-layout">
    <!-- 左侧栏 25% -->
    <aside class="home-sidebar home-sidebar-left">
      <div class="sidebar-avatar">
        <div class="sidebar-avatar-circle">
          <i class="fa-solid fa-user-astronaut"></i>
        </div>
        <h2 class="sidebar-name">{SITE.TITLE}</h2>
        <p class="sidebar-desc">{SITE.DESCRIPTION}</p>
      </div>
    </aside>

    <!-- 中间栏 50%：文章列表 -->
    <section class="home-main">
      {sorted.length === 0 && (
        <p class="empty-state">暂无文章，深夜书房正在筹备中...</p>
      )}
      {sorted.map((post, i) => (
        <PostCard
          slug={post.slug}
          title={post.title}
          date={post.date}
          excerpt={post.excerpt}
          tags={post.tags}
          readingTime={post.readingTime}
          index={i}
        />
      ))}
    </section>

    <!-- 右侧栏 25% -->
    <aside class="home-sidebar home-sidebar-right">
      <div class="sidebar-card glass-card">
        <h3 class="sidebar-title">热门文章</h3>
        <ul class="sidebar-list">
          {sorted.slice(0, 5).map(post => (
            <li><a href={`/blog/${post.slug}/`}>{post.title}</a></li>
          ))}
        </ul>
      </div>
      <div class="sidebar-card glass-card">
        <h3 class="sidebar-title">分类</h3>
        <div class="sidebar-tags">
          {[...new Set(sorted.flatMap(p => p.tags || []))].slice(0, 12).map(tag => (
            <a href={`/blog/?tag=${tag}`} class="sidebar-tag">{tag}</a>
          ))}
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  .home-layout {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .home-sidebar {
    position: sticky;
    top: 100px;
    width: 25%;
    flex-shrink: 0;
  }

  .home-main {
    width: 50%;
    flex-shrink: 0;
  }

  /* 左侧栏 - 头像 Logo */
  .sidebar-avatar {
    text-align: center;
    padding: 2rem 0;
  }

  .sidebar-avatar-circle {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    margin: 0 auto 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(167, 139, 250, 0.08);
    border: 2px solid rgba(167, 139, 250, 0.3);
    box-shadow: 0 0 24px rgba(167, 139, 250, 0.15);
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    font-size: 2.8rem;
    color: #A78BFA;
  }

  .sidebar-avatar-circle:hover {
    transform: rotate(360deg);
  }

  .sidebar-name {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: 0.1em;
  }

  .sidebar-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 0.4rem;
    letter-spacing: 0.08em;
  }

  /* 右侧栏 */
  .sidebar-card {
    padding: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .sidebar-title {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    color: #A78BFA;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(167, 139, 250, 0.1);
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
  }

  .sidebar-list li {
    margin-bottom: 0.5rem;
  }

  .sidebar-list a {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    transition: color 0.2s;
  }

  .sidebar-list a:hover {
    color: #A78BFA;
  }

  .sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .sidebar-tag {
    font-size: 0.72rem;
    padding: 0.2em 0.65em;
    border-radius: 12px;
    background: rgba(167, 139, 250, 0.1);
    color: #A78BFA;
    transition: background 0.2s;
  }

  .sidebar-tag:hover {
    background: rgba(167, 139, 250, 0.2);
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-muted);
    padding: 4rem 0;
    font-size: 0.9rem;
  }

  @media (max-width: 1024px) {
    .home-layout {
      flex-direction: column;
    }

    .home-sidebar,
    .home-main {
      width: 100%;
    }

    .home-sidebar {
      position: static;
      order: -1;
    }

    .sidebar-avatar-circle {
      width: 80px;
      height: 80px;
      font-size: 2rem;
    }
  }
</style>
