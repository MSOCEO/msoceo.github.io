---
// src/pages/index.astro — 黑曜石星光入口页
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main class="entrance-main">
      <div class="entrance-card">
        <h1 class="entrance-title">探索 · 发现 · 热爱</h1>
        <p class="entrance-subtitle">
          在代码的星空中寻找光，在生活的烟火里记录温度。<br/>
          这里是一个探索者的小站，分享科技、生活与一切值得被看见的事物。
        </p>
        <a href="/home" class="entrance-btn">
          <span>开始探索</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12,5 19,12 12,19"/>
          </svg>
        </a>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
.entrance-main {
  min-height: calc(100vh - 60px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl);
  position: relative;
}

.entrance-card {
  position: relative;
  max-width: 580px;
  width: 100%;
  padding: var(--space-3xl) var(--space-2xl);
  background: var(--surface-void);
  backdrop-filter: blur(24px) saturate(160%);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-2xl);
  text-align: center;
  box-shadow:
    0 0 60px oklch(78% 0.18 65 / 0.04),
    0 0 120px oklch(72% 0.14 195 / 0.02);
  animation: fadeInUp var(--duration-very-slow) var(--ease-out-expo) forwards;
}

.entrance-title {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 600;
  letter-spacing: 0.04em;
  margin-bottom: var(--space-md);
  background: linear-gradient(
    135deg,
    var(--star-warm) 0%,
    var(--lantern-warm) 40%,
    var(--tech-cyan) 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.entrance-subtitle {
  font-size: var(--text-base);
  color: var(--text-secondary);
  line-height: var(--leading-relaxed);
  margin-bottom: var(--space-xl);
  font-weight: 300;
}

.entrance-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2xs);
  padding: var(--space-sm) var(--space-xl);
  background: transparent;
  border: 1px solid oklch(78% 0.18 65 / 0.3);
  color: var(--star-warm);
  font-family: var(--font-body);
  font-size: var(--text-base);
  font-weight: 500;
  letter-spacing: 0.06em;
  border-radius: var(--radius-full);
  text-decoration: none;
  transition: all var(--duration-slow) var(--ease-out-expo);
}

.entrance-btn:hover {
  border-color: var(--star-warm);
  color: var(--obsidian-deep);
  background: var(--star-warm);
  transform: translateY(-2px);
  box-shadow:
    0 0 24px oklch(78% 0.18 65 / 0.2),
    0 0 48px oklch(78% 0.18 65 / 0.08);
}

.entrance-btn:active {
  transform: translateY(0);
}

@media (max-width: 640px) {
  .entrance-card {
    padding: var(--space-xl) var(--space-md);
  }

  .entrance-title {
    font-size: var(--text-2xl);
  }
}
</style>