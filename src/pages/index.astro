---
import Page from '../layouts/Page.astro';

const title = '寒影';
const description = '在沉寂中沉淀，于代码间生光';
---

<Page {title} {description}>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-accent" aria-hidden="true"></div>
      <h1 class="hero-title">寒影</h1>
      <p class="hero-subtitle-cn">在沉寂中沉淀，于代码间生光</p>
      <p class="hero-subtitle-en">Code in silence. Shine in depth.</p>
      <div class="hero-actions">
        <a href="/blog" class="btn btn-lg btn-primary">浏览博客</a>
        <a href="/links" class="btn btn-lg btn-secondary">开始探索</a>
      </div>
      <div class="hero-scroll-indicator" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
    <div class="hero-bg-orb hero-bg-orb-1" aria-hidden="true"></div>
    <div class="hero-bg-orb hero-bg-orb-2" aria-hidden="true"></div>
  </section>

  <!-- 导航站介绍 -->
  <section class="product-section section-alt" id="nav-station">
    <div class="content-narrow">
      <div class="product-row reverse">
        <div class="product-text">
          <span class="product-tag">产品</span>
          <h2>星迹导航</h2>
          <p>精心筛选的开发者工具、设计资源、开源项目导航站，数百个优质站点分类整理，一触即达。</p>
          <div class="product-features">
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>分类索引</span>
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>搜索直达</span>
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>持续更新</span>
          </div>
          <a href="/links" class="btn btn-md btn-accent">进入导航站 &rarr;</a>
        </div>
        <div class="product-visual">
          <div class="card-grid-demo">
            <div class="cg-card cg-1"></div><div class="cg-card cg-2"></div><div class="cg-card cg-3"></div>
            <div class="cg-card cg-4"></div><div class="cg-card cg-5"></div><div class="cg-card cg-6"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 备案系统介绍 -->
  <section class="product-section" id="icp-system">
    <div class="content-narrow">
      <div class="product-row">
        <div class="product-visual">
          <div class="icp-demo">
            <div class="icp-header-bar">
              <span class="icp-star">&#9733;</span>
              <span>ICP 备案公示系统</span>
            </div>
            <div class="icp-table">
              <div class="icp-row icp-head"><span>站点名称</span><span>备案号</span><span>状态</span></div>
              <div class="icp-row"><span>寒影</span><span>备2026-001号</span><span class="icp-ok">已公示</span></div>
              <div class="icp-row"><span>示例站点</span><span>备2026-002号</span><span class="icp-ok">已公示</span></div>
            </div>
          </div>
        </div>
        <div class="product-text">
          <span class="product-tag">系统</span>
          <h2>星舟备案</h2>
          <p>自主开发的 ICP 备案公示系统，支持站点登记、备案查询、公示列表管理，红金政府风格界面。</p>
          <div class="product-features">
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>站点登记</span>
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>备案查询</span>
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>公示管理</span>
          </div>
          <a href="/icp" class="btn btn-md btn-accent">进入备案系统 &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 博客介绍 -->
  <section class="product-section section-alt" id="blog-section">
    <div class="content-narrow">
      <div class="product-row reverse">
        <div class="product-text">
          <span class="product-tag">内容</span>
          <h2>技术博客</h2>
          <p>记录开发过程中的思考与沉淀，不贩卖焦虑，只写经过验证的技术实践与深度复盘。</p>
          <div class="product-features">
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>深度技术</span>
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>实战复盘</span>
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>持续更新</span>
          </div>
          <a href="/blog" class="btn btn-md btn-accent">浏览文章 &rarr;</a>
        </div>
        <div class="product-visual">
          <div class="blog-demo">
            <div class="blog-card-demo">
              <div class="bd-date"></div>
              <div class="bd-title"></div>
              <div class="bd-desc"></div>
              <div class="bd-desc bd-desc-short"></div>
            </div>
            <div class="blog-card-demo bd-offset">
              <div class="bd-date"></div>
              <div class="bd-title bd-title-short"></div>
              <div class="bd-desc"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 云笺 · 博客托管平台 -->
  <section class="product-section" id="yunjian">
    <div class="content-narrow">
      <div class="product-row">
        <div class="product-visual">
          <div class="yunjian-code-preview" style="background:var(--ink-10);border:1px solid var(--ink-20);border-radius:var(--radius-lg);padding:24px;font-family:monospace;font-size:12px;color:var(--ink-50);line-height:1.6;">
            <div style="color:var(--amber-400);margin-bottom:8px;">$ npm create hanhub-blog</div>
            <div style="color:#6366f1;">?</div> <span>Blog title:</span> <span style="color:#10b981;">My Blog</span><br>
            <div style="color:#6366f1;">?</div> <span>Theme:</span> <span style="color:#10b981;">next</span><br>
            <div style="color:#6366f1;">?</div> <span>Deploy:</span> <span style="color:#10b981;">GitHub Pages</span><br>
            <div style="margin-top:8px;color:var(--ink-40);">Creating project...</div>
            <div style="color:#22c55e;">Done. Blog is live!</div>
          </div>
        </div>
        <div class="product-text">
          <span class="product-tag" style="background:rgba(16,185,129,0.1);color:#10b981;">Yunjian</span>
          <h2>云笺 · 博客托管<span class="dot">平台</span></h2>
          <p>三分钟拥有自己的独立博客，基于 GitHub Pages，永久免费。无需服务器，无需运维，让你专注写作。</p>
          <div class="product-features">
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>一键部署</span>
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>永久免费</span>
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Markdown写作</span>
          </div>
          <a href="/yunjian" class="btn btn-md btn-accent">了解更多 &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 寒搜 · 搜索引擎 -->
  <section class="product-section section-alt" id="search">
    <div class="content-narrow">
      <div class="product-row">
        <div class="product-visual">
          <div style="background:var(--ink-10);border:1px solid var(--ink-20);border-radius:var(--radius-lg);padding:28px;text-align:center;">
            <div style="width:64px;height:64px;margin:0 auto 16px;background:linear-gradient(135deg,rgba(99,102,241,0.2),rgba(139,92,246,0.1));border-radius:50%;display:flex;align-items:center;justify-content:center;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="#6366f1" stroke-width="1.5"/><path d="M21 21l-4.35-4.35" stroke="#6366f1" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <div style="background:var(--ink-15);border:1px solid var(--ink-20);border-radius:24px;padding:12px 20px;display:inline-flex;align-items:center;gap:8px;color:var(--ink-40);font-size:13px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.5"/></svg>
              搜索互联网...
              <span style="margin-left:auto;font-size:10px;opacity:0.5;">Enter</span>
            </div>
          </div>
        </div>
        <div class="product-text">
          <span class="product-tag" style="background:rgba(99,102,241,0.1);color:#6366f1;">HanSearch</span>
          <h2>寒搜 · 搜索引擎</h2>
          <p>不追踪、不过滤、不投毒、无广告。聚合高价值信源，给你最干净的搜索结果。</p>
          <div class="product-features">
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>无广告</span>
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>不追踪</span>
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>安全搜索</span>
          </div>
          <a href="/search" class="btn btn-md btn-accent">开始搜索 &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 寒盾 · 安全管家 -->
  <section class="product-section" id="security">
    <div class="content-narrow">
      <div class="product-row">
        <div class="product-text">
          <span class="product-tag" style="background:rgba(16,185,129,0.1);color:#10b981;">HanShield</span>
          <h2>寒盾 · 安全管家</h2>
          <p>聚合国内外安全产品优势，在线安全工具与威胁情报，守护你的数字生活。</p>
          <div class="product-features">
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>密码检测</span>
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>URL检查</span>
            <span class="pf-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>泄露检测</span>
          </div>
          <a href="/security" class="btn btn-md btn-accent">安全检查 &rarr;</a>
        </div>
        <div class="product-visual">
          <div style="background:var(--ink-10);border:1px solid var(--ink-20);border-radius:var(--radius-lg);padding:28px;text-align:center;">
            <div style="width:64px;height:64px;margin:0 auto 16px;background:linear-gradient(135deg,rgba(16,185,129,0.2),rgba(34,197,94,0.1));border-radius:50%;display:flex;align-items:center;justify-content:center;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#10b981" stroke-width="1.5"/><path d="M9 12l2 2 4-4" stroke="#10b981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;">
              <span style="background:rgba(34,197,94,0.1);color:#22c55e;font-size:11px;padding:4px 10px;border-radius:12px;">密码生成器</span>
              <span style="background:rgba(99,102,241,0.1);color:#6366f1;font-size:11px;padding:4px 10px;border-radius:12px;">哈希计算</span>
              <span style="background:rgba(245,158,11,0.1);color:#f59e0b;font-size:11px;padding:4px 10px;border-radius:12px;">URL检测</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 底部 CTA -->
  <section class="cta-section">
    <div class="content-narrow cta-content">
      <h2>开始构建你的数字角落</h2>
      <p>从导航到备案，从博客到搜索，一站式个人站点解决方案。</p>
      <a href="/register" class="btn btn-lg btn-primary">立即注册</a>
    </div>
  </section>
</Page>

<style>
  /* ===== Hero ===== */
  .hero {
    min-height: calc(100vh - var(--header-height));
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: var(--ink-10);
  }

  .hero-content {
    text-align: center;
    position: relative;
    z-index: 2;
    max-width: 680px;
    padding: var(--space-2xl) var(--space-xl);
    animation: fade-in-up 0.8s var(--ease-out);
  }

  .hero-accent {
    width: 48px;
    height: 2px;
    background: var(--amber-400);
    margin: 0 auto var(--space-xl);
    border-radius: 1px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: var(--weight-medium);
    color: var(--ink-100);
    letter-spacing: 0.08em;
    margin-bottom: var(--space-lg);
    line-height: 1.15;
  }

  .hero-subtitle-cn {
    font-size: var(--text-lg);
    color: var(--ink-60);
    margin: 0 auto var(--space-sm);
    line-height: var(--leading-relaxed);
    font-weight: 500;
  }

  .hero-subtitle-en {
    font-size: var(--text-base);
    color: var(--ink-40);
    margin: 0 auto var(--space-2xl);
    font-style: italic;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.02em;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-scroll-indicator {
    margin-top: var(--space-3xl);
    color: var(--ink-40);
    animation: float 2s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  .hero-bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.12;
    pointer-events: none;
  }
  .hero-bg-orb-1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, var(--amber-400), transparent);
    top: -10%; right: -15%;
    animation: orb-drift-1 12s ease-in-out infinite alternate;
  }
  .hero-bg-orb-2 {
    width: 350px; height: 350px;
    background: radial-gradient(circle, rgba(255,255,255,0.08), transparent);
    bottom: 10%; left: -10%;
    animation: orb-drift-2 15s ease-in-out infinite alternate;
  }

  @keyframes orb-drift-1 {
    0% { transform: translate(0, 0); }
    100% { transform: translate(-60px, 40px); }
  }
  @keyframes orb-drift-2 {
    0% { transform: translate(0, 0); }
    100% { transform: translate(40px, -30px); }
  }

  /* ===== Product Sections ===== */
  .product-section {
    padding: var(--space-5xl) 0;
    background: var(--ink-5);
  }
  .section-alt {
    background: var(--ink-10);
  }

  .product-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }
  .product-row.reverse { direction: rtl; }
  .product-row.reverse > * { direction: ltr; }

  .product-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .product-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--amber-400);
    background: rgba(212,165,116,0.1);
    padding: 4px 12px;
    border-radius: var(--radius-sm);
    width: fit-content;
  }

  .product-text h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--ink-100);
    letter-spacing: 0.04em;
    margin: 0;
  }

  .product-text p {
    font-size: var(--text-base);
    color: var(--ink-50);
    line-height: var(--leading-relaxed);
    margin: 0;
    max-width: 420px;
  }

  .product-features {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }
  .pf-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-xs);
    color: var(--ink-40);
    font-weight: 500;
  }
  .pf-item svg { color: var(--amber-400); }

  .btn-accent {
    background: transparent;
    border: 1px solid var(--amber-400);
    color: var(--amber-400);
    padding: 10px 24px;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s var(--ease-out);
    text-decoration: none;
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .btn-accent:hover {
    background: var(--amber-400);
    color: var(--ink-5);
  }

  /* ===== Card Grid Demo ===== */
  .card-grid-demo {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    padding: 24px;
    background: var(--ink-10);
    border: 1px solid var(--ink-20);
    border-radius: var(--radius-lg);
  }
  .cg-card {
    height: 60px;
    border-radius: var(--radius-md);
    background: var(--ink-15);
    border: 1px solid var(--ink-20);
    transition: all 0.3s var(--ease-out);
    animation: cg-pulse 3s ease-in-out infinite;
  }
  .cg-1 { animation-delay: 0s; }
  .cg-2 { animation-delay: 0.3s; }
  .cg-3 { animation-delay: 0.6s; }
  .cg-4 { animation-delay: 0.9s; }
  .cg-5 { animation-delay: 1.2s; }
  .cg-6 { animation-delay: 1.5s; }
  @keyframes cg-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }

  /* ===== ICP Demo ===== */
  .icp-demo {
    background: linear-gradient(135deg, #1a1210, #1a0f0e);
    border: 1px solid rgba(180,40,30,0.15);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .icp-header-bar {
    background: linear-gradient(135deg, #8b1a1a, #a02c2c);
    color: #f5d78c;
    padding: 14px 20px;
    font-size: var(--text-sm);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
    letter-spacing: 0.05em;
  }
  .icp-star { font-size: 18px; color: #f5d78c; }
  .icp-table { padding: 8px 0; }
  .icp-row {
    display: grid;
    grid-template-columns: 1.2fr 1fr 0.8fr;
    padding: 10px 20px;
    font-size: var(--text-xs);
    border-bottom: 1px solid rgba(255,255,255,0.04);
    color: var(--ink-40);
  }
  .icp-head { font-weight: 600; color: #a08060; font-size: 11px; letter-spacing: 0.04em; }
  .icp-ok { color: #6ab04c; font-weight: 500; }

  /* ===== Blog Card Demo ===== */
  .blog-demo {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .blog-card-demo {
    background: var(--ink-10);
    border: 1px solid var(--ink-20);
