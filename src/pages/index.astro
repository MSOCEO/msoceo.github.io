---
import Page from '../layouts/Page.astro';
import { getCollection } from 'astro:content';

const allPostsUnsorted = await getCollection('blog');
const allPosts = allPostsUnsorted.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const PAGE_SIZE = 3;
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);

const allTags = new Map();
allPosts.forEach(p => {
  const tags = p.data.tags || [];
  tags.forEach(t => {
    const tag = String(t).trim();
    if (tag) allTags.set(tag, (allTags.get(tag) || 0) + 1);
  });
});
const tagsSorted = [...allTags.entries()].sort((a, b) => b[1] - a[1]);

const SOLAR_TERMS: Record<string, string> = {
  '1-1': '元旦', '2-4': '立春', '3-5': '惊蛰', '3-20': '春分',
  '4-4': '清明', '4-20': '谷雨', '5-5': '立夏', '5-21': '小满',
  '6-5': '芒种', '6-21': '夏至', '7-7': '小暑', '7-23': '大暑',
  '8-7': '立秋', '8-23': '处暑', '9-7': '白露', '9-23': '秋分',
  '10-8': '寒露', '10-23': '霜降', '11-7': '立冬', '11-22': '小雪',
  '12-7': '大雪', '12-21': '冬至', '1-5': '小寒', '1-20': '大寒',
};
const WEEKDAYS = ['日曜', '月曜', '火曜', '水曜', '木曜', '金曜', '土曜'];

function formatDiaryDate(date: Date): string {
  const m = date.getMonth() + 1;
  const d = date.getDate();
  const key = `${m}-${d}`;
  const term = SOLAR_TERMS[key] || '';
  const wd = WEEKDAYS[date.getDay()];
  const base = `${m}月${d}日 · ${wd}`;
  return term ? `${base} · ${term}` : base;
}

const title = '寒影·拾光';
const description = '在深夜书房里，拾取散落的光';
---

<Page {title} {description}>
  <div class="diary-page">
    <header class="diary-header">
      <div class="diary-header-decoration">
        <span class="decoration-dot"></span>
        <span class="decoration-line"></span>
        <span class="decoration-dot"></span>
      </div>
      <h1 class="diary-title">拾光日记</h1>
      <p class="diary-subtitle">{description}</p>
    </header>

    <div class="diary-search-bar">
      <svg class="diary-search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="text" class="diary-search-input" id="blogSearch" placeholder="搜索日记..." autocomplete="off" />
      <span class="diary-search-count">{allPosts.length} 篇</span>
    </div>

    {tagsSorted.length > 0 && (
      <div class="diary-tag-cloud">
        <button class="diary-tag diary-tag-active" onclick="filterByTag(null, this)">全部</button>
        {tagsSorted.map(([tag, count]) => (
          <button class="diary-tag" onclick={`filterByTag('${tag}', this)`}>{tag}({count})</button>
        ))}
      </div>
    )}

    <div class="diary-feed" id="postGrid">
      {allPosts.map((post, i) => (
        <article class="diary-card" style={`--anim-delay: ${i * 80}ms`} data-tags={JSON.stringify(post.data.tags || [])}>
          <a href={`/blog/${post.id}`} class="diary-card-link">
            <div class="diary-card-line"></div>
            <div class="diary-card-inner">
              <time class="diary-date" datetime={post.data.pubDate.toISOString()}>
                {formatDiaryDate(post.data.pubDate)}
              </time>
              <h2 class="diary-entry-title">{post.data.title}</h2>
              <p class="diary-excerpt">{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="diary-tags">
                  {post.data.tags.map(tag => <span class="diary-post-tag">{tag}</span>)}
                </div>
              )}
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</Page>

<style>
  .diary-page {
    max-width: var(--content-width, 680px);
    margin: 0 auto;
  }

  .diary-header {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .diary-header-decoration {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .decoration-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent, #c4a35a);
  }

  .decoration-line {
    width: 60px;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-accent, #c4a35a), transparent);
  }

  .diary-title {
    font-family: var(--font-serif, 'Noto Serif SC', serif);
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-text-primary, #e8e0d5);
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
  }

  .diary-subtitle {
    font-size: 0.9rem;
    color: var(--color-text-muted, #6b6560);
    letter-spacing: 0.05em;
  }

  .diary-search-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--color-bg-secondary, #25221e);
    border: 1px solid var(--color-border, rgba(255,255,255,0.06));
    border-radius: var(--radius-lg, 14px);
    padding: 0.6rem 1rem;
    margin-bottom: 1.5rem;
    transition: border-color 0.2s;
  }

  .diary-search-bar:focus-within {
    border-color: var(--color-border-focus, rgba(196,163,90,0.35));
  }

  .diary-search-icon {
    flex-shrink: 0;
    color: var(--color-text-muted, #6b6560);
  }

  .diary-search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-size: 0.9rem;
    color: var(--color-text-primary, #e8e0d5);
    font-family: inherit;
  }

  .diary-search-input::placeholder {
    color: var(--color-text-muted, #6b6560);
  }

  .diary-search-count {
    font-size: 0.78rem;
    color: var(--color-text-muted, #6b6560);
    flex-shrink: 0;
  }

  .diary-tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .diary-tag {
    font-size: 0.75rem;
    padding: 0.25em 0.75em;
    border-radius: 14px;
    border: 1px solid var(--color-border, rgba(255,255,255,0.06));
    background: var(--color-bg-secondary, #25221e);
    color: var(--color-text-secondary, #9a9085);
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }

  .diary-tag:hover {
    border-color: var(--color-accent, #c4a35a);
    color: var(--color-accent, #c4a35a);
  }

  .diary-tag-active {
    background: var(--color-accent-soft, rgba(196,163,90,0.12));
    border-color: var(--color-accent, #c4a35a);
    color: var(--color-accent, #c4a35a);
  }

  .diary-feed {
    position: relative;
  }

  .diary-card {
    position: relative;
    padding-left: 2rem;
    margin-bottom: 0;
    opacity: 0;
    animation: diaryFadeIn 0.5s cubic-bezier(0.22,1,0.36,1) forwards;
    animation-delay: var(--anim-delay, 0ms);
  }

  @keyframes diaryFadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .diary-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, var(--color-accent, #c4a35a), transparent 80%);
  }

  .diary-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.5rem 0;
    transition: transform 0.35s cubic-bezier(0.22,1,0.36,1);
  }

  .diary-card-link:hover {
    transform: translateX(6px);
  }

  .diary-card-line {
    position: absolute;
    left: -4px;
    top: 1.8rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-accent, #c4a35a);
    transition: transform 0.3s;
  }

  .diary-card-link:hover .diary-card-line {
    transform: scale(1.4);
  }

  .diary-date {
    font-size: 0.8rem;
    color: var(--color-text-muted, #6b6560);
    letter-spacing: 0.05em;
    margin-bottom: 0.3rem;
    display: block;
  }

  .diary-entry-title {
    font-family: var(--font-serif, 'Noto Serif SC', serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-primary, #e8e0d5);
    margin-bottom: 0.4rem;
    line-height: 1.4;
    transition: color 0.3s;
  }

  .diary-card-link:hover .diary-entry-title {
    color: var(--color-accent, #c4a35a);
  }

  .diary-excerpt {
    font-size: 0.88rem;
    color: var(--color-text-secondary, #9a9085);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .diary-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }

  .diary-post-tag {
    font-size: 0.7rem;
    padding: 0.15em 0.55em;
    border-radius: 10px;
    background: var(--color-accent-soft, rgba(196,163,90,0.12));
    color: var(--color-accent, #c4a35a);
  }

  @media (max-width: 768px) {
    .diary-title {
      font-size: 1.5rem;
    }

    .diary-card-link {
      padding: 1.2rem 0;
    }

    .diary-entry-title {
      font-size: 1.1rem;
    }
  }
</style>

<script>
  function filterByTag(tag, btn) {
    document.querySelectorAll('.diary-tag').forEach(b => b.classList.remove('diary-tag-active'));
    if (btn) btn.classList.add('diary-tag-active');
    
    const cards = document.querySelectorAll('.diary-card');
    cards.forEach(card => {
      if (!tag) {
        card.style.display = '';
        return;
      }
      try {
        const tags = JSON.parse(card.dataset.tags || '[]');
        card.style.display = tags.includes(tag) ? '' : 'none';
      } catch(e) {
        card.style.display = '';
      }
    });
  }

  document.getElementById('blogSearch')?.addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase();
    document.querySelectorAll('.diary-card').forEach(card => {
      const text = card.textContent?.toLowerCase() || '';
      card.style.display = text.includes(q) ? '' : 'none';
    });
  });
</script>
