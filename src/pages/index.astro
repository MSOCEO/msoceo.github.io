---
// src/pages/index.astro — 黑曜石星光入口页
import Page from '../layouts/Page.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<Page title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <main class="entrance-main">
    <div class="entrance-card">
      <h1 class="entrance-title">探索 · 发现 · 热爱</h1>
      <p class="entrance-subtitle">
        在代码的星空中寻找光，在生活的烟火里记录温度。<br/>
        这里是一个探索者的小站，分享科技、生活与一切值得被看见的事物。
      </p>
      <p class="entrance-hint">请通过导航栏探索</p>
    </div>
  </main>
</Page>

<style>
.entrance-main {
  min-height: calc(100vh - 60px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl);
  position: relative;
}

.entrance-card {
  position: relative;
  max-width: 580px;
  width: 100%;
  padding: var(--space-3xl) var(--space-2xl);
  background: var(--surface-void);
  backdrop-filter: blur(24px) saturate(160%);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-2xl);
  text-align: center;
  box-shadow:
    0 0 60px oklch(78% 0.18 65 / 0.04),
    0 0 120px oklch(72% 0.14 195 / 0.02);
  animation: fadeInUp var(--duration-very-slow) var(--ease-out-expo) forwards;
}

.entrance-title {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 600;
  letter-spacing: 0.04em;
  margin-bottom: var(--space-md);
  background: linear-gradient(
    135deg,
    var(--star-warm) 0%,
    var(--lantern-warm) 40%,
    var(--tech-cyan) 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.entrance-subtitle {
  font-size: var(--text-base);
  color: var(--text-secondary);
  line-height: var(--leading-relaxed);
  margin-bottom: var(--space-xl);
  font-weight: 300;
}

.entrance-hint {
  font-size: var(--text-sm);
  color: var(--text-muted);
  font-weight: 300;
  letter-spacing: 0.04em;
}

@media (max-width: 640px) {
  .entrance-card {
    padding: var(--space-xl) var(--space-md);
  }

  .entrance-title {
    font-size: var(--text-2xl);
  }
}
</style>