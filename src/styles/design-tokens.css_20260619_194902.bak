/* ===== 寒影拾光 · 深夜书房 设计令牌 ===== */

:root {
  /* ---------- 深色基底 ---------- */
  --color-bg-primary: #0d0f14;
  --color-bg-secondary: #141822;
  --color-bg-tertiary: #1a1f2e;
  --color-bg-card: rgba(20, 24, 34, 0.72);
  --color-bg-hover: rgba(26, 31, 46, 0.64);

  /* ---------- 文字 ---------- */
  --color-text-primary: #e4e1dc;
  --color-text-secondary: #9a9894;
  --color-text-muted: #5f5d5a;

  /* ---------- 靛蓝强调 ---------- */
  --color-accent: #4f8bc9;
  --color-accent-soft: rgba(79, 139, 201, 0.15);
  --color-accent-hover: #6aa0d8;

  /* ---------- 旧金点缀 ---------- */
  --color-gold: #d4a373;
  --color-gold-soft: rgba(212, 163, 115, 0.12);
  --color-gold-hover: #e0b88a;

  /* ---------- 边界 ---------- */
  --color-border: rgba(255, 255, 255, 0.06);
  --color-border-focus: rgba(79, 139, 201, 0.32);

  /* ---------- 间距/圆角 ---------- */
  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 16px;

  /* ---------- 字体 ---------- */
  --font-serif: 'Playfair Display', 'Noto Serif SC', serif;
  --font-sans: 'Inter', 'Noto Sans SC', sans-serif;
  --font-mono: 'JetBrains Mono', monospace;

  /* ---------- 阴影 ---------- */
  --shadow-card: 0 1px 3px rgba(0, 0, 0, 0.4);
  --shadow-elevated: 0 4px 16px rgba(0, 0, 0, 0.5);

  /* ---------- 过渡 ---------- */
  --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
}

/* 浅色模式覆盖 */
:root.light {
  --color-bg-primary: #faf8f5;
  --color-bg-secondary: #f2eeea;
  --color-bg-tertiary: #e8e3dd;
  --color-bg-card: rgba(242, 238, 234, 0.85);
  --color-bg-hover: rgba(232, 227, 221, 0.72);

  --color-text-primary: #2a2522;
  --color-text-secondary: #6b6560;
  --color-text-muted: #9a9490;

  --color-accent: #3b6da8;
  --color-accent-soft: rgba(59, 109, 168, 0.1);

  --color-gold: #b8863f;
  --color-gold-soft: rgba(184, 134, 63, 0.1);

  --color-border: rgba(0, 0, 0, 0.08);
  --color-border-focus: rgba(59, 109, 168, 0.35);

  --shadow-card: 0 1px 4px rgba(0, 0, 0, 0.06);
  --shadow-elevated: 0 4px 20px rgba(0, 0, 0, 0.08);
}
