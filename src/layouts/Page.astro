---
// 寒影拾光 · Page Layout
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import RightPanel from '../components/RightPanel.astro';
import Footer from '../components/Footer.astro';
import MusicPlayer from '../components/MusicPlayer.astro';

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Liu+Jian+Mao+Cao&family=Noto+Serif+SC:wght@400;600&text=寒影拾光在深夜书房里取散落的下降阅读博客文章全文搜索标签全部页共篇没有找到匹配上一&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <div class="layout-row">
      <Sidebar />
      <main class="site-main">
        <slot />
      </main>
      <RightPanel />
    </div>
    <MusicPlayer />
    <Footer />

    <script is:inline src="/blog/starry-sky.js"></script>
  </body>
</html>

<style>
  .layout-row {
    display: flex;
    max-width: var(--layout-max);
    margin: 0 auto;
    min-height: 100vh;
    padding-top: 56px;
  }

  .site-main {
    flex: 1;
    width: var(--content-width);
    max-width: var(--content-width);
    min-width: 0;
    padding: 2.5rem var(--gap-column);
  }

  /* 全屏 Hero 页面不需要边栏 */
  body:has(.blog-hero) .layout-row {
    padding-top: 0;
  }

  body:has(.blog-hero) .site-main {
    padding: 0;
    max-width: 100%;
    width: 100%;
  }

  body:has(.blog-hero) .sidebar,
  body:has(.blog-hero) .right-panel {
    display: none;
  }

  body:has(.blog-hero) header {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 10;
    background: transparent;
  }

  /* 移动端 */
  @media (max-width: 768px) {
    .layout-row {
      flex-direction: column;
      padding-top: 52px;
    }
    .site-main {
      padding: 1.25rem 1rem;
      max-width: 100%;
      width: 100%;
    }
  }
</style>
