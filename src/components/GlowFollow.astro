---
/* ===== GlowFollow.astro · 鼠标光晕跟随 ===== */
---
<div class="glow-follow" id="glow-follow" aria-hidden="true"></div>

<script>
  const glow = document.getElementById('glow-follow');
  if (glow) {
    let rafId = 0;
    let targetX = 0, targetY = 0;
    let currentX = -999, currentY = -999;

    document.addEventListener('mousemove', (e) => {
      targetX = e.clientX;
      targetY = e.clientY;
      glow.classList.add('active');
    });

    document.addEventListener('mouseleave', () => {
      glow.classList.remove('active');
    });

    // 使用 requestAnimationFrame 做 0.08 平滑跟随后（不粘滞），性能友好
    function follow() {
      currentX += (targetX - currentX) * 0.08;
      currentY += (targetY - currentY) * 0.08;
      glow.style.left = currentX + 'px';
      glow.style.top = currentY + 'px';
      rafId = requestAnimationFrame(follow);
    }

    rafId = requestAnimationFrame(follow);
  }
</script>
