<!-- 图片放大灯箱 -->
<div class="lightbox-overlay" id="lightbox-overlay">
  <button class="lightbox-close" id="lightbox-close" aria-label="关闭">✕</button>
  <img class="lightbox-image" id="lightbox-image" src="" alt="" />
</div>

<script>
  const lbOverlay = document.getElementById('lightbox-overlay');
  const lbImage = document.getElementById('lightbox-image') as HTMLImageElement;
  const lbClose = document.getElementById('lightbox-close');

  // 为文章内容中的图片绑定点击事件
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.tagName === 'IMG' && target.closest('article, .prose, main')) {
      if (lbImage && lbOverlay) {
        lbImage.src = (target as HTMLImageElement).src;
        lbImage.alt = (target as HTMLImageElement).alt || '';
        lbOverlay.classList.add('active');
      }
    }
  });

  lbOverlay?.addEventListener('click', (e) => {
    if (e.target === lbOverlay || e.target === lbClose) {
      lbOverlay.classList.remove('active');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lbOverlay?.classList.contains('active')) {
      lbOverlay.classList.remove('active');
    }
  });
</script>
