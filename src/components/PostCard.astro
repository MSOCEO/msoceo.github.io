---
interface Props {
  slug: string;
  title: string;
  date: string;
  excerpt?: string;
  tags?: string[];
  readingTime?: string;
  index?: number;
}

const { slug, title, date, excerpt, tags = [], readingTime, index = 0 } = Astro.props;
const isEven = index % 2 === 1;
---

<article class="post-card" class:list={`${isEven ? 'post-card--alt' : ''}`}>
  <a href={`/blog/${slug}/`} class="post-card-link">
    <time class="post-card-date" datetime={date}>
      {new Date(date).toLocaleDateString('zh-CN', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })}
    </time>
    <h2 class="post-card-title">{title}</h2>
    {excerpt && <p class="post-card-excerpt">{excerpt}</p>}

    <div class="post-card-meta">
      {readingTime && <span class="post-card-time">{readingTime}</span>}
      {
        tags.length > 0 && (
          <span class="post-card-tags">
            {tags.map((tag) => (
              <span class="post-card-tag">{tag}</span>
            ))}
          </span>
        )
      }
    </div>

    <span class="post-card-read">读下去 →</span>
  </a>
</article>

<style>
  .post-card {
    border-bottom: 1px solid var(--color-border);
    padding: 2.5rem 0;
    transition: all 0.3s var(--ease-out);
  }

  .post-card:first-child {
    padding-top: 0;
  }

  .post-card:hover {
    transform: translateX(8px);
  }

  .post-card--alt:hover {
    transform: translateX(-8px);
  }

  .post-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-card-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .post-card-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0.5rem 0 0.65rem;
    color: var(--color-text-primary);
    transition: color 0.25s var(--ease-out);
  }

  .post-card:hover .post-card-title {
    color: var(--color-accent);
  }

  .post-card-excerpt {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .post-card-tags {
    display: flex;
    gap: 0.4rem;
  }

  .post-card-tag {
    background: var(--color-accent-soft);
    color: var(--color-accent);
    padding: 0.1em 0.55em;
    border-radius: 3px;
    font-size: 0.72rem;
  }

  .post-card-read {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.82rem;
    color: var(--color-accent);
    font-weight: 500;
    opacity: 0;
    transform: translateX(-8px);
    transition: all 0.3s var(--ease-out);
  }

  .post-card:hover .post-card-read {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 640px) {
    .post-card {
      padding: 1.5rem 0;
    }

    .post-card-title {
      font-size: 1.25rem;
    }
  }
</style>
