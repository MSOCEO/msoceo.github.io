---
// 墨影 AuthLogo — 寒影几何标志
---

<div class="auth-logo">
  <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <!-- 外环 -->
    <circle cx="24" cy="24" r="22" stroke="var(--amber-400)" stroke-width="0.8" opacity="0.15"/>
    <circle cx="24" cy="24" r="22" stroke="var(--amber-400)" stroke-width="0.5" opacity="0.3"
            stroke-dasharray="4 8" stroke-dashoffset="2">
      <animateTransform attributeName="transform" type="rotate" from="0 24 24" to="360 24 24"
                        dur="60s" repeatCount="indefinite"/>
    </circle>

    <!-- 四芒星 -->
    <g opacity="0.9">
      <line x1="24" y1="6" x2="24" y2="42" stroke="url(#star-grad)" stroke-width="1.2" stroke-linecap="round"/>
      <line x1="6" y1="24" x2="42" y2="24" stroke="url(#star-grad)" stroke-width="1.2" stroke-linecap="round"/>
      <line x1="11.3" y1="11.3" x2="36.7" y2="36.7" stroke="url(#star-grad-diag)" stroke-width="0.6" stroke-linecap="round"/>
      <line x1="36.7" y1="11.3" x2="11.3" y2="36.7" stroke="url(#star-grad-diag)" stroke-width="0.6" stroke-linecap="round"/>
    </g>

    <!-- 中心光点 -->
    <circle cx="24" cy="24" r="3" fill="var(--amber-400)" opacity="0.8">
      <animate attributeName="r" values="3;4;3" dur="3s" repeatCount="indefinite"/>
      <animate attributeName="opacity" values="0.8;0.5;0.8" dur="3s" repeatCount="indefinite"/>
    </circle>
    <circle cx="24" cy="24" r="8" fill="var(--amber-400)" opacity="0.08">
      <animate attributeName="r" values="8;14;8" dur="4s" repeatCount="indefinite"/>
      <animate attributeName="opacity" values="0.08;0.02;0.08" dur="4s" repeatCount="indefinite"/>
    </circle>

    <!-- 四角小星 -->
    <circle cx="24" cy="10" r="1" fill="var(--amber-400)" opacity="0.6"/>
    <circle cx="24" cy="38" r="1" fill="var(--amber-400)" opacity="0.6"/>
    <circle cx="10" cy="24" r="1" fill="var(--amber-400)" opacity="0.6"/>
    <circle cx="38" cy="24" r="1" fill="var(--amber-400)" opacity="0.6"/>

    <defs>
      <linearGradient id="star-grad" x1="24" y1="6" x2="24" y2="42" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="var(--amber-400)" stop-opacity="1"/>
        <stop offset="50%" stop-color="var(--amber-400)" stop-opacity="0.3"/>
        <stop offset="100%" stop-color="var(--amber-400)" stop-opacity="1"/>
      </linearGradient>
      <linearGradient id="star-grad-diag" x1="11.3" y1="11.3" x2="36.7" y2="36.7" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="var(--amber-400)" stop-opacity="0.4"/>
        <stop offset="50%" stop-color="var(--amber-400)" stop-opacity="0.1"/>
        <stop offset="100%" stop-color="var(--amber-400)" stop-opacity="0.4"/>
      </linearGradient>
    </defs>
  </svg>
  <span class="auth-logo-text">寒影</span>
</div>

<style>
  .auth-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-bottom: var(--space-xl);
  }

  .auth-logo svg {
    filter: drop-shadow(0 0 16px rgba(212,165,116,0.15));
  }

  .auth-logo-text {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: var(--weight-bold);
    color: var(--ink-90);
    letter-spacing: 0.12em;
    background: linear-gradient(135deg, var(--ink-90), var(--amber-200));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
