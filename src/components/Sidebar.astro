---
export interface Props {
  author?: string;
  avatar?: string;
  bio?: string;
  location?: string;
  socialLinks?: Array<{ name: string; url: string; icon: string }>;
  tags?: string[];
}

const {
  author = "@msoceo",
  avatar = "/blog/avatar.jpg",
  bio = "深夜写代码，凌晨读闲书。",
  location = "浮游于数字海",
  socialLinks = [
    { name: "GitHub", url: "https://github.com/MSOCEO", icon: "github" },
    { name: "RSS", url: "/blog/rss.xml", icon: "rss" },
  ],
} = Astro.props;
---

<aside class="sidebar">
  <div class="sidebar-inner">
    <!-- 头像 -->
    <div class="avatar-holder">
      <a href="/blog/" class="avatar-link">
        <img src={avatar} alt={author} class="avatar-img" width="80" height="80" loading="eager" />
        <div class="avatar-ring"></div>
      </a>
    </div>

    <!-- 作者信息 -->
    <div class="author-info">
      <h2 class="author-name">{author}</h2>
      <p class="author-bio">{bio}</p>
      <span class="author-location">{location}</span>
    </div>

    <!-- 分割线 -->
    <div class="section-divider"></div>

    <!-- 导航链接 -->
    <nav class="sidebar-nav">
      <a href="/blog/" class="nav-item active">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 12h3v8h6v-6h2v6h6v-8h3L12 2z"/></svg>
        <span>日记</span>
      </a>
      <a href="/blog/about/" class="nav-item">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        <span>关于</span>
      </a>
      <a href="/blog/links/" class="nav-item">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
        <span>链接</span>
      </a>
      <a href="/blog/search/" class="nav-item">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <span>搜索</span>
      </a>
    </nav>

    <!-- 分割线 -->
    <div class="section-divider"></div>

    <!-- 社交链接 -->
    <div class="social-links">
      {socialLinks.map(link => (
        <a href={link.url} class="social-link" target="_blank" rel="noopener noreferrer" title={link.name}>
          {link.icon === 'github' ? (
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          ) : (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 11a9 9 0 019 9M4 4a16 16 0 0116 16"/><circle cx="5" cy="19" r="1"/></svg>
          )}
        </a>
      ))}
    </div>

    <!-- 页脚装饰 -->
    <div class="sidebar-footer">
      <span class="footer-text">寒影拾光</span>
      <span class="footer-divider">·</span>
      <span class="footer-text">深夜书房</span>
    </div>
  </div>
</aside>

<style>
.sidebar {
  width: var(--sidebar-width);
  flex-shrink: 0;
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
  border-right: 1px solid var(--color-border);
  background: var(--color-bg-secondary);
  z-index: 5;
  scrollbar-width: thin;
  scrollbar-color: var(--color-border) transparent;
}

.sidebar-inner {
  padding: 2rem 1.25rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  min-height: 100%;
}

/* ---- 头像 ---- */
.avatar-holder { position: relative; }
.avatar-link { display: block; position: relative; border-radius: 50%; }
.avatar-img {
  width: 80px; height: 80px; border-radius: 50%;
  object-fit: cover; border: 2px solid var(--color-accent-soft);
  transition: transform var(--duration-normal) var(--ease-out),
              border-color var(--duration-fast) var(--ease-out);
}
.avatar-link:hover .avatar-img {
  transform: scale(1.05);
  border-color: var(--color-accent);
}
.avatar-ring {
  position: absolute; inset: -3px; border-radius: 50%;
  border: 1px dashed var(--color-accent-soft);
  animation: ringSpin 12s linear infinite;
  pointer-events: none;
}
@keyframes ringSpin { to { transform: rotate(360deg); } }

/* ---- 作者 ---- */
.author-info { text-align: center; }
.author-name { font-family: var(--font-serif); font-size: 1.1rem; font-weight: 600; margin: 0; color: var(--color-text-primary); }
.author-bio { font-size: 0.8rem; color: var(--color-text-secondary); margin: 0.3rem 0 0; line-height: 1.6; }
.author-location { display: block; font-size: 0.72rem; color: var(--color-text-muted); margin-top: 0.2rem; }

/* ---- 分割线 ---- */
.section-divider {
  width: 60%; height: 1px;
  background: linear-gradient(90deg, transparent, var(--color-accent-soft), transparent);
}

/* ---- 导航 ---- */
.sidebar-nav { width: 100%; display: flex; flex-direction: column; gap: 2px; }
.nav-item {
  display: flex; align-items: center; gap: 0.65rem;
  padding: 0.55rem 0.85rem; border-radius: var(--radius-md);
  font-size: 0.875rem; color: var(--color-text-secondary);
  transition: all var(--duration-fast) var(--ease-out);
  text-decoration: none;
}
.nav-item:hover { background: var(--color-bg-hover); color: var(--color-text-primary); }
.nav-item.active { background: var(--color-accent-soft); color: var(--color-accent); }
.nav-icon { width: 1.1rem; height: 1.1rem; flex-shrink: 0; }

/* ---- 社交 ---- */
.social-links { display: flex; gap: 0.75rem; }
.social-link {
  display: flex; align-items: center; justify-content: center;
  width: 30px; height: 30px; border-radius: 50%;
  border: 1px solid var(--color-border); color: var(--color-text-muted);
  transition: all var(--duration-fast) var(--ease-out);
}
.social-link svg { width: 0.95rem; height: 0.95rem; }
.social-link:hover { color: var(--color-accent); border-color: var(--color-accent); }

/* ---- 页脚 ---- */
.sidebar-footer { display: flex; align-items: center; gap: 0.5rem; margin-top: auto; padding-top: 1rem; }
.footer-text { font-family: var(--font-serif); font-size: 0.7rem; color: var(--color-text-muted); letter-spacing: 0.08em; }
.footer-divider { color: var(--color-border); font-size: 0.7rem; }

/* ---- 移动端 ---- */
@media (max-width: 768px) {
  .sidebar {
    position: fixed; bottom: 0; left: 0; right: 0; top: auto;
    width: 100%; height: auto; max-height: 56px; overflow: hidden;
    border-right: none; border-top: 1px solid var(--color-border);
    background: var(--color-bg-secondary); z-index: 50;
    transition: max-height var(--duration-normal) var(--ease-out);
  }
  .sidebar.open { max-height: 100vh; }
  .sidebar-inner { flex-direction: row; padding: 0.5rem 1rem; gap: 0; min-height: auto; flex-wrap: wrap; justify-content: center; }
  .avatar-holder { display: none; }
  .author-info { display: none; }
  .section-divider { display: none; }
  .social-links { display: none; }
  .sidebar-footer { display: none; }
  .sidebar-nav { flex-direction: row; gap: 0; width: auto; }
  .sidebar-nav .nav-item { padding: 0.4rem 0.6rem; font-size: 0.78rem; }
  .sidebar-nav .nav-item span { font-size: 0.75rem; }
  .sidebar-nav .nav-icon { width: 0.9rem; height: 0.9rem; }
}
</style>
