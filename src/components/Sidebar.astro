---
import { SITE_AUTHOR, SITE_DESCRIPTION } from '../consts';
---

<div class="space-y-6">
  <!-- 个人简介卡片 -->
  <div class="ink-card ink-card-alt p-5">
    <div class="flex flex-col items-center text-center">
      <div class="avatar-sketch w-20 h-20 mb-3">
        <div class="w-full h-full rounded-full bg-[var(--ink-200)] dark:bg-[var(--ink-700)] flex items-center justify-center text-2xl font-serif text-[var(--accent)]">
          寒
        </div>
      </div>
      <h3 class="font-serif font-bold text-lg">{SITE_AUTHOR}</h3>
      <p class="text-sm text-[var(--text-tertiary)] mt-1">{SITE_DESCRIPTION}</p>
      <div class="flex gap-3 mt-3">
        <a href="https://github.com/msoceo" target="_blank" rel="noopener" class="text-[var(--text-tertiary)] hover:text-[var(--accent)] transition-colors" title="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="/rss.xml" class="text-[var(--text-tertiary)] hover:text-[var(--accent)] transition-colors" title="RSS">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- 分类云 -->
  <div class="ink-card ink-card-alt p-5">
    <h4 class="font-serif font-bold text-sm mb-3 text-[var(--text-secondary)]">分类</h4>
    <div class="tag-cloud">
      <a href="/categories/tech" class="tag-cloud-item">技术</a>
      <a href="/categories/life" class="tag-cloud-item">生活</a>
      <a href="/categories/essay" class="tag-cloud-item">随笔</a>
      <a href="/categories/reading" class="tag-cloud-item">阅读</a>
      <a href="/categories/design" class="tag-cloud-item">设计</a>
    </div>
  </div>

  <!-- 标签云 -->
  <div class="ink-card ink-card-alt p-5">
    <h4 class="font-serif font-bold text-sm mb-3 text-[var(--text-secondary)]">标签</h4>
    <div class="tag-cloud">
      {['Astro', 'JavaScript', 'CSS', 'TypeScript', '前端', 'Python', 'Linux', 'Docker'].map(tag => (
        <a href={`/tags/${tag.toLowerCase()}`} class="tag-cloud-item">{tag}</a>
      ))}
    </div>
  </div>

  <!-- 友情链接 -->
  <div class="ink-card ink-card-alt p-5">
    <h4 class="font-serif font-bold text-sm mb-3 text-[var(--text-secondary)]">友情链接</h4>
    <div class="space-y-2 text-sm">
      <a href="https://astro.build" target="_blank" rel="noopener" class="block text-[var(--text-tertiary)] hover:text-[var(--accent)] transition-colors">Astro 官网</a>
      <a href="https://tailwindcss.com" target="_blank" rel="noopener" class="block text-[var(--text-tertiary)] hover:text-[var(--accent)] transition-colors">TailwindCSS</a>
    </div>
  </div>
</div>
