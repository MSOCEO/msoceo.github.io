---
// Yun 风格导航栏
---

<header class="yun-nav">
  <div class="yun-nav-container">
    <!-- 左侧：Logo + 菜单按钮（移动端） -->
    <div class="yun-nav-left">
      <button class="yun-menu-btn" id="menu-toggle" aria-label="菜单">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M3 12H21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M3 6H21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M3 18H21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <a href="/" class="yun-logo">
        <span class="yun-logo-text">枕星</span>
      </a>
    </div>

    <!-- 中间：导航项（桌面端） -->
    <nav class="yun-nav-center" aria-label="主要导航">
      <a href="/" class="yun-nav-item" aria-label="首页">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M9 22V12h6v10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="yun-nav-label">首页</span>
      </a>
      <a href="/articles" class="yun-nav-item" aria-label="文章">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="yun-nav-label">文章</span>
      </a>
      <a href="/resources" class="yun-nav-item" aria-label="资源">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="yun-nav-label">资源</span>
      </a>
      <a href="/about" class="yun-nav-item" aria-label="关于">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M12 16v-4M12 8h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="yun-nav-label">关于</span>
      </a>
      <a href="/guestbook" class="yun-nav-item" aria-label="留言">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2v10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="yun-nav-label">留言</span>
      </a>
    </nav>

    <!-- 右侧：工具按钮 -->
    <div class="yun-nav-right">
      <button class="yun-icon-btn" id="search-toggle" aria-label="搜索">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="yun-icon-btn" id="theme-toggle" aria-label="切换主题">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="yun-icon-sun">
          <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M12 2v2M12 20v2M4 12H2M22 12h-2M5.64 5.64l1.42 1.42M16.94 16.94l1.42 1.42M18.36 5.64l-1.42 1.42M7.06 16.94l-1.42 1.42" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="yun-icon-moon">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- 移动端侧边菜单 -->
<div class="yun-mobile-menu" id="mobile-menu">
  <div class="yun-mobile-menu-backdrop" id="menu-backdrop"></div>
  <div class="yun-mobile-menu-panel">
    <div class="yun-mobile-menu-header">
      <span class="yun-mobile-menu-title">导航</span>
      <button class="yun-mobile-menu-close" id="menu-close" aria-label="关闭菜单">&times;</button>
    </div>
    <nav class="yun-mobile-menu-nav">
      <a href="/" class="yun-mobile-menu-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M9 22V12h6v10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>首页</span>
      </a>
      <a href="/articles" class="yun-mobile-menu-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>文章</span>
      </a>
      <a href="/resources" class="yun-mobile-menu-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>资源</span>
      </a>
      <a href="/about" class="yun-mobile-menu-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M12 16v-4M12 8h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>关于</span>
      </a>
      <a href="/guestbook" class="yun-mobile-menu-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2v10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>留言</span>
      </a>
    </nav>
  </div>
</div>

<!-- 搜索弹窗 -->
<div class="yun-search-modal" id="search-modal">
  <div class="yun-search-backdrop" id="search-backdrop"></div>
  <div class="yun-search-container">
    <div class="yun-search-header">
      <div class="yun-search-input-wrapper">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="yun-search-icon">
          <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <input type="text" class="yun-search-input" id="search-input" placeholder="搜索文章、标签..." autocomplete="off"/>
      </div>
      <button class="yun-search-close" id="search-close" aria-label="关闭搜索">&times;</button>
    </div>
    <div class="yun-search-results" id="search-results"></div>
  </div>
</div>

<script>
  // 暗色模式切换
  const themeToggle = document.getElementById('theme-toggle');
  const sunIcon = themeToggle.querySelector('.yun-icon-sun');
  const moonIcon = themeToggle.querySelector('.yun-icon-moon');
  
  function setTheme(isDark) {
    if (isDark) {
      document.documentElement.classList.add('dark');
      sunIcon.style.display = 'none';
      moonIcon.style.display = 'block';
    } else {
      document.documentElement.classList.remove('dark');
      sunIcon.style.display = 'block';
      moonIcon.style.display = 'none';
    }
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  }
  
  function toggleTheme() {
    const isDark = document.documentElement.classList.contains('dark');
    setTheme(!isDark);
  }
  
  // 初始化主题
  const savedTheme = localStorage.getItem('theme');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const initialTheme = savedTheme === 'dark' || (!savedTheme && prefersDark);
  setTheme(initialTheme);
  
  themeToggle.addEventListener('click', toggleTheme);
  
  // 移动端菜单
  const menuToggle = document.getElementById('menu-toggle');
  const menuClose = document.getElementById('menu-close');
  const menuBackdrop = document.getElementById('menu-backdrop');
  const mobileMenu = document.getElementById('mobile-menu');
  
  function openMenu() {
    mobileMenu.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  
  function closeMenu() {
    mobileMenu.classList.remove('open');
    document.body.style.overflow = '';
  }
  
  menuToggle.addEventListener('click', openMenu);
  menuClose.addEventListener('click', closeMenu);
  menuBackdrop.addEventListener('click', closeMenu);
  
  // 搜索
  const searchToggle = document.getElementById('search-toggle');
  const searchClose = document.getElementById('search-close');
  const searchBackdrop = document.getElementById('search-backdrop');
  const searchModal = document.getElementById('search-modal');
  const searchInput = document.getElementById('search-input');
  
  function openSearch() {
    searchModal.classList.add('open');
    searchInput.focus();
    document.body.style.overflow = 'hidden';
  }
  
  function closeSearch() {
    searchModal.classList.remove('open');
    document.body.style.overflow = '';
    searchInput.value = '';
  }
  
  searchToggle.addEventListener('click', openSearch);
  searchClose.addEventListener('click', closeSearch);
  searchBackdrop.addEventListener('click', closeSearch);
  
  // 键盘快捷键
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (mobileMenu.classList.contains('open')) closeMenu();
      if (searchModal.classList.contains('open')) closeSearch();
    }
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
  });
</script>

<style>
  /* ===== 导航栏容器 ===== */
  .yun-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--yun-nav-height);
    background: var(--yun-nav-bg-color);
    backdrop-filter: blur(var(--yun-nav-blur));
    -webkit-backdrop-filter: blur(var(--yun-nav-blur));
    border-bottom: 1px solid var(--va-c-divider);
    z-index: 100;
    transition: all var(--duration-normal) var(--ease-in-out);
  }
  
  .yun-nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: var(--yun-post-card-max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }
  
  /* ===== 左侧 ===== */
  .yun-nav-left {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  
  .yun-menu-btn {
    display: none;
    background: none;
    border: none;
    color: var(--va-c-text);
    cursor: pointer;
    padding: var(--space-xs);
    border-radius: var(--radius-sm);
  }
  
  .yun-menu-btn:hover {
    background: var(--va-c-bg-soft);
  }
  
  .yun-logo {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--va-c-text);
    text-decoration: none;
  }
  
  .yun-logo-text {
    background: linear-gradient(120deg, var(--va-c-primary) 30%, #41d1ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  /* ===== 中间导航项 ===== */
  .yun-nav-center {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  
  .yun-nav-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-md);
    color: var(--va-c-text-light);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out);
  }
  
  .yun-nav-item:hover {
    color: var(--va-c-text);
    background: var(--va-c-bg-soft);
  }
  
  .yun-nav-label {
    font-size: 0.875rem;
    font-weight: 500;
  }
  
  /* ===== 右侧工具按钮 ===== */
  .yun-nav-right {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }
  
  .yun-icon-btn {
    background: none;
    border: none;
    color: var(--va-c-text-light);
    cursor: pointer;
    padding: var(--space-xs);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--duration-fast) var(--ease-out);
  }
  
  .yun-icon-btn:hover {
    color: var(--va-c-text);
    background: var(--va-c-bg-soft);
  }
  
  .yun-icon-moon {
    display: none;
  }
  
  /* ===== 移动端菜单 ===== */
  .yun-mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: none;
  }
  
  .yun-mobile-menu.open {
    display: block;
  }
  
  .yun-mobile-menu-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }
  
  .yun-mobile-menu-panel {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 280px;
    background: var(--va-c-bg-light);
    border-right: 1px solid var(--va-c-divider);
    transform: translateX(-100%);
    transition: transform var(--duration-normal) var(--ease-in-out);
    display: flex;
    flex-direction: column;
  }
  
  .yun-mobile-menu.open .yun-mobile-menu-panel {
    transform: translateX(0);
  }
  
  .yun-mobile-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md);
    border-bottom: 1px solid var(--va-c-divider);
  }
  
  .yun-mobile-menu-title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--va-c-text);
  }
  
  .yun-mobile-menu-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--va-c-text-light);
    cursor: pointer;
    line-height: 1;
    padding: var(--space-xs);
  }
  
  .yun-mobile-menu-close:hover {
    color: var(--va-c-text);
  }
  
  .yun-mobile-menu-nav {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  
  .yun-mobile-menu-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm);
    border-radius: var(--radius-md);
    color: var(--va-c-text-light);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out);
  }
  
  .yun-mobile-menu-item:hover {
    color: var(--va-c-text);
    background: var(--va-c-bg-soft);
  }
  
  /* ===== 搜索弹窗 ===== */
  .yun-search-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: none;
  }
  
  .yun-search-modal.open {
    display: block;
  }
  
  .yun-search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
  }
  
  .yun-search-container {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    max-width: 600px;
    background: var(--va-c-bg-light);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  
  .yun-search-header {
    display: flex;
    align-items: center;
    padding: var(--space-md);
    border-bottom: 1px solid var(--va-c-divider);
  }
  
  .yun-search-input-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  
  .yun-search-icon {
    color: var(--va-c-text-light);
    flex-shrink: 0;
  }
  
  .yun-search-input {
    flex: 1;
    background: none;
    border: none;
    font-size: 1rem;
    color: var(--va-c-text);
    outline: none;
  }
  
  .yun-search-input::placeholder {
    color: var(--va-c-text-lighter);
  }
  
  .yun-search-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--va-c-text-light);
    cursor: pointer;
    line-height: 1;
    padding: var(--space-xs);
    margin-left: var(--space-sm);
  }
  
  .yun-search-close:hover {
    color: var(--va-c-text);
  }
  
  .yun-search-results {
    max-height: 400px;
    overflow-y: auto;
    padding: var(--space-md);
  }
  
  /* ===== 响应式 ===== */
  @media (max-width: 768px) {
    .yun-nav-center {
      display: none;
    }
    
    .yun-menu-btn {
      display: block;
    }
    
    .yun-nav-container {
      padding: 0 var(--space-sm);
    }
  }
</style>