---
import { SITE_TITLE } from '../consts';
const currentPath = Astro.url.pathname;
---

<header>
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-text">{SITE_TITLE}</span>
    </a>
    <nav>
      <a href="/" class:list={['nav-link', { active: currentPath === '/' }]}>首页</a>
      <a href="/blog" class:list={['nav-link', { active: currentPath.startsWith('/blog') }]}>文章</a>
      <a href="/resources" class:list={['nav-link', { active: currentPath === '/resources' }]}>资源</a>
      <a href="/about" class:list={['nav-link', { active: currentPath === '/about' }]}>关于</a>
    </nav>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: oklch(10% 0.025 265 / 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid oklch(28% 0.025 265 / 0.5);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: oklch(92% 0.01 265);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: color 0.3s ease;
  }

  .logo:hover {
    color: oklch(72% 0.18 62);
  }

  nav {
    display: flex;
    gap: 0.25rem;
  }

  .nav-link {
    font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: oklch(68% 0.015 265);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    letter-spacing: 0.02em;
  }

  .nav-link:hover {
    color: oklch(92% 0.01 265);
    background: oklch(22% 0.018 265);
  }

  .nav-link.active {
    color: oklch(72% 0.18 62);
    background: oklch(72% 0.18 62 / 0.08);
  }

  @media (max-width: 640px) {
    .header-inner {
      padding: 0 1rem;
    }

    .nav-link {
      padding: 0.35rem 0.5rem;
      font-size: 0.8rem;
    }
  }
</style>