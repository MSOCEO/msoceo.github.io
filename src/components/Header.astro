---
// src/components/Header.astro — 黑曜石星光导航栏（独特图标风格）
import { SITE_TITLE } from '../consts';
---

<header class="glass-nav">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="MSOCEO — 返回入口">
      <svg class="logo-icon" viewBox="0 0 40 40" width="36" height="36" aria-hidden="true">
        <!-- 黑曜石几何体 Logo — 多面体 + 内部星光 -->
        <defs>
          <linearGradient id="obsidianGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#1a1e2e"/>
            <stop offset="40%" stop-color="#0d111a"/>
            <stop offset="100%" stop-color="#1e2438"/>
          </linearGradient>
          <linearGradient id="starInner" x1="50%" y1="0%" x2="50%" y2="100%">
            <stop offset="0%" stop-color="#f5e6c8"/>
            <stop offset="100%" stop-color="#e88a2b"/>
          </linearGradient>
        </defs>
        <!-- 黑曜石主体 — 六边形切割面 -->
        <polygon points="20,3 35,13 35,29 20,37 5,29 5,13" fill="url(#obsidianGrad)" stroke="#3a4060" stroke-width="0.8"/>
        <!-- 切割线 — 黑曜石纹理 -->
        <line x1="20" y1="3" x2="20" y2="37" stroke="rgba(80,90,130,0.3)" stroke-width="0.5"/>
        <line x1="5" y1="21" x2="35" y2="21" stroke="rgba(80,90,130,0.2)" stroke-width="0.5"/>
        <!-- 中心星光 -->
        <circle cx="20" cy="20" r="3.5" fill="url(#starInner)" opacity="0.9"/>
        <circle cx="20" cy="20" r="7" fill="rgba(232,138,43,0.08)"/>
      </svg>
      <span class="brand-text">{SITE_TITLE}</span>
    </a>

    <nav class="nav-links" aria-label="主导航">
      <!-- 入口 - 独特风格：星门 -->
      <a href="/" class="nav-item" data-icon="entrance">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="2" x2="12" y2="6"/>
          <line x1="12" y1="18" x2="12" y2="22"/>
          <line x1="2" y1="12" x2="6" y2="12"/>
          <line x1="18" y1="12" x2="22" y2="12"/>
        </svg>
        <span>入口</span>
      </a>
      <!-- 首页 - 独特风格：星光小屋 -->
      <a href="/home" class="nav-item" data-icon="home">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <polygon points="12,2 22,9 22,22 2,22 2,9"/>
          <circle cx="12" cy="12" r="2" fill="currentColor"/>
          <line x1="8" y1="22" x2="8" y2="12"/>
          <line x1="16" y1="22" x2="16" y2="12"/>
        </svg>
        <span>首页</span>
      </a>
      <!-- 文章 - 独特风格：星轨文档 -->
      <a href="/blog" class="nav-item" data-icon="blog">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <line x1="8" y1="8" x2="16" y2="8"/>
          <line x1="8" y1="12" x2="16" y2="12"/>
          <path d="M8,16 L12,16 L16,16"/>
        </svg>
        <span>文章</span>
      </a>
      <!-- 资源 - 独特风格：星云宝箱 -->
      <a href="/resources" class="nav-item" data-icon="resources">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <line x1="3" y1="9" x2="21" y2="9"/>
          <line x1="9" y1="3" x2="9" y2="21"/>
          <circle cx="12" cy="15" r="2"/>
        </svg>
        <span>资源</span>
      </a>
      <!-- 关于 - 独特风格：星尘人像 -->
      <a href="/about" class="nav-item" data-icon="about">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4,20c0-4,3.6-8,8-8s8,4,8,8"/>
          <circle cx="12" cy="12" r="1" fill="currentColor"/>
        </svg>
        <span>关于</span>
      </a>
      <!-- 留言 - 独特风格：星语气泡 -->
      <a href="#comments" class="nav-item" data-icon="comments">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M21,15a2,2,0,0,1-2,2H7l-4,4V5a2,2,0,0,1,2-2H19a2,2,0,0,1,2,2Z"/>
          <line x1="8" y1="10" x2="16" y2="10"/>
          <line x1="8" y1="14" x2="12" y2="14"/>
        </svg>
        <span>留言</span>
      </a>
    </nav>
  </div>
</header>

<style>
.glass-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(6, 8, 16, 0.88);
  backdrop-filter: blur(20px) saturate(140%);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  transition: border-color var(--duration-normal) var(--ease-out-expo);
}

.glass-nav::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(240, 181, 69, 0.15) 20%,
    rgba(72, 187, 240, 0.1) 50%,
    rgba(240, 181, 69, 0.15) 80%,
    transparent 100%
  );
}

.nav-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--space-md);
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand {
  display: flex;
  align-items: center;
  gap: var(--space-2xs);
  text-decoration: none;
  color: var(--text-primary);
}

.logo-icon {
  flex-shrink: 0;
  filter: drop-shadow(0 0 6px rgba(240, 181, 69, 0.3));
  transition: filter var(--duration-normal) var(--ease-out-expo);
}

.brand:hover .logo-icon {
  filter: drop-shadow(0 0 12px rgba(240, 181, 69, 0.5));
}

.brand-text {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: var(--text-lg);
  letter-spacing: 0.06em;
  color: var(--text-primary);
  background: linear-gradient(135deg, var(--star-warm), var(--tech-cyan));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: var(--space-3xs);
}

.nav-item {
  display: flex;
  align-items: center;
  gap: var(--space-3xs);
  padding: var(--space-2xs) var(--space-sm);
  color: var(--text-muted);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 500;
  letter-spacing: 0.02em;
  text-decoration: none;
  border-radius: var(--radius-md);
  transition: all var(--duration-normal) var(--ease-out-expo);
  position: relative;
}

.nav-item svg {
  transition: all var(--duration-normal) var(--ease-out-expo);
  opacity: 0.6;
}

.nav-item:hover {
  color: var(--star-warm);
  background: rgba(240, 181, 69, 0.06);
}

.nav-item:hover svg {
  opacity: 1;
  filter: drop-shadow(0 0 4px rgba(240, 181, 69, 0.4));
  transform: scale(1.1);
}

.nav-item:active {
  transform: scale(0.97);
}

/* 图标悬停效果增强 */
.nav-item[data-icon="entrance"]:hover svg {
  animation: rotateStar 1.5s ease-in-out infinite;
}

.nav-item[data-icon="home"]:hover svg circle {
  animation: pulseStar 1.2s ease-in-out infinite;
}

@keyframes rotateStar {
  0%, 100% { transform: rotate(0deg); }
  50% { transform: rotate(180deg); }
}

@keyframes pulseStar {
  0%, 100% { r: 2; }
  50% { r: 3; }
}

@media (max-width: 640px) {
  .nav-item span {
    display: none;
  }

  .nav-item {
    padding: var(--space-2xs) var(--space-xs);
  }

  .brand-text {
    font-size: var(--text-base);
  }
}
</style>