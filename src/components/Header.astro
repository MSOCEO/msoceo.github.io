---
import ThemeToggle from './ThemeToggle.astro';
import { SITE_TITLE } from '../consts';

const navLinks = [
  { href: '/', label: '首页' },
  { href: '/archive', label: '归档' },
  { href: '/categories', label: '分类' },
  { href: '/tags', label: '标签' },
  { href: '/about', label: '关于' },
  { href: '/guestbook', label: '留言板' },
];
---

<header class="sticky top-0 z-50 bg-[var(--bg-primary)]/90 backdrop-blur-md border-b border-[var(--border-color)] transition-colors">
  <!-- 顶部状态栏 -->
  <div class="status-bar">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex items-center justify-between">
      <time id="status-time" datetime="" class="tabular-nums">
        <span id="status-date"></span> <span id="status-clock"></span>
      </time>
      <div class="flex items-center gap-3">
        <a href="/rss.xml" class="text-xs opacity-60 hover:opacity-100 transition-opacity" title="RSS 订阅">RSS</a>
        <ThemeToggle />
      </div>
    </div>
  </div>

  <!-- 导航栏 -->
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="flex items-center gap-2 font-serif font-bold text-xl tracking-tight">
        <span class="text-[var(--accent)]">寒</span>影
      </a>

      <!-- 桌面导航 -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="link-underline px-3 py-2 text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors"
          >
            {link.label}
          </a>
        ))}
        <button
          id="search-trigger"
          class="flex items-center justify-center w-9 h-9 rounded-lg border border-[var(--border-color)] text-[var(--text-tertiary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] transition-all ml-2"
          aria-label="搜索"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
          </svg>
        </button>
      </div>

      <!-- 移动端菜单按钮 -->
      <div class="flex md:hidden items-center gap-2">
        <button id="search-trigger-mobile" class="flex items-center justify-center w-9 h-9 rounded-lg border border-[var(--border-color)] text-[var(--text-tertiary)]" aria-label="搜索">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
          </svg>
        </button>
        <button id="mobile-menu-btn" class="flex items-center justify-center w-9 h-9 rounded-lg border border-[var(--border-color)] text-[var(--text-secondary)]" aria-label="菜单">
          <svg id="menu-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- 移动端折叠菜单 -->
    <div id="mobile-menu" class="md:hidden overflow-hidden transition-all duration-300" style="max-height:0">
      <div class="flex flex-col gap-1 pb-4 pt-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="link-underline px-3 py-2.5 text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors rounded-lg hover:bg-[var(--bg-secondary)]"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  // 状态栏时间
  function updateTime() {
    const now = new Date();
    const dateEl = document.getElementById('status-date');
    const clockEl = document.getElementById('status-clock');
    if (dateEl) {
      dateEl.textContent = now.toLocaleDateString('zh-CN', {
        year: 'numeric', month: 'long', day: 'numeric', weekday: 'short'
      });
    }
    if (clockEl) {
      clockEl.textContent = now.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
    }
  }
  updateTime();
  setInterval(updateTime, 30000);

  // 移动端菜单
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  if (menuBtn && menu) {
    menuBtn.addEventListener('click', () => {
      const isOpen = menu.style.maxHeight !== '0px';
      menu.style.maxHeight = isOpen ? '0px' : '300px';
      if (menuIcon) {
        menuIcon.innerHTML = isOpen
          ? '<line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/>'
          : '<line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/>';
      }
    });
  }
</script>
