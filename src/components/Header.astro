---
// 墨影 Header — 极简暗色导航
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="枕星首页">
      <span class="logo-text">枕星</span>
      <span class="logo-dot" aria-hidden="true"></span>
    </a>

    <nav class="nav-links" aria-label="主导航">
      <a href="/blog" class="nav-link">文章</a>
      <a href="/resources" class="nav-link">资源</a>
      <a href="/about" class="nav-link">关于</a>
      <a href="/guestbook" class="nav-link">留言</a>
    </nav>

    <div class="nav-actions">
      <a href="/login" class="btn btn-ghost">登录</a>
      <a href="/register" class="btn btn-primary">注册</a>
    </div>

    <button class="mobile-toggle" id="mobile-toggle" aria-label="菜单">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="mobile-nav" id="mobile-nav">
  <div class="mobile-nav-bg" id="mobile-nav-bg"></div>
  <div class="mobile-nav-panel">
    <nav>
      <a href="/blog" class="mobile-link">文章</a>
      <a href="/resources" class="mobile-link">资源</a>
      <a href="/about" class="mobile-link">关于</a>
      <a href="/guestbook" class="mobile-link">留言</a>
    </nav>
    <div class="mobile-auth">
      <a href="/login" class="btn btn-secondary">登录</a>
      <a href="/register" class="btn btn-primary">注册</a>
    </div>
  </div>
</div>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('mobile-toggle');
  const nav = document.getElementById('mobile-nav');
  const bg = document.getElementById('mobile-nav-bg');

  let scrolled = false;
  window.addEventListener('scroll', () => {
    const now = window.scrollY > 20;
    if (now !== scrolled) {
      scrolled = now;
      header.classList.toggle('scrolled', scrolled);
    }
  }, { passive: true });

  let open = false;
  toggle.addEventListener('click', () => {
    open = !open;
    nav.classList.toggle('open', open);
    document.body.style.overflow = open ? 'hidden' : '';
    toggle.classList.toggle('active', open);
  });
  bg.addEventListener('click', () => {
    open = false;
    nav.classList.remove('open');
    document.body.style.overflow = '';
    toggle.classList.remove('active');
  });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    z-index: 100;
    transition: background var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
    background: transparent;
  }

  .site-header.scrolled {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border-bottom: 1px solid var(--glass-border);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-xl);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: var(--weight-bold);
    color: var(--ink-90);
    letter-spacing: 0.06em;
  }

  .logo-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--amber-400);
    box-shadow: 0 0 8px var(--amber-400);
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.5); }
  }

  /* Nav links */
  .nav-links {
    display: flex;
    gap: 4px;
  }

  .nav-link {
    padding: 6px 14px;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--ink-50);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .nav-link:hover {
    color: var(--ink-90);
    background: rgba(255,255,255,0.05);
  }

  /* Actions */
  .nav-actions {
    display: flex;
    gap: var(--space-sm);
    align-items: center;
  }

  /* Mobile toggle */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .mobile-toggle span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--ink-70);
    border-radius: 1px;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .mobile-toggle.active span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .mobile-toggle.active span:nth-child(2) {
    opacity: 0;
  }
  .mobile-toggle.active span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Mobile nav */
  .mobile-nav {
    display: none;
  }

  @media (max-width: 768px) {
    .nav-links, .nav-actions {
      display: none;
    }
    .mobile-toggle { display: flex; }
    .header-inner { padding: 0 var(--space-lg); }

    .mobile-nav {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 200;
      pointer-events: none;
    }
    .mobile-nav.open { pointer-events: auto; }

    .mobile-nav-bg {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.6);
      opacity: 0;
      transition: opacity var(--duration-normal) var(--ease-out);
    }
    .mobile-nav.open .mobile-nav-bg { opacity: 1; }

    .mobile-nav-panel {
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: 260px;
      background: var(--ink-15);
      border-left: 1px solid var(--ink-20);
      padding: calc(var(--header-height) + var(--space-lg)) var(--space-lg) var(--space-lg);
      transform: translateX(100%);
      transition: transform var(--duration-normal) var(--ease-out);
      display: flex;
      flex-direction: column;
      gap: var(--space-xl);
    }
    .mobile-nav.open .mobile-nav-panel {
      transform: translateX(0);
    }

    .mobile-link {
      display: block;
      padding: var(--space-sm) 0;
      font-size: var(--text-lg);
      color: var(--ink-70);
      text-decoration: none;
      border-bottom: 1px solid var(--ink-20);
    }
    .mobile-link:hover { color: var(--ink-90); }

    .mobile-auth {
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
      margin-top: auto;
    }
  }
</style>
