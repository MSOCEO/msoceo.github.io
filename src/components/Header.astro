---
// src/components/Header.astro — 极简专业导航栏
import { SITE_TITLE } from '../consts';
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand" aria-label="拾光 — 返回入口">
      <svg class="logo-icon" viewBox="0 0 36 36" width="32" height="32" aria-hidden="true">
        <defs>
          <linearGradient id="logoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#f0b545"/>
            <stop offset="100%" stop-color="#e88a2b"/>
          </linearGradient>
        </defs>
        <!-- 简化几何星光 Logo -->
        <circle cx="18" cy="18" r="16" fill="none" stroke="url(#logoGrad)" stroke-width="1.2" opacity="0.4"/>
        <circle cx="18" cy="18" r="12" fill="none" stroke="url(#logoGrad)" stroke-width="0.6" opacity="0.25"/>
        <polygon points="18,4 22,14 18,32 14,14" fill="url(#logoGrad)" opacity="0.9"/>
        <circle cx="18" cy="18" r="2.5" fill="#f5e6c8"/>
        <circle cx="18" cy="18" r="5" fill="none" stroke="rgba(240,181,69,0.2)" stroke-width="0.5"/>
      </svg>
      <span class="brand-text">{SITE_TITLE}</span>
    </a>

    <nav class="nav-links" aria-label="主导航">
      <a href="/home" class="nav-item">首页</a>
      <a href="/blog" class="nav-item">文章</a>
      <a href="/resources" class="nav-item">资源</a>
      <a href="/about" class="nav-item">关于</a>
    </nav>
  </div>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(8, 10, 20, 0.92);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--space-lg);
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  text-decoration: none;
}

.logo-icon {
  flex-shrink: 0;
  filter: drop-shadow(0 0 4px rgba(240, 181, 69, 0.2));
  transition: filter var(--duration-normal) ease;
}

.brand:hover .logo-icon {
  filter: drop-shadow(0 0 8px rgba(240, 181, 69, 0.4));
}

.brand-text {
  font-family: var(--font-body);
  font-size: var(--text-lg);
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--text-primary);
}

.nav-links {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.nav-item {
  padding: var(--space-xs) var(--space-md);
  color: var(--text-muted);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 500;
  letter-spacing: 0.04em;
  text-decoration: none;
  border-radius: var(--radius-sm);
  transition: all var(--duration-fast) ease;
}

.nav-item:hover {
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.04);
}

@media (max-width: 640px) {
  .header-inner {
    padding: 0 var(--space-md);
  }

  .nav-item {
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-xs);
  }
}
</style>