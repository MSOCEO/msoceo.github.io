---
import { SITE_TITLE } from '../consts';
const currentPath = Astro.url.pathname;
---

<header>
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-bracket">[</span>
      <span class="logo-text">{SITE_TITLE}</span>
      <span class="logo-bracket">]</span>
      <span class="logo-cursor"></span>
    </a>
    <nav>
      <a href="/" class:list={['nav-link', { active: currentPath === '/' }]}>
        <span class="nav-index">00</span>Home
      </a>
      <a href="/blog" class:list={['nav-link', { active: currentPath.startsWith('/blog') }]}>
        <span class="nav-index">01</span>Articles
      </a>
      <a href="/resources" class:list={['nav-link', { active: currentPath === '/resources' }]}>
        <span class="nav-index">02</span>Resources
      </a>
      <a href="/about" class:list={['nav-link', { active: currentPath === '/about' }]}>
        <span class="nav-index">03</span>About
      </a>
    </nav>
    <div class="header-status">
      <span class="status-dot"></span>
      <span class="status-text">ONLINE</span>
    </div>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: oklch(10% 0.025 265 / 0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
  }

  .logo {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0;
    white-space: nowrap;
  }

  .logo:hover {
    color: var(--accent-glow);
    text-shadow: none;
  }

  .logo-bracket {
    color: var(--text-muted);
  }

  .logo-text {
    color: var(--accent);
  }

  .logo-cursor {
    display: inline-block;
    width: 1ch;
    height: 1.2em;
    background: var(--accent);
    margin-left: 2px;
    animation: cursor-blink 1s step-end infinite;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  nav {
    display: flex;
    gap: var(--space-xs);
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    text-decoration: none;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
    letter-spacing: 0.03em;
    position: relative;
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: var(--bg-hover);
    text-shadow: none;
  }

  .nav-link.active {
    color: var(--accent);
    background: oklch(18% 0.04 62 / 0.12);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
  }

  .nav-index {
    color: var(--text-muted);
    margin-right: 4px;
    font-size: 0.8em;
  }

  .nav-link.active .nav-index {
    color: var(--accent-dim);
  }

  .header-status {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 8px var(--success);
    animation: status-pulse 2s ease-in-out infinite;
  }

  @keyframes status-pulse {
    0%, 100% { box-shadow: 0 0 4px var(--success); }
    50% { box-shadow: 0 0 12px var(--success), 0 0 24px var(--success); }
  }

  .status-text {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  @media (max-width: 640px) {
    .header-inner {
      padding: 0 var(--space-md);
      gap: var(--space-sm);
    }
    .header-status {
      display: none;
    }
    .nav-link {
      padding: var(--space-xs) 4px;
    }
  }
</style>