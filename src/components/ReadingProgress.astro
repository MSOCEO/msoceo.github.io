<script>
  function ReadingProgress() {
    const progress = document.getElementById('reading-progress');
    if (!progress) return;
    const update = () => {
      const h = document.documentElement;
      const scrollTop = h.scrollTop;
      const scrollHeight = h.scrollHeight - h.clientHeight;
      const pct = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
      progress.style.width = `${pct}%`;
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
  document.addEventListener('DOMContentLoaded', ReadingProgress);
  document.addEventListener('astro:page-load', ReadingProgress);
</script>

<div id="reading-progress" class="reading-progress" style="width:0%" />
