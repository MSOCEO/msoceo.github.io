---
// src/components/Comments.astro — 留言区域组件（含表情选择）
---

<section id="comments" class="comments-section">
  <div class="comments-header">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
      <path d="M21,15a2,2,0,0,1-2,2H7l-4,4V5a2,2,0,0,1,2-2H19a2,2,0,0,1,2,2Z"/>
      <line x1="8" y1="10" x2="16" y2="10"/>
      <line x1="8" y1="14" x2="12" y2="14"/>
    </svg>
    <h3>留言</h3>
    <span class="comment-count">12 条留言</span>
  </div>

  <div class="comments-list">
    <!-- 留言 1 -->
    <div class="comment-item">
      <div class="comment-avatar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4,20c0-4,3.6-8,8-8s8,4,8,8"/>
        </svg>
      </div>
      <div class="comment-body">
        <div class="comment-meta">
          <span class="comment-author">星辰旅人</span>
          <span class="comment-badge">来访者</span>
          <span class="comment-time">3 分钟前</span>
        </div>
        <p class="comment-text">在黑夜中寻找星光，这个主题太美了。来自上海的朋友路过~</p>
        <div class="comment-visitor-info">
          <span>上海</span>
          <span class="dot">·</span>
          <span>iPhone 15 Pro</span>
          <span class="dot">·</span>
          <span>106.38.xx.xx</span>
        </div>
        <!-- 表情回应 -->
        <div class="comment-reactions">
          <button class="reaction-btn active" title="喜欢">❤️ <span>5</span></button>
          <button class="reaction-btn" title="赞">👍 <span>3</span></button>
          <button class="reaction-btn" title="大笑">😂 <span>1</span></button>
          <button class="reaction-btn" title="惊叹">😮 <span>2</span></button>
          <button class="reaction-btn add-reaction" title="添加回应">+</button>
        </div>
      </div>
    </div>

    <!-- 留言 2 -->
    <div class="comment-item">
      <div class="comment-avatar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4,20c0-4,3.6-8,8-8s8,4,8,8"/>
        </svg>
      </div>
      <div class="comment-body">
        <div class="comment-meta">
          <span class="comment-author">探索者</span>
          <span class="comment-time">1 小时前</span>
        </div>
        <p class="comment-text">终于找到一个有品位的博客了，黑曜石的设计确实独特。</p>
        <div class="comment-visitor-info">
          <span>北京</span>
          <span class="dot">·</span>
          <span>Windows PC</span>
          <span class="dot">·</span>
          <span>114.246.xx.xx</span>
        </div>
        <div class="comment-reactions">
          <button class="reaction-btn active" title="赞">👍 <span>7</span></button>
          <button class="reaction-btn" title="喜欢">❤️ <span>4</span></button>
          <button class="reaction-btn" title="鼓掌">👏 <span>3</span></button>
          <button class="reaction-btn add-reaction" title="添加回应">+</button>
        </div>
      </div>
    </div>

    <!-- 留言 3 -->
    <div class="comment-item">
      <div class="comment-avatar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4,20c0-4,3.6-8,8-8s8,4,8,8"/>
        </svg>
      </div>
      <div class="comment-body">
        <div class="comment-meta">
          <span class="comment-author">星河漫步者</span>
          <span class="comment-time">3 小时前</span>
        </div>
        <p class="comment-text">从 GitHub 找过来的，代码风格很干净，期待更多技术文章。</p>
        <div class="comment-visitor-info">
          <span>深圳</span>
          <span class="dot">·</span>
          <span>Android</span>
          <span class="dot">·</span>
          <span>121.35.xx.xx</span>
        </div>
        <div class="comment-reactions">
          <button class="reaction-btn active" title="赞">👍 <span>2</span></button>
          <button class="reaction-btn" title="加油">💪 <span>1</span></button>
          <button class="reaction-btn add-reaction" title="添加回应">+</button>
        </div>
      </div>
    </div>
  </div>

  <div class="comment-form-wrapper">
    <h4>留下足迹</h4>
    <form class="comment-form" id="commentForm">
      <div class="form-row">
        <input type="text" name="nickname" placeholder="你的昵称" class="form-input" maxlength="20" required />
        <input type="text" name="location" placeholder="所在城市" class="form-input" maxlength="10" />
      </div>
      <div class="textarea-wrapper">
        <textarea name="content" id="commentTextarea" placeholder="说点什么吧..." class="form-textarea" rows="3" maxlength="500" required></textarea>
        <!-- 选中的表情预览 -->
        <div class="selected-emoji-preview" id="selectedEmojiPreview"></div>
      </div>
      <div class="form-actions">
        <!-- 表情选择器 -->
        <div class="emoji-picker-container">
          <button type="button" class="emoji-toggle" id="emojiToggle" title="选择表情">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M8,14c0,0,1.5,2,4,2s4-2,4-2"/>
              <line x1="9" y1="9" x2="9.01" y2="9"/>
              <line x1="15" y1="9" x2="15.01" y2="9"/>
            </svg>
            <span>表情</span>
          </button>
          <!-- 表情面板 -->
          <div class="emoji-panel" id="emojiPanel">
            <div class="emoji-categories">
              <button type="button" class="emoji-cat active" data-cat="smileys">😊</button>
              <button type="button" class="emoji-cat" data-cat="gestures">👋</button>
