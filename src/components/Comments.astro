  let selectedEmoji = '';

  // 打开/关闭表情面板
  emojiToggle.addEventListener('click', (e) => {
    e.preventDefault();
    emojiPanel.classList.toggle('open');
    emojiToggle.classList.toggle('active');
  });

  // 点击面板外部关闭
  document.addEventListener('click', (e) => {
    if (!emojiPanel.contains(e.target) && e.target !== emojiToggle && !emojiToggle.contains(e.target)) {
      emojiPanel.classList.remove('open');
      emojiToggle.classList.remove('active');
    }
  });

  // 分类切换
  document.querySelectorAll('.emoji-cat').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.emoji-cat').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = btn.dataset.cat;
      document.querySelectorAll('.emoji-grid').forEach(g => g.classList.remove('active'));
      document.querySelector(`.emoji-grid[data-cat="${cat}"]`).classList.add('active');
    });
  });

  // 表情选择
  document.querySelectorAll('.emoji-item').forEach(btn => {
    btn.addEventListener('click', () => {
      selectedEmoji = btn.textContent;
      selectedEmojiPreview.textContent = selectedEmoji;
      selectedEmojiPreview.classList.add('visible');
    });
  });

  // 表单提交处理
  document.getElementById('commentForm').addEventListener('submit', (e) => {
    e.preventDefault();
    const nickname = e.target.nickname.value.trim();
    const content = e.target.content.value.trim();
    const prefix = selectedEmoji ? selectedEmoji + ' ' : '';
    const fullContent = prefix + content;
    console.log('留言:', { nickname, content: fullContent });
    // 清空
    e.target.content.value = '';
    selectedEmoji = '';
    selectedEmojiPreview.textContent = '';
    selectedEmojiPreview.classList.remove('visible');
    emojiPanel.classList.remove('open');
    emojiToggle.classList.remove('active');
  });

  // 表情回应按钮交互
  document.querySelectorAll('.reaction-btn').forEach(btn => {
    if (!btn.classList.contains('add-reaction')) {
      btn.addEventListener('click', function() {
        this.classList.toggle('active');
        const span = this.querySelector('span');
        const currentCount = parseInt(span.textContent);
        if (this.classList.contains('active')) {
          span.textContent = currentCount + 1;
        } else {
          span.textContent = Math.max(0, currentCount - 1);
        }
      });
    }
  });

  // 添加回应按钮
  document.querySelectorAll('.add-reaction').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      const reactions = this.parentElement;
      const quickEmojis = ['❤️', '👍', '😂', '😮', '👏', '💪', '🔥', '😍'];
      const emoji = quickEmojis[Math.floor(Math.random() * quickEmojis.length)];
      const newBtn = document.createElement('button');
      newBtn.className = 'reaction-btn active';
      newBtn.title = '新回应';
      newBtn.innerHTML = `${emoji} <span>1</span>`;
      newBtn.addEventListener('click', function() {
        this.classList.toggle('active');
        const span = this.querySelector('span');
        const count = parseInt(span.textContent);
        span.textContent = this.classList.contains('active') ? count + 1 : Math.max(0, count - 1);
      });
      reactions.insertBefore(newBtn, this);
    });
  });
</script>

