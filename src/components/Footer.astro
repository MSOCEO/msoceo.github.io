---
const today = new Date();
---

<footer>
  <div class="footer-inner">
    <div class="footer-content">
      <span>&copy; {today.getFullYear()} MSOCEO</span>
      <span class="footer-sep">&middot;</span>
      <span>Powered by Astro</span>
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 2.5rem 1.5rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-content {
    font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
    font-size: 0.8rem;
    color: oklch(48% 0.015 265);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    letter-spacing: 0.02em;
  }

  .footer-sep {
    color: oklch(28% 0.025 265);
  }

  @media (max-width: 640px) {
    footer {
      padding: 2rem 1rem;
    }
  }
</style>