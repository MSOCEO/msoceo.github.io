---
// src/components/Footer.astro — 黑曜石星光页脚
---

<footer class="obsidian-footer">
  <div class="footer-inner">
    <p class="footer-text">在黑暗中寻找光，在代码里写下温度。</p>
    <p class="footer-copy">&copy; {new Date().getFullYear()} MSOCEO &middot; Built with Astro</p>
  </div>
</footer>

<style>
.obsidian-footer {
  border-top: 1px solid var(--border-ghost);
  padding: var(--space-xl) var(--space-md);
  margin-top: var(--space-3xl);
  position: relative;
}

.obsidian-footer::before {
  content: '';
  position: absolute;
  top: -1px;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, oklch(78% 0.18 65 / 0.1) 30%, oklch(78% 0.18 65 / 0.1) 70%, transparent);
}

.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  text-align: center;
}

.footer-text {
  font-family: var(--font-display);
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-2xs);
  font-style: italic;
}

.footer-copy {
  font-size: var(--text-xs);
  color: var(--text-muted);
}
</style>