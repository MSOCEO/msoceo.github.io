---
// Yun 风格 Footer — 波浪装饰
---

<footer class="yun-footer">
  <!-- 波浪装饰 -->
  <div class="yun-waves">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="yun-wave yun-wave-1">
      <path d="M0,40 C360,100 720,0 1080,60 C1260,90 1380,30 1440,40 L1440,120 L0,120 Z" fill="var(--va-c-bg-soft)" opacity="0.5"/>
    </svg>
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="yun-wave yun-wave-2">
      <path d="M0,60 C240,20 600,100 960,40 C1140,10 1320,80 1440,50 L1440,120 L0,120 Z" fill="var(--va-c-bg-soft)" opacity="0.7"/>
    </svg>
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="yun-wave yun-wave-3">
      <path d="M0,80 C300,40 540,100 900,50 C1140,10 1320,70 1440,60 L1440,120 L0,120 Z" fill="var(--va-c-bg-soft)"/>
    </svg>
  </div>

  <!-- Footer 内容 -->
  <div class="yun-footer-content">
    <div class="yun-footer-brand">
      <span class="yun-footer-logo">枕星</span>
      <span class="yun-footer-tagline">代码与日常的缝隙之间</span>
    </div>
    <div class="yun-footer-info">
      <p>&copy; 2025 枕星. Built with Astro.</p>
    </div>
  </div>
</footer>

<!-- 返回顶部按钮 -->
<button class="yun-back-to-top" id="back-to-top" aria-label="返回顶部">
  <svg width="100%" height="100%" viewBox="0 0 40 40" class="yun-btt-ring">
    <circle cx="20" cy="20" r="17" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.15"/>
    <circle cx="20" cy="20" r="17" fill="none" stroke="currentColor" stroke-width="1.5"
      stroke-dasharray="106.8" stroke-dashoffset="106.8" stroke-linecap="round"
      class="yun-btt-progress" id="btt-progress"/>
  </svg>
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="yun-btt-arrow">
    <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

<script>
  const btt = document.getElementById('back-to-top');
  const bttProgress = document.getElementById('btt-progress');
  
  function updateBackToTop() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
    
    if (scrollTop > 300) {
      btt.classList.add('visible');
    } else {
      btt.classList.remove('visible');
    }
    
    const circumference = 2 * Math.PI * 17; // ~106.8
    bttProgress.style.strokeDashoffset = circumference * (1 - progress);
  }
  
  window.addEventListener('scroll', updateBackToTop, { passive: true });
  
  btt.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
  
  updateBackToTop();
</script>

<style>
  .yun-footer {
    position: relative;
    background: var(--va-c-bg-soft);
    overflow: hidden;
  }

  /* ===== 波浪装饰 ===== */
  .yun-waves {
    position: relative;
    width: 100%;
    height: 80px;
    margin-top: -1px;
  }

  .yun-wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .yun-wave-1 {
    animation: wave-move-1 8s ease-in-out infinite alternate;
  }

  .yun-wave-2 {
    animation: wave-move-2 6s ease-in-out infinite alternate;
  }

  .yun-wave-3 {
    animation: wave-move-3 10s ease-in-out infinite alternate;
  }

  @keyframes wave-move-1 {
    0% { transform: translateX(0) scaleY(1); }
    100% { transform: translateX(-15px) scaleY(1.05); }
  }

  @keyframes wave-move-2 {
    0% { transform: translateX(0) scaleY(1); }
    100% { transform: translateX(10px) scaleY(0.95); }
  }

  @keyframes wave-move-3 {
    0% { transform: translateX(0) scaleY(1); }
    100% { transform: translateX(-8px) scaleY(1.02); }
  }

  /* ===== Footer 内容 ===== */
  .yun-footer-content {
    max-width: var(--yun-post-card-max-width);
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--va-c-divider);
  }

  .yun-footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .yun-footer-logo {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1rem;
    color: var(--va-c-text);
  }

  .yun-footer-tagline {
    font-size: 0.8rem;
    color: var(--va-c-text-lighter);
  }

  .yun-footer-info {
    font-size: 0.8rem;
    color: var(--va-c-text-lighter);
  }

  /* ===== 返回顶部 ===== */
  .yun-back-to-top {
    position: fixed;
    bottom: var(--space-xl);
    right: var(--space-xl);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: var(--va-c-bg-light);
    box-shadow: var(--shadow-md);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 80;
    opacity: 0;
    transform: translateY(10px);
    pointer-events: none;
    transition: all var(--duration-normal) var(--ease-out);
    color: var(--va-c-primary);
  }

  .yun-back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .yun-back-to-top:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .yun-btt-ring {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .yun-btt-progress {
    transition: stroke-dashoffset 0.1s linear;
  }

  .yun-btt-arrow {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .yun-footer-content {
      flex-direction: column;
      text-align: center;
      gap: var(--space-sm);
      padding: var(--space-md) var(--space-sm);
    }

    .yun-back-to-top {
      bottom: var(--space-md);
      right: var(--space-md);
      width: 36px;
      height: 36px;
    }
  }
</style>