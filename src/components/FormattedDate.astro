---
interface Props {
  date: Date;
}

const { date } = Astro.props;
const formatted = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<time datetime={date.toISOString()} class="text-sm text-[var(--text-tertiary)] tabular-nums">
  {formatted}
</time>
