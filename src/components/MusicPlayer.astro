---
// src/components/MusicPlayer.astro — 悬浮迷你音乐播放器
---

<div id="music-player" class="music-player" aria-label="音乐播放器">
  <button class="player-toggle" id="player-toggle" aria-label="展开音乐播放器">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
      <path d="M9 18V5l12-2v13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="6" cy="18" r="3" stroke="currentColor" stroke-width="1.5"/>
      <circle cx="18" cy="16" r="3" stroke="currentColor" stroke-width="1.5"/>
    </svg>
  </button>

  <div class="player-panel" id="player-panel">
    <div class="player-now-playing">
      <div class="album-cover" id="album-cover">
        <div class="cover-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.2" opacity="0.4"/>
            <circle cx="12" cy="12" r="6" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
            <circle cx="12" cy="12" r="2" fill="currentColor" opacity="0.6"/>
          </svg>
        </div>
        <div class="cover-disc" id="cover-disc"></div>
      </div>
      <div class="track-info">
        <span class="track-title" id="track-title">未在播放</span>
        <span class="track-artist" id="track-artist">--</span>
      </div>
    </div>

    <div class="player-controls">
      <div class="progress-bar" id="progress-bar">
        <div class="progress-fill" id="progress-fill"></div>
        <div class="progress-thumb" id="progress-thumb"></div>
      </div>
      <div class="time-display">
        <span id="current-time">00:00</span>
        <span id="total-time">00:00</span>
      </div>

      <div class="control-buttons">
        <button class="ctrl-btn" id="btn-prev" aria-label="上一首">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M19 5v14l-11-7 11-7zM4 5h2v14H4V5z" fill="currentColor"/>
          </svg>
        </button>
        <button class="ctrl-btn ctrl-btn-play" id="btn-play" aria-label="播放">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="icon-play">
            <polygon points="7,4 21,12 7,20" fill="currentColor"/>
          </svg>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="icon-pause">
            <rect x="6" y="4" width="4" height="16" rx="1" fill="currentColor"/>
            <rect x="14" y="4" width="4" height="16" rx="1" fill="currentColor"/>
          </svg>
        </button>
        <button class="ctrl-btn" id="btn-next" aria-label="下一首">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M5 5v14l11-7-11-7zM18 5h2v14h-2V5z" fill="currentColor"/>
          </svg>
        </button>
      </div>

      <div class="player-footer">
        <button class="ctrl-btn" id="btn-mode" aria-label="播放模式" title="顺序播放">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="icon-loop">
            <path d="M17 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M3 11V9a4 4 0 014-4h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M7 22l-4-4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M21 13v2a4 4 0 01-4 4H3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <div class="volume-control">
          <button class="ctrl-btn" id="btn-volume" aria-label="音量">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M11 5L6 9H2v6h4l5 4V5z" fill="currentColor"/>
              <path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
          <input type="range" class="volume-slider" id="volume-slider" min="0" max="100" value="60" aria-label="音量调节"/>
        </div>
        <button class="ctrl-btn" id="btn-playlist" aria-label="播放列表">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="playlist-panel" id="playlist-panel">
      <div class="playlist-header">
        <span>播放列表</span>
        <button class="playlist-close" id="playlist-close">&times;</button>
      </div>
      <ul class="playlist-list" id="playlist-list"></ul>
    </div>
  </div>
</div>

<audio id="audio-player" preload="metadata"></audio>

<script>
  // 默认曲目（可替换为用户自己的音乐路径）
  const defaultPlaylist = [
    { title: '星夜', artist: '拾光精选', src: '', cover: '' },
    { title: '晨光微熹', artist: '拾光精选', src: '', cover: '' },
    { title: '暮色海岸', artist: '拾光精选', src: '', cover: '' },
  ];

  let playlist = [...defaultPlaylist];
  let currentIndex = 0;
  let mode = 'loop'; // 'loop' | 'one' | 'shuffle'
  let isDragging = false;

  const audio = document.getElementById('audio-player');
  const panel = document.getElementById('player-panel');
  const toggle = document.getElementById('player-toggle');
  const titleEl = document.getElementById('track-title');
  const artistEl = document.getElementById('track-artist');
  const playBtn = document.getElementById('btn-play');
  const progressBar = document.getElementById('progress-bar');
  const progressFill = document.getElementById('progress-fill');
  const progressThumb = document.getElementById('progress-thumb');
  const currentTimeEl = document.getElementById('current-time');
  const totalTimeEl = document.getElementById('total-time');
  const volumeSlider = document.getElementById('volume-slider');
  const playlistPanel = document.getElementById('playlist-panel');
  const playlistList = document.getElementById('playlist-list');
  const coverDisc = document.getElementById('cover-disc');
  const btnMode = document.getElementById('btn-mode');

  let panelVisible = false;
  let playlistVisible = false;

  function formatTime(s) {
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return `${String(m).padStart(2, '0')}:${String(sec).padStart(2, '0')}`;
  }

  function loadTrack(index) {
    currentIndex = index;
    const track = playlist[index];
    audio.src = track.src;
    titleEl.textContent = track.title || '未知曲目';
    artistEl.textContent = track.artist || '--';
    updatePlaylistActive();
    if (track.src) {
      audio.play().catch(() => {});
    }
  }

  function togglePlay() {
    if (!playlist[currentIndex]?.src) return;
    if (audio.paused) {
      audio.play().catch(() => {});
    } else {
      audio.pause();
    }
  }

  function updatePlayPauseIcon() {
    const p = playBtn;
    if (audio.paused) {
      p.classList.remove('is-playing');
    } else {
      p.classList.add('is-playing');
    }
  }

  function updateProgress() {
    if (isDragging) return;
    const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
    progressFill.style.width = `${pct}%`;
    progressThumb.style.left = `${pct}%`;
    currentTimeEl.textContent = formatTime(audio.currentTime);
  }

  function setProgress(e) {
    const rect = progressBar.getBoundingClientRect();
    const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
    if (audio.duration) audio.currentTime = pct * audio.duration;
  }

  function nextTrack() {
    let next;
    if (mode === 'shuffle') {
      next = Math.floor(Math.random() * playlist.length);
    } else {
      next = (currentIndex + 1) % playlist.length;
    }
    loadTrack(next);
  }

  function prevTrack() {
    let prev;
    if (mode === 'shuffle') {
      prev = Math.floor(Math.random() * playlist.length);
    } else {
      prev = (currentIndex - 1 + playlist.length) % playlist.length;
    }
    loadTrack(prev);
  }

  function cycleMode() {
    const modes = ['loop', 'one', 'shuffle'];
    const idx = modes.indexOf(mode);
    mode = modes[(idx + 1) % 3];
    const labels = { loop: '顺序播放', one: '单曲循环', shuffle: '随机播放' };
    const icons = { loop: 'icon-loop', one: 'icon-one', shuffle: 'icon-shuffle' };
    btnMode.title = labels[mode];
    btnMode.querySelectorAll('svg').forEach(s => s.style.display = 'none');
    const svg = btnMode.querySelector('.' + icons[mode]);
    if (svg) svg.style.display = '';
    if (!svg) {
      btnMode.querySelector('.icon-loop').style.display = '';
    }
  }

  function updatePlaylistUI() {
    playlistList.innerHTML = playlist.map((t, i) => {
      const active = i === currentIndex ? ' active' : '';
      return `<li class="playlist-item${active}" data-index="${i}">
        <span class="pl-index">${String(i + 1).padStart(2, '0')}</span>
        <span class="pl-title">${t.title}</span>
        <span class="pl-artist">${t.artist}</span>
      </li>`;
    }).join('');
  }

  function updatePlaylistActive() {
    playlistList.querySelectorAll('.playlist-item').forEach((li, i) => {
      li.classList.toggle('active', i === currentIndex);
    });
  }

  // events
  toggle.addEventListener('click', () => {
    panelVisible = !panelVisible;
    panel.classList.toggle('open', panelVisible);
    playlistPanel.classList.remove('open');
    playlistVisible = false;
  });

  playBtn.addEventListener('click', togglePlay);
  document.getElementById('btn-next').addEventListener('click', nextTrack);
  document.getElementById('btn-prev').addEventListener('click', prevTrack);

  progressBar.addEventListener('mousedown', (e) => {
    isDragging = true;
    setProgress(e);
    const move = (ev) => setProgress(ev);
    const up = () => { isDragging = false; document.removeEventListener('mousemove', move); document.removeEventListener('mouseup', up); };
    document.addEventListener('mousemove', move);
    document.addEventListener('mouseup', up);
  });

  volumeSlider.addEventListener('input', () => {
    audio.volume = volumeSlider.value / 100;
  });
  audio.volume = 0.6;

  audio.addEventListener('timeupdate', updateProgress);
  audio.addEventListener('loadedmetadata', () => {
    totalTimeEl.textContent = formatTime(audio.duration);
  });
  audio.addEventListener('play', updatePlayPauseIcon);
  audio.addEventListener('pause', updatePlayPauseIcon);
  audio.addEventListener('ended', () => {
    if (mode === 'one') {
      audio.currentTime = 0;
      audio.play().catch(() => {});
    } else {
      nextTrack();
    }
  });

  btnMode.addEventListener('click', cycleMode);
  document.getElementById('btn-playlist').addEventListener('click', () => {
    playlistVisible = !playlistVisible;
    playlistPanel.classList.toggle('open', playlistVisible);
  });
  document.getElementById('playlist-close').addEventListener('click', () => {
    playlistVisible = false;
    playlistPanel.classList.remove('open');
  });

  playlistList.addEventListener('click', (e) => {
    const item = e.target.closest('.playlist-item');
    if (!item) return;
    loadTrack(parseInt(item.dataset.index));
    playlistVisible = false;
    playlistPanel.classList.remove('open');
  });

  // 初始化
  updatePlaylistUI();
  loadTrack(0);
</script>

<style>
.music-player {
  position: fixed;
  bottom: var(--space-xl);
  right: var(--space-xl);
  z-index: 90;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.player-toggle {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(12, 16, 30, 0.92);
  backdrop-filter: blur(20px);
  color: var(--text-muted);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-normal) ease;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
}

.player-toggle:hover {
  color: var(--color-starlight);
  border-color: rgba(240, 181, 69, 0.3);
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3), 0 0 16px rgba(240, 181, 69, 0.1);
}

.player-panel {
  position: absolute;
  bottom: 56px;
  right: 0;
  width: 300px;
  background: rgba(12, 16, 30, 0.95);
  backdrop-filter: blur(24px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  opacity: 0;
  visibility: hidden;
  transform: translateY(8px) scale(0.95);
  transition: all var(--duration-normal) cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 12px 48px rgba(0, 0, 0, 0.4);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.player-panel.open {
  opacity: 1;
  visibility: visible;
  transform: translateY(0) scale(1);
}

.player-now-playing {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.album-cover {
  width: 64px;
  height: 64px;
  border-radius: var(--radius-md);
  background: rgba(240, 181, 69, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.cover-placeholder {
  width: 48px;
  height: 48px;
  color: rgba(240, 181, 69, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-disc {
  display: none;
}

.track-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.track-title {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.track-artist {
  font-size: var(--text-xs);
  color: var(--text-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Controls */
.player-controls {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.progress-bar {
  width: 100%;
  height: 4px;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 2px;
  cursor: pointer;
  position: relative;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #d4903c, #f0b545);
  border-radius: 2px;
  width: 0%;
  transition: width 0.1s linear;
  position: relative;
}

.progress-thumb {
  position: absolute;
  top: 50%;
  left: 0%;
  width: 10px;
  height: 10px;
  background: #f0b545;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  opacity: 0;
  transition: opacity var(--duration-fast) ease;
  box-shadow: 0 0 6px rgba(240, 181, 69, 0.4);
}

.progress-bar:hover .progress-thumb {
  opacity: 1;
}

.time-display {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: var(--text-muted);
  font-variant-numeric: tabular-nums;
}

.control-buttons {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-md);
}

.ctrl-btn {
  background: none;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  padding: var(--space-xs);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast) ease;
}

.ctrl-btn:hover {
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.04);
}

.ctrl-btn-play {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(240, 181, 69, 0.1);
  border: 1px solid rgba(240, 181, 69, 0.2);
  color: var(--color-starlight);
}

.ctrl-btn-play:hover {
  background: rgba(240, 181, 69, 0.18);
  border-color: rgba(240, 181, 69, 0.35);
}

.ctrl-btn-play .icon-pause { display: none; }
.ctrl-btn-play.is-playing .icon-play { display: none; }
.ctrl-btn-play.is-playing .icon-pause { display: block; }

.player-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
}

.volume-control {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.volume-slider {
  width: 60px;
  height: 3px;
  -webkit-appearance: none;
  appearance: none;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 2px;
  outline: none;
  cursor: pointer;
}

.volume-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 10px;
  height: 10px;
  background: var(--color-starlight);
  border-radius: 50%;
  cursor: pointer;
}

/* Playlist */
.playlist-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  top: 0;
  background: rgba(8, 12, 24, 0.98);
  backdrop-filter: blur(24px);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  opacity: 0;
  visibility: hidden;
  transform: scale(0.95);
  transition: all var(--duration-fast) cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  z-index: 2;
}

.playlist-panel.open {
  opacity: 1;
  visibility: visible;
  transform: scale(1);
}

.playlist-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--text-primary);
  padding-bottom: var(--space-xs);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.playlist-close {
  background: none;
  border: none;
  color: var(--text-muted);
  font-size: 20px;
  cursor: pointer;
  line-height: 1;
  padding: 0;
}

.playlist-close:hover {
  color: var(--text-primary);
}

.playlist-list {
  list-style: none;
  padding: 0;
  margin: 0;
  overflow-y: auto;
  max-height: 200px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.playlist-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background var(--duration-fast) ease;
  font-size: var(--text-xs);
  color: var(--text-muted);
}

.playlist-item:hover {
  background: rgba(255, 255, 255, 0.04);
  color: var(--text-primary);
}

.playlist-item.active {
  background: rgba(240, 181, 69, 0.08);
  color: var(--color-starlight);
}

.pl-index {
  font-variant-numeric: tabular-nums;
  width: 20px;
  color: var(--text-muted);
  opacity: 0.5;
}

.pl-title {
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pl-artist {
  color: var(--text-muted);
  opacity: 0.5;
  font-size: 11px;
}

@media (max-width: 640px) {
  .music-player {
    bottom: var(--space-md);
    right: var(--space-md);
  }

  .player-panel {
    width: 280px;
    padding: var(--space-md);
  }
}
</style>