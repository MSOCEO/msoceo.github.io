</div>

<audio id="mp-audio" preload="metadata" crossorigin="anonymous"></audio>

<script>
  const playlists = [
    {
      name: '个性电台',
      songs: [
        { title: '明年今日', artist: '陈奕迅', rid: 152842664 },
        { title: '十年', artist: '陈奕迅', rid: 474539555 },
        { title: '富士山下', artist: '陈奕迅', rid: 481644008 },
        { title: '吻别', artist: '张学友', rid: 99722 },
        { title: '匆匆那年', artist: '王菲', rid: 201331227 },
        { title: '后来', artist: '刘若英', rid: 477928143 },
      ],
    },
    {
      name: '晨光序曲',
      songs: [
        { title: '晴天', artist: '周杰伦', rid: 152809941 },
        { title: '稻香', artist: '周杰伦', rid: 154737010 },
        { title: '江南', artist: '林俊杰', rid: 480546383 },
        { title: '遇见', artist: '孙燕姿', rid: 482902367 },
        { title: '年少有为', artist: '李荣浩', rid: 197391854 },
      ],
    },
    {
      name: '旅途漫游',
      songs: [
        { title: '光年之外', artist: 'G.E.M. 邓紫棋', rid: 452466926 },
        { title: '七里香', artist: '周杰伦', rid: 488357764 },
        { title: '好久不见', artist: '陈奕迅', rid: 303316116 },
        { title: '夜曲', artist: '周杰伦', rid: 143849264 },
        { title: '起风了', artist: '买辣椒也用券', rid: 165028958 },
      ],
    },
  ];

  let currentPlaylistIdx = 0;
  let currentSongIdx = 0;
  let mode = 'list';
  let isDragging = false;
  let favorites = new Set();
  let lyrics = [];            // [{time: 秒, text: 字符串}]
  let lyricTimer = null;

  const audio = document.getElementById('mp-audio');
  const panel = document.getElementById('mp-panel');
  const toggle = document.getElementById('mp-toggle');
  const togglePulse = document.getElementById('mp-toggle-pulse');
  const titleEl = document.getElementById('mp-title');
  const artistEl = document.getElementById('mp-artist');
  const playBtn = document.getElementById('mp-play');
  const progressBar = document.getElementById('mp-progress');
  const fillEl = document.getElementById('mp-fill');
  const thumbEl = document.getElementById('mp-thumb');
  const curTimeEl = document.getElementById('mp-cur');
  const totalTimeEl = document.getElementById('mp-total');
  const modeBtn = document.getElementById('mp-mode');
  const modeLabel = document.getElementById('mp-mode-label');
  const listEl = document.getElementById('mp-list');
  const tabsEl = document.getElementById('mp-tabs');
  const visualizer = document.getElementById('mp-visualizer');
  const favBtn = document.getElementById('mp-fav');
  const lyricEl = document.getElementById('mp-lyric');

  let panelOpen = false;

  function getCurrentPlaylist() { return playlists[currentPlaylistIdx]; }
  function getCurrentSong() { return getCurrentPlaylist().songs[currentSongIdx]; }

  function fmt(t) {
    if (!t || !isFinite(t)) return '00:00';
    const m = Math.floor(t / 60);
    const s = Math.floor(t % 60);
    return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
  }

  /* ============ LRC 解析 ============ */
  function parseLRC(lrcText) {
    const lines = lrcText.split('\n');
    const result = [];
    const timeRe = /\[(\d{2}):(\d{2})\.(\d{2,3})\]/g;

    for (const line of lines) {
      const texts = line.split(']');
      const text = texts[texts.length - 1].trim();
      if (!text) continue;

      let match;
      while ((match = timeRe.exec(line)) !== null) {
        const min = parseInt(match[1], 10);
        const sec = parseInt(match[2], 10);
        const ms = match[3].length === 2
          ? parseInt(match[3], 10) / 100
          : parseInt(match[3], 10) / 1000;
        result.push({ time: min * 60 + sec + ms, text });
      }
    }

    result.sort((a, b) => a.time - b.time);
    return result;
  }

  /* ============ 歌词获取 ============ */
  async function fetchLyrics(artist, title) {
    lyrics = [];
    lyricEl.textContent = '♫';
    try {
      const url = `https://lrclib.net/api/get?artist_name=${encodeURIComponent(artist)}&track_name=${encodeURIComponent(title)}`;
      const resp = await fetch(url);
      if (!resp.ok) return;
      const data = await resp.json();
      if (data.syncedLyrics) {
        lyrics = parseLRC(data.syncedLyrics);
      }
    } catch (_) {
      // 歌词获取失败不影响播放
    }
  }

  function updateLyric() {
    if (!lyrics.length || !audio.currentTime) {
      lyricEl.textContent = '♫';
      return;
    }
    const t = audio.currentTime;
    let idx = -1;
    for (let i = 0; i < lyrics.length; i++) {
      if (lyrics[i].time <= t) {
        idx = i;
      } else {
        break;
      }
    }
    if (idx >= 0) {
      lyricEl.textContent = lyrics[idx].text;
      lyricEl.classList.add('active');
    } else {
      lyricEl.textContent = '♫';
      lyricEl.classList.remove('active');
    }
  }

  /* ============ 构建时预取 CDN 直链 ============ */
  const kuwoURLs = JSON.parse(document.getElementById('music-player').dataset.kuwoUrls || '{}');

  /* ============ 歌曲加载 ============ */
  function loadSong(index) {
    currentSongIdx = index;
    const song = getCurrentSong();
    titleEl.textContent = song.title;
    artistEl.textContent = song.artist;
    favBtn.classList.toggle('active', favorites.has(song.title));
    updateListActive();

    // 使用构建时预取的 CDN 直链
    const url = kuwoURLs[song.rid] || '';

    // 降级：304 重定向直连（CDN 过期时兜底）
    audio.src = url || `https://antiserver.kuwo.cn/anti.s?type=convert_url3&rid=${song.rid}&format=mp3&response=url`;
    audio.play().catch(() => {});

    // 异步获取歌词，不阻塞播放
    fetchLyrics(song.artist, song.title);
  }

  function togglePlay() {
    if (!audio.src) return;
    if (audio.paused) {
      audio.play().catch(() => {});
    } else {
      audio.pause();
    }
  }

  function updatePlayIcon() {
    playBtn.classList.toggle('is-playing', !audio.paused);
    togglePulse.classList.toggle('active', !audio.paused);
    visualizer.classList.toggle('active', !audio.paused);
  }

  function nextTrack() {
    const pl = getCurrentPlaylist();
    let next;
    if (mode === 'shuffle') {
      next = Math.floor(Math.random() * pl.songs.length);
    } else {
      next = currentSongIdx + 1;
      if (next >= pl.songs.length) {
        if (mode === 'list') {
          audio.pause();
          audio.currentTime = 0;
          updatePlayIcon();
          return;
        }
        next = 0;
      }
    }
    loadSong(next);
  }

  function prevTrack() {
    const pl = getCurrentPlaylist();
    let prev;
    if (mode === 'shuffle') {
      prev = Math.floor(Math.random() * pl.songs.length);
    } else {
      prev = currentSongIdx - 1;
      if (prev < 0) prev = pl.songs.length - 1;
    }
    loadSong(prev);
  }

  function setModeUI() {
    const icons = document.querySelectorAll('.mp-mode-icon');
    icons.forEach(i => i.style.display = 'none');
    if (mode === 'list') {
      document.querySelector('.mp-icon-list').style.display = '';
      modeLabel.textContent = '列表';
      modeBtn.title = '列表播放';
    } else if (mode === 'one') {
      document.querySelector('.mp-icon-one').style.display = '';
      modeLabel.textContent = '单曲';
      modeBtn.title = '单曲循环';
    } else {
      document.querySelector('.mp-icon-shuffle').style.display = '';
      modeLabel.textContent = '随机';
      modeBtn.title = '随机播放';
    }
  }

  function cycleMode() {
    const modes = ['list', 'one', 'shuffle'];
    const idx = modes.indexOf(mode);
    mode = modes[(idx + 1) % 3];
    setModeUI();
  }

  function updateProgress() {
    if (isDragging) return;
    const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
    fillEl.style.width = `${pct}%`;
    thumbEl.style.left = `${pct}%`;
    curTimeEl.textContent = fmt(audio.currentTime);
  }

  function setProgress(e) {
    const rect = progressBar.getBoundingClientRect();
    const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
    if (audio.duration) audio.currentTime = pct * audio.duration;
  }

  function renderList() {
    const pl = getCurrentPlaylist();
    listEl.innerHTML = pl.songs.map((s, i) => {
      const active = i === currentSongIdx ? ' active' : '';
      const fav = favorites.has(s.title) ? ' fav' : '';
      return `<li class="mp-list-item${active}${fav}" data-idx="${i}">
        <span class="mp-li-idx">${String(i + 1).padStart(2, '0')}</span>
        <span class="mp-li-title">${s.title}</span>
        <span class="mp-li-artist">${s.artist}</span>
        <span class="mp-li-dur">--:--</span>
      </li>`;
    }).join('');
  }

  function updateListActive() {
    listEl.querySelectorAll('.mp-list-item').forEach((li, i) => {
      li.classList.toggle('active', i === currentSongIdx);
    });
  }

  function switchPlaylist(idx) {
    currentPlaylistIdx = idx;
    currentSongIdx = 0;
    renderList();
    loadSong(0);
  }

  // Events
  toggle.addEventListener('click', () => {
    panelOpen = !panelOpen;
    panel.classList.toggle('open', panelOpen);
  });

  playBtn.addEventListener('click', togglePlay);
  document.getElementById('mp-next').addEventListener('click', nextTrack);
  document.getElementById('mp-prev').addEventListener('click', prevTrack);

  progressBar.addEventListener('mousedown', e => {
    isDragging = true;
    setProgress(e);
    const move = ev => setProgress(ev);
    const up = () => { isDragging = false; document.removeEventListener('mousemove', move); document.removeEventListener('mouseup', up); };
    document.addEventListener('mousemove', move);
    document.addEventListener('mouseup', up);
  });

  document.getElementById('mp-vol-slider').addEventListener('input', e => {
    audio.volume = e.target.value / 100;
  });
  audio.volume = 0.6;

  audio.addEventListener('timeupdate', () => {
    updateProgress();
    updateLyric();
  });

  audio.addEventListener('loadedmetadata', () => {
    totalTimeEl.textContent = fmt(audio.duration);
  });
  audio.addEventListener('play', updatePlayIcon);
  audio.addEventListener('pause', updatePlayIcon);
  audio.addEventListener('ended', () => {
    if (mode === 'one') {
      audio.currentTime = 0;
      audio.play().catch(() => {});
    } else {
      nextTrack();
    }
  });
  audio.addEventListener('error', () => {
    titleEl.textContent = '加载失败';
    artistEl.textContent = '请检查网络连接';
  });

  modeBtn.addEventListener('click', cycleMode);

  favBtn.addEventListener('click', () => {
    const song = getCurrentSong();
    if (!song) return;
    if (favorites.has(song.title)) {
      favorites.delete(song.title);
    } else {
      favorites.add(song.title);
    }
    favBtn.classList.toggle('active', favorites.has(song.title));
    renderList();
  });

  tabsEl.addEventListener('click', e => {
    const tab = e.target.closest('.mp-tab');
    if (!tab) return;
    const idx = parseInt(tab.dataset.list);
    tabsEl.querySelectorAll('.mp-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    switchPlaylist(idx);
  });

  listEl.addEventListener('click', e => {
    const item = e.target.closest('.mp-list-item');
    if (!item) return;
    loadSong(parseInt(item.dataset.idx));
  });

  // Init
  setModeUI();
  renderList();
  loadSong(0);
</script>

<style>
/* ============================================
   枕星·星轨音乐播放器 v5
   ============================================ */

/* ----- 根容器 ----- */
.mp-root {
  position: fixed;
  bottom: 28px;
  right: 28px;
  z-index: 90;
}

/* ----- 折叠按钮 ----- */
.mp-toggle {
  position: relative;
  width: 46px;
  height: 46px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: linear-gradient(135deg, rgba(18, 22, 40, 0.92), rgba(10, 14, 28, 0.95));
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  color: rgba(255, 255, 255, 0.55);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow:
    0 4px 20px rgba(0, 0, 0, 0.4),
    inset 0 1px 0 rgba(255, 255, 255, 0.04);
  margin-left: auto;
}

.mp-toggle:hover {
  color: #f0b545;
  border-color: rgba(240, 181, 69, 0.3);
  box-shadow:
    0 4px 24px rgba(0, 0, 0, 0.45),
    0 0 24px rgba(240, 181, 69, 0.1);
  transform: scale(1.05);
}

.mp-toggle-pulse {
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  border: 2px solid rgba(240, 181, 69, 0);
  pointer-events: none;
  transition: border-color 0.4s;
}

.mp-toggle-pulse.active {
  border-color: rgba(240, 181, 69, 0.25);
  animation: mp-pulse-ring 2.2s ease-out infinite;
}

@keyframes mp-pulse-ring {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.4); opacity: 0; }
}

/* ----- 主面板 ----- */
.mp-panel {
  position: absolute;
  bottom: 60px;
  right: 0;
  width: 348px;
  max-height: 560px;
  background: linear-gradient(175deg, rgba(16, 21, 38, 0.97) 0%, rgba(9, 13, 26, 0.985) 100%);
  backdrop-filter: blur(32px);
  -webkit-backdrop-filter: blur(32px);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 22px;
  padding: 20px;
  opacity: 0;
  visibility: hidden;
  transform: translateY(12px) scale(0.94);
  transition: all 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow:
    0 20px 60px rgba(0, 0, 0, 0.55),
    0 0 0 1px rgba(255, 255, 255, 0.03) inset,
    0 0 50px rgba(240, 181, 69, 0.02);
  display: flex;
