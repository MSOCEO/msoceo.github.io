// src/components/MusicPlayer.astro — 枕星·星轨音乐播放器 v5 (build-time CDN prefetch)
import { fileURLToPath } from 'url';
import { readFileSync, writeFileSync, existsSync, mkdirSync } from 'fs';
import { dirname, join } from 'path';

const __dirname = dirname(fileURLToPath(import.meta.url));
const cacheFile = join(__dirname, '..', 'data', 'song-urls.json');

// All song RIDs
const allRids = [
  152842664, 474539555, 481644008, 99722, 201331227, 477928143,  // 个性电台
  152809941, 154737010, 480546383, 482902367, 197391854,          // 晨光序曲
  452466926, 488357764, 303316116, 143849264, 165028958,          // 旅途漫游
];

// Try cache first
let urlMap = {};
const dataDir = dirname(cacheFile);
if (!existsSync(dataDir)) mkdirSync(dataDir, { recursive: true });

if (existsSync(cacheFile)) {
  const cached = JSON.parse(readFileSync(cacheFile, 'utf-8'));
  const age = Date.now() - (cached._ts || 0);
  if (age < 6 * 3600 * 1000) {
    urlMap = cached;
  }
}

// Fetch fresh URLs if cache expired or empty
if (!urlMap._ts) {
  const results = await Promise.all(allRids.map(async (rid) => {
    try {
      const resp = await fetch(`https://antiserver.kuwo.cn/anti.s?type=convert_url3&rid=${rid}&format=mp3&response=url`);
      const data = await resp.json();
      return { rid, url: data.url || '' };
    } catch {
      return { rid, url: '' };
    }
  }));
  for (const { rid, url } of results) {
    urlMap[rid] = url;
  }
  urlMap._ts = Date.now();
  writeFileSync(cacheFile, JSON.stringify(urlMap));
}

const kuwoURLs = urlMap;
---

