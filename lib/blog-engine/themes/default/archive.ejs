<main>
  <h1 style="margin-bottom:2rem">归档</h1>
  <%
  const byYear = {};
  for (const p of posts) {
    const y = new Date(p.date).getFullYear();
    if (!byYear[y]) byYear[y] = [];
    byYear[y].push(p);
  }
  for (const [year, yearPosts] of Object.entries(byYear).sort((a,b)=>b[0]-a[0])) {
  %>
  <section style="margin-bottom:1.5rem">
    <h2 style="font-size:1.2rem;margin-bottom:.5rem;color:var(--muted)"><%= year %></h2>
    <ul style="list-style:none">
      <% for (const p of yearPosts) { %>
      <li style="margin-bottom:.3rem;display:flex;justify-content:space-between;flex-wrap:wrap">
        <a href="/posts/<%= p.slug %>/"><%= p.title %></a>
        <time style="color:var(--muted);font-size:.85rem"><%= formatDate(p.date) %></time>
      </li>
      <% } %>
    </ul>
  </section>
  <% } %>
</main>
