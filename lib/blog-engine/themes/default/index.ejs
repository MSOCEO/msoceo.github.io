<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><% if (post) { %><%= post.title %> · <% } %><%= config.title %></title>
  <meta name="description" content="<%= config.subtitle %>">
  <meta name="author" content="<%= config.author %>">
  <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="<%= config.title %>">
  <style>
    /* default — 极简白底黑字，Bear Blog 风格 */
    :root { --w: 720px; --c: #222; --bg: #fff; --muted: #666; --border: #e5e5e5; --link: #0051c3; }
    @media (prefers-color-scheme: dark) { :root { --c: #e0e0e0; --bg: #1a1a1a; --muted: #999; --border: #333; --link: #68a3ff; } }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; max-width: var(--w); margin: 0 auto; padding: 2rem 1.5rem; color: var(--c); background: var(--bg); line-height: 1.7; font-size: 17px; }
    header { margin-bottom: 3rem; }
    header h1 { font-size: 2rem; margin-bottom: .25rem; }
    header p { color: var(--muted); font-size: .95rem; }
    nav { margin-bottom: 2rem; }
    nav a { margin-right: 1.25rem; color: var(--link); text-decoration: none; font-weight: 500; }
    nav a:hover { text-decoration: underline; }
    .posts { list-style: none; }
    .posts li { margin-bottom: 1.75rem; }
    .posts li h2 { font-size: 1.3rem; margin-bottom: .2rem; }
    .posts li h2 a { color: var(--c); text-decoration: none; }
    .posts li h2 a:hover { color: var(--link); }
    .posts li time { color: var(--muted); font-size: .85rem; }
    .posts li p { color: var(--muted); margin-top: .3rem; }
    .pagination { display: flex; gap: 1rem; margin-top: 2rem; }
    .pagination a { color: var(--link); }
    article { margin-bottom: 3rem; }
    article h1 { font-size: 2rem; margin-bottom: .5rem; }
    article time { color: var(--muted); display: block; margin-bottom: 1.5rem; }
    article h2, article h3 { margin: 1.5rem 0 .5rem; }
    article p { margin-bottom: 1rem; }
    article pre { background: #f5f5f5; border: 1px solid var(--border); border-radius: 6px; padding: 1rem; overflow-x: auto; font-size: .9rem; line-height: 1.5; }
    @media (prefers-color-scheme: dark) { article pre { background: #252525; } }
    article code { font-family: "SF Mono", Menlo, Consolas, monospace; font-size: .9em; }
    article blockquote { border-left: 3px solid var(--link); padding-left: 1rem; color: var(--muted); margin: 1rem 0; }
    article table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    article th, article td { border: 1px solid var(--border); padding: .5rem .75rem; text-align: left; }
    article img { max-width: 100%; height: auto; border-radius: 6px; }
    footer { margin-top: 4rem; padding-top: 1.5rem; border-top: 1px solid var(--border); color: var(--muted); font-size: .85rem; }
    .tags { margin-bottom: 2rem; }
    .tags a { display: inline-block; margin: 0 .5rem .5rem 0; padding: .2rem .6rem; background: #f0f0f0; border-radius: 4px; color: var(--muted); text-decoration: none; font-size: .85rem; }
    @media (prefers-color-scheme: dark) { .tags a { background: #2a2a2a; } }
    .tags a:hover { background: var(--link); color: #fff; }
  </style>
</head>
<body>
  <header>
    <h1><a href="/" style="color:inherit;text-decoration:none;"><%= config.title %></a></h1>
    <% if (config.subtitle) { %><p><%= config.subtitle %></p><% } %>
  </header>
  <nav>
    <% for (const item of config.nav) { %><a href="<%= item.url %>"><%= item.label %></a><% } %>
  </nav>
  <main>
    <% if (page) { %>
      <% if (Object.keys(tags).length) { %>
      <div class="tags">
        <% for (const [tag, data] of Object.entries(tags).slice(0, 20)) { %><a href="/tags/<%= tag %>/"><%= tag %>(<%= data.count %>)</a><% } %>
      </div>
      <% } %>
      <ul class="posts">
        <% for (const post of page.items) { %>
        <li>
          <h2><a href="/posts/<%= post.slug %>/"><%= post.title %></a></h2>
          <time><%= formatDate(post.date) %></time>
          <% if (post.excerpt) { %><p><%= post.excerpt %></p><% } %>
        </li>
        <% } %>
      </ul>
      <% if (page.totalPages > 1) { %>
      <div class="pagination">
        <% if (page.hasPrev) { %><a href="/page/<%= page.page-1 %>/">&larr; 上一页</a><% } %>
        <span><%= page.page %> / <%= page.totalPages %></span>
        <% if (page.hasNext) { %><a href="/page/<%= page.page+1 %>/">下一页 &rarr;</a><% } %>
      </div>
      <% } %>
    <% } else if (post) { %>
    <article>
      <h1><%= post.title %></h1>
      <time><%= formatDate(post.date) %></time>
      <%- post.content %>
    </article>
    <% } %>
  </main>
  <footer>&copy; <%= currentYear %> <%= config.author %></footer>
</body>
</html>
