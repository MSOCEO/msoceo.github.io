<main>
  <h1 style="color:#7ee787;font-size:1.2rem;margin-bottom:1.5rem">// Archive</h1>
  <%
  const byYear = {};
  for (const p of posts) {
    const y = new Date(p.date).getFullYear();
    if (!byYear[y]) byYear[y] = [];
    byYear[y].push(p);
  }
  for (const [year, yearPosts] of Object.entries(byYear).sort((a,b)=>b[0]-a[0])) {
  %>
  <section style="margin-bottom:1.5rem">
    <h2 style="color:#d2a8ff;font-size:1rem;margin-bottom:.5rem">## <%= year %>/</h2>
    <ul style="list-style:none">
      <% for (const p of yearPosts) { %>
      <li style="padding:.2rem 0;font-size:.85rem">
        <span style="color:#30363d">$ ls -la </span><a href="/posts/<%= p.slug %>/"><%= p.title %></a>
        <span style="color:#484f58;margin-left:.5rem"># <%= formatDate(p.date) %></span>
      </li>
      <% } %>
    </ul>
  </section>
  <% } %>
</main>
