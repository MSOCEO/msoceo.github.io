<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><% if (post) { %><%= post.title %> · <% } %><%= config.title %></title>
  <style>
    /* mono — 等宽字体极客主题 */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "JetBrains Mono", "SF Mono", "Fira Code", Consolas, monospace; max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem; background: #0d1117; color: #c9d1d9; line-height: 1.6; font-size: 14px; }
    header { margin-bottom: 3rem; padding-bottom: 1rem; border-bottom: 1px solid #30363d; }
    header h1 { font-size: 1.5rem; color: #58a6ff; }
    header h1::before { content: "~/"; color: #8b949e; }
    header p { color: #8b949e; font-size: .85rem; margin-top: .3rem; }
    nav { margin-bottom: 2rem; }
    nav::before { content: "> "; color: #58a6ff; }
    nav a { margin-right: 1.5rem; color: #58a6ff; text-decoration: none; }
    nav a:hover { text-decoration: underline; }
    .posts { list-style: none; counter-reset: post-counter; }
    .posts li { margin-bottom: 1.8rem; padding: .8rem; border: 1px solid #21262d; border-radius: 6px; background: #161b22; }
    .posts li::before { counter-increment: post-counter; content: "#" counter(post-counter, decimal-leading-zero) "  "; color: #30363d; font-size: .8rem; }
    .posts li h2 { font-size: 1rem; display: inline; }
    .posts li h2 a { color: #58a6ff; text-decoration: none; }
    .posts li h2 a:hover { text-decoration: underline; }
    .posts li time { color: #484f58; font-size: .75rem; margin-left: .5rem; }
    .posts li p { color: #8b949e; font-size: .8rem; margin-top: .3rem; margin-left: 2.3rem; }
    .pagination { display: flex; gap: 1rem; margin-top: 1.5rem; }
    .pagination a { color: #58a6ff; text-decoration: none; }
    .pagination a::before { content: "$ "; color: #30363d; }
    article h1 { font-size: 1.3rem; color: #7ee787; margin-bottom: .5rem; }
    article h1::before { content: "/* "; color: #8b949e; }
    article h1::after { content: " */"; color: #8b949e; }
    article time { color: #484f58; display: block; margin-bottom: 1.5rem; font-size: .8rem; }
    article time::before { content: "// published: "; }
    article h2 { color: #d2a8ff; font-size: 1.1rem; margin: 1.5rem 0 .5rem; }
    article h2::before { content: "## "; color: #30363d; }
    article h3 { color: #79c0ff; font-size: 1rem; }
    article h3::before { content: "### "; color: #30363d; }
    article p { margin-bottom: .8rem; }
    article pre { background: #161b22; border: 1px solid #30363d; border-radius: 6px; padding: 1rem; overflow-x: auto; font-size: .82rem; }
    article code { font-size: inherit; color: #ff7b72; }
    article pre code { color: #c9d1d9; }
    article blockquote { border-left: 3px solid #30363d; padding: .3rem 1rem; color: #8b949e; margin: .8rem 0; }
    article table { width: 100%; border-collapse: collapse; margin: .8rem 0; font-size: .85rem; }
    article th, td { border: 1px solid #30363d; padding: .4rem .6rem; }
    article th { background: #161b22; color: #58a6ff; }
    article img { max-width: 100%; border: 1px solid #30363d; }
    footer { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #21262d; color: #484f58; font-size: .75rem; }
    footer::before { content: "// "; }
    .tags { margin-bottom: 1.5rem; }
    .tags a { color: #d2a8ff; text-decoration: none; margin-right: .8rem; font-size: .8rem; }
    .tags a::before { content: "["; color: #30363d; }
    .tags a::after { content: "]"; color: #30363d; }
  </style>
</head>
<body>
  <header>
    <h1><a href="/" style="color:inherit;text-decoration:none;"><%= config.title %></a></h1>
    <% if (config.subtitle) { %><p><%= config.subtitle %></p><% } %>
  </header>
  <nav>
    <% for (const item of config.nav) { %><a href="<%= item.url %>"><%= item.label %></a><% } %>
  </nav>
  <main>
    <% if (page) { %>
      <ul class="posts">
        <% for (const post of page.items) { %>
        <li>
          <h2><a href="/posts/<%= post.slug %>/"><%= post.title %></a></h2>
          <time><%= formatDate(post.date) %></time>
          <% if (post.excerpt) { %><p><%= post.excerpt %></p><% } %>
        </li>
        <% } %>
      </ul>
      <% if (page.totalPages > 1) { %>
      <div class="pagination">
        <% if (page.hasPrev) { %><a href="/page/<%= page.page-1 %>/">cd ..</a><% } %>
        <% if (page.hasNext) { %><a href="/page/<%= page.page+1 %>/">ls next/</a><% } %>
      </div>
      <% } %>
    <% } else if (post) { %>
    <article>
      <h1><%= post.title %></h1>
      <time><%= formatDate(post.date) %></time>
      <%- post.content %>
    </article>
    <% } %>
  </main>
  <footer>&copy; <%= currentYear %> <%= config.author %></footer>
</body>
</html>
