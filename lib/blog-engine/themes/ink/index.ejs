<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><% if (post) { %><%= post.title %> · <% } %><%= config.title %></title>
  <style>
    /* ink — 墨迹风格，深色底 + 暖金色点缀 */
    :root { --w: 760px; --bg: #0f0f0f; --c: #d4d4d4; --muted: #888; --accent: #d4a574; --border: #2a2a2a; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Noto Serif SC", "Source Han Serif SC", Georgia, serif; max-width: var(--w); margin: 0 auto; padding: 3rem 1.5rem; color: var(--c); background: var(--bg); line-height: 1.85; font-size: 17px; }
    header { margin-bottom: 3rem; text-align: center; }
    header h1 { font-size: 2.2rem; color: var(--accent); font-weight: 700; }
    header p { color: var(--muted); margin-top: .5rem; font-size: .95rem; }
    nav { text-align: center; margin-bottom: 2.5rem; }
    nav a { margin: 0 .75rem; color: var(--muted); text-decoration: none; transition: color .2s; font-size: .95rem; }
    nav a:hover { color: var(--accent); }
    .posts { list-style: none; }
    .posts li { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
    .posts li h2 { font-size: 1.4rem; }
    .posts li h2 a { color: var(--c); text-decoration: none; }
    .posts li h2 a:hover { color: var(--accent); }
    .posts li time { color: var(--accent); font-size: .8rem; display: block; margin-bottom: .5rem; }
    .posts li p { color: var(--muted); }
    .pagination { display: flex; justify-content: center; gap: 1.5rem; margin-top: 2rem; }
    .pagination a { color: var(--accent); }
    article h1 { font-size: 2rem; color: var(--accent); margin-bottom: .5rem; }
    article time { color: var(--muted); display: block; margin-bottom: 2rem; font-size: .9rem; }
    article h2, h3 { color: var(--accent); margin: 1.5rem 0 .5rem; }
    article p { margin-bottom: 1.2rem; }
    article pre { background: #1a1a1a; border: 1px solid var(--border); border-radius: 8px; padding: 1.2rem; overflow-x: auto; font-size: .88rem; }
    article code { font-family: "SF Mono", Menlo, monospace; font-size: .9em; }
    article blockquote { border-left: 3px solid var(--accent); padding: .5rem 1.2rem; color: var(--muted); margin: 1.2rem 0; background: rgba(212,165,116,.05); border-radius: 0 6px 6px 0; }
    article table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    article th, td { border: 1px solid var(--border); padding: .5rem .75rem; }
    article th { background: rgba(212,165,116,.08); }
    article img { max-width: 100%; border-radius: 8px; }
    footer { text-align: center; margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border); color: var(--muted); font-size: .85rem; }
    .tags a { display: inline-block; margin: 0 .4rem .4rem 0; padding: .25rem .7rem; border: 1px solid var(--border); border-radius: 4px; color: var(--muted); text-decoration: none; font-size: .85rem; }
    .tags a:hover { border-color: var(--accent); color: var(--accent); }
  </style>
</head>
<body>
  <header>
    <h1><a href="/" style="color:inherit;text-decoration:none;"><%= config.title %></a></h1>
    <% if (config.subtitle) { %><p><%= config.subtitle %></p><% } %>
  </header>
  <nav>
    <% for (const item of config.nav) { %><a href="<%= item.url %>"><%= item.label %></a><% } %>
  </nav>
  <main>
    <% if (page) { %>
      <ul class="posts">
        <% for (const post of page.items) { %>
        <li>
          <time><%= formatDate(post.date) %></time>
          <h2><a href="/posts/<%= post.slug %>/"><%= post.title %></a></h2>
          <% if (post.excerpt) { %><p><%= post.excerpt %></p><% } %>
        </li>
        <% } %>
      </ul>
      <% if (page.totalPages > 1) { %>
      <div class="pagination">
        <% if (page.hasPrev) { %><a href="/page/<%= page.page-1 %>/">&larr; 上一页</a><% } %>
        <span><%= page.page %> / <%= page.totalPages %></span>
        <% if (page.hasNext) { %><a href="/page/<%= page.page+1 %>/">下一页 &rarr;</a><% } %>
      </div>
      <% } %>
    <% } else if (post) { %>
    <article>
      <h1><%= post.title %></h1>
      <time><%= formatDate(post.date) %></time>
      <%- post.content %>
    </article>
    <% } %>
  </main>
  <footer>&copy; <%= currentYear %> <%= config.author %> · Powered by HanBlog</footer>
</body>
</html>
