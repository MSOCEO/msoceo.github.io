<main>
  <h1 style="margin-bottom:2rem;color:var(--accent);text-align:center">归档</h1>
  <%
  const byYear = {};
  for (const p of posts) {
    const y = new Date(p.date).getFullYear();
    if (!byYear[y]) byYear[y] = [];
    byYear[y].push(p);
  }
  for (const [year, yearPosts] of Object.entries(byYear).sort((a,b)=>b[0]-a[0])) {
  %>
  <section style="margin-bottom:2rem">
    <h2 style="color:var(--accent);margin-bottom:.8rem;font-size:1.3rem;border-bottom:1px solid var(--border);padding-bottom:.3rem"><%= year %></h2>
    <ul style="list-style:none">
      <% for (const p of yearPosts) { %>
      <li style="margin-bottom:.5rem;display:flex;justify-content:space-between">
        <a href="/posts/<%= p.slug %>/"><%= p.title %></a>
        <time style="color:var(--accent);font-size:.85rem"><%= formatDate(p.date) %></time>
      </li>
      <% } %>
    </ul>
  </section>
  <% } %>
</main>
