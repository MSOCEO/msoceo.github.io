<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><% if (post) { %><%= post.title %> · <% } %><%= config.title %></title>
  <style>
    /* paper — 纸张纹理暖色主题 */
    :root { --w: 780px; --bg: #fdf6e3; --c: #3a3226; --muted: #8a7a62; --accent: #b6561c; --border: #e0d5c1; }
    @media (prefers-color-scheme: dark) { :root { --bg: #2a2420; --c: #e8d8c0; --muted: #a0907a; --accent: #e09050; --border: #4a3a2a; } }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "LXGW WenKai", "Noto Serif SC", Georgia, serif; max-width: var(--w); margin: 0 auto; padding: 3rem 2rem; color: var(--c); background: var(--bg); background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence baseFrequency='.65' numOctaves='3'/%3E%3C/filter%3E%3Crect width='60' height='60' filter='url(%23n)' opacity='.03'/%3E%3C/svg%3E"); line-height: 1.9; }
    header { text-align: center; margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 2px solid var(--accent); }
    header h1 { font-size: 2.2rem; color: var(--accent); }
    header p { color: var(--muted); font-style: italic; }
    nav { text-align: center; margin-bottom: 2.5rem; }
    nav a { margin: 0 1rem; color: var(--muted); text-decoration: none; font-size: 1rem; border-bottom: 1px dashed transparent; transition: .2s; }
    nav a:hover { color: var(--accent); border-bottom-color: var(--accent); }
    .post-item { padding: 1.5rem 0; border-bottom: 1px dashed var(--border); }
    .post-item h2 { font-size: 1.3rem; }
    .post-item h2 a { color: var(--c); text-decoration: none; }
    .post-item h2 a:hover { color: var(--accent); }
    .post-item time { color: var(--accent); font-size: .85rem; }
    .post-item p { color: var(--muted); margin-top: .3rem; }
    .pagination { display: flex; justify-content: center; gap: 2rem; margin-top: 2rem; }
    .pagination a { color: var(--accent); font-style: italic; }
    article { line-height: 1.95; }
    article h1 { font-size: 2rem; color: var(--accent); margin-bottom: .5rem; }
    article time { color: var(--muted); display: block; margin-bottom: 2rem; font-style: italic; }
    article h2, h3 { color: var(--accent); margin: 1.8rem 0 .5rem; }
    article p { margin-bottom: 1.2rem; text-indent: 2em; }
    article p:first-of-type { text-indent: 0; }
    article pre { background: rgba(0,0,0,.03); border: 1px solid var(--border); border-radius: 4px; padding: 1rem; overflow-x: auto; font-size: .88rem; }
    @media (prefers-color-scheme: dark) { article pre { background: rgba(255,255,255,.03); } }
    article code { font-family: monospace; font-size: .9em; }
    article blockquote { border-left: 3px solid var(--accent); padding: .5rem 1.5rem; color: var(--muted); margin: 1rem 0; font-style: italic; }
    article table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    article th, td { border: 1px solid var(--border); padding: .5rem .75rem; }
    article img { max-width: 100%; border: 1px solid var(--border); padding: 4px; background: #fff; }
    footer { text-align: center; margin-top: 4rem; padding-top: 2rem; border-top: 2px double var(--border); color: var(--muted); font-size: .85rem; }
    .tags { text-align: center; margin-bottom: 2rem; }
    .tags a { display: inline-block; margin: .2rem; padding: .2rem .6rem; color: var(--muted); text-decoration: none; font-size: .85rem; }
    .tags a:hover { color: var(--accent); }
  </style>
</head>
<body>
  <header>
    <h1><a href="/" style="color:inherit;text-decoration:none;"><%= config.title %></a></h1>
    <% if (config.subtitle) { %><p><%= config.subtitle %></p><% } %>
  </header>
  <nav>
    <% for (const item of config.nav) { %><a href="<%= item.url %>"><%= item.label %></a><% } %>
  </nav>
  <main>
    <% if (page) { %>
      <% for (const post of page.items) { %>
      <div class="post-item">
        <time><%= formatDate(post.date) %></time>
        <h2><a href="/posts/<%= post.slug %>/"><%= post.title %></a></h2>
        <% if (post.excerpt) { %><p><%= post.excerpt %></p><% } %>
      </div>
      <% } %>
      <% if (page.totalPages > 1) { %>
      <div class="pagination">
        <% if (page.hasPrev) { %><a href="/page/<%= page.page-1 %>/">&larr; 旧文</a><% } %>
        <span><%= page.page %> / <%= page.totalPages %></span>
        <% if (page.hasNext) { %><a href="/page/<%= page.page+1 %>/">新文 &rarr;</a><% } %>
      </div>
      <% } %>
    <% } else if (post) { %>
    <article>
      <h1><%= post.title %></h1>
      <time><%= formatDate(post.date) %></time>
      <%- post.content %>
    </article>
    <% } %>
  </main>
  <footer>&copy; <%= currentYear %> <%= config.author %></footer>
</body>
</html>
