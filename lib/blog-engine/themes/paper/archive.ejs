<main>
  <h1 style="text-align:center;color:var(--accent);margin-bottom:2rem;font-size:1.8rem">归档</h1>
  <%
  const byYear = {};
  for (const p of posts) {
    const y = new Date(p.date).getFullYear();
    if (!byYear[y]) byYear[y] = [];
    byYear[y].push(p);
  }
  for (const [year, yearPosts] of Object.entries(byYear).sort((a,b)=>b[0]-a[0])) {
  %>
  <section style="margin-bottom:1.5rem">
    <h2 style="color:var(--accent);margin-bottom:.6rem;border-bottom:1px dashed var(--border);padding-bottom:.3rem"><%= year %></h2>
    <ul style="list-style:none">
      <% for (const p of yearPosts) { %>
      <li style="padding:.4rem 0;display:flex;justify-content:space-between;border-bottom:1px dotted var(--border)">
        <a href="/posts/<%= p.slug %>/"><%= p.title %></a>
        <time style="color:var(--accent);font-size:.85rem;font-style:italic"><%= formatDate(p.date) %></time>
      </li>
      <% } %>
    </ul>
  </section>
  <% } %>
</main>
