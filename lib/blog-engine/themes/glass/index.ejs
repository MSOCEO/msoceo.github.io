<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><% if (post) { %><%= post.title %> · <% } %><%= config.title %></title>
  <style>
    /* glass — 玻璃态深色主题 */
    :root { --w: 800px; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Inter", -apple-system, sans-serif; max-width: var(--w); margin: 0 auto; padding: 2.5rem 1.5rem; min-height: 100vh; background: linear-gradient(135deg, #0f0c29, #302b63, #24243e); color: #e4e4e7; line-height: 1.8; font-size: 16px; }
    header { background: rgba(255,255,255,.06); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,.08); border-radius: 16px; padding: 2rem; margin-bottom: 2rem; text-align: center; }
    header h1 { font-size: 2rem; background: linear-gradient(135deg, #a78bfa, #60a5fa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    header p { color: #a1a1aa; margin-top: .3rem; }
    nav { display: flex; justify-content: center; gap: 1.5rem; margin-bottom: 2rem; flex-wrap: wrap; }
    nav a { color: #a78bfa; text-decoration: none; font-weight: 500; padding: .5rem 1rem; border-radius: 8px; background: rgba(167,139,250,.08); transition: .2s; }
    nav a:hover { background: rgba(167,139,250,.18); }
    .card { background: rgba(255,255,255,.05); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,.06); border-radius: 14px; padding: 1.5rem; margin-bottom: 1.5rem; transition: .2s; }
    .card:hover { background: rgba(255,255,255,.08); border-color: rgba(167,139,250,.2); }
    .card h2 { font-size: 1.2rem; }
    .card h2 a { color: #e4e4e7; text-decoration: none; }
    .card h2 a:hover { color: #a78bfa; }
    .card time { color: #60a5fa; font-size: .8rem; display: block; margin-bottom: .5rem; }
    .card p { color: #a1a1aa; font-size: .92rem; }
    .pagination { display: flex; justify-content: center; gap: 1.5rem; margin-top: 2rem; }
    .pagination a { color: #a78bfa; }
    article { background: rgba(255,255,255,.05); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,.06); border-radius: 16px; padding: 2.5rem; }
    article h1 { font-size: 2rem; background: linear-gradient(135deg, #a78bfa, #60a5fa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: .5rem; }
    article time { color: #a1a1aa; display: block; margin-bottom: 2rem; }
    article h2, h3 { color: #a78bfa; margin: 1.5rem 0 .5rem; }
    article p { margin-bottom: 1rem; }
    article pre { background: rgba(0,0,0,.3); border: 1px solid rgba(255,255,255,.06); border-radius: 10px; padding: 1.2rem; overflow-x: auto; font-size: .88rem; }
    article code { font-family: "JetBrains Mono", "SF Mono", monospace; font-size: .88em; }
    article blockquote { border-left: 3px solid #a78bfa; padding: .5rem 1rem; color: #a1a1aa; margin: 1rem 0; background: rgba(167,139,250,.06); border-radius: 0 8px 8px 0; }
    article table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    article th, td { border: 1px solid rgba(255,255,255,.08); padding: .5rem .75rem; }
    article th { background: rgba(167,139,250,.1); }
    article img { max-width: 100%; border-radius: 12px; }
    footer { text-align: center; margin-top: 3rem; padding-top: 2rem; color: #71717a; font-size: .85rem; }
    .tags { display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 2rem; justify-content: center; }
    .tags a { background: rgba(167,139,250,.1); padding: .3rem .8rem; border-radius: 6px; color: #a78bfa; text-decoration: none; font-size: .85rem; }
    .tags a:hover { background: rgba(167,139,250,.25); }
  </style>
</head>
<body>
  <header>
    <h1><a href="/" style="color:inherit;text-decoration:none;"><%= config.title %></a></h1>
    <% if (config.subtitle) { %><p><%= config.subtitle %></p><% } %>
  </header>
  <nav>
    <% for (const item of config.nav) { %><a href="<%= item.url %>"><%= item.label %></a><% } %>
  </nav>
  <main>
    <% if (page) { %>
      <% for (const post of page.items) { %>
      <div class="card">
        <time><%= formatDate(post.date) %></time>
        <h2><a href="/posts/<%= post.slug %>/"><%= post.title %></a></h2>
        <% if (post.excerpt) { %><p><%= post.excerpt %></p><% } %>
      </div>
      <% } %>
      <% if (page.totalPages > 1) { %>
      <div class="pagination">
        <% if (page.hasPrev) { %><a href="/page/<%= page.page-1 %>/">&larr; 上一页</a><% } %>
        <span><%= page.page %> / <%= page.totalPages %></span>
        <% if (page.hasNext) { %><a href="/page/<%= page.page+1 %>/">下一页 &rarr;</a><% } %>
      </div>
      <% } %>
    <% } else if (post) { %>
    <article>
      <h1><%= post.title %></h1>
      <time><%= formatDate(post.date) %></time>
      <%- post.content %>
    </article>
    <% } %>
  </main>
  <footer>&copy; <%= currentYear %> <%= config.author %></footer>
</body>
</html>
