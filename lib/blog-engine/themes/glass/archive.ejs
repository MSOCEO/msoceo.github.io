<main>
  <h1 style="margin-bottom:2rem;text-align:center;background: linear-gradient(135deg, #a78bfa, #60a5fa);-webkit-background-clip: text;-webkit-text-fill-color: transparent;">归档</h1>
  <%
  const byYear = {};
  for (const p of posts) {
    const y = new Date(p.date).getFullYear();
    if (!byYear[y]) byYear[y] = [];
    byYear[y].push(p);
  }
  for (const [year, yearPosts] of Object.entries(byYear).sort((a,b)=>b[0]-a[0])) {
  %>
  <section style="margin-bottom:2rem">
    <h2 style="color:#a78bfa;margin-bottom:.8rem;font-size:1.3rem"><%= year %></h2>
    <% for (const p of yearPosts) { %>
    <div class="card">
      <time><%= formatDate(p.date) %></time>
      <h2><a href="/posts/<%= p.slug %>/"><%= p.title %></a></h2>
      <% if (p.excerpt) { %><p><%= p.excerpt %></p><% } %>
    </div>
    <% } %>
  </section>
  <% } %>
</main>
