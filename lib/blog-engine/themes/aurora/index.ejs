<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><% if (post) { %><%= post.title %> · <% } %><%= config.title %></title>
  <style>
    /* aurora — 渐变炫彩主题 */
    :root { --w: 780px; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Inter", -apple-system, sans-serif; max-width: var(--w); margin: 0 auto; padding: 2.5rem 1.5rem; background: linear-gradient(180deg, #0a0020 0%, #1a0040 30%, #0d1b2a 60%, #1b0a30 100%); min-height: 100vh; color: #e0e0ff; line-height: 1.8; font-size: 16px; }
    header { text-align: center; margin-bottom: 3rem; padding: 3rem 2rem; background: linear-gradient(135deg, rgba(168,85,247,.1), rgba(59,130,246,.1), rgba(236,72,153,.1)); border-radius: 20px; border: 1px solid rgba(168,85,247,.15); position: relative; overflow: hidden; }
    header::before { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, #a855f7, #3b82f6, #ec4899, #f59e0b, #10b981); opacity: .06; filter: blur(40px); }
    header h1 { font-size: 2.5rem; background: linear-gradient(135deg, #a855f7, #3b82f6, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; position: relative; }
    header p { color: #94a3b8; margin-top: .5rem; position: relative; }
    nav { display: flex; justify-content: center; gap: .5rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
    nav a { padding: .5rem 1.2rem; border-radius: 20px; color: #c4b5fd; text-decoration: none; font-size: .9rem; transition: .3s; background: rgba(168,85,247,.06); }
    nav a:hover { background: rgba(168,85,247,.2); color: #fff; transform: translateY(-1px); }
    .post-card { background: linear-gradient(135deg, rgba(168,85,247,.06), rgba(59,130,246,.06)); border: 1px solid rgba(168,85,247,.1); border-radius: 14px; padding: 1.5rem; margin-bottom: 1.2rem; transition: .3s; }
    .post-card:hover { border-color: rgba(168,85,247,.3); transform: translateY(-2px); }
    .post-card h2 { font-size: 1.2rem; }
    .post-card h2 a { color: #e0e0ff; text-decoration: none; }
    .post-card h2 a:hover { color: #a78bfa; }
    .post-card time { color: #ec4899; font-size: .8rem; display: block; margin-bottom: .4rem; }
    .post-card p { color: #94a3b8; font-size: .9rem; }
    .pagination { display: flex; justify-content: center; gap: 1.5rem; margin-top: 2rem; }
    .pagination a { background: rgba(168,85,247,.1); padding: .5rem 1.2rem; border-radius: 20px; color: #a78bfa; text-decoration: none; }
    article { background: linear-gradient(135deg, rgba(168,85,247,.04), rgba(59,130,246,.04)); border: 1px solid rgba(168,85,247,.1); border-radius: 18px; padding: 2.5rem; }
    article h1 { font-size: 2rem; background: linear-gradient(135deg, #a855f7, #3b82f6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: .5rem; }
    article time { color: #94a3b8; display: block; margin-bottom: 2rem; }
    article h2 { color: #a78bfa; margin: 1.5rem 0 .5rem; }
    article h3 { color: #3b82f6; margin: 1.2rem 0 .5rem; }
    article p { margin-bottom: 1rem; }
    article pre { background: rgba(0,0,0,.3); border: 1px solid rgba(168,85,247,.12); border-radius: 10px; padding: 1.2rem; overflow-x: auto; font-size: .88rem; }
    article code { font-family: "JetBrains Mono", monospace; font-size: .88em; }
    article blockquote { border-left: 3px solid #a855f7; padding: .5rem 1.2rem; color: #94a3b8; margin: 1rem 0; background: rgba(168,85,247,.05); border-radius: 0 8px 8px 0; }
    article table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    article th, td { border: 1px solid rgba(168,85,247,.1); padding: .5rem .75rem; }
    article th { background: rgba(168,85,247,.08); }
    article img { max-width: 100%; border-radius: 12px; }
    footer { text-align: center; margin-top: 3rem; padding-top: 2rem; color: #64748b; font-size: .85rem; }
    .tags { display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 2rem; justify-content: center; }
    .tags a { padding: .3rem .8rem; border-radius: 20px; background: rgba(236,72,153,.08); color: #f9a8d4; text-decoration: none; font-size: .85rem; }
    .tags a:hover { background: rgba(236,72,153,.2); }
  </style>
</head>
<body>
  <header>
    <h1><a href="/" style="color:inherit;text-decoration:none;"><%= config.title %></a></h1>
    <% if (config.subtitle) { %><p><%= config.subtitle %></p><% } %>
  </header>
  <nav>
    <% for (const item of config.nav) { %><a href="<%= item.url %>"><%= item.label %></a><% } %>
  </nav>
  <main>
    <% if (page) { %>
      <% for (const post of page.items) { %>
      <div class="post-card">
        <time><%= formatDate(post.date) %></time>
        <h2><a href="/posts/<%= post.slug %>/"><%= post.title %></a></h2>
        <% if (post.excerpt) { %><p><%= post.excerpt %></p><% } %>
      </div>
      <% } %>
      <% if (page.totalPages > 1) { %>
      <div class="pagination">
        <% if (page.hasPrev) { %><a href="/page/<%= page.page-1 %>/">&larr; 上一页</a><% } %>
        <span><%= page.page %> / <%= page.totalPages %></span>
        <% if (page.hasNext) { %><a href="/page/<%= page.page+1 %>/">下一页 &rarr;</a><% } %>
      </div>
      <% } %>
    <% } else if (post) { %>
    <article>
      <h1><%= post.title %></h1>
      <time><%= formatDate(post.date) %></time>
      <%- post.content %>
    </article>
    <% } %>
  </main>
  <footer>&copy; <%= currentYear %> <%= config.author %> · Aurora Theme</footer>
</body>
</html>
